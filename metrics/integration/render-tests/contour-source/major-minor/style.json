{
  "version": 8,
  "metadata": {
    "test": {
      "height": 256,
      "width": 256,
      "description": "Native contour source emits a per-feature `major` boolean controlled by `majorMultiplier`. Two line layers filter on `[\"get\", \"major\"]` and paint different stroke widths/colours: thin grey for minor lines, thicker brown for major lines (every 5th, i.e. every 500m at intervals=100)."
    }
  },
  "center": [
    -113.26903,
    35.9654
  ],
  "zoom": 12,
  "sources": {
    "dem": {
      "type": "raster-dem",
      "tiles": [
        "local://tiles/{z}-{x}-{y}.terrain.png"
      ],
      "maxzoom": 12,
      "tileSize": 256
    },
    "contours": {
      "type": "contour",
      "source": "dem",
      "intervals": [
        100
      ],
      "unit": "meters",
      "majorMultiplier": [
        5
      ]
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "white"
      }
    },
    {
      "id": "contour-minor",
      "type": "line",
      "source": "contours",
      "filter": [
        "==",
        [
          "get",
          "major"
        ],
        false
      ],
      "paint": {
        "line-color": "#a0a0a0",
        "line-width": 0.5
      }
    },
    {
      "id": "contour-major",
      "type": "line",
      "source": "contours",
      "filter": [
        "==",
        [
          "get",
          "major"
        ],
        true
      ],
      "paint": {
        "line-color": "#7c4a14",
        "line-width": 1.5
      }
    }
  ]
}