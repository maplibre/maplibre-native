{
  "version": 8,
  "metadata": {
    "test": {
      "height": 256,
      "width": 256,
      "description": "Same as the fill-sandwich test but without the fill layer, to verify that two color-relief layers with hillshade render correctly on all backends (Metal, Vulkan, WebGPU) when no vector layer is present. Used to isolate whether the fill layer is the cause of the rendering regression."
    }
  },
  "center": [0, 45],
  "zoom": 1,
  "sources": {
    "dem-ocean-color-relief": {
      "type": "raster-dem",
      "tiles": [
        "local://tiles/{z}-{x}-{y}.ocean.webp"
      ]
    },
    "dem-ocean-hillshade": {
      "type": "raster-dem",
      "tiles": [
        "local://tiles/{z}-{x}-{y}.ocean.webp"
      ]
    },
    "dem-terrain-color-relief": {
      "type": "raster-dem",
      "tiles": [
        "local://tiles/{z}-{x}-{y}.terrain.png"
      ]
    },
    "dem-terrain-hillshade": {
      "type": "raster-dem",
      "tiles": [
        "local://tiles/{z}-{x}-{y}.terrain.png"
      ]
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#0d1a0a"
      }
    },
    {
      "id": "bathymetry-color-relief",
      "type": "color-relief",
      "source": "dem-ocean-color-relief",
      "paint": {
        "color-relief-opacity": 1,
        "color-relief-color": [
          "interpolate",
          ["linear"],
          ["elevation"],
          -9500, "#020d18",
          -4000, "#041828",
          -500,  "#082438",
          -1,    "#0d3050",
          0,     "rgba(0,0,0,0)"
        ]
      }
    },
    {
      "id": "bathymetry-hillshade",
      "type": "hillshade",
      "source": "dem-ocean-hillshade",
      "paint": {
        "hillshade-method": "igor",
        "hillshade-illumination-anchor": "map",
        "hillshade-exaggeration": 0.4,
        "hillshade-shadow-color": "#000000",
        "hillshade-highlight-color": "#1a3a5c",
        "hillshade-accent-color": "#000000"
      }
    },
    {
      "id": "terrain-color-relief",
      "type": "color-relief",
      "source": "dem-terrain-color-relief",
      "paint": {
        "color-relief-opacity": 1,
        "color-relief-color": [
          "interpolate",
          ["linear"],
          ["elevation"],
          0,    "rgba(0,0,0,0)",
          0.1,  "#006600",
          500,  "#00FF00",
          1000, "#FFFF00",
          2000, "#FF8800",
          3000, "#FF0000",
          5000, "#FFFFFF"
        ]
      }
    },
    {
      "id": "terrain-hillshade",
      "type": "hillshade",
      "source": "dem-terrain-hillshade",
      "paint": {
        "hillshade-method": "standard",
        "hillshade-exaggeration": 0.6,
        "hillshade-shadow-color": "#000000",
        "hillshade-highlight-color": "#ffffff",
        "hillshade-accent-color": "#000000"
      }
    }
  ]
}
