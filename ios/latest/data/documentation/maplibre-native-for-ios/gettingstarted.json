r you should be greeted with the default ","type":"text"},{"type":"reference","identifier":"https:\/\/demotiles.maplibre.org\/","isActive":true},{"text":" style:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"DemotilesScreenshot.png"}],"type":"paragraph"},{"text":"UIKit","type":"heading","level":2,"anchor":"UIKit"},{"inlineContent":[{"type":"text","text":"You can use the following "},{"code":"UIViewController","type":"codeVoice"},{"type":"text","text":" to get started with MapLibre Native iOS with UIKit."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"]}]}],"references":{"https://swiftpackageindex.com/maplibre/maplibre-gl-native-distribution":{"titleInlineContent":[{"type":"text","text":"Swift Package Index"}],"url":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","title":"Swift Package Index","type":"link","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution"},"DemotilesScreenshot.png":{"variants":[{"traits":["2x","light"],"url":"\/images\/org.swift.MyProject\/DemotilesScreenshot@2x.png"}],"alt":null,"type":"image","identifier":"DemotilesScreenshot.png"},"https://github.com/maplibre/maplibre-native":{"titleInlineContent":[{"type":"text","text":"maplibre-native"}],"url":"https:\/\/github.com\/maplibre\/maplibre-native","title":"maplibre-native","type":"link","identifier":"https:\/\/github.com\/maplibre\/maplibre-native"},"doc://org.swift