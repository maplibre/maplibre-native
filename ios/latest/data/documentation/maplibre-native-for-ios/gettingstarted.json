"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"],"syntax":null,"type":"codeListing"},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","type":"reference","isActive":true},{"text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the ","type":"text"},{"identifier":"https:\/\/github.com\/maplibre\/maplibre-native","type":"reference","isActive":true},{"text":" repository.","type":"text"}]}],"type":"aside","style":"note"},{"inlineContent":[{"text":"Verify you can import MapLibre in your app:","type":"text"}],"type":"paragraph"},{"code":["import MapLibre"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"SwiftUI","text":"SwiftUI","type":"heading"},{"inlineContent":[{"type":"text","text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:"}],"type":"paragraph"},{"code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"You can use this view directly in a SwiftUI View hierarchy, for example:","type":"text"}],"type":"paragraph"},{"code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"When running your app in the simulator you should be greeted with the default ","type":"text"},{"isActive":true,"identifier":"https:\/\/demotiles.maplibre.org\/","type":"reference"},{"text":" style:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"DemotilesScreenshot.png"}],"type":"paragraph"},{"level":2,"anchor":"UIKit","text":"UIKit","type":"heading"},{"inlineContent":[{"type":"text","text":"You can use the following "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":" to get started with MapLibre Native iOS with UIKit."}],"type":"paragraph"},{"code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"]}],"references":{"https://cocoapods.org":{"type":"link","identifier":"https:\/\/cocoapods.org","title":"Cocoapods","url":"https:\/\/cocoapods.org","titleInlineContent":[{"text":"Cocoapods","type":"text"}]},"AddPackageDependencies.png":{"variants":[{"url":"\/images\/org.swift.MyProject\/AddPackageDependencies@2x.png","traits":["2x","light"]}],"identifier":"AddPackageDependencies.png","type":"image","alt":null},"DemotilesScreenshot.png":{"type":"image","identifier":"DemotilesScreenshot.png","alt":null,"variants":[{"traits":["2x","light"],"url":"\/images\/org.swift.MyProject\/DemotilesScreenshot@2x.png"}]},"https://github.com/maplibre/maplibre-gl-native-distribution":{"identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","title":"maplibre-gl-native-distributon","titleInlineContent":[{"text":"maplibre-gl-native-distributon","type