{"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Create a new iOS project","anchor":"Create-a-new-iOS-project","type":"heading"},{"inlineContent":[{"type":"text","text":"Create a new (SwiftUI) iOS project with Xcode. Go to "},{"inlineContent":[{"type":"text","text":"File > New > Project…"}],"type":"emphasis"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"text":"Add MapLibre Native as a dependency","anchor":"Add-MapLibre-Native-as-a-dependency","type":"heading"},{"inlineContent":[{"text":"MapLibre Native for iOS is available on ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/cocoapods.org"},{"text":" and on the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution"},{"text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In Xcode, right click your project and select “Add Package Dependencies…”:"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"AddPackageDependencies.png"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Paste the following URL and click Add Package:"}],"type":"paragraph"},{"code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"],"type":"codeListing","syntax":null},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"},{"type":"text","text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/maplibre\/maplibre-native"},{"type":"text","text":" repository."}]}],"type":"aside","name":"Note"},{"inlineContent":[{"text":"Verify you can import MapLibre in your app:","type":"text"}],"type":"paragraph"},{"code":["import MapLibre"],"type":"codeListing","syntax":"swift"},{"level":2,"text":"SwiftUI","anchor":"SwiftUI","type":"heading"},{"inlineContent":[{"text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:","type":"text"}],"type":"paragraph"},{"code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"You can use this view directly in a SwiftUI View hierarchy, for example:","type":"text"}],"type":"paragraph"},{"code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"When running your app in the simulator you should be greeted with the default ","type":"text"},{"type":"reference","identifier":"https:\/\/demotiles.maplibre.org\/","isActive":true},{"text":" style:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"DemotilesScreenshot.png"}],"type":"paragraph"},{"level":2,"text":"UIKit","anchor":"UIKit","type":"heading"},{"inlineContent":[{"text":"You can use the following ","type":"text"},{"code":"UIViewController","type":"codeVoice"},{"text":" to get started with MapLibre Native iOS with UIKit.","type":"text"}],"type":"paragraph"},{"code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"],"type":"codeListing","syntax":"swift"}]}],"seeAlsoSections":[{"title":"Essentials","anchor":"Essentials","generated":true,"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"]}],"metadata":{"roleHeading":"Article","modules":[{"name":"MapLibre"}],"role":"article","title":"Getting Started"},"abstract":[{"text":"Setting up an Xcode project that uses MapLibre Native for iOS.","type":"text"}],"kind":"article","references":{"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol","type":"topic","url":"\/documentation\/maplibre","role":"collection","title":"MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}]},"AddPackageDependencies.png":{"variants":[{"url":"\/images\/org.swift.MyProject\/AddPackageDependencies@2x.png","traits":["2x","light"]}],"identifier":"AddPackageDependencies.png","alt":null,"type":"image"},"https://cocoapods.org":{"title":"Cocoapods","url":"https:\/\/cocoapods.org","titleInlineContent":[{"type":"text","text":"Cocoapods"}],"identifier":"https:\/\/cocoapods.org","type":"link"},"https://github.com/maplibre/maplibre-gl-native-distribution":{"titleInlineContent":[{"typ