{"abstract":[{"type":"text","text":"Setting up an Xcode project that uses MapLibre Native for iOS."}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"kind":"article","sections":[],"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"],"anchor":"Essentials","title":"Essentials"}],"primaryContentSections":[{"content":[{"type":"heading","anchor":"Create-a-new-iOS-project","level":2,"text":"Create a new iOS project"},{"type":"paragraph","inlineContent":[{"text":"Create a new (SwiftUI) iOS project with Xcode. Go to ","type":"text"},{"inlineContent":[{"type":"text","text":"File > New > Project…"}],"type":"emphasis"},{"text":".","type":"text"}]},{"type":"heading","anchor":"Add-MapLibre-Native-as-a-dependency","level":2,"text":"Add MapLibre Native as a dependency"},{"type":"paragraph","inlineContent":[{"type":"text","text":"MapLibre Native for iOS is available on "},{"type":"reference","identifier":"https:\/\/cocoapods.org","isActive":true},{"type":"text","text":" and on the "},{"type":"reference","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","isActive":true},{"type":"text","text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly."}]},{"type":"paragraph","inlineContent":[{"text":"In Xcode, right click your project and select “Add Package Dependencies…”:","type":"text"}]},{"type":"paragraph","inlineContent":[{"identifier":"AddPackageDependencies.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Paste the following URL and click Add Package:"}]},{"type":"codeListing","syntax":null,"code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"]},{"type":"aside","content":[{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"},{"type":"text","text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/maplibre\/maplibre-native"},{"type":"text","text":" repository."}],"type":"paragraph"}],"style":"note","name":"Note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Verify you can import MapLibre in your app:"}]},{"type":"codeListing","syntax":"swift","code":["import MapLibre"]},{"type":"heading","anchor":"SwiftUI","level":2,"text":"SwiftUI"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:"}]},{"type":"codeListing","syntax":"swift","code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"]},{"type":"paragraph","inlineContent":[{"text":"You can use this view directly in a SwiftUI View hierarchy, for example:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"When running your app in the simulator you should be greeted with the default ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/demotiles.maplibre.org\/"},{"text":" style:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"DemotilesScreenshot.png"}]},{"type":"heading","anchor":"UIKit","level":2,"text":"UIKit"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use the following "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":" to get started with MapLibre Native iOS with UIKit."}]},{"type":"codeListing","syntax":"swift","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"]}],"kind":"content"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted"},"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"modules":[{"name":"MapLibre"}],"role":"article","roleHeading":"Article","title":"Getting Started"},"references":{"AddPackageDependencies.png":{"variants":[{"url":"\/images\/org.swift.MyProject\/AddPackageDependencies@2x.png","traits":["2x","light"]}],"identifier":"AddPackageDependencies.png","type":"image","alt":null},"https://github.com/maplibre/maplibre-native":{"title":"maplibre-native","titleInlineContent":[{"text":"maplibre-native","type":"text"}],"identifier":"https:\/\/github.com\/maplibre\/maplibre-native","type":"link","url":"https:\/\/github.com\/maplibre\/maplibre-native"},"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","title":"MapLibre","kind":"symbol"},"https:/