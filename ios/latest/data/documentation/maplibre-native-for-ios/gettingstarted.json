{"abstract":[{"text":"Setting up an Xcode project that uses MapLibre Native for iOS.","type":"text"}],"primaryContentSections":[{"content":[{"level":2,"anchor":"Create-a-new-iOS-project","type":"heading","text":"Create a new iOS project"},{"inlineContent":[{"type":"text","text":"Create a new (SwiftUI) iOS project with Xcode. Go to "},{"inlineContent":[{"type":"text","text":"File > New > Project…"}],"type":"emphasis"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"anchor":"Add-MapLibre-Native-as-a-dependency","type":"heading","text":"Add MapLibre Native as a dependency"},{"inlineContent":[{"type":"text","text":"MapLibre Native for iOS is available on "},{"identifier":"https:\/\/cocoapods.org","isActive":true,"type":"reference"},{"type":"text","text":" and on the "},{"identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","isActive":true,"type":"reference"},{"type":"text","text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In Xcode, right click your project and select “Add Package Dependencies…”:"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"AddPackageDependencies.png"}],"type":"paragraph"},{"inlineContent":[{"text":"Paste the following URL and click Add Package:","type":"text"}],"type":"paragraph"},{"code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"],"type":"codeListing","syntax":null},{"name":"Note","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","isActive":true},{"text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/maplibre\/maplibre-native","isActive":true},{"text":" repository.","type":"text"}]}]},{"inlineContent":[{"text":"Verify you can import MapLibre in your app:","type":"text"}],"type":"paragraph"},{"code":["import MapLibre"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":2,"text":"SwiftUI","anchor":"SwiftUI"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:"}]},{"type":"codeListing","code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use this view directly in a SwiftUI View hierarchy, for example:"}]},{"type":"codeListing","code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When running your app in the simulator you should be greeted with the default "},{"type":"reference","isActive":true,"identifier":"https:\/\/demotiles.maplibre.org\/"},{"type":"text","text":" style:"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"DemotilesScreenshot.png"}]},{"type":"heading","text":"UIKit","anchor":"UIKit","level":2},{"type":"paragraph","inlineContent":[{"text":"You can use the following ","type":"text"},{"type":"codeVoice","code":"UIViewController"},{"text":" to get started with MapLibre Native iOS with UIKit.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"]}],"kind":"content"}],"seeAlsoSections":[{"anchor":"Essentials","generated":true,"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"],"title":"Essentials"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"]}],"kind":"article","identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted","interfaceLanguage":"occ"},"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"title":"Getting Started","modules":[{"name":"MapLibre"}],"role":"article","roleHeading":"Article"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"sections":[],"references":{"https://demotiles.maplibre.org/":{"titleInlineContent":[{"text":"Demotiles","type":"text"}],"type":"link","title":"Demotiles","identifier":"https:\/\/demotiles.maplibre.org\/","url":"https:\/\/demotiles.maplibre.org\/"},"https://swiftpackageindex.com/maplibre/maplibre-gl-native-distribution":{"type":"link","titleInlineContent":[{"text":"Swift Package Index","type":"text"}],"url":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","title":"Swift Package Index"},"DemotilesScreenshot.png":{"alt":null,"type":"image","identifier":"DemotilesScreenshot.png","variants":[{"url":"\/images\/org.swift.MyProject\/DemotilesScreenshot@2x.png","traits":["2x","light"]}]},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/A