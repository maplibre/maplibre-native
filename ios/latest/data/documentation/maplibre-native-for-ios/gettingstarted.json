{"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Create-a-new-iOS-project","level":2,"text":"Create a new iOS project"},{"type":"paragraph","inlineContent":[{"text":"Create a new (SwiftUI) iOS project with Xcode. Go to ","type":"text"},{"inlineContent":[{"text":"File > New > Project…","type":"text"}],"type":"emphasis"},{"text":".","type":"text"}]},{"type":"heading","anchor":"Add-MapLibre-Native-as-a-dependency","level":2,"text":"Add MapLibre Native as a dependency"},{"type":"paragraph","inlineContent":[{"type":"text","text":"MapLibre Native for iOS is available on "},{"isActive":true,"type":"reference","identifier":"https:\/\/cocoapods.org"},{"type":"text","text":" and on the "},{"isActive":true,"type":"reference","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution"},{"type":"text","text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In Xcode, right click your project and select “Add Package Dependencies…”:"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"AddPackageDependencies.png"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Paste the following URL and click Add Package:"}]},{"type":"codeListing","code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"],"syntax":null},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","type":"reference"},{"text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/maplibre\/maplibre-native","type":"reference"},{"text":" repository.","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"text":"Verify you can import MapLibre in your app:","type":"text"}]},{"type":"codeListing","code":["import MapLibre"],"syntax":"swift"},{"type":"heading","anchor":"SwiftUI","level":2,"text":"SwiftUI"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:"}]},{"type":"codeListing","code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use this view directly in a SwiftUI View hierarchy, for example:"}]},{"type":"codeListing","code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When running your app in the simulator you should be greeted with the default "},{"type":"reference","isActive":true,"identifier":"https:\/\/demotiles.maplibre.org\/"},{"type":"text","text":" style:"}]},{"type":"paragraph","inlineContent":[{"identifier":"DemotilesScreenshot.png","type":"image"}]},{"type":"heading","anchor":"UIKit","level":2,"text":"UIKit"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use the following "},{"code":"UIViewController","type":"codeVoice"},{"type":"text","text":" to get started with MapLibre Native iOS with UIKit."}]},{"type":"codeListing","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"],"syntax":"swift"}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted","interfaceLanguage":"occ"},"sections":[],"abstract":[{"text":"Setting up an Xcode project that uses MapLibre Native for iOS.","type":"text"}],"seeAlsoSections":[{"anchor":"Essentials","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"],"title":"Essentials","generated":true}],"kind":"article","metadata":{"title":"Getting Started","modules":[{"name":"MapLibre"}],"role":"article","roleHeading":"Article"},"references":{"AddPackageDependencies.png":{"variants":[{"traits":["2x","light"],"url":"\/images\/org.swift.MyProject\/AddPackageDependencies@2x.png"}],"identifier":"AddPackageDependencies.png","alt":null,"type":"image"},"https://swiftpackageindex.com/maplibre/maplibre-gl-native-distribution":{"titleInlineContent":[{"type":"text","text":"Swift Package Index"}],"url":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","title":"Swift Package Index","type":"link"},"https://github.com/maplibre/maplibre-gl-native-distribution":{"title":"maplibre-gl-native-distributon","identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","url":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","titleInlineContent":[{