ed with MapLibre Native iOS with UIKit."}]},{"code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted"},"sections":[],"seeAlsoSections":[{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"],"title":"Essentials","generated":true,"anchor":"Essentials"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"https://cocoapods.org":{"url":"https:\/\/cocoapods.org","type":"link","identifier":"https:\/\/cocoapods.org","title":"Cocoapods","titleInlineContent":[{"text":"Cocoapods","type":"text"}]},"AddPackageDependencies.png":{"identifier":"AddPackageDependencies.png","type":"image","alt":null,"variants":[{"url":"\/images\/org.swift.MyProject\/AddPackageDependencies@2x.png","traits":["2x","light"]}]},"https://github.com/maplibre/maplibre-native":{"url":"https:\/\/github.com\/maplibre\/maplibre-native","type":"link","identifier":"https:\/\/github.com\/maplibre\/maplibre-native","title":"maplibre-native","titleInlineContent":[{"text":"maplibre-native","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/AddMarkerSymbolExample":{"type":"topic","kind":"article","abstract":[{"text":"Simply add a marker to a map!","typ