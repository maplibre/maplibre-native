,{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use the following "},{"code":"UIViewController","type":"codeVoice"},{"type":"text","text":" to get started with MapLibre Native iOS with UIKit."}]},{"syntax":"swift","type":"codeListing","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"references":{"https://cocoapods.org":{"title":"Cocoapods","titleInlineContent":[{"type":"text","text":"Cocoapods"}],"url":"https:\/\/cocoapods.org","type":"link","identifier":"https:\/\/cocoapods.org"},"https://github.com/maplibre/maplibre-native":{"title":"maplibre-native","titleInlineContent":[{"type":"text","text":"maplibre-native"}],"url":"https:\/\/github.com\/maplibre\/maplibre-native","type":"link","identifier":"https:\/\/github.com\/maplibre\/maplibre-native"},"https://demotiles.maplibre.org/":{"title":"Demotiles","titleInlineContent":[{"type":"text","text":"Demotiles"}],"url":"https:\/\/demotiles.maplibre.org\/","type":"link","identifier":"https:\/\/demotiles.maplibre.org\/"},"AddPackageDependencies.png":{"alt":null,"variants":[{"url":"\/images\/org.swift.MyProject\/AddPackageDependencies@2x.png","traits":["2x","light"]}],"type":"image",