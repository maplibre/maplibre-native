{"kind":"article","schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"content":[{"text":"Create a new iOS project","anchor":"Create-a-new-iOS-project","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Create a new (SwiftUI) iOS project with Xcode. Go to "},{"type":"emphasis","inlineContent":[{"type":"text","text":"File > New > Project…"}]},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Add MapLibre Native as a dependency","anchor":"Add-MapLibre-Native-as-a-dependency","type":"heading","level":2},{"inlineContent":[{"text":"MapLibre Native for iOS is available on ","type":"text"},{"identifier":"https:\/\/cocoapods.org","type":"reference","isActive":true},{"text":" and on the ","type":"text"},{"identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","type":"reference","isActive":true},{"text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In Xcode, right click your project and select “Add Package Dependencies…”:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"AddPackageDependencies.png"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Paste the following URL and click Add Package:"}],"type":"paragraph"},{"code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"],"syntax":null,"type":"codeListing"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","type":"reference"},{"type":"text","text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the "},{"isActive":true,"identifier":"https:\/\/github.com\/maplibre\/maplibre-native","type":"reference"},{"type":"text","text":" repository."}]}],"type":"aside","name":"Note"},{"inlineContent":[{"type":"text","text":"Verify you can import MapLibre in your app:"}],"type":"paragraph"},{"code":["import MapLibre"],"syntax":"swift","type":"codeListing"},{"text":"SwiftUI","anchor":"SwiftUI","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:"}],"type":"paragraph"},{"code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"You can use this view directly in a SwiftUI View hierarchy, for example:"}],"type":"paragraph"},{"code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"When running your app in the simulator you should be greeted with the default ","type":"text"},{"identifier":"https:\/\/demotiles.maplibre.org\/","isActive":true,"type":"reference"},{"text":" style:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"DemotilesScreenshot.png","type":"image"}],"type":"paragraph"},{"text":"UIKit","anchor":"UIKit","type":"heading","level":2},{"inlineContent":[{"text":"You can use the following ","type":"text"},{"code":"UIViewController","type":"codeVoice"},{"text":" to get started with MapLibre Native iOS with UIKit.","type":"text"}],"type":"paragraph"},{"code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"abstract":[{"text":"Setting up an Xcode project that uses MapLibre Native for iOS.","type":"text"}],"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted","interfaceLanguage":"occ"},"metadata":{"title":"Getting Started","roleHeading":"Article","modules":[{"name":"MapLibre"}],"role":"article"},"sections":[],"seeAlsoSections":[{"title":"Essentials","generated":true,"anchor":"Essentials","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"url":"\/documentation\/maplibre","title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol"},"https://github.com/maplibre/maplibre-native":{"url":"https:\/\/github.com\/maplibre\/maplibre-native","title":"maplibre-native","type":"link","identifier":"https:\/\/github.com\/maplibre\/maplibre-native","titleInlineContent":[{"text":"maplibre-native","type":"text"}]},"AddPackageDependencies.png":{"alt":null,"type":"image","identifier":"AddPackageDependencies.png","variants":[{"url":"\/images\/org.swift.MyProject\/AddPackageDependencies@2x.png","traits":["2x","light"]}]},"doc://o