{"kind":"article","primaryContentSections":[{"content":[{"level":2,"anchor":"Create-a-new-iOS-project","text":"Create a new iOS project","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Create a new (SwiftUI) iOS project with Xcode. Go to ","type":"text"},{"inlineContent":[{"type":"text","text":"File > New > Project…"}],"type":"emphasis"},{"text":".","type":"text"}]},{"level":2,"anchor":"Add-MapLibre-Native-as-a-dependency","text":"Add MapLibre Native as a dependency","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"MapLibre Native for iOS is available on ","type":"text"},{"identifier":"https:\/\/cocoapods.org","isActive":true,"type":"reference"},{"text":" and on the ","type":"text"},{"identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","isActive":true,"type":"reference"},{"text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In Xcode, right click your project and select “Add Package Dependencies…”:"}]},{"type":"paragraph","inlineContent":[{"identifier":"AddPackageDependencies.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"text":"Paste the following URL and click Add Package:","type":"text"}]},{"code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"],"syntax":null,"type":"codeListing"},{"content":[{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","type":"reference"},{"text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/maplibre\/maplibre-native","type":"reference"},{"text":" repository.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Verify you can import MapLibre in your app:"}]},{"code":["import MapLibre"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"SwiftUI","text":"SwiftUI","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:","type":"text"}]},{"code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use this view directly in a SwiftUI View hierarchy, for example:"}]},{"code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When running your app in the simulator you should be greeted with the default "},{"type":"reference","identifier":"https:\/\/demotiles.maplibre.org\/","isActive":true},{"type":"text","text":" style:"}]},{"type":"paragraph","inlineContent":[{"identifier":"DemotilesScreenshot.png","type":"image"}]},{"level":2,"anchor":"UIKit","text":"UIKit","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use the following "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":" to get started with MapLibre Native iOS with UIKit."}]},{"code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"abstract":[{"type":"text","text":"Setting up an Xcode project that uses MapLibre Native for iOS."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"]}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted","interfaceLanguage":"occ"},"seeAlsoSections":[{"anchor":"Essentials","title":"Essentials","generated":true,"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"]}],"metadata":{"role":"article","roleHeading":"Article","title":"Getting Started","modules":[{"name":"MapLibre"}]},"references":{"https://github.com/maplibre/maplibre-gl-native-distribution":{"title":"maplibre-gl-native-distributon","titleInlineContent":[{"type":"text","text":"maplibre-gl-native-distributon"}],"type":"link","url":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"},"https://swiftpackageindex.com/maplibre/maplibre-gl-native-distribution":{"title":"Swift Package Index","titleInlineContent":[{"text":"Swift Package Index","type":"text"}],"type":"link","url":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution"},"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","abstract":[{"type":"text","text":"Powerful, free and open-sourc