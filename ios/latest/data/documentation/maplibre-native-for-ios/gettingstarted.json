{"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"article","sections":[],"primaryContentSections":[{"content":[{"type":"heading","anchor":"Create-a-new-iOS-project","level":2,"text":"Create a new iOS project"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a new (SwiftUI) iOS project with Xcode. Go to "},{"type":"emphasis","inlineContent":[{"text":"File > New > Project…","type":"text"}]},{"type":"text","text":"."}]},{"type":"heading","anchor":"Add-MapLibre-Native-as-a-dependency","level":2,"text":"Add MapLibre Native as a dependency"},{"type":"paragraph","inlineContent":[{"type":"text","text":"MapLibre Native for iOS is available on "},{"isActive":true,"type":"reference","identifier":"https:\/\/cocoapods.org"},{"type":"text","text":" and on the "},{"isActive":true,"type":"reference","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution"},{"type":"text","text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly."}]},{"type":"paragraph","inlineContent":[{"text":"In Xcode, right click your project and select “Add Package Dependencies…”:","type":"text"}]},{"type":"paragraph","inlineContent":[{"identifier":"AddPackageDependencies.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Paste the following URL and click Add Package:"}]},{"type":"codeListing","code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"],"syntax":null},{"type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","isActive":true,"type":"reference"},{"text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the ","type":"text"},{"identifier":"https:\/\/github.com\/maplibre\/maplibre-native","isActive":true,"type":"reference"},{"text":" repository.","type":"text"}]}],"style":"note"},{"type":"paragraph","inlineContent":[{"text":"Verify you can import MapLibre in your app:","type":"text"}]},{"type":"codeListing","code":["import MapLibre"],"syntax":"swift"},{"type":"heading","anchor":"SwiftUI","level":2,"text":"SwiftUI"},{"type":"paragraph","inlineContent":[{"text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:","type":"text"}]},{"type":"codeListing","code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"You can use this view directly in a SwiftUI View hierarchy, for example:","type":"text"}]},{"type":"codeListing","code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When running your app in the simulator you should be greeted with the default "},{"type":"reference","identifier":"https:\/\/demotiles.maplibre.org\/","isActive":true},{"type":"text","text":" style:"}]},{"type":"paragraph","inlineContent":[{"identifier":"DemotilesScreenshot.png","type":"image"}]},{"type":"heading","anchor":"UIKit","level":2,"text":"UIKit"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use the following "},{"code":"UIViewController","type":"codeVoice"},{"type":"text","text":" to get started with MapLibre Native iOS with UIKit."}]},{"type":"codeListing","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"],"syntax":"swift"}],"kind":"content"}],"seeAlsoSections":[{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"],"anchor":"Essentials","generated":true,"title":"Essentials"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted"},"abstract":[{"type":"text","text":"Setting up an Xcode project that uses MapLibre Native for iOS."}],"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"title":"Getting Started","roleHeading":"Article","role":"article","modules":[{"name":"MapLibre"}]},"references":{"https://swiftpackageindex.com/maplibre/maplibre-gl-native-distribution":{"url":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","title":"Swift Package Index","type":"link","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","titleInlineContent":[{"text":"Swift Package Index","type":"text"}]},"https://github.com/maplibre/maplibre-native":{"titleInlineContent":[{"text":"maplibre-native","type":"text"}],"url":"https:\/\/github.com\/maplibre\/maplibre-native","identifier":"https:\/\/github.com\/maplibre\/maplibre-native","type":"link","title":"maplibre-native"},"https://github.com/maplibre/maplibre-gl-native-distribution":{"url":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","title":"maplibre-gl-native-distributon","type":"link","identifier":"https:\/\/