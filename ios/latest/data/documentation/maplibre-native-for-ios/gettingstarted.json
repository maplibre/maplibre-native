{"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted","interfaceLanguage":"occ"},"sections":[],"primaryContentSections":[{"content":[{"level":2,"anchor":"Create-a-new-iOS-project","text":"Create a new iOS project","type":"heading"},{"inlineContent":[{"type":"text","text":"Create a new (SwiftUI) iOS project with Xcode. Go to "},{"type":"emphasis","inlineContent":[{"text":"File > New > Project…","type":"text"}]},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"anchor":"Add-MapLibre-Native-as-a-dependency","text":"Add MapLibre Native as a dependency","type":"heading"},{"inlineContent":[{"type":"text","text":"MapLibre Native for iOS is available on "},{"isActive":true,"type":"reference","identifier":"https:\/\/cocoapods.org"},{"type":"text","text":" and on the "},{"isActive":true,"type":"reference","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution"},{"type":"text","text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly."}],"type":"paragraph"},{"inlineContent":[{"text":"In Xcode, right click your project and select “Add Package Dependencies…”:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"AddPackageDependencies.png","type":"image"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Paste the following URL and click Add Package:"}],"type":"paragraph"},{"syntax":null,"code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"],"type":"codeListing"},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"},{"type":"text","text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/maplibre\/maplibre-native"},{"type":"text","text":" repository."}]}],"type":"aside"},{"inlineContent":[{"text":"Verify you can import MapLibre in your app:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["import MapLibre"],"type":"codeListing"},{"level":2,"anchor":"SwiftUI","text":"SwiftUI","type":"heading"},{"inlineContent":[{"text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"You can use this view directly in a SwiftUI View hierarchy, for example:"}],"type":"paragraph"},{"syntax":"swift","code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"When running your app in the simulator you should be greeted with the default "},{"isActive":true,"identifier":"https:\/\/demotiles.maplibre.org\/","type":"reference"},{"type":"text","text":" style:"}],"type":"paragraph"},{"inlineContent":[{"identifier":"DemotilesScreenshot.png","type":"image"}],"type":"paragraph"},{"level":2,"anchor":"UIKit","text":"UIKit","type":"heading"},{"inlineContent":[{"text":"You can use the following ","type":"text"},{"type":"codeVoice","code":"UIViewController"},{"text":" to get started with MapLibre Native iOS with UIKit.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"],"type":"codeListing"}],"kind":"content"}],"metadata":{"modules":[{"name":"MapLibre"}],"roleHeading":"Article","title":"Getting Started","role":"article"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"]}],"kind":"article","schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Setting up an Xcode project that uses MapLibre Native for iOS."}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"seeAlsoSections":[{"anchor":"Essentials","title":"Essentials","generated":true,"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/AddMarkerSymbolExample":{"kind":"article","url":"\/documentation\/maplibre-native-for-ios\/addmarkersymbolexample","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample","type":"topic","title":"Add Marker","abstract":[{"text":"Simply add a marker to a map!","type":"text"}],"role":"article"},"https://demotiles.maplibre.org/":{"url":"https:\/\/demotiles.maplibre.org\/","identifier":"https:\/\/demotiles.maplibre.org\/","titleInlineContent":[{"type":"text","text":"Demotiles"}],"type":"link","title":"Demotiles"},"AddPackageDependencies.png":{"alt":null,"identifier":"AddPackageDependencies.png","type":"image","variants":[{"traits":["2x","light"],"url":"\/images\/org.swift.MyProject\/AddPackageDependencies@2x.png"}]},"doc://o