ge"}]},{"text":"UIKit","type":"heading","level":2,"anchor":"UIKit"},{"type":"paragraph","inlineContent":[{"text":"You can use the following ","type":"text"},{"code":"UIViewController","type":"codeVoice"},{"text":" to get started with MapLibre Native iOS with UIKit.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"]}]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted","interfaceLanguage":"occ"},"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"kind":"article","references":{"https://swiftpackageindex.com/maplibre/maplibre-gl-native-distribution":{"type":"link","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","url":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","titleInlineContent":[{"text":"Swift Package Index","type":"text"}],"title":"Swift Package Index"},"DemotilesScreenshot.png":{"type":"image","identifier":"DemotilesScreenshot.png","alt":null,"variants":[{"url":"\/images\/org.swift.MyProject\/DemotilesScreenshot@2x.png","traits":["2x","light"]}]},"AddPackageDependencies.png":{"type":"image","identifier":"AddPackageDependencies.png","alt":null,"variants":[{"url":"\/images\/org.swift.MyProject\/AddPackageDependencies@2x.png","traits":["2x","light"]}]},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/AddMarkerSymbol