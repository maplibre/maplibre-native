{"metadata":{"roleHeading":"Article","title":"Getting Started","role":"article","modules":[{"name":"MapLibre"}]},"kind":"article","abstract":[{"text":"Setting up an Xcode project that uses MapLibre Native for iOS.","type":"text"}],"primaryContentSections":[{"content":[{"text":"Create a new iOS project","type":"heading","anchor":"Create-a-new-iOS-project","level":2},{"type":"paragraph","inlineContent":[{"text":"Create a new (SwiftUI) iOS project with Xcode. Go to ","type":"text"},{"inlineContent":[{"type":"text","text":"File > New > Project…"}],"type":"emphasis"},{"text":".","type":"text"}]},{"text":"Add MapLibre Native as a dependency","type":"heading","anchor":"Add-MapLibre-Native-as-a-dependency","level":2},{"type":"paragraph","inlineContent":[{"text":"MapLibre Native for iOS is available on ","type":"text"},{"isActive":true,"identifier":"https:\/\/cocoapods.org","type":"reference"},{"text":" and on the ","type":"text"},{"isActive":true,"identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","type":"reference"},{"text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In Xcode, right click your project and select “Add Package Dependencies…”:","type":"text"}]},{"type":"paragraph","inlineContent":[{"identifier":"AddPackageDependencies.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"text":"Paste the following URL and click Add Package:","type":"text"}]},{"type":"codeListing","code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"],"syntax":null},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","isActive":true},{"type":"text","text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the "},{"type":"reference","identifier":"https:\/\/github.com\/maplibre\/maplibre-native","isActive":true},{"type":"text","text":" repository."}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"text":"Verify you can import MapLibre in your app:","type":"text"}]},{"type":"codeListing","code":["import MapLibre"],"syntax":"swift"},{"text":"SwiftUI","type":"heading","anchor":"SwiftUI","level":2},{"type":"paragraph","inlineContent":[{"text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:","type":"text"}]},{"type":"codeListing","code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"You can use this view directly in a SwiftUI View hierarchy, for example:","type":"text"}]},{"type":"codeListing","code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"When running your app in the simulator you should be greeted with the default ","type":"text"},{"isActive":true,"identifier":"https:\/\/demotiles.maplibre.org\/","type":"reference"},{"text":" style:","type":"text"}]},{"type":"paragraph","inlineContent":[{"identifier":"DemotilesScreenshot.png","type":"image"}]},{"text":"UIKit","type":"heading","anchor":"UIKit","level":2},{"type":"paragraph","inlineContent":[{"text":"You can use the following ","type":"text"},{"code":"UIViewController","type":"codeVoice"},{"text":" to get started with MapLibre Native iOS with UIKit.","type":"text"}]},{"type":"codeListing","code":["class 