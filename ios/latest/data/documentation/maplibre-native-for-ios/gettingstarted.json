e.org\/"},{"type":"text","text":" style:"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"DemotilesScreenshot.png"}]},{"level":2,"text":"UIKit","type":"heading","anchor":"UIKit"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use the following "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":" to get started with MapLibre Native iOS with UIKit."}]},{"code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"]}],"sections":[],"references":{"https://cocoapods.org":{"identifier":"https:\/\/cocoapods.org","type":"link","url":"https:\/\/cocoapods.org","title":"Cocoapods","titleInlineContent":[{"type":"text","text":"Cocoapods"}]},"https://github.com/maplibre/maplibre-gl-native-distribution":{"type":"link","titleInlineContent":[{"type":"text","text":"maplibre-gl-native-distributon"}],"title":"maplibre-gl-native-distributon","url":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"},"AddPackageDependencies.png":{"identifier":"AddPackageDependencies.png","type":"image","variants":[{"traits":["2x","light"],"url":"\/images\/org.swift.MyProject\/AddPackageDependencies@2x.png"}],"alt":null},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","title":"MapLi