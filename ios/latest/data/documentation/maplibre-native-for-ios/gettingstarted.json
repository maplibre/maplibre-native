{"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"]}],"primaryContentSections":[{"content":[{"anchor":"Create-a-new-iOS-project","type":"heading","text":"Create a new iOS project","level":2},{"inlineContent":[{"text":"Create a new (SwiftUI) iOS project with Xcode. Go to ","type":"text"},{"inlineContent":[{"text":"File > New > Project…","type":"text"}],"type":"emphasis"},{"text":".","type":"text"}],"type":"paragraph"},{"anchor":"Add-MapLibre-Native-as-a-dependency","type":"heading","text":"Add MapLibre Native as a dependency","level":2},{"inlineContent":[{"type":"text","text":"MapLibre Native for iOS is available on "},{"type":"reference","identifier":"https:\/\/cocoapods.org","isActive":true},{"type":"text","text":" and on the "},{"type":"reference","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","isActive":true},{"type":"text","text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly."}],"type":"paragraph"},{"inlineContent":[{"text":"In Xcode, right click your project and select “Add Package Dependencies…”:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"AddPackageDependencies.png"}],"type":"paragraph"},{"inlineContent":[{"text":"Paste the following URL and click Add Package:","type":"text"}],"type":"paragraph"},{"syntax":null,"code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"],"type":"codeListing"},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","type":"reference","isActive":true},{"type":"text","text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the "},{"identifier":"https:\/\/github.com\/maplibre\/maplibre-native","type":"reference","isActive":true},{"type":"text","text":" repository."}]}],"type":"aside","style":"note"},{"inlineContent":[{"text":"Verify you can import MapLibre in your app:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["import MapLibre"],"type":"codeListing"},{"anchor":"SwiftUI","type":"heading","text":"SwiftUI","level":2},{"inlineContent":[{"type":"text","text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:"}],"type":"paragraph"},{"syntax":"swift","code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"You can use this view directly in a SwiftUI View hierarchy, for example:"}],"type":"paragraph"},{"syntax":"swift","code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"When running your app in the simulator you should be greeted with the default "},{"isActive":true,"type":"reference","identifier":"https:\/\/demotiles.maplibre.org\/"},{"type":"text","text":" style:"}],"type":"paragraph"},{"inlineContent":[{"identifier":"DemotilesScreenshot.png","type":"image"}],"type":"paragraph"},{"anchor":"UIKit","type":"heading","text":"UIKit","level":2},{"inlineContent":[{"type":"text","text":"You can use the following "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":" to get started with MapLibre Native iOS with UIKit."}],"type":"paragraph"},{"syntax":"swift","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"],"type":"codeListing"}],"kind":"content"}],"abstract":[{"type":"text","text":"Setting up an Xcode project that uses MapLibre Native for iOS."}],"kind":"article","identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted","interfaceLanguage":"occ"},"metadata":{"modules":[{"name":"MapLibre"}],"roleHeading":"Article","role":"article","title":"Getting Started"},"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"sections":[],"seeAlsoSections":[{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"],"title":"Essentials","anchor":"Essentials","generated":true}],"references":{"https://swiftpackageindex.com/maplibre/maplibre-gl-native-distribution":{"type":"link","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","titleInlineContent":[{"type":"text","text":"Swift Package Index"}],"url":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","title":"Swift Package Index"},"https://cocoapods.org":{"title":"Cocoapods","titleInlineContent":[{"type":"text","text":"Cocoapods"}],"identifier":"https:\/\/cocoapods.org","type":"link","url":"https:\/\/cocoapods.org"},"https://github.com/maplibre/maplibre-gl-native-distribution":{"type":"link","identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","titleInlineContent":[{"type":"text","text":"maplibre-gl-native-distributon"}],"url":"https:\/\/github.com\/maplibre\/maplibre-gl-native-dis