{"primaryContentSections":[{"content":[{"level":2,"text":"Create a new iOS project","anchor":"Create-a-new-iOS-project","type":"heading"},{"inlineContent":[{"type":"text","text":"Create a new (SwiftUI) iOS project with Xcode. Go to "},{"type":"emphasis","inlineContent":[{"text":"File > New > Project…","type":"text"}]},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"text":"Add MapLibre Native as a dependency","anchor":"Add-MapLibre-Native-as-a-dependency","type":"heading"},{"inlineContent":[{"text":"MapLibre Native for iOS is available on ","type":"text"},{"isActive":true,"identifier":"https:\/\/cocoapods.org","type":"reference"},{"text":" and on the ","type":"text"},{"isActive":true,"identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","type":"reference"},{"text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In Xcode, right click your project and select “Add Package Dependencies…”:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"AddPackageDependencies.png","type":"image"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Paste the following URL and click Add Package:"}],"type":"paragraph"},{"syntax":null,"code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"],"type":"codeListing"},{"content":[{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"},{"type":"text","text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/maplibre\/maplibre-native"},{"type":"text","text":" repository."}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"},{"inlineContent":[{"type":"text","text":"Verify you can import MapLibre in your app:"}],"type":"paragraph"},{"syntax":"swift","code":["import MapLibre"],"type":"codeListing"},{"level":2,"text":"SwiftUI","anchor":"SwiftUI","type":"heading"},{"inlineContent":[{"text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"],"type":"codeListing"},{"inlineContent":[{"text":"You can use this view directly in a SwiftUI View hierarchy, for example:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"When running your app in the simulator you should be greeted with the default ","type":"text"},{"isActive":true,"identifier":"https:\/\/demotiles.maplibre.org\/","type":"reference"},{"text":" style:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"DemotilesScreenshot.png","type":"image"}],"type":"paragraph"},{"level":2,"text":"UIKit","anchor":"UIKit","type":"heading"},{"inlineContent":[{"text":"You can use the following ","type":"text"},{"type":"codeVoice","code":"UIViewController"},{"text":" to get started with MapLibre Native iOS with UIKit.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"],"type":"codeListing"}],"kind":"content"}],"seeAlsoSections":[{"title":"Essentials","generated":true,"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"],"anchor":"Essentials"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"kind":"article","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted","interfaceLanguage":"occ"},"abstract":[{"type":"text","text":"Setting up an Xcode project that uses MapLibre Native for iOS."}],"sections":[],"metadata":{"title":"Getting Started","modules":[{"name":"MapLibre"}],"roleHeading":"Article","role":"article"},"references":{"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/AddMarkerSymbolExample":{"kind":"article","title":"Add Marker","abstract":[{"text":"Simply add a marker to a map!","type":"text"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample","role":"article","url":"\/documentation\/maplibre-native-for-ios\/addmarkersymbolexample"},"DemotilesScreenshot.png":{"variants":[{"url":"\/images\/org.swift.MyProject\/DemotilesScreenshot@2x.png","traits":["2x","light"]}],"type":"image","alt":null,"identifier":"DemotilesScreenshot.png"},"https://demotiles.maplibre.org/":{"title":"Demotiles","url":"https:\/\/demotiles.maplibre.org\/","titleInlineContent":[{"text":"Demotiles","type":"text"}],"type":"link","identifier":"https:\/\/demotiles.maplibre.org\/"},"https://github.com/maplibre/maplibre-gl-native-distribution":{"url":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","type":"link","title":"maplibre-gl-native-distributon","titleInlineContent":[{"text":"maplibre-gl-native-distributon","type":"text"}],"identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"},"https://cocoapods.org":{"title":"Cocoapods","url":"https:\/\/cocoapods.org","titleInlineContent":[{"text":"Cocoapods","type":"text"}],"type":"link","identifier":"https:\/\/cocoapods.org"},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","type":"topic","url":"\/documentation\/maplibre","kind":"symbol","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}]},"https://github.com/maplibre/maplibre-native":{"url":"https:\/\/github.com\/maplibre\/maplibre-native","type":"link","title":"maplibre-native","titleInlineContent":[{"text":"maplibre-native","type":"text"}],"identifier":"https:\/\/github.com\/maplibre\/maplibre-native"},"https://swiftpackageindex.com/maplibre/maplibre-gl-native-distribution":{"title":"Swift Package Index","url":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","titleInlineContent":[{"text":"Swift Package Index","type":"text"}],"type":"link","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution"},"AddPackageDependencies.png":{"variants":[{"url":"\/images\/org.swift.MyProject\/AddPackageDependencies@2x.png","traits":["2x","light"]}],"type":"image","alt":null,"identifier":"AddPackageDependencies.png"}}}