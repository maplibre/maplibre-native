{"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"article","sections":[],"abstract":[{"text":"Setting up an Xcode project that uses MapLibre Native for iOS.","type":"text"}],"metadata":{"role":"article","modules":[{"name":"MapLibre"}],"roleHeading":"Article","title":"Getting Started"},"primaryContentSections":[{"content":[{"text":"Create a new iOS project","type":"heading","anchor":"Create-a-new-iOS-project","level":2},{"inlineContent":[{"text":"Create a new (SwiftUI) iOS project with Xcode. Go to ","type":"text"},{"inlineContent":[{"type":"text","text":"File > New > Project…"}],"type":"emphasis"},{"text":".","type":"text"}],"type":"paragraph"},{"text":"Add MapLibre Native as a dependency","type":"heading","anchor":"Add-MapLibre-Native-as-a-dependency","level":2},{"inlineContent":[{"text":"MapLibre Native for iOS is available on ","type":"text"},{"identifier":"https:\/\/cocoapods.org","type":"reference","isActive":true},{"text":" and on the ","type":"text"},{"identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","type":"reference","isActive":true},{"text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In Xcode, right click your project and select “Add Package Dependencies…”:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"AddPackageDependencies.png","type":"image"}],"type":"paragraph"},{"inlineContent":[{"text":"Paste the following URL and click Add Package:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"]},{"type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"},{"type":"text","text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/maplibre\/maplibre-native"},{"type":"text","text":" repository."}],"type":"paragraph"}],"name":"Note"},{"inlineContent":[{"text":"Verify you can import MapLibre in your app:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["import MapLibre"]},{"text":"SwiftUI","type":"heading","anchor":"SwiftUI","level":2},{"inlineContent":[{"text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"]},{"inlineContent":[{"text":"You can use this view directly in a SwiftUI View hierarchy, for example:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"]},{"inlineContent":[{"text":"When running your app in the simulator you should be greeted with the default ","type":"text"},{"identifier":"https:\/\/demotiles.maplibre.org\/","type":"reference","isActive":true},{"text":" style:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"DemotilesScreenshot.png","type":"image"}],"type":"paragraph"},{"text":"UIKit","type":"heading","anchor":"UIKit","level":2},{"inlineContent":[{"text":"You can use the following ","type":"text"},{"code":"UIViewController","type":"codeVoice"},{"text":" to get started with MapLibre Native iOS with UIKit.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"]}],"kind":"content"}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"]}],"seeAlsoSections":[{"title":"Essentials","generated":true,"anchor":"Essentials","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"]}],"references":{"DemotilesScreenshot.png":{"type":"image","alt":null,"identifier":"DemotilesScreenshot.png","variants":[{"traits":["2x","light"],"url":"\/images\/org.swift.MyProject\/DemotilesScreenshot@2x.png"}]},"https://demotiles.maplibre.org/":{"title":"Demotiles","type":"link","titleInlineContent":[{"text":"Demotiles","type":"text"}],"identifier":"https:\/\/demotiles.maplibre.org\/","url":"https:\/\/demotiles.maplibre.org\/"},"https://swiftpackageindex.com/maplibre/maplibre-gl-native-distribution":{"title":"Swift Package Index","type":"link","titleInlineContent":[{"text":"Swift Package Index","type":"text"}],"identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","url":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/A