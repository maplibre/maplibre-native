":"heading","level":2,"anchor":"UIKit","text":"UIKit"},{"type":"paragraph","inlineContent":[{"text":"You can use the following ","type":"text"},{"type":"codeVoice","code":"UIViewController"},{"text":" to get started with MapLibre Native iOS with UIKit.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"kind":"article","references":{"AddPackageDependencies.png":{"alt":null,"variants":[{"url":"\/images\/org.swift.MyProject\/AddPackageDependencies@2x.png","traits":["2x","light"]}],"type":"image","identifier":"AddPackageDependencies.png"},"https://github.com/maplibre/maplibre-native":{"url":"https:\/\/github.com\/maplibre\/maplibre-native","type":"link","titleInlineContent":[{"type":"text","text":"maplibre-native"}],"title":"maplibre-native","identifier":"https:\/\/github.com\/maplibre\/maplibre-native"},"https://demotiles.maplibre.org/":{"titleInlineContent":[{"type":"text","text":"Demotiles"}],"title":"Demotiles","url":"https:\/\/demotiles.maplibre.org\/","type":"link","identifier":"https:\/\/demotiles.maplibre.org\/"},"https://swiftpackageindex.com/maplibre/maplibre-gl-native-distribution":{"url":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-dis