libre\/maplibre-gl-native-distribution","isActive":true,"type":"reference"},{"text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the ","type":"text"},{"identifier":"https:\/\/github.com\/maplibre\/maplibre-native","isActive":true,"type":"reference"},{"text":" repository.","type":"text"}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"},{"inlineContent":[{"type":"text","text":"Verify you can import MapLibre in your app:"}],"type":"paragraph"},{"syntax":"swift","code":["import MapLibre"],"type":"codeListing"},{"text":"SwiftUI","type":"heading","anchor":"SwiftUI","level":2},{"inlineContent":[{"type":"text","text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:"}],"type":"paragraph"},{"syntax":"swift","code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"You can use this view directly in a SwiftUI View hierarchy, for example:"}],"type":"paragraph"},{"syntax":"swift","code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"When running your app in the simulator you should be greeted with the default "},{"type":"reference","identifier":"https:\/\/demotiles.maplibre.org\/","isActive":true},{"type":"text","text":" style:"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"DemotilesScreenshot.png"}],"type":"paragraph"},{"text":"UIKit","type":"heading","anchor":"UIKit","level":2},{"inlineContent":[{"type":"text","te