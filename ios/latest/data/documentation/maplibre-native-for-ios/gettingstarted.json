{"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"]}],"sections":[],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted"},"metadata":{"modules":[{"name":"MapLibre"}],"title":"Getting Started","role":"article","roleHeading":"Article"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"kind":"article","abstract":[{"type":"text","text":"Setting up an Xcode project that uses MapLibre Native for iOS."}],"primaryContentSections":[{"content":[{"anchor":"Create-a-new-iOS-project","type":"heading","level":2,"text":"Create a new iOS project"},{"inlineContent":[{"type":"text","text":"Create a new (SwiftUI) iOS project with Xcode. Go to "},{"type":"emphasis","inlineContent":[{"type":"text","text":"File > New > Project…"}]},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Add-MapLibre-Native-as-a-dependency","type":"heading","level":2,"text":"Add MapLibre Native as a dependency"},{"inlineContent":[{"text":"MapLibre Native for iOS is available on ","type":"text"},{"type":"reference","identifier":"https:\/\/cocoapods.org","isActive":true},{"text":" and on the ","type":"text"},{"type":"reference","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","isActive":true},{"text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In Xcode, right click your project and select “Add Package Dependencies…”:"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"AddPackageDependencies.png"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Paste the following URL and click Add Package:"}],"type":"paragraph"},{"type":"codeListing","code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"],"syntax":null},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","isActive":true},{"type":"text","text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the "},{"type":"reference","identifier":"https:\/\/github.com\/maplibre\/maplibre-native","isActive":true},{"type":"text","text":" repository."}]}]},{"inlineContent":[{"text":"Verify you can import MapLibre in your app:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["import MapLibre"],"syntax":"swift"},{"anchor":"SwiftUI","type":"heading","level":2,"text":"SwiftUI"},{"inlineContent":[{"type":"text","text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:"}],"type":"paragraph"},{"type":"codeListing","code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"You can use this view directly in a SwiftUI View hierarchy, for example:"}],"type":"paragraph"},{"type":"codeListing","code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"When running your app in the simulator you should be greeted with the default "},{"type":"reference","identifier":"https:\/\/demotiles.maplibre.org\/","isActive":true},{"type":"text","text":" style:"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"DemotilesScreenshot.png"}],"type":"paragraph"},{"anchor":"UIKit","type":"heading","level":2,"text":"UIKit"},{"inlineContent":[{"text":"You can use the following ","type":"text"},{"type":"codeVoice","code":"UIViewController"},{"text":" to get started with MapLibre Native iOS with UIKit.","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"],"syntax":"swift"}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"seeAlsoSections":[{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"],"title":"Essentials","generated":true,"anchor":"Essentials"}],"references":{"AddPackageDependencies.png":{"variants":[{"traits":["2x","light"],"url":"\/images\/org.swift.MyProject\/AddPackageDependencies@2x.png"}],"type":"image","identifier":"AddPackageDependencies.png","alt":null},"https://github.com/maplibre/maplibre-native":{"titleInlineContent":[{"text":"maplibre-native","type":"text"}],"identifier":"https:\/\/github.com\/maplibre\/maplibre-native","url":"https:\/\/github.com\/maplibre\/maplibre-native","type":"link","title":"maplibre-native"},"https://demotiles.maplibre.org/":{"titleInlineContent":[{"text":"Demotiles","type":"text"}],"type":"link","url":"https:\/\/demotiles.maplibre.org\/","identifier":"https:\/\/demotiles.maplibre.org\/","title":"Demotiles"},"https://github.com/maplibre/maplibre-gl-native-distribution":{"titleInlineContent":[{"text":"maplibre-gl-native-distributon","type":"text"}],"ide