bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"]}]}],"metadata":{"role":"article","title":"Getting Started","roleHeading":"Article","modules":[{"name":"MapLibre"}]},"abstract":[{"text":"Setting up an Xcode project that uses MapLibre Native for iOS.","type":"text"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted","interfaceLanguage":"occ"},"kind":"article","schemaVersion":{"major":0,"minor":3,"patch":0},"seeAlsoSections":[{"title":"Essentials","anchor":"Essentials","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"],"generated":true}],"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"https://github.com/maplibre/maplibre-gl-native-distribution":{"identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","titleInlineContent":[{"text":"maplibre-gl-native-distributon","type":"text"}],"title":"maplibre-gl-native-distributon","type":"link","url":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"},"https://swiftpackageindex.com/maplibre/maplibre-gl-native-distribution":{"identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","titleInlineContent":[{"text":"Swift Package Index","type":"text"}],"title":"Swift Package Index","type":"link","url":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution"},"DemotilesScreenshot.png":{"identifier":"DemotilesScreenshot.png","variants":[{"traits":["2x","light"],"url":"\/images\/org.swift.MyProj