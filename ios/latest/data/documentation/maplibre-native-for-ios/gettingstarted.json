{"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Setting up an Xcode project that uses MapLibre Native for iOS."}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"article","metadata":{"title":"Getting Started","roleHeading":"Article","role":"article","modules":[{"name":"MapLibre"}]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted"},"sections":[],"seeAlsoSections":[{"title":"Essentials","anchor":"Essentials","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"],"generated":true}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Create-a-new-iOS-project","level":2,"text":"Create a new iOS project","type":"heading"},{"inlineContent":[{"text":"Create a new (SwiftUI) iOS project with Xcode. Go to ","type":"text"},{"inlineContent":[{"text":"File > New > Project…","type":"text"}],"type":"emphasis"},{"text":".","type":"text"}],"type":"paragraph"},{"anchor":"Add-MapLibre-Native-as-a-dependency","level":2,"text":"Add MapLibre Native as a dependency","type":"heading"},{"inlineContent":[{"text":"MapLibre Native for iOS is available on ","type":"text"},{"identifier":"https:\/\/cocoapods.org","type":"reference","isActive":true},{"text":" and on the ","type":"text"},{"identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","type":"reference","isActive":true},{"text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In Xcode, right click your project and select “Add Package Dependencies…”:"}],"type":"paragraph"},{"inlineContent":[{"identifier":"AddPackageDependencies.png","type":"image"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Paste the following URL and click Add Package:"}],"type":"paragraph"},{"syntax":null,"code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"],"type":"codeListing"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","isActive":true},{"type":"text","text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the "},{"type":"reference","identifier":"https:\/\/github.com\/maplibre\/maplibre-native","isActive":true},{"type":"text","text":" repository."}]}],"type":"aside"},{"inlineContent":[{"text":"Verify you can import MapLibre in your app:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["import MapLibre"],"type":"codeListing"},{"anchor":"SwiftUI","level":2,"text":"SwiftUI","type":"heading"},{"inlineContent":[{"type":"text","text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:"}],"type":"paragraph"},{"syntax":"swift","code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"You can use this view directly in a SwiftUI View hierarchy, for example:"}],"type":"paragraph"},{"syntax":"swift","code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"When running your app in the simulator you should be greeted with the default ","type":"text"},{"identifier":"https:\/\/demotiles.maplibre.org\/","isActive":true,"type":"reference"},{"text":" style:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"DemotilesScreenshot.png","type":"image"}],"type":"paragraph"},{"anchor":"UIKit","level":2,"text":"UIKit","type":"heading"},{"inlineContent":[{"type":"text","text":"You can use the following "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":" to get started with MapLibre Native iOS with UIKit."}],"type":"paragraph"},{"syntax":"swift","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"],"type":"codeListing"}]}],"references":{"https://swiftpackageindex.com/maplibre/maplibre-gl-native-distribution":{"title":"Swift Package Index","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","type":"link","titleInlineContent":[{"text":"Swift Package Index","type":"text"}],"url":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution"},"https://github.com/maplibre/maplibre-native":{"url":"https:\/\/github.com\/maplibre\/maplibre-native","title":"maplibre-native","type":"link","identifier":"https:\/\/github.com\/maplibre\/maplibre-native","titleInlineContent":[{"text":"maplibre-native","type":"text"}]},"DemotilesScreenshot.png":{"identifier":"DemotilesScreenshot.png","type":"image","variants":[{"traits":["2x","light"],"url":"\/images\/org.swift.MyProject\/DemotilesScreenshot@2x.png"}],"alt":null},"https://cocoapo