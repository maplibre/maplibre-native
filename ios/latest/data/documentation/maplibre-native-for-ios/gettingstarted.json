{"sections":[],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Create a new iOS project","anchor":"Create-a-new-iOS-project"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a new (SwiftUI) iOS project with Xcode. Go to "},{"type":"emphasis","inlineContent":[{"type":"text","text":"File > New > Project…"}]},{"type":"text","text":"."}]},{"type":"heading","level":2,"text":"Add MapLibre Native as a dependency","anchor":"Add-MapLibre-Native-as-a-dependency"},{"type":"paragraph","inlineContent":[{"type":"text","text":"MapLibre Native for iOS is available on "},{"type":"reference","identifier":"https:\/\/cocoapods.org","isActive":true},{"type":"text","text":" and on the "},{"type":"reference","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","isActive":true},{"type":"text","text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly."}]},{"type":"paragraph","inlineContent":[{"text":"In Xcode, right click your project and select “Add Package Dependencies…”:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"AddPackageDependencies.png"}]},{"type":"paragraph","inlineContent":[{"text":"Paste the following URL and click Add Package:","type":"text"}]},{"syntax":null,"code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"],"type":"codeListing"},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"},{"type":"text","text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/maplibre\/maplibre-native"},{"type":"text","text":" repository."}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Verify you can import MapLibre in your app:"}]},{"syntax":"swift","code":["import MapLibre"],"type":"codeListing"},{"type":"heading","level":2,"text":"SwiftUI","anchor":"SwiftUI"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:"}]},{"syntax":"swift","code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use this view directly in a SwiftUI View hierarchy, for example:"}]},{"syntax":"swift","code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When running your app in the simulator you should be greeted with the default "},{"isActive":true,"identifier":"https:\/\/demotiles.maplibre.org\/","type":"reference"},{"type":"text","text":" style:"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"DemotilesScreenshot.png"}]},{"type":"heading","level":2,"text":"UIKit","anchor":"UIKit"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use the following "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":" to get started with MapLibre Native iOS with UIKit."}]},{"syntax":"swift","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"],"type":"codeListing"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"title":"Getting Started","role":"article","modules":[{"name":"MapLibre"}],"roleHeading":"Article"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"kind":"article","seeAlsoSections":[{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"],"anchor":"Essentials","generated":true,"title":"Essentials"}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted","interfaceLanguage":"occ"},"abstract":[{"text":"Setting up an Xcode project that uses MapLibre Native for iOS.","type":"text"}],"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"https://cocoapods.org":{"title":"Cocoapods","url":"https:\/\/cocoapods.org","type":"link","identifier":"https:\/\/cocoapods.org","titleInlineContent":[{"text":"Cocoapods","type":"text"}]},"https://swiftpackageindex.com/maplibre/maplibre-gl-native-distribution":{"titleInlineContent":[{"text":"Swift Package Index","type":"text"}],"title":"Swift Package Index","url":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","type":"link","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution"},"DemotilesScreenshot.png":{"alt":null,"type":"image","identifier":"DemotilesScreenshot.png","variants":[{"url":"\/images\/org.swift.MyProject\/DemotilesScreenshot@2x.png","traits":["2x","light"]}]},"https://github.com/maplibre/maplibre-native":{"titleInlineContent":[{"text":"maplibre-native","ty