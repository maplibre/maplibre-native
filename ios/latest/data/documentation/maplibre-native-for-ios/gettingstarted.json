{"metadata":{"roleHeading":"Article","title":"Getting Started","modules":[{"name":"MapLibre"}],"role":"article"},"seeAlsoSections":[{"title":"Essentials","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"],"anchor":"Essentials","generated":true}],"kind":"article","primaryContentSections":[{"kind":"content","content":[{"text":"Create a new iOS project","type":"heading","anchor":"Create-a-new-iOS-project","level":2},{"inlineContent":[{"type":"text","text":"Create a new (SwiftUI) iOS project with Xcode. Go to "},{"inlineContent":[{"text":"File > New > Project…","type":"text"}],"type":"emphasis"},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Add MapLibre Native as a dependency","type":"heading","anchor":"Add-MapLibre-Native-as-a-dependency","level":2},{"inlineContent":[{"text":"MapLibre Native for iOS is available on ","type":"text"},{"identifier":"https:\/\/cocoapods.org","isActive":true,"type":"reference"},{"text":" and on the ","type":"text"},{"identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","isActive":true,"type":"reference"},{"text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In Xcode, right click your project and select “Add Package Dependencies…”:"}],"type":"paragraph"},{"inlineContent":[{"identifier":"AddPackageDependencies.png","type":"image"}],"type":"paragraph"},{"inlineContent":[{"text":"Paste the following URL and click Add Package:","type":"text"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","type":"reference","isActive":true},{"text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the ","type":"text"},{"identifier":"https:\/\/github.com\/maplibre\/maplibre-native","type":"reference","isActive":true},{"text":" repository.","type":"text"}]}],"name":"Note","style":"note","type":"aside"},{"inlineContent":[{"text":"Verify you can import MapLibre in your app:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["import MapLibre"]},{"level":2,"type":"heading","text":"SwiftUI","anchor":"SwiftUI"},{"inlineContent":[{"type":"text","text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:"}],"type":"paragraph"},{"code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"You can use this view directly in a SwiftUI View hierarchy, for example:"}],"type":"paragraph"},{"code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"When running your app in the simulator you should be greeted with the default ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/demotiles.maplibre.org\/"},{"text":" style:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"DemotilesScreenshot.png"}],"type":"paragraph"},{"text":"UIKit","level":2,"anchor":"UIKit","type":"heading"},{"inlineContent":[{"type":"text","text":"You can use the following "},{"code":"UIViewController","type":"codeVoice"},{"type":"text","text":" to g