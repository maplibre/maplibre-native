{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Create-a-new-iOS-project","level":2,"text":"Create a new iOS project","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Create a new (SwiftUI) iOS project with Xcode. Go to ","type":"text"},{"inlineContent":[{"text":"File > New > Project…","type":"text"}],"type":"emphasis"},{"text":".","type":"text"}]},{"anchor":"Add-MapLibre-Native-as-a-dependency","level":2,"text":"Add MapLibre Native as a dependency","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"MapLibre Native for iOS is available on "},{"type":"reference","identifier":"https:\/\/cocoapods.org","isActive":true},{"type":"text","text":" and on the "},{"type":"reference","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","isActive":true},{"type":"text","text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In Xcode, right click your project and select “Add Package Dependencies…”:"}]},{"type":"paragraph","inlineContent":[{"identifier":"AddPackageDependencies.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"text":"Paste the following URL and click Add Package:","type":"text"}]},{"type":"codeListing","code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"],"syntax":null},{"content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"},{"text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/maplibre\/maplibre-native"},{"text":" repository.","type":"text"}]}],"type":"aside","style":"note","name":"Note"},{"