n the simulator you should be greeted with the default "},{"isActive":true,"type":"reference","identifier":"https:\/\/demotiles.maplibre.org\/"},{"type":"text","text":" style:"}],"type":"paragraph"},{"inlineContent":[{"identifier":"DemotilesScreenshot.png","type":"image"}],"type":"paragraph"},{"level":2,"anchor":"UIKit","text":"UIKit","type":"heading"},{"inlineContent":[{"type":"text","text":"You can use the following "},{"code":"UIViewController","type":"codeVoice"},{"type":"text","text":" to get started with MapLibre Native iOS with UIKit."}],"type":"paragraph"},{"syntax":"swift","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"],"type":"codeListing"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/AddMarkerSymbolExample":{"url":"\/documentation\/maplibre-native-for-ios\/addmarkersymbolexample","abstract":[{"type":"text","text":"Simply add a marker to a map!"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample","kind":"article","type":"topic","role":"article","title":"Add Marker"},"https://cocoapods.org":{"title":"Cocoapods","titleInlineContent":[{"type":"text","text":"Cocoapods"}],"identifier":"https:\/\/cocoapods.org","url":"https:\/\/cocoapods.org","type":"link"},"https://swiftpackageindex.com/maplibre/maplibre-gl-native-distribution":{"titleInlineContent":[{"type":"text","text":"Swift Package Index"}],"url":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","title":"Swift Package