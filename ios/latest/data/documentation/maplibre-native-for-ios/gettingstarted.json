{"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Create a new iOS project","anchor":"Create-a-new-iOS-project"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a new (SwiftUI) iOS project with Xcode. Go to "},{"type":"emphasis","inlineContent":[{"text":"File > New > Project…","type":"text"}]},{"type":"text","text":"."}]},{"level":2,"type":"heading","text":"Add MapLibre Native as a dependency","anchor":"Add-MapLibre-Native-as-a-dependency"},{"type":"paragraph","inlineContent":[{"type":"text","text":"MapLibre Native for iOS is available on "},{"type":"reference","identifier":"https:\/\/cocoapods.org","isActive":true},{"type":"text","text":" and on the "},{"type":"reference","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","isActive":true},{"type":"text","text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly."}]},{"type":"paragraph","inlineContent":[{"text":"In Xcode, right click your project and select “Add Package Dependencies…”:","type":"text"}]},{"type":"paragraph","inlineContent":[{"identifier":"AddPackageDependencies.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"text":"Paste the following URL and click Add Package:","type":"text"}]},{"type":"codeListing","syntax":null,"code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"]},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","type":"reference","isActive":true},{"text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the ","type":"text"},{"identifier":"https:\/\/github.com\/maplibre\/maplibre-native","type":"reference","isActive":true},{"text":" repository.","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"text":"Verify you can import MapLibre in your app:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import MapLibre"]},{"level":2,"type":"heading","text":"SwiftUI","anchor":"SwiftUI"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:"}]},{"type":"codeListing","syntax":"swift","code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use this view directly in a SwiftUI View hierarchy, for example:"}]},{"type":"codeListing","syntax":"swift","code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When running your app in the simulator you should be greeted with the default "},{"type":"reference","isActive":true,"identifier":"https:\/\/demotiles.maplibre.org\/"},{"type":"text","text":" style:"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"DemotilesScreenshot.png"}]},{"level":2,"type":"heading","text":"UIKit","anchor":"UIKit"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use the following "},{"code":"UIViewController","type":"codeVoice"},{"type":"text","text":" to get started with MapLibre Native iOS with UIKit."}]},{"type":"codeListing","syntax":"swift","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"]}],"kind":"content"}],"metadata":{"roleHeading":"Article","title":"Getting Started","role":"article","modules":[{"name":"MapLibre"}]},"kind":"article","seeAlsoSections":[{"anchor":"Essentials","generated":true,"title":"Essentials","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Setting up an Xcode project that uses MapLibre Native for iOS."}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted","interfaceLanguage":"occ"},"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"references":{"https://github.com/maplibre/maplibre-gl-native-distribution":{"url":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","titleInlineContent":[{"type":"text","text":"maplibre-gl-native-distributon"}],"type":"link","title":"maplibre-gl-native-distributon"},"https://demotiles.maplibre.org/":{"url":"https:\/\/demotiles.maplibre.org\/","identifier":"https:\/\/demotiles.maplibre.org\/","titleInlineContent":[{"type":"text","text":"Demotiles"}],"type":"link","title":"Demotiles"},"https://github.com/maplibre/maplibre-native":{"url":"https:\/\/github.com\/maplibre\/maplibre-native","identifier":"https:\/\/github.com\/maplibre\/maplibre-native","titleInlineContent":[{"type":"text","text":"maplibre-native"}],"type":"link","title":"maplibre-native"},"Dem