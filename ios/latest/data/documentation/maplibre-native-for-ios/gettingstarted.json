reenshot.png","type":"image"}]},{"level":2,"type":"heading","text":"UIKit","anchor":"UIKit"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use the following "},{"code":"UIViewController","type":"codeVoice"},{"type":"text","text":" to get started with MapLibre Native iOS with UIKit."}]},{"syntax":"swift","type":"codeListing","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"]}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"https://demotiles.maplibre.org/":{"titleInlineContent":[{"type":"text","text":"Demotiles"}],"type":"link","identifier":"https:\/\/demotiles.maplibre.org\/","title":"Demotiles","url":"https:\/\/demotiles.maplibre.org\/"},"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"role":"collection","kind":"symbol","url":"\/documentation\/maplibre","title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre"},"https://cocoapods.org":{"titleInlineContent":[{"type":"text","text":"Cocoapods"}],"type":"link","identifier":"https:\/\/cocoapods.org","title":"Cocoapods","url":"https:\/\/cocoapods.org"},"https://swiftpackageindex.com/maplibre/maplibre-gl-native-distribution":{"t