{"sections":[],"metadata":{"roleHeading":"Article","role":"article","title":"Getting Started","modules":[{"name":"MapLibre"}]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted"},"abstract":[{"text":"Setting up an Xcode project that uses MapLibre Native for iOS.","type":"text"}],"seeAlsoSections":[{"title":"Essentials","anchor":"Essentials","generated":true,"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"]}],"primaryContentSections":[{"kind":"content","content":[{"text":"Create a new iOS project","level":2,"type":"heading","anchor":"Create-a-new-iOS-project"},{"inlineContent":[{"type":"text","text":"Create a new (SwiftUI) iOS project with Xcode. Go to "},{"type":"emphasis","inlineContent":[{"type":"text","text":"File > New > Project…"}]},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Add MapLibre Native as a dependency","level":2,"type":"heading","anchor":"Add-MapLibre-Native-as-a-dependency"},{"inlineContent":[{"type":"text","text":"MapLibre Native for iOS is available on "},{"type":"reference","identifier":"https:\/\/cocoapods.org","isActive":true},{"type":"text","text":" and on the "},{"type":"reference","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","isActive":true},{"type":"text","text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly."}],"type":"paragraph"},{"inlineContent":[{"text":"In Xcode, right click your project and select “Add Package Dependencies…”:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"AddPackageDependencies.png"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Paste the following URL and click Add Package:"}],"type":"paragraph"},{"code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"],"syntax":null,"type":"codeListing"},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","type":"reference"},{"type":"text","text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the "},{"isActive":true,"identifier":"https:\/\/github.com\/maplibre\/maplibre-native","type":"reference"},{"type":"text","text":" repository."}]}],"type":"aside","style":"note"},{"inlineContent":[{"type":"text","text":"Verify you can import MapLibre in your app:"}],"type":"paragraph"},{"code":["import MapLibre"],"syntax":"swift","type":"codeListing"},{"text":"SwiftUI","level":2,"type":"heading","anchor":"SwiftUI"},{"inlineContent":[{"type":"text","text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:"}],"type":"paragraph"},{"code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"You can use this view directly in a SwiftUI View hierarchy, for example:"}],"type":"paragraph"},{"code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"When running your app in the simulator you should be greeted with the default ","type":"text"},{"type":"reference","identifier":"https:\/\/demotiles.maplibre.org\/","isActive":true},{"text":" style:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"DemotilesScreenshot.png"}],"type":"paragraph"},{"text":"UIKit","level":2,"type":"heading","anchor":"UIKit"},{"inlineContent":[{"type":"text","text":"You can use the following "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":" to get started with MapLibre Native iOS with UIKit."}],"type":"paragraph"},{"code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"],"syntax":"swift","type":"codeListing"}]}],"kind":"article","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/AddMarkerSymbolExample":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample","title":"Add Marker","type":"topic","role":"article","kind":"article","abstract":[{"type":"text","text":"Simply add a marker to a map!"}],"url":"\/documentation\/maplibre-native-for-ios\/addmarkersymbolexample"},"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","type":"topic","role":"collection","title":"MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol"},"https://github.com/maplibre/maplibre-native":{"type":"link","title":"maplibr