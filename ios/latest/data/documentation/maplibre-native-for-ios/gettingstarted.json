{"inlineContent":[{"text":"You can use the following ","type":"text"},{"code":"UIViewController","type":"codeVoice"},{"type":"text","text":" to get started with MapLibre Native iOS with UIKit."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"]}]}],"sections":[],"seeAlsoSections":[{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"],"anchor":"Essentials","title":"Essentials","generated":true}],"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"text":"Setting up an Xcode project that uses MapLibre Native for iOS.","type":"text"}],"references":{"https://cocoapods.org":{"type":"link","url":"https:\/\/cocoapods.org","titleInlineContent":[{"type":"text","text":"Cocoapods"}],"title":"Cocoapods","identifier":"https:\/\/cocoapods.org"},"DemotilesScreenshot.png":{"alt":null,"variants":[{"url":"\/images\/org.swift.MyProject\/DemotilesScreenshot@2x.png","traits":["2x","light"]}],"type":"image","identifier":"DemotilesScreenshot.png"},"https://github.com/maplibre/maplibre-gl-native-distribution":{"identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","url":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","title":"maplibre-gl-native-distributon","titleInlineContent":[{"type":"text","text":"maplibre-gl-native-distributon"}],"type":"link"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/AddMarkerSymbolExample":{"url":"\/documentat