{"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"Setting up an Xcode project that uses MapLibre Native for iOS."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"]}],"metadata":{"title":"Getting Started","roleHeading":"Article","role":"article","modules":[{"name":"MapLibre"}]},"seeAlsoSections":[{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"],"title":"Essentials","generated":true,"anchor":"Essentials"}],"sections":[],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Create-a-new-iOS-project","type":"heading","level":2,"text":"Create a new iOS project"},{"inlineContent":[{"text":"Create a new (SwiftUI) iOS project with Xcode. Go to ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"File > New > Project…"}]},{"text":".","type":"text"}],"type":"paragraph"},{"anchor":"Add-MapLibre-Native-as-a-dependency","type":"heading","level":2,"text":"Add MapLibre Native as a dependency"},{"inlineContent":[{"type":"text","text":"MapLibre Native for iOS is available on "},{"type":"reference","identifier":"https:\/\/cocoapods.org","isActive":true},{"type":"text","text":" and on the "},{"type":"reference","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","isActive":true},{"type":"text","text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In Xcode, right click your project and select “Add Package Dependencies…”:"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"AddPackageDependencies.png"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Paste the following URL and click Add Package:"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"]},{"name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","type":"reference","isActive":true},{"text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the ","type":"text"},{"identifier":"https:\/\/github.com\/maplibre\/maplibre-native","type":"reference","isActive":true},{"text":" repository.","type":"text"}]}],"style":"note"},{"inlineContent":[{"type":"text","text":"Verify you can import MapLibre in your app:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["import MapLibre"]},{"anchor":"SwiftUI","type":"heading","level":2,"text":"SwiftUI"},{"inlineContent":[{"type":"text","text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"]},{"inlineContent":[{"text":"You can use this view directly in a SwiftUI View hierarchy, for example:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"]},{"inlineContent":[{"text":"When running your app in the simulator you should be greeted with the default ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/demotiles.maplibre.org\/"},{"text":" style:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"DemotilesScreenshot.png"}],"type":"paragraph"},{"anchor":"UIKit","type":"heading","level":2,"text":"UIKit"},{"inlineContent":[{"type":"text","text":"You can use the following "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":" to get started with MapLibre Native iOS with UIKit."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"]}]}],"kind":"article","references":{"https://github.com/maplibre/maplibre-gl-native-distribution":{"type":"link","title":"maplibre-gl-native-distributon","url":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","titleInlineContent":[{"text":"maplibre-gl-native-distributon","type":"text"}]},"https://swiftpackageindex.com/maplibre/maplibre-gl-native-distribution":{"type":"link","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","url":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","title":"Swift Package Index","titleInlineContent":[{"text":"Swift Package Index","type":"text"}]},"https://github.com/maplibre/maplibre-native":{"type":"link","title":"maplibre-native","url":"https:\/\/github.com\/maplibre\/maplibre-n