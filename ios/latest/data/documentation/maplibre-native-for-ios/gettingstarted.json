{"metadata":{"roleHeading":"Article","role":"article","modules":[{"name":"MapLibre"}],"title":"Getting Started"},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Create-a-new-iOS-project","text":"Create a new iOS project","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a new (SwiftUI) iOS project with Xcode. Go to "},{"type":"emphasis","inlineContent":[{"type":"text","text":"File > New > Project…"}]},{"type":"text","text":"."}]},{"anchor":"Add-MapLibre-Native-as-a-dependency","text":"Add MapLibre Native as a dependency","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"MapLibre Native for iOS is available on "},{"type":"reference","identifier":"https:\/\/cocoapods.org","isActive":true},{"type":"text","text":" and on the "},{"type":"reference","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","isActive":true},{"type":"text","text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In Xcode, right click your project and select “Add Package Dependencies…”:"}]},{"type":"paragraph","inlineContent":[{"identifier":"AddPackageDependencies.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Paste the following URL and click Add Package:"}]},{"code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"],"syntax":null,"type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","type":"reference","isActive":true},{"type":"text","text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/maplibre\/maplibre-native"},{"type":"text","text":" repository."}]}],"name":"Note","type":"aside","style":"note"},{"type":"paragraph","inlineContent":[{"text":"Verify you can import MapLibre in your app:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import MapLibre"]},{"type":"heading","level":2,"text":"SwiftUI","anchor":"SwiftUI"},{"type":"paragraph","inlineContent":[{"text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use this view directly in a SwiftUI View hierarchy, for example:"}]},{"type":"codeListing","syntax":"swift","code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When running your app in the simulator you should be greeted with the default "},{"identifier":"https:\/\/demotiles.maplibre.org\/","isActive":true,"type":"reference"},{"type":"text","text":" style:"}]},{"type":"paragraph","inlineContent":[{"identifier":"DemotilesScreenshot.png","type":"image"}]},{"type":"heading","level":2,"text":"UIKit","anchor":"UIKit"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use the following "},{"code":"UIViewController","type":"codeVoice"},{"type":"text","text":" to get started with MapLibre Native iOS with UIKit."}]},{"type":"codeListing","syntax":"swift","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!",""