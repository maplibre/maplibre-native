{"seeAlsoSections":[{"title":"Essentials","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"],"anchor":"Essentials","generated":true}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted","interfaceLanguage":"occ"},"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"content":[{"anchor":"Create-a-new-iOS-project","text":"Create a new iOS project","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a new (SwiftUI) iOS project with Xcode. Go to "},{"type":"emphasis","inlineContent":[{"type":"text","text":"File > New > Project…"}]},{"type":"text","text":"."}]},{"anchor":"Add-MapLibre-Native-as-a-dependency","text":"Add MapLibre Native as a dependency","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"MapLibre Native for iOS is available on "},{"type":"reference","isActive":true,"identifier":"https:\/\/cocoapods.org"},{"type":"text","text":" and on the "},{"type":"reference","isActive":true,"identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution"},{"type":"text","text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly."}]},{"type":"paragraph","inlineContent":[{"text":"In Xcode, right click your project and select “Add Package Dependencies…”:","type":"text"}]},{"type":"paragraph","inlineContent":[{"identifier":"AddPackageDependencies.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"text":"Paste the following URL and click Add Package:","type":"text"}]},{"syntax":null,"type":"codeListing","code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"]},{"style":"note","name":"Note","type":"aside","content":[{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","type":"reference"},{"text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/maplibre\/maplibre-native","type":"reference"},{"text":" repository.","type":"text"}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Verify you can import MapLibre in your app:"}]},{"syntax":"swift","type":"codeListing","code":["import MapLibre"]},{"anchor":"SwiftUI","text":"SwiftUI","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"]},{"type":"paragraph","inlineContent":[{"text":"You can use this view directly in a SwiftUI View hierarchy, for example:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When running your app in the simulator you should be greeted with the default "},{"isActive":true,"identifier":"https:\/\/demotiles.maplibre.org\/","type":"reference"},{"type":"text","text":" style:"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"DemotilesScreenshot.png"}]},{"anchor":"UIKit","text":"UIKit","type":"heading","level":2},{"type":"paragraph","inlineCo