{"sections":[],"abstract":[{"type":"text","text":"Setting up an Xcode project that uses MapLibre Native for iOS."}],"metadata":{"modules":[{"name":"MapLibre"}],"role":"article","roleHeading":"Article","title":"Getting Started"},"seeAlsoSections":[{"title":"Essentials","generated":true,"anchor":"Essentials","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"]}],"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Create a new iOS project","anchor":"Create-a-new-iOS-project"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a new (SwiftUI) iOS project with Xcode. Go to "},{"type":"emphasis","inlineContent":[{"type":"text","text":"File > New > Project…"}]},{"type":"text","text":"."}]},{"type":"heading","level":2,"text":"Add MapLibre Native as a dependency","anchor":"Add-MapLibre-Native-as-a-dependency"},{"type":"paragraph","inlineContent":[{"type":"text","text":"MapLibre Native for iOS is available on "},{"type":"reference","identifier":"https:\/\/cocoapods.org","isActive":true},{"type":"text","text":" and on the "},{"type":"reference","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","isActive":true},{"type":"text","text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly."}]},{"type":"paragraph","inlineContent":[{"text":"In Xcode, right click your project and select “Add Package Dependencies…”:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"AddPackageDependencies.png"}]},{"type":"paragraph","inlineContent":[{"text":"Paste the following URL and click Add Package:","type":"text"}]},{"syntax":null,"code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"],"type":"codeListing"},{"style":"note","name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","isActive":true,"type":"reference"},{"type":"text","text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the "},{"identifier":"https:\/\/github.com\/maplibre\/maplibre-native","isActive":true,"type":"reference"},{"type":"text","text":" repository."}]}]},{"type":"paragraph","inlineContent":[{"text":"Verify you can import MapLibre in your app:","type":"text"}]},{"syntax":"swift","code":["import MapLibre"],"type":"codeListing"},{"type":"heading","level":2,"text":"SwiftUI","anchor":"SwiftUI"},{"type":"paragraph","inlineContent":[{"text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:","type":"text"}]},{"syntax":"swift","code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"You can use this view directly in a SwiftUI View hierarchy, for example:","type":"text"}]},{"syntax":"swift","code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"When running your app in the simulator you should be greeted with the default ","type":"text"},{"identifier":"https:\/\/demotiles.maplibre.org\/","isActive":true,"type":"reference"},{"text":" style:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"DemotilesScreenshot.png"}]},{"type":"heading","level":2,"text":"UIKit","anchor":"UIKit"},{"type":"paragraph","inlineContent":[{"text":"You can use the following ","type":"text"},{"code":"UIViewController","type":"codeVoice"},{"text":" to get started with MapLibre Native iOS with UIKit.","type":"text"}]},{"syntax":"swift","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"],"type":"codeListing"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"article","references":{"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/AddMarkerSymbolExample":{"role":"article","url":"\/documentation\/maplibre-native-for-ios\/addmarkersymbolexample","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample","kind":"article","title":"Add Marker","abstract":[{"text":"Simply add a marker to a map!","type":"text"}]},"DemotilesScreenshot.png":{"identifier":"DemotilesScreenshot.png","alt":null,"type":"image","variants":[{"url":"\/images\/org.swift.MyProject\/DemotilesScreenshot@2x.png","traits":["2x","light"]}]},"AddPackageDependencies.png":{"variants":[{"traits":["2x","light"],"url":"\/images\/org.swift.MyProject\/AddPackageDependencies@2x.png"}],"alt":null,"type":"image","identifier":"AddPackageDependencies.png"},"doc://org.swift.MyProject/docu