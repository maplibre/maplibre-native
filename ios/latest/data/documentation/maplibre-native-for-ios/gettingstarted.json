 running your app in the simulator you should be greeted with the default "},{"type":"reference","identifier":"https:\/\/demotiles.maplibre.org\/","isActive":true},{"type":"text","text":" style:"}]},{"type":"paragraph","inlineContent":[{"identifier":"DemotilesScreenshot.png","type":"image"}]},{"type":"heading","text":"UIKit","level":2,"anchor":"UIKit"},{"type":"paragraph","inlineContent":[{"text":"You can use the following ","type":"text"},{"type":"codeVoice","code":"UIViewController"},{"text":" to get started with MapLibre Native iOS with UIKit.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"]}]}],"references":{"DemotilesScreenshot.png":{"identifier":"DemotilesScreenshot.png","alt":null,"type":"image","variants":[{"traits":["2x","light"],"url":"\/images\/org.swift.MyProject\/DemotilesScreenshot@2x.png"}]},"AddPackageDependencies.png":{"variants":[{"url":"\/images\/org.swift.MyProject\/AddPackageDependencies@2x.png","traits":["2x","light"]}],"alt":null,"identifier":"AddPackageDependencies.png","type":"image"},"https://github.com/maplibre/maplibre-native":{"identifier":"https:\/\/github.com\/maplibre\/maplibre-native","url":"https:\/\/github.com\/maplibre\/maplibre-native","title":"maplibre-native","titleInlineContent":[{"text":"maplibre-native","type":"text"}],"type":"link"},"https://swiftpackageindex.com/maplibre/maplibre-gl-native-distribution":{"title":"Swift Package Index","type":"link","titleInlineContent":[{"text":"Swift Package Index"