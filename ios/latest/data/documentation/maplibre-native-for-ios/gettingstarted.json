Mask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"],"type":"codeListing"}],"kind":"content"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted"},"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"text":"Setting up an Xcode project that uses MapLibre Native for iOS.","type":"text"}],"seeAlsoSections":[{"generated":true,"title":"Essentials","anchor":"Essentials","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"]}],"kind":"article","sections":[],"metadata":{"roleHeading":"Article","title":"Getting Started","modules":[{"name":"MapLibre"}],"role":"article"},"references":{"DemotilesScreenshot.png":{"type":"image","identifier":"DemotilesScreenshot.png","variants":[{"traits":["2x","light"],"url":"\/images\/org.swift.MyProject\/DemotilesScreenshot@2x.png"}],"alt":null},"AddPackageDependencies.png":{"identifier":"AddPackageDependencies.png","alt":null,"variants":[{"traits":["2x","light"],"url":"\/images\/org.swift.MyProject\/AddPackageDependencies@2x.png"}],"type":"image"},"https://swiftpackageindex.com/maplibre/maplibre-gl-native-distribution":{"type":"link","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","title":"Swift Package Index","titleInlineContent":[{"text":"Swift Package Index","type":"text"}],"url":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution"},"https://cocoapods.org":{"title":"Cocoapods","identifier":"https:\/\/cocoapods.o