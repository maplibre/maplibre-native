{"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Create a new iOS project","anchor":"Create-a-new-iOS-project"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a new (SwiftUI) iOS project with Xcode. Go to "},{"type":"emphasis","inlineContent":[{"type":"text","text":"File > New > Project…"}]},{"type":"text","text":"."}]},{"type":"heading","level":2,"text":"Add MapLibre Native as a dependency","anchor":"Add-MapLibre-Native-as-a-dependency"},{"type":"paragraph","inlineContent":[{"type":"text","text":"MapLibre Native for iOS is available on "},{"type":"reference","identifier":"https:\/\/cocoapods.org","isActive":true},{"type":"text","text":" and on the "},{"type":"reference","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","isActive":true},{"type":"text","text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In Xcode, right click your project and select “Add Package Dependencies…”:"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"AddPackageDependencies.png"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Paste the following URL and click Add Package:"}]},{"type":"codeListing","syntax":null,"code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","isActive":true},{"text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/maplibre\/maplibre-native","isActive":true},{"text":" repository.","type":"text"}]}],"style":"note","name":"Note"},{"