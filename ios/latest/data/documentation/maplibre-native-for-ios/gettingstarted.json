{"kind":"article","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"abstract":[{"text":"Setting up an Xcode project that uses MapLibre Native for iOS.","type":"text"}],"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted","interfaceLanguage":"occ"},"primaryContentSections":[{"content":[{"text":"Create a new iOS project","type":"heading","anchor":"Create-a-new-iOS-project","level":2},{"type":"paragraph","inlineContent":[{"text":"Create a new (SwiftUI) iOS project with Xcode. Go to ","type":"text"},{"inlineContent":[{"text":"File > New > Project…","type":"text"}],"type":"emphasis"},{"text":".","type":"text"}]},{"text":"Add MapLibre Native as a dependency","type":"heading","anchor":"Add-MapLibre-Native-as-a-dependency","level":2},{"type":"paragraph","inlineContent":[{"text":"MapLibre Native for iOS is available on ","type":"text"},{"identifier":"https:\/\/cocoapods.org","type":"reference","isActive":true},{"text":" and on the ","type":"text"},{"identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","type":"reference","isActive":true},{"text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In Xcode, right click your project and select “Add Package Dependencies…”:"}]},{"type":"paragraph","inlineContent":[{"identifier":"AddPackageDependencies.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"text":"Paste the following URL and click Add Package:","type":"text"}]},{"code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"],"type":"codeListing","syntax":null},{"name":"Note","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","isActive"