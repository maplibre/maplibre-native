":"text"},{"identifier":"https:\/\/demotiles.maplibre.org\/","type":"reference","isActive":true},{"text":" style:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"DemotilesScreenshot.png"}],"type":"paragraph"},{"level":2,"text":"UIKit","anchor":"UIKit","type":"heading"},{"inlineContent":[{"text":"You can use the following ","type":"text"},{"type":"codeVoice","code":"UIViewController"},{"text":" to get started with MapLibre Native iOS with UIKit.","type":"text"}],"type":"paragraph"},{"code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"],"type":"codeListing","syntax":"swift"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"https://github.com/maplibre/maplibre-native":{"type":"link","title":"maplibre-native","identifier":"https:\/\/github.com\/maplibre\/maplibre-native","titleInlineContent":[{"type":"text","text":"maplibre-native"}],"url":"https:\/\/github.com\/maplibre\/maplibre-native"},"AddPackageDependencies.png":{"alt":null,"identifier":"AddPackageDependencies.png","variants":[{"url":"\/images\/org.swift.MyProject\/AddPackageDependencies@2x.png","traits":["2x","light"]}],"type":"image"},"https://cocoapods.org":{"type":"link","title":"Cocoapods","identifier":"https:\/\/cocoapods.org","titleInlineContent":[{"type":"text","text":"Cocoapods"}],"url":"https:\/\/cocoapods.org"},"https://swiftpackageindex.com/maplibre/maplibre-gl-native-distribution":{"title":"Swift Package Index","url":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distr