:"UIViewController"},{"text":" to get started with MapLibre Native iOS with UIKit.","type":"text"}],"type":"paragraph"},{"code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"],"type":"codeListing","syntax":"swift"}]}],"metadata":{"modules":[{"name":"MapLibre"}],"role":"article","roleHeading":"Article","title":"Getting Started"},"seeAlsoSections":[{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"],"generated":true,"anchor":"Essentials","title":"Essentials"}],"sections":[],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted"},"references":{"https://cocoapods.org":{"title":"Cocoapods","identifier":"https:\/\/cocoapods.org","url":"https:\/\/cocoapods.org","titleInlineContent":[{"text":"Cocoapods","type":"text"}],"type":"link"},"https://github.com/maplibre/maplibre-native":{"type":"link","titleInlineContent":[{"text":"maplibre-native","type":"text"}],"title":"maplibre-native","identifier":"https:\/\/github.com\/maplibre\/maplibre-native","url":"https:\/\/github.com\/maplibre\/maplibre-native"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/AddMarkerSymbolExample":{"abstract":[{"text":"Simply add a marker to a map!","type":"text"}],"url":"\/documentation\/maplibre-native-for-ios\/addmarkersymbolexample","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample","title":"Add Marker","kind":"article","type":"t