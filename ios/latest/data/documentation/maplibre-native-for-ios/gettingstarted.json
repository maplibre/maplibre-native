{"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"article","abstract":[{"text":"Setting up an Xcode project that uses MapLibre Native for iOS.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"metadata":{"roleHeading":"Article","modules":[{"name":"MapLibre"}],"role":"article","title":"Getting Started"},"seeAlsoSections":[{"generated":true,"title":"Essentials","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AddMarkerSymbolExample"],"anchor":"Essentials"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GettingStarted"},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Create-a-new-iOS-project","level":2,"text":"Create a new iOS project","type":"heading"},{"inlineContent":[{"text":"Create a new (SwiftUI) iOS project with Xcode. Go to ","type":"text"},{"inlineContent":[{"type":"text","text":"File > New > Project…"}],"type":"emphasis"},{"text":".","type":"text"}],"type":"paragraph"},{"anchor":"Add-MapLibre-Native-as-a-dependency","level":2,"text":"Add MapLibre Native as a dependency","type":"heading"},{"inlineContent":[{"type":"text","text":"MapLibre Native for iOS is available on "},{"type":"reference","isActive":true,"identifier":"https:\/\/cocoapods.org"},{"type":"text","text":" and on the "},{"type":"reference","isActive":true,"identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution"},{"type":"text","text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In Xcode, right click your project and select “Add Package Dependencies…”:"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"AddPackageDependencies.png"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Paste the following URL and click Add Package:"}],"type":"paragraph"},{"syntax":null,"code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"],"type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","isActive":true,"type":"reference"},{"text":" repository only exists for distributing the iOS package of MapLibre Native. To report issues and ask questions, use the ","type":"text"},{"identifier":"https:\/\/github.com\/maplibre\/maplibre-native","isActive":true,"type":"reference"},{"text":" repository.","type":"text"}]}],"style":"note","name":"Note","type":"aside"},{"inlineContent":[{"type":"text","text":"Verify you can import MapLibre in your app:"}],"type":"paragraph"},{"syntax":"swift","code":["import MapLibre"],"type":"codeListing"},{"text":"SwiftUI","level":2,"type":"heading","anchor":"SwiftUI"},{"inlineContent":[{"text":"To use MapLibre with SwiftUI we need to create a wrapper for the UIKit view that MapLibre provides (using UIViewRepresentable. The simplest way to implement this protocol is as follows:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct SimpleMap: UIViewRepresentable {","    func makeUIView(context _: Context) -> MLNMapView {","        let mapView = MLNMapView()","        return mapView","    }","","    func updateUIView(_: MLNMapView, context _: Context) {}","}"]},{"inlineContent":[{"type":"text","text":"You can use this view directly in a SwiftUI View hierarchy, for example:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            SimpleMap().edgesIgnoringSafeArea(.all)","        }","    }","}"]},{"inlineContent":[{"type":"text","text":"When running your app in the simulator you should be greeted with the default "},{"type":"reference","identifier":"https:\/\/demotiles.maplibre.org\/","isActive":true},{"type":"text","text":" style:"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"DemotilesScreenshot.png"}],"type":"paragraph"},{"text":"UIKit","level":2,"type":"heading","anchor":"UIKit"},{"inlineContent":[{"text":"You can use the following ","type":"text"},{"code":"UIViewController","type":"codeVoice"},{"text":" to get started with MapLibre Native iOS with UIKit.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class SimpleMap: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(mapView)","","        mapView.delegate = self","    }","","    \/\/ MLNMapViewDelegate method called when map has finished loading","    func mapView(_: MLNMapView, didFinishLoading _: MLNStyle) {","    }","}"]}]}],"references":{"https://swiftpackageindex.com/maplibre/maplibre-gl-native-distribution":{"titleInlineContent":[{"type":"text","text":"Swift Package Index"}],"title":"Swift Package Index","identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","url":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution","type":"link"},"https://demotiles.maplibre.org/":{"url":"https:\/\/demotiles.maplibre.org\/","type":"link","identifier":"https:\/\/demotiles.maplibre.org\/","title":"Demotiles","titleInlineContent":[{"type":"text","text":"Demotiles"}]},"https://github.com/maplibre/maplibre-gl-native-distribution":{"titleInlineContent":[{"type":"text","text":"maplibre-gl-native-distributon"}],"title":"maplibre-gl-native-distributon","identifier":"https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution","u