{"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/gettingstarted"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"article","abstract":[{"type":"text","text":"Setting up an Xcode project that uses MapLibre Native for iOS."}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Create-a-new-iOS-project","text":"Create a new iOS project"},{"inlineContent":[{"type":"text","text":"Create a new (SwiftUI) iOS project with Xcode. Go to "},{"type":"emphasis","inlineContent":[{"text":"File > New > Project…","type":"text"}]},{"type":"text","text":"."}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"Add-MapLibre-Native-as-a-dependency","text":"Add MapLibre Native as a dependency"},{"inlineContent":[{"text":"MapLibre Native for iOS is available on ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/cocoapods.org"},{"text":" and on the ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/swiftpackageindex.com\/maplibre\/maplibre-gl-native-distribution"},{"text":" (for use with the Swift Package Manager). However, for this guide we will add the MapLibre Native as a package dependency directly.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In Xcode, right click your project and select “Add Package Dependencies…”:"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"AddPackageDependencies.png"}],"type":"paragraph"},{"inlineContent":[{"text":"Paste the following URL and click Add Package:","type":"text"}],"type":"paragraph"},{"code":["https:\/\/github.com\/maplibre\/maplibre-gl-native-distribution"],"type":"codeListing","syntax":null},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"https: