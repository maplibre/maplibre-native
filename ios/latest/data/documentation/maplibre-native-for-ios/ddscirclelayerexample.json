\/maplibre-style-spec\/expressions\/#step","url":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","title":"step","type":"link"},"https://github.com/maplibre/demotiles/tree/gh-pages/tiles-omt":{"url":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","type":"link","identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","titleInlineContent":[{"text":"tiles around Innsbruck, Austria","type":"text"}],"title":"tiles around Innsbruck, Austria"},"https://openmaptiles.org/schema/#poi":{"titleInlineContent":[{"text":"POIs","type":"text"}],"identifier":"https:\/\/openmaptiles.org\/schema\/#poi","url":"https:\/\/openmaptiles.org\/schema\/#poi","title":"POIs","type":"link"},"doc://org.swift.MyProject/documentation/MapLibre/MLNLineStyleLayer":{"fragments":[{"text":"MLNLineStyleLayer","kind":"identifier"}],"type":"topic","abstract":[{"text":"An ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer"},{"text":" is a style layer that renders one or more stroked","type":"text"},{"text":" ","type":"text"},{"text":"polylines on the map.","type":"text"}],"title":"MLNLineStyleLayer","url":"\/documentation\/maplibre\/mlnlinestylelayer","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","kind":"symbol"}}}