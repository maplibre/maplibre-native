{"type":"text","text":" is a style layer that renders one or more stroked"},{"type":"text","text":" "},{"type":"text","text":"polylines on the map."}],"type":"topic","title":"MLNLineStyleLayer","role":"symbol","url":"\/documentation\/maplibre\/mlnlinestylelayer","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/LineStyleLayerExample":{"title":"Using GeoJSON with a line style layer","abstract":[{"text":"Adding an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","type":"reference","isActive":true},{"text":" to the map using a GeoJSON file.","type":"text"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","role":"article","kind":"article","url":"\/documentation\/maplibre-native-for-ios\/linestylelayerexample"},"https://openmaptiles.org/schema/#poi":{"type":"link","title":"POIs","identifier":"https:\/\/openmaptiles.org\/schema\/#poi","titleInlineContent":[{"type":"text","text":"POIs"}],"url":"https:\/\/openmaptiles.org\/schema\/#poi"},"https://maplibre.org/maplibre-style-spec/expressions/#step":{"title":"step","identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","type":"link","url":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","titleInlineContent":[{"type":"text","text":"step"}]}}}