{"abstract":[{"text":"Add and style a vector tile source","type":"text"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"kind":"article","seeAlsoSections":[{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles"],"anchor":"Styling-and-Dynamic-Data","title":"Styling and Dynamic Data","generated":true}],"primaryContentSections":[{"content":[{"type":"aside","name":"Note","content":[{"inlineContent":[{"text":"This example uses UIKit","type":"text"}],"type":"paragraph"}],"style":"note"},{"inlineContent":[{"text":"This example shows how a vector data source can be added and a style for it can be configured dynamically.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The tiles are ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt"},{"text":" that use the OpenMapTiles schema. We are interested in the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/openmaptiles.org\/schema\/#poi"},{"text":" that are in the ","type":"text"},{"type":"codeVoice","code":"poi"},{"text":" layer, and filter this further with an ","type":"text"},{"type":"codeVoice","code":"NSPredicate"},{"text":" to only show POIs with a ","type":"text"},{"type":"codeVoice","code":"class"},{"text":" of shop. Each POI has a ","type":"text"},{"type":"codeVoice","code":"rank"},{"text":" which is normally used to reduce label density. In this example, we use it to demonstrate how a numeric attribute can be used for styling with the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step"},{"text":" expression. POIs with a rank between 0 and 10 get a red color, between 10 and 20 green, etc.","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["class DDSCircleLayerExample: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds, styleURL: AMERICANA_STYLE)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        mapView.tintColor = .darkGray","","        \/\/ Set the map’s center coordinate and zoom level.","        let innsbruck = CLLocationCoordinate2D(latitude: 47.26497, longitude: 11.4088)","        mapView.setCenter(innsbruck, animated: false)","        mapView.zoomLevel = 14","","        mapView.delegate = self","        view.addSubview(mapView)","    }","","    \/\/ Wait until the style is loaded before modifying the map style.","    func mapView(_: MLNMapView, didFinishLoading style: MLNStyle) {","        let source = MLNVectorTileSource(identifier: \"demotiles\", configurationURL: URL(string: \"https:\/\/demotiles.maplibre.org\/tiles-omt\/tiles.json\")!)","","        style.addSource(source)","","        let layer = MLNCircleStyleLayer(identifier: \"poi-shop-style\", source: source)","","        layer.sourceLayerIdentifier = \"poi\"","        layer.predicate = NSPredicate(format: \"class == %@\", \"shop\")","","        \/\/ Style the circle layer color based on the rank","        layer.circleColor = NSExpression(mglJSONObject: [\"step\", [\"get\", \"rank\"], 0, \"red\", 10, \"green\", 20, \"blue\", 30, \"purple\", 40, \"yellow\"] as [Any])","        layer.circleRadius = NSExpression(forConstantValue: 3)","","        style.addLayer(layer)","    }","}"],"syntax":"swift"},{"inlineContent":[{"type":"image","identifier":"DDSCircleLayerExample.png"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Map data from OpenStreetMap. Style uses OpenMapTiles."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/ddscirclelayerexample"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"role":"article","modules":[{"name":"MapLibre"}],"roleHeading":"Article","title":"Vector Tile Sources"},"sections":[],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/DDSCircleLayerExample","interfaceLanguage":"occ"},"references":{"https://maplibre.org/maplibre-style-spec/expressions/#step":{"type":"link","identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","title":"step","titleInlineContent":[{"text":"step","type":"text"}],"url":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/GeoJSON":{"kind":"article","type":"topic","abstract":[],"url":"\/documentation\/maplibre-native-for-ios\/geojson","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","role":"article","title":"Working with GeoJSON Data"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/PMTiles":{"kind":"article","type":"topic","role":"article","abstract":[{"text":"Working with PMTiles","type":"text"}],"url":"\/documentation\/maplibre-native-for-ios\/pmtiles","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles","title":"PMTiles"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/LineStyleLayerExample":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","title":"Using GeoJSON with a line style layer","role":"article","kind":"article","url":"\/documentation\/maplibre-native-for-ios\/linestylelayerexample","type":"topic","abstract":[{"type":"text","text":"Adding an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer"},{"type":"text","text":" to the map using a GeoJSON file."}]},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/WebAPIDataExample":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","title":"Showing data from an API","type":"topic","abstract":[{"text":"Showing data from an API with custom styling and interaction","type":"text"}],"kind":"article","role":"article","url":"\/documentation\/maplibre-native-for-ios\/webapidataexample"},"https://github.com/maplibre/demotiles/tree/gh-pages/tiles-omt":{"identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","type":"link","title":"tiles around Innsbruck, Austria","titleInlineContent":[{"type":"text","text":"tiles around Innsbruck, Austria"}],"url":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt"},"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","url":"\/documentation\/maplibre","role":"collection","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"type":"topic","kind":"symbol"},"https://openmaptiles.org/schema/#poi":{"type":"link","identifier":"https:\/\/openmaptiles.org\/schema\/#poi","title":"POIs","titleInlineContent":[{"text":"POIs","type":"text"}],"url":"https:\/\/openmaptiles.org\/schema\/#poi"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/AnimatedLineExample":{"type":"topic","title":"Animated Line","kind":"article","url":"\/documentation\/maplibre-native-for-ios\/animatedlineexample","role":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","abstract":[{"type":"text","text":"Add an animated line to a map"}]},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/POIAlongRouteExample":{"title":"POI Along a Route","abstract":[{"text":"Use an ","type":"text"},{"code":"NSPredicate","type":"codeVoice"},{"text":" to show POI and road labels along a route.","type":"text"}],"url":"\/documentation\/maplibre-native-for-ios\/poialongrouteexample","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","role":"article","kind":"article","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNLineStyleLayer":{"role":"symbol","title":"MLNLineStyleLayer","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","isActive":true},{"type":"text","text":" is a style layer that renders one or more stroked"},{"type":"text","text":" "},{"type":"text","text":"polylines on the map."}],"fragments":[{"kind":"identifier","text":"MLNLineStyleLayer"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","url":"\/documentation\/maplibre\/mlnlinestylelayer"},"DDSCircleLayerExample.png":{"variants":[{"traits":["2x","light"],"url":"\/images\/org.swift.MyProject\/DDSCircleLayerExample@2x.png"}],"type":"image","identifier":"DDSCircleLayerExample.png","alt":null}}}