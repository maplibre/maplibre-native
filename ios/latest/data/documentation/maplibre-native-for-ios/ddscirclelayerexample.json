{"kind":"article","schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"primaryContentSections":[{"content":[{"content":[{"type":"paragraph","inlineContent":[{"text":"This example uses UIKit","type":"text"}]}],"style":"note","name":"Note","type":"aside"},{"inlineContent":[{"type":"text","text":"This example shows how a vector data source can be added and a style for it can be configured dynamically."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The tiles are "},{"type":"reference","identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","isActive":true},{"type":"text","text":" that use the OpenMapTiles schema. We are interested in the "},{"type":"reference","identifier":"https:\/\/openmaptiles.org\/schema\/#poi","isActive":true},{"type":"text","text":" that are in the "},{"type":"codeVoice","code":"poi"},{"type":"text","text":" layer, and filter this further with an "},{"type":"codeVoice","code":"NSPredicate"},{"type":"text","text":" to only show POIs with a "},{"type":"codeVoice","code":"class"},{"type":"text","text":" of shop. Each POI has a "},{"type":"codeVoice","code":"rank"},{"type":"text","text":" which is normally used to reduce label density. In this example, we use it to demonstrate how a numeric attribute can be used for styling with the "},{"type":"reference","identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","isActive":true},{"type":"text","text":" expression. POIs with a rank between 0 and 10 get a red color, between 10 and 20 green, etc."}],"type":"paragraph"},{"syntax":"swift","code":["class DDSCircleLayerExample: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds, styleURL: AMERICANA_STYLE)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        mapView.tintColor = .darkGray","","        \/\/ Set the map’s center coordinate and zoom level.","        let innsbruck = CLLocationCoordinate2D(latitude: 47.26497, longitude: 11.4088)","        mapView.setCenter(innsbruck, animated: false)","        mapView.zoomLevel = 14","","        mapView.delegate = self","        view.addSubview(mapView)","    }","","    \/\/ Wait until the style is loaded before modifying the map style.","    func mapView(_: MLNMapView, didFinishLoading style: MLNStyle) {","        let source = MLNVectorTileSource(identifier: \"demotiles\", configurationURL: URL(string: \"https:\/\/demotiles.maplibre.org\/tiles-omt\/tiles.json\")!)","","        style.addSource(source)","","        let layer = MLNCircleStyleLayer(identifier: \"poi-shop-style\", source: source)","","        layer.sourceLayerIdentifier = \"poi\"","        layer.predicate = NSPredicate(format: \"class == %@\", \"shop\")","","        \/\/ Style the circle layer color based on the rank","        layer.circleColor = NSExpression(mglJSONObject: [\"step\", [\"get\", \"rank\"], 0, \"red\", 10, \"green\", 20, \"blue\", 30, \"purple\", 40, \"yellow\"] as [Any])","        layer.circleRadius = NSExpression(forConstantValue: 3)","","        style.addLayer(layer)","    }","}"],"type":"codeListing"},{"inlineContent":[{"identifier":"DDSCircleLayerExample.png","type":"image"}],"type":"paragraph"},{"inlineContent":[{"text":"Map data from OpenStreetMap. Style uses OpenMapTiles.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/ddscirclelayerexample"]}],"metadata":{"role":"article","title":"Vector Tile Sources","modules":[{"name":"MapLibre"}],"roleHeading":"Article"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"seeAlsoSections":[{"generated":true,"anchor":"Styling-and-Dynamic-Data","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles"],"title":"Styling and Dynamic Data"}],"abstract":[{"text":"Add and style a vector tile source","type":"text"}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/DDSCircleLayerExample","interfaceLanguage":"occ"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNLineStyleLayer":{"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","url":"\/documentation\/maplibre\/mlnlinestylelayer","type":"topic","abstract":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","isActive":true,"type":"reference"},{"text":" is a style layer that renders one or more stroked","type":"text"},{"text":" ","type":"text"},{"text":"polylines on the map.","type":"text"}],"fragments":[{"text":"MLNLineStyleLayer","kind":"identifier"}],"kind":"symbol","title":"MLNLineStyleLayer"},"https://openmaptiles.org/schema/#poi":{"type":"link","identifier":"https:\/\/openmaptiles.org\/schema\/#poi","title":"POIs","titleInlineContent":[{"type":"text","text":"POIs"}],"url":"https:\/\/openmaptiles.org\/schema\/#poi"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/GeoJSON":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","url":"\/documentation\/maplibre-native-for-ios\/geojson","title":"Working with GeoJSON Data","type":"topic","role":"article","abstract":[],"kind":"article"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/POIAlongRouteExample":{"kind":"article","url":"\/documentation\/maplibre-native-for-ios\/poialongrouteexample","title":"POI Along a Route","type":"topic","role":"article","abstract":[{"text":"Use an ","type":"text"},{"code":"NSPredicate","type":"codeVoice"},{"text":" to show POI and road labels along a route.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/AnimatedLineExample":{"kind":"article","url":"\/documentation\/maplibre-native-for-ios\/animatedlineexample","title":"Animated Line","type":"topic","role":"article","abstract":[{"type":"text","text":"Add an animated line to a map"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample"},"DDSCircleLayerExample.png":{"type":"image","identifier":"DDSCircleLayerExample.png","variants":[{"traits":["2x","light"],"url":"\/images\/org.swift.MyProject\/DDSCircleLayerExample@2x.png"}],"alt":null},"https://maplibre.org/maplibre-style-spec/expressions/#step":{"type":"link","identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","title":"step","titleInlineContent":[{"type":"text","text":"step"}],"url":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step"},"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol","title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/LineStyleLayerExample":{"kind":"article","url":"\/documentation\/maplibre-native-for-ios\/linestylelayerexample","title":"Using GeoJSON with a line style layer","type":"topic","role":"article","abstract":[{"type":"text","text":"Adding an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","type":"reference","isActive":true},{"type":"text","text":" to the map using a GeoJSON file."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/PMTiles":{"kind":"article","url":"\/documentation\/maplibre-native-for-ios\/pmtiles","title":"PMTiles","type":"topic","role":"article","abstract":[{"type":"text","text":"Working with PMTiles"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles"},"https://github.com/maplibre/demotiles/tree/gh-pages/tiles-omt":{"type":"link","identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","title":"tiles around Innsbruck, Austria","titleInlineContent":[{"type":"text","text":"tiles around Innsbruck, Austria"}],"url":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/WebAPIDataExample":{"kind":"article","url":"\/documentation\/maplibre-native-for-ios\/webapidataexample","title":"Showing data from an API","type":"topic","role":"article","abstract":[{"type":"text","text":"Showing data from an API with custom styling and interaction"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample"}}}