{"seeAlsoSections":[{"title":"Styling and Dynamic Data","anchor":"Styling-and-Dynamic-Data","generated":true,"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles"]}],"kind":"article","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/DDSCircleLayerExample","interfaceLanguage":"occ"},"sections":[],"metadata":{"roleHeading":"Article","role":"article","title":"Vector Tile Sources","modules":[{"name":"MapLibre"}]},"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"Add and style a vector tile source"}],"primaryContentSections":[{"kind":"content","content":[{"content":[{"inlineContent":[{"type":"text","text":"This example uses UIKit"}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This example shows how a vector data source can be added and a style for it can be configured dynamically."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The tiles are "},{"type":"reference","identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","isActive":true},{"type":"text","text":" that use the OpenMapTiles schema. We are interested in the "},{"type":"reference","identifier":"https:\/\/openmaptiles.org\/schema\/#poi","isActive":true},{"type":"text","text":" that are in the "},{"type":"codeVoice","code":"poi"},{"type":"text","text":" layer, and filter this further with an "},{"type":"codeVoice","code":"NSPredicate"},{"type":"text","text":" to only show POIs with a "},{"type":"codeVoice","code":"class"},{"type":"text","text":" of shop. Each POI has a "},{"type":"codeVoice","code":"rank"},{"type":"text","text":" which is normally used to reduce label density. In this example, we use it to demonstrate how a numeric attribute can be used for styling with the "},{"type":"reference","identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","isActive":true},{"type":"text","text":" expression. POIs with a rank between 0 and 10 get a red color, between 10 and 20 green, etc."}]},{"syntax":"swift","type":"codeListing","code":["class DDSCircleLayerExample: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds, styleURL: AMERICANA_STYLE)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        mapView.tintColor = .darkGray","","        \/\/ Set the map’s center coordinate and zoom level.","        let innsbruck = CLLocationCoordinate2D(latitude: 47.26497, longitude: 11.4088)","        mapView.setCenter(innsbruck, animated: false)","        mapView.zoomLevel = 14","","        mapView.delegate = self","        view.addSubview(mapView)","    }","","    \/\/ Wait until the style is loaded before modifying the map style.","    func mapView(_: MLNMapView, didFinishLoading style: MLNStyle) {","        let source = MLNVectorTileSource(identifier: \"demotiles\", configurationURL: URL(string: \"https:\/\/demotiles.maplibre.org\/tiles-omt\/tiles.json\")!)","","        style.addSource(source)","","        let layer = MLNCircleStyleLayer(identifier: \"poi-shop-style\", source: source)","","        layer.sourceLayerIdentifier = \"poi\"","        layer.predicate = NSPredicate(format: \"class == %@\", \"shop\")","","        \/\/ Style the circle layer color based on the rank","        layer.circleColor = NSExpression(mglJSONObject: [\"step\", [\"get\", \"rank\"], 0, \"red\", 10, \"green\", 20, \"blue\", 30, \"purple\", 40, \"yellow\"] as [Any])","        layer.circleRadius = NSExpression(forConstantValue: 3)","","        style.addLayer(layer)","    }","}"]},{"type":"paragraph","inlineContent":[{"identifier":"DDSCircleLayerExample.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"text":"Map data from OpenStreetMap. Style uses OpenMapTiles.","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/ddscirclelayerexample"]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/PMTiles":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles","url":"\/documentation\/maplibre-native-for-ios\/pmtiles","title":"PMTiles","kind":"article","type":"topic","abstract":[{"type":"text","text":"Working with PMTiles"}],"role":"article"},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","title":"MapLibre","role":"collection","url":"\/documentation\/maplibre","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}]},"DDSCircleLayerExample.png":{"type":"image","identifier":"DDSCircleLayerExample.png","variants":[{"traits":["2x","light"],"url":"\/images\/org.swift.MyProject\/DDSCircleLayerExample@2x.png"}],"alt":null},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/LineStyleLayerExample":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","abstract":[{"type":"text","text":"Adding an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","isActive":true},{"type":"text","text":" to the map using a GeoJSON file."}],"url":"\/documentation\/maplibre-native-for-ios\/linestylelayerexample","kind":"article","title":"Using GeoJSON with a line style layer","role":"article","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/POIAlongRouteExample":{"role":"article","kind":"article","abstract":[{"text":"Use an ","type":"text"},{"code":"NSPredicate","type":"codeVoice"},{"text":" to show POI and road labels along a route.","type":"text"}],"url":"\/documentation\/maplibre-native-for-ios\/poialongrouteexample","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","title":"POI Along a Route","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/WebAPIDataExample":{"abstract":[{"text":"Showing data from an API with custom styling and interaction","type":"text"}],"role":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","url":"\/documentation\/maplibre-native-for-ios\/webapidataexample","type":"topic","title":"Showing data from an API","kind":"article"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/GeoJSON":{"abstract":[],"kind":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","title":"Working with GeoJSON Data","role":"article","type":"topic","url":"\/documentation\/maplibre-native-for-ios\/geojson"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/AnimatedLineExample":{"url":"\/documentation\/maplibre-native-for-ios\/animatedlineexample","abstract":[{"text":"Add an animated line to a map","type":"text"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","kind":"article","title":"Animated Line","role":"article"},"https://maplibre.org/maplibre-style-spec/expressions/#step":{"title":"step","type":"link","identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","titleInlineContent":[{"type":"text","text":"step"}],"url":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step"},"doc://org.swift.MyProject/documentation/MapLibre/MLNLineStyleLayer":{"fragments":[{"kind":"identifier","text":"MLNLineStyleLayer"}],"role":"symbol","abstract":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer"},{"type":"text","text":" is a style layer that renders one or more stroked"},{"type":"text","text":" "},{"type":"text","text":"polylines on the map."}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","title":"MLNLineStyleLayer","type":"topic","url":"\/documentation\/maplibre\/mlnlinestylelayer"},"https://github.com/maplibre/demotiles/tree/gh-pages/tiles-omt":{"title":"tiles around Innsbruck, Austria","type":"link","identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","url":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","titleInlineContent":[{"text":"tiles around Innsbruck, Austria","type":"text"}]},"https://openmaptiles.org/schema/#poi":{"title":"POIs","type":"link","identifier":"https:\/\/openmaptiles.org\/schema\/#poi","titleInlineContent":[{"type":"text","text":"POIs"}],"url":"https:\/\/openmaptiles.org\/schema\/#poi"}}}