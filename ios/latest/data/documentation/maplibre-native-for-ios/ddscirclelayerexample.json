{"seeAlsoSections":[{"title":"Styling and Dynamic Data","generated":true,"anchor":"Styling-and-Dynamic-Data","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles"]}],"primaryContentSections":[{"content":[{"content":[{"inlineContent":[{"text":"This example uses UIKit","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Note"},{"type":"paragraph","inlineContent":[{"text":"This example shows how a vector data source can be added and a style for it can be configured dynamically.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The tiles are ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt"},{"text":" that use the OpenMapTiles schema. We are interested in the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/openmaptiles.org\/schema\/#poi"},{"text":" that are in the ","type":"text"},{"type":"codeVoice","code":"poi"},{"text":" layer, and filter this further with an ","type":"text"},{"type":"codeVoice","code":"NSPredicate"},{"text":" to only show POIs with a ","type":"text"},{"type":"codeVoice","code":"class"},{"text":" of shop. Each POI has a ","type":"text"},{"type":"codeVoice","code":"rank"},{"text":" which is normally used to reduce label density. In this example, we use it to demonstrate how a numeric attribute can be used for styling with the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step"},{"text":" expression. POIs with a rank between 0 and 10 get a red color, between 10 and 20 green, etc.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class DDSCircleLayerExample: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds, styleURL: AMERICANA_STYLE)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        mapView.tintColor = .darkGray","","        \/\/ Set the map’s center coordinate and zoom level.","        let innsbruck = CLLocationCoordinate2D(latitude: 47.26497, longitude: 11.4088)","        mapView.setCenter(innsbruck, animated: false)","        mapView.zoomLevel = 14","","        mapView.delegate = self","        view.addSubview(mapView)","    }","","    \/\/ Wait until the style is loaded before modifying the map style.","    func mapView(_: MLNMapView, didFinishLoading style: MLNStyle) {","        let source = MLNVectorTileSource(identifier: \"demotiles\", configurationURL: URL(string: \"https:\/\/demotiles.maplibre.org\/tiles-omt\/tiles.json\")!)","","        style.addSource(source)","","        let layer = MLNCircleStyleLayer(identifier: \"poi-shop-style\", source: source)","","        layer.sourceLayerIdentifier = \"poi\"","        layer.predicate = NSPredicate(format: \"class == %@\", \"shop\")","","        \/\/ Style the circle layer color based on the rank","        layer.circleColor = NSExpression(mglJSONObject: [\"step\", [\"get\", \"rank\"], 0, \"red\", 10, \"green\", 20, \"blue\", 30, \"purple\", 40, \"yellow\"] as [Any])","        layer.circleRadius = NSExpression(forConstantValue: 3)","","        style.addLayer(layer)","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"DDSCircleLayerExample.png"}]},{"type":"paragraph","inlineContent":[{"text":"Map data from OpenStreetMap. Style uses OpenMapTiles.","type":"text"}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/ddscirclelayerexample"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"modules":[{"name":"MapLibre"}],"title":"Vector Tile Sources","roleHeading":"Article","role":"article"},"kind":"article","abstract":[{"text":"Add and style a vector tile source","type":"text"}],"sections":[],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/DDSCircleLayerExample","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/WebAPIDataExample":{"role":"article","type":"topic","title":"Showing data from an API","abstract":[{"type":"text","text":"Showing data from an API with custom styling and interaction"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","kind":"article","url":"\/documentation\/maplibre-native-for-ios\/webapidataexample"},"doc://org.swift.MyProject/documentation/MapLibre/MLNLineStyleLayer":{"role":"symbol","type":"topic","title":"MLNLineStyleLayer","abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","isActive":true},{"type":"text","text":" is a style layer that renders one or more stroked"},{"type":"text","text":" "},{"type":"text","text":"polylines on the map."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","kind":"symbol","fragments":[{"text":"MLNLineStyleLayer","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnlinestylelayer"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/PMTiles":{"url":"\/documentation\/maplibre-native-for-ios\/pmtiles","title":"PMTiles","kind":"article","abstract":[{"text":"Working with PMTiles","type":"text"}