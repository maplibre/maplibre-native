{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"sections":[],"metadata":{"role":"article","roleHeading":"Article","title":"Vector Tile Sources","modules":[{"name":"MapLibre"}]},"kind":"article","identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/DDSCircleLayerExample","interfaceLanguage":"occ"},"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles"],"anchor":"Styling-and-Dynamic-Data","title":"Styling and Dynamic Data"}],"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/ddscirclelayerexample"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Add and style a vector tile source"}],"primaryContentSections":[{"content":[{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This example uses UIKit"}]}]},{"type":"paragraph","inlineContent":[{"text":"This example shows how a vector data source can be added and a style for it can be configured dynamically.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The tiles are "},{"identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","type":"reference","isActive":true},{"type":"text","text":" that use the OpenMapTiles schema. We are interested in the "},{"identifier":"https:\/\/openmaptiles.org\/schema\/#poi","type":"reference","isActive":true},{"type":"text","text":" that are in the "},{"type":"codeVoice","code":"poi"},{"type":"text","text":" layer, and filter this further with an "},{"type":"codeVoice","code":"NSPredicate"},{"type":"text","text":" to only show POIs with a "},{"type":"codeVoice","code":"class"},{"type":"text","text":" of shop. Each POI has a "},{"type":"codeVoice","code":"rank"},{"type":"text","text":" which is normally used to reduce label density. In this example, we use it to demonstrate how a numeric attribute can be used for styling with the "},{"identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","type":"reference","isActive":true},{"type":"text","text":" expression. POIs with a rank between 0 and 10 get a red color, between 10 and 20 green, etc."}]},{"type":"codeListing","syntax":"swift","code":["class DDSCircleLayerExample: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds, styleURL: AMERICANA_STYLE)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        mapView.tintColor = .darkGray","","        \/\/ Set the map’s center coordinate and zoom level.","        let innsbruck = CLLocationCoordinate2D(latitude: 47.26497, longitude: 11.4088)","        mapView.setCenter(innsbruck, animated: false)","        mapView.zoomLevel = 14","","        mapView.delegate = self","        view.addSubview(mapView)","    }","","    \/\/ Wait until the style is loaded before modifying the map style.","    func mapView(_: MLNMapView, didFinishLoading style: MLNStyle) {","        let source = MLNVectorTileSource(identifier: \"demotiles\", configurationURL: URL(string: \"https:\/\/demotiles.maplibre.org\/tiles-omt\/tiles.json\")!)","","        style.addSource(source)","","        let layer = MLNCircleStyleLayer(identifier: \"poi-shop-style\", source: source)","","        layer.sourceLayerIdentifier = \"poi\"","        layer.predicate = NSPredicate(format: \"class == %@\", \"shop\")","","        \/\/ Style the circle layer color based on the rank","        layer.circleColor = NSExpression(mglJSONObject: [\"step\", [\"get\", \"rank\"], 0, \"red\", 10, \"green\", 20, \"blue\", 30, \"purple\", 40, \"yellow\"] as [Any])","        layer.circleRadius = NSExpression(forConstantValue: 3)","","        style.addLayer(layer)","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"DDSCircleLayerExample.png"}]},{"type":"paragraph","inlineContent":[{"text":"Map data from OpenStreetMap. Style uses OpenMapTiles.","type":"text"}]}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/LineStyleLayerExample":{"url":"\/documentation\/maplibre-native-for-ios\/linestylelayerexample","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","type":"topic","title":"Using GeoJSON with a line style layer","role":"article","kind":"article","abstract":[{"type":"text","text":"Adding an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","isActive":true,"type":"reference"},{"type":"text","text":" to the map using a GeoJSON file."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNLineStyleLayer":{"fragments":[{"kind":"identifier","text":"MLNLineStyleLayer"}],"abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","type":"reference","isActive":true},{"type":"text","text":" is a style layer that renders one or more stroked"},{"type":"text","text":" "},{"type":"text","text":"polylines on the map."}],"kind":"symbol","title":"MLNLineStyleLayer","url":"\/documentation\/maplibre\/mlnlinestylelayer","role":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/GeoJSON":{"kind":"article","abstract":[],"title":"Working with GeoJSON Data","type":"topic","url":"\/documentation\/maplibre-native-for-ios\/geojson","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","role":"article"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/POIAlongRouteExample":{"kind":"article","role":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","abstract":[{"type":"text","text":"Use an "},{"code":"NSPredicate","type":"codeVoice"},{"type":"text","text":" to show POI and road labels along a route."}],"type":"topic","title":"POI Along a Route","url":"\/documentation\/maplibre-native-for-ios\/poialongrouteexample"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/AnimatedLineExample":{"title":"Animated Line","kind":"article","role":"article","abstract":[{"type":"text","text":"Add an animated line to a map"}],"url":"\/documentation\/maplibre-native-for-ios\/animatedlineexample","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/PMTiles":{"title":"PMTiles","kind":"article","role":"article","abstract":[{"type":"text","text":"Working with PMTiles"}],"url":"\/documentation\/maplibre-native-for-ios\/pmtiles","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/WebAPIDataExample":{"url":"\/documentation\/maplibre-native-for-ios\/webapidataexample","kind":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","role":"article","title":"Showing data from an API","abstract":[{"type":"text","text":"Showing data from an API with custom styling and interaction"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","url":"\/documentation\/maplibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"role":"collection","title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic"},"DDSCircleLayerExample.png":{"type":"image","alt":null,"variants":[{"traits":["2x","light"],"url":"\/images\/org.swift.MyProject\/DDSCircleLayerExample@2x.png"}],"identifier":"DDSCircleLayerExample.png"},"https://github.com/maplibre/demotiles/tree/gh-pages/tiles-omt":{"type":"link","identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","titleInlineContent":[{"type":"text","text":"tiles around Innsbruck, Austria"}],"title":"tiles around Innsbruck, Austria","url":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt"},"https://maplibre.org/maplibre-style-spec/expressions/#step":{"type":"link","identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","titleInlineContent":[{"type":"text","text":"step"}],"title":"step","url":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step"},"https://openmaptiles.org/schema/#poi":{"type":"link","identifier":"https:\/\/openmaptiles.org\/schema\/#poi","titleInlineContent":[{"type":"text","text":"POIs"}],"title":"POIs","url":"https:\/\/openmaptiles.org\/schema\/#poi"}}}