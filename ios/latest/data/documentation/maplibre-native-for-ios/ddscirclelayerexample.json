{"primaryContentSections":[{"kind":"content","content":[{"content":[{"inlineContent":[{"type":"text","text":"This example uses UIKit"}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"},{"inlineContent":[{"text":"This example shows how a vector data source can be added and a style for it can be configured dynamically.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The tiles are ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","type":"reference"},{"text":" that use the OpenMapTiles schema. We are interested in the ","type":"text"},{"isActive":true,"identifier":"https:\/\/openmaptiles.org\/schema\/#poi","type":"reference"},{"text":" that are in the ","type":"text"},{"code":"poi","type":"codeVoice"},{"text":" layer, and filter this further with an ","type":"text"},{"code":"NSPredicate","type":"codeVoice"},{"text":" to only show POIs with a ","type":"text"},{"code":"class","type":"codeVoice"},{"text":" of shop. Each POI has a ","type":"text"},{"code":"rank","type":"codeVoice"},{"text":" which is normally used to reduce label density. In this example, we use it to demonstrate how a numeric attribute can be used for styling with the ","type":"text"},{"isActive":true,"identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","type":"reference"},{"text":" expression. POIs with a rank between 0 and 10 get a red color, between 10 and 20 green, etc.","type":"text"}],"type":"paragraph"},{"code":["class DDSCircleLayerExample: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds, styleURL: AMERICANA_STYLE)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        mapView.tintColor = .darkGray","","        \/\/ Set the map’s center coordinate and zoom level.","        let innsbruck = CLLocationCoordinate2D(latitude: 47.26497, longitude: 11.4088)","        mapView.setCenter(innsbruck, animated: false)","        mapView.zoomLevel = 14","","        mapView.delegate = self","        view.addSubview(mapView)","    }","","    \/\/ Wait until the style is loaded before modifying the map style.","    func mapView(_: MLNMapView, didFinishLoading style: MLNStyle) {","        let source = MLNVectorTileSource(identifier: \"demotiles\", configurationURL: URL(string: \"https:\/\/demotiles.maplibre.org\/tiles-omt\/tiles.json\")!)","","        style.addSource(source)","","        let layer = MLNCircleStyleLayer(identifier: \"poi-shop-style\", source: source)","","        layer.sourceLayerIdentifier = \"poi\"","        layer.predicate = NSPredicate(format: \"class == %@\", \"shop\")","","        \/\/ Style the circle layer color based on the rank","        layer.circleColor = NSExpression(mglJSONObject: [\"step\", [\"get\", \"rank\"], 0, \"red\", 10, \"green\", 20, \"blue\", 30, \"purple\", 40, \"yellow\"] as [Any])","        layer.circleRadius = NSExpression(forConstantValue: 3)","","        style.addLayer(layer)","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"identifier":"DDSCircleLayerExample.png","type":"image"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Map data from OpenStreetMap. Style uses OpenMapTiles."}],"type":"paragraph"}]}],"sections":[],"kind":"article","abstract":[{"type":"text","text":"Add and style a vector tile source"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/DDSCircleLayerExample"},"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/ddscirclelayerexample"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"title":"Vector Tile Sources","roleHeading":"Article","modules":[{"name":"MapLibre"}],"role":"article"},"seeAlsoSections":[{"generated":true,"id