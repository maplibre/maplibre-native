{"seeAlsoSections":[{"anchor":"Styling-and-Dynamic-Data","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles"],"generated":true,"title":"Styling and Dynamic Data"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/DDSCircleLayerExample","interfaceLanguage":"occ"},"metadata":{"roleHeading":"Article","role":"article","modules":[{"name":"MapLibre"}],"title":"Vector Tile Sources"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/ddscirclelayerexample"]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"abstract":[{"type":"text","text":"Add and style a vector tile source"}],"primaryContentSections":[{"kind":"content","content":[{"type":"aside","name":"Note","style":"note","content":[{"inlineContent":[{"text":"This example uses UIKit","type":"text"}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This example shows how a vector data source can be added and a style for it can be configured dynamically."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The tiles are "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt"},{"type":"text","text":" that use the OpenMapTiles schema. We are interested in the "},{"type":"reference","isActive":true,"identifier":"https:\/\/openmaptiles.org\/schema\/#poi"},{"type":"text","text":" that are in the "},{"type":"codeVoice","code":"poi"},{"type":"text","text":" layer, and filter this further with an "},{"type":"codeVoice","code":"NSPredicate"},{"type":"text","text":" to only show POIs with a "},{"type":"codeVoice","code":"class"},{"type":"text","text":" of shop. Each POI has a "},{"type":"codeVoice","code":"rank"},{"type":"text","text":" which is normally used to reduce label density. In this example, we use it to demonstrate how a numeric attribute can be used for styling with the "},{"type":"reference","isActive":true,"identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step"},{"type":"text","text":" expression. POIs with a rank between 0 and 10 get a red color, between 10 and 20 green, etc."}]},{"type":"codeListing","syntax":"swift","code":["class DDSCircleLayerExample: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds, styleURL: AMERICANA_STYLE)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        mapView.tintColor = .darkGray","","        \/\/ Set the map’s center coordinate and zoom level.","        let innsbruck = CLLocationCoordinate2D(latitude: 47.26497, longitude: 11.4088)","        mapView.setCenter(innsbruck, animated: false)","        mapView.zoomLevel = 14","","        mapView.delegate = self","        view.addSubview(mapView)","    }","","    \/\/ Wait until the style is loaded before modifying the map style.","    func mapView(_: MLNMapView, didFinishLoading style: MLNStyle) {","        let source = MLNVectorTileSource(identifier: \"demotiles\", configurationURL: URL(string: \"https:\/\/demotiles.maplibre.org\/tiles-omt\/tiles.json\")!)","","        style.addSource(source)","","        let layer = MLNCircleStyleLayer(identifier: \"poi-shop-style\", source: source)","","        layer.sourceLayerIdentifier = \"poi\"","        layer.predicate = NSPredicate(format: \"class == %@\", \"shop\")","","        \/\/ Style the circle layer color based on the rank","        layer.circleColor = NSExpression(mglJSONObject: [\"step\", [\"get\", \"rank\"], 0, \"red\", 10, \"green\", 20, \"blue\", 30, \"purple\", 40, \"yellow\"] as [Any])","        layer.circleRadius = NSExpression(forConstantValue: 3)","","        style.addLayer(layer)","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"DDSCircleLayerExample.png"}]},{"type":"paragraph","inlineContent":[{"text":"Map data from OpenStreetMap. Style uses OpenMapTiles.","type":"text"}]}]}],"kind":"article","references":{"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","role":"collection","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","title":"MapLibre","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/PMTiles":{"url":"\/documentation\/maplibre-native-for-ios\/pmtiles","title":"PMTiles","kind":"article","role":"article","abstract":[{"type":"text","text":"Working with PMTiles"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles"},"DDSCircleLayerExample.png":{"type":"image","identifier":"DDSCircleLayerExample.png","alt":null,"variants":[{"url":"\/images\/org.swift.MyProject\/DDSCircleLayerExample@2x.png","traits":["2x","light"]}]},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/AnimatedLineExample":{"kind":"article","role":"article","url":"\/documentation\/maplibre-native-for-ios\/animatedlineexample","abstract":[{"type":"text","text":"Add an animated line to a map"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","title":"Animated Line","type":"topic"},"https://op