{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"seeAlsoSections":[{"title":"Styling and Dynamic Data","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles"],"generated":true,"anchor":"Styling-and-Dynamic-Data"}],"primaryContentSections":[{"content":[{"name":"Note","type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"This example uses UIKit"}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This example shows how a vector data source can be added and a style for it can be configured dynamically."}]},{"type":"paragraph","inlineContent":[{"text":"The tiles are ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","type":"reference"},{"type":"text","text":" that use the OpenMapTiles schema. We are interested in the "},{"type":"reference","isActive":true,"identifier":"https:\/\/openmaptiles.org\/schema\/#poi"},{"type":"text","text":" that are in the "},{"code":"poi","type":"codeVoice"},{"type":"text","text":" layer, and filter this further with an "},{"code":"NSPredicate","type":"codeVoice"},{"text":" to only show POIs with a ","type":"text"},{"code":"class","type":"codeVoice"},{"type":"text","text":" of shop. Each POI has a "},{"code":"rank","type":"codeVoice"},{"type":"text","text":" which is normally used to reduce label density. In this example, we use it to demonstrate how a numeric attribute can be used for styling with the "},{"type":"reference","identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","isActive":true},{"type":"text","text":" expression. POIs with a rank between 0 and 10 get a red color, between 10 and 20 green, etc."}]},{"syntax":"swift","code":["class DDSCircleLayerExample: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds, styleURL: AMERICANA_STYLE)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        mapView.tintColor = .darkGray","","        \/\/ Set the map’s center coordinate and zoom level.","        let innsbruck = CLLocationCoordinate2D(latitude: 47.26497, longitude: 11.4088)","        mapView.setCenter(innsbruck, animated: false)","        mapView.zoomLevel = 14","","        mapView.delegate = self","        view.addSubview(mapView)","    }","","    \/\/ Wait until the style is loaded before modifying the map style.","    func mapView(_: MLNMapView, didFinishLoading style: MLNStyle) {","        let source = MLNVectorTileSource(identifier: \"demotiles\", configurationURL: URL(string: \"https:\/\/demotiles.maplibre.org\/tiles-omt\/tiles.json\")!)","","        style.addSource(source)","","        let layer = MLNCircleStyleLayer(identifier: \"poi-shop-style\", source: source)","","        layer.sourceLayerIdentifier = \"poi\"","        layer.predicate = NSPredicate(format: \"class == %@\", \"shop\")","","        \/\/ Style the circle layer color based on the rank","        layer.circleColor = NSExpression(mglJSONObject: [\"step\", [\"get\", \"rank\"], 0, \"red\", 10, \"green\", 20, \"blue\", 30, \"purple\", 40, \"yellow\"] as [Any])","        layer.circleRadius = NSExpression(forConstantValue: 3)","","        style.addLayer(layer)","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"image","identifier":"DDSCircleLayerExample.png"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Map data from OpenStreetMap. Style uses OpenMapTiles.","type":"text"}]}],"kind":"content"}],"kind":"article","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/DDSCircleLayerExample"},"abstract":[{"text":"Add and style a vector tile source","type":"text"}],"metadata":{"role":"article","title":"Vector Tile Sources","modules":[{"name":"MapLibre"}],"roleHeading":"Article"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/ddscirclelayerexample"]}],"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNLineStyleLayer":{"url":"\/documentation\/maplibre\/mlnlinestylelayer","title":"MLNLineStyleLayer","abstract":[{"text":"An ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","type":"reference"},{"text":" is a style layer that renders one or more stroked","type":"text"},{"text":" ","type":"text"},{"text":"polylines on the map.","type":"text"}],"role":"symbol","fragments":[{"kind":"identifier","text":"MLNLineStyleLayer"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/AnimatedLineExample":{"url":"\/documentation\/maplibre-native-for-ios\/animatedlineexample","role":"article","abstract":[{"type":"text","text":"Add an animated line to a map"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","kind":"article","title":"Animated Line","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/WebAPIDataExample":{"url":"\/documentation\/maplibre-native-for-ios\/webapidataexample","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","title":"Showing data from an API","role":"article","type":"topic","abstract":[{"text":"Showing data from an API with custom styling and interaction","type":"text"}],"kind":"article"},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","url":"\/documentation\/maplibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol"},"https://github.com/maplibre/demotiles/tree/gh-pages/tiles-omt":{"titleInlineContent":[{"text":"tiles around Innsbruck, Austria","type":"text"}],"identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","title":"tiles around Innsbruck, Austria","type":"link","url":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/GeoJSON":{"url":"\/documentation\/maplibre-native-for-ios\/geojson","role":"article","kind":"article","abstract":[],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","title":"Working with GeoJSON Data","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/LineStyleLayerExample":{"title":"Using GeoJSON with a line style layer","url":"\/documentation\/maplibre-native-for-ios\/linestylelayerexample","abstract":[{"text":"Adding an ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer"},{"text":" to the map using a GeoJSON file.","type":"text"}],"role":"article","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","kind":"article"},"https://openmaptiles.org/schema/#poi":{"titleInlineContent":[{"text":"POIs","type":"text"}],"identifier":"https:\/\/openmaptiles.org\/schema\/#poi","title":"POIs","type":"link","url":"https:\/\/openmaptiles.org\/schema\/#poi"},"https://maplibre.org/maplibre-style-spec/expressions/#step":{"titleInlineContent":[{"text":"step","type":"text"}],"identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","title":"step","type":"link","url":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/PMTiles":{"title":"PMTiles","url":"\/documentation\/maplibre-native-for-ios\/pmtiles","abstract":[{"text":"Working with PMTiles","type":"text"}],"role":"article","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles","kind":"article"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/POIAlongRouteExample":{"url":"\/documentation\/maplibre-native-for-ios\/poialongrouteexample","role":"article","kind":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","type":"topic","title":"POI Along a Route","abstract":[{"text":"Use an ","type":"text"},{"code":"NSPredicate","type":"codeVoice"},{"text":" to show POI and road labels along a route.","type":"text"}]},"DDSCircleLayerExample.png":{"alt":null,"variants":[{"traits":["2x","light"],"url":"\/images\/org.swift.MyProject\/DDSCircleLayerExample@2x.png"}],"type":"image","identifier":"DDSCircleLayerExample.png"}}}