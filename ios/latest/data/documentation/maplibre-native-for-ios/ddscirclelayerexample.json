{"primaryContentSections":[{"kind":"content","content":[{"content":[{"inlineContent":[{"text":"This example uses UIKit","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Note","style":"note"},{"type":"paragraph","inlineContent":[{"text":"This example shows how a vector data source can be added and a style for it can be configured dynamically.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The tiles are ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt"},{"text":" that use the OpenMapTiles schema. We are interested in the ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/openmaptiles.org\/schema\/#poi"},{"text":" that are in the ","type":"text"},{"type":"codeVoice","code":"poi"},{"text":" layer, and filter this further with an ","type":"text"},{"type":"codeVoice","code":"NSPredicate"},{"text":" to only show POIs with a ","type":"text"},{"type":"codeVoice","code":"class"},{"text":" of shop. Each POI has a ","type":"text"},{"type":"codeVoice","code":"rank"},{"text":" which is normally used to reduce label density. In this example, we use it to demonstrate how a numeric attribute can be used for styling with the ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step"},{"text":" expression. POIs with a rank between 0 and 10 get a red color, between 10 and 20 green, etc.","type":"text"}]},{"syntax":"swift","code":["class DDSCircleLayerExample: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds, styleURL: AMERICANA_STYLE)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        mapView.tintColor = .darkGray","","        \/\/ Set the map’s center coordinate and zoom level.","        let innsbruck = CLLocationCoordinate2D(latitude: 47.26497, longitude: 11.4088)","        mapView.setCenter(innsbruck, animated: false)","        mapView.zoomLevel = 14","","        mapView.delegate = self","        view.addSubview(mapView)","    }","","    \/\/ Wait until the style is loaded before modifying the map style.","    func mapView(_: MLNMapView, didFinishLoading style: MLNStyle) {","        let source = MLNVectorTileSource(identifier: \"demotiles\", configurationURL: URL(string: \"https:\/\/demotiles.maplibre.org\/tiles-omt\/tiles.json\")!)","","        style.addSource(source)","","        let layer = MLNCircleStyleLayer(identifier: \"poi-shop-style\", source: source)","","        layer.sourceLayerIdentifier = \"poi\"","        layer.predicate = NSPredicate(format: \"class == %@\", \"shop\")","","        \/\/ Style the circle layer color based on the rank","        layer.circleColor = NSExpression(mglJSONObject: [\"step\", [\"get\", \"rank\"], 0, \"red\", 10, \"green\", 20, \"blue\", 30, \"purple\", 40, \"yellow\"] as [Any])","        layer.circleRadius = NSExpression(forConstantValue: 3)","","        style.addLayer(layer)","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"identifier":"DDSCircleLayerExample.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"text":"Map data from OpenStreetMap. Style uses OpenMapTiles.","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/ddscirclelayerexample"]}],"abstract":[{"type":"text","text":"Add and style a vector tile source"}],"metadata":{"modules":[{"name":"MapLibre"}],"roleHeading":"Article","title":"Vector Tile Sources","role":"article"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"sections":[],"kind":"article","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/DDSCircleLayerExample"},"schemaVersion":{"minor":3,"patch":0,"major":0},"seeAlsoSections":[{"title":"Styling and Dynamic Data","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles"],"generated":true,"anchor":"Styling-and-Dynamic-Data"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"type":"topic","title":"MapLibre","kind":"symbol","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNLineStyleLayer":{"abstract":[{"text":"An ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","isActive":true},{"text":" is a style layer that renders one or more stroked","type":"text"},{"text":" ","type":"text"},{"text":"polylines on the map.","type":"text"}],"url":"\/documentation\/maplibre\/mlnlinestylelayer","fragments":[{"text":"MLNLineStyleLayer","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","kind":"symbol","type":"topic","title":"MLNLineStyleLayer","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/LineStyleLayerExample":{"role":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","abstract":[{"text":"Adding an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","isActive":true,"type":"reference"},{"text":" to the map using a GeoJSON file.","type":"text"}],"type":"topic","url":"\/documentation\/maplibre-native-for-ios\/linestylelayerexample","title":"Using GeoJSON with a line style layer","kind":"article"},"DDSCircleLayerExample.png":{"type":"image","variants":[{"traits":["2x","light"],"url":"\/images\/org.swift.MyProject\/DDSCircleLayerExample@2x.png"}],"identifier":"DDSCircleLayerExample.png","alt":null},"https://maplibre.org/maplibre-style-spec/expressions/#step":{"title":"step","titleInlineContent":[{"text":"step","type":"text"}],"url":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","type":"link","identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/POIAlongRouteExample":{"abstract":[{"text":"Use an ","type":"text"},{"type":"codeVoice","code":"NSPredicate"},{"text":" to show POI and road labels along a route.","type":"text"}],"kind":"article","title":"POI Along a Route","role":"article","url":"\/documentation\/maplibre-native-for-ios\/poialongrouteexample","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample"},"https://openmaptiles.org/schema/#poi":{"title":"POIs","titleInlineContent":[{"text":"POIs","type":"text"}],"url":"https:\/\/openmaptiles.org\/schema\/#poi","type":"link","identifier":"https:\/\/openmaptiles.org\/schema\/#poi"},"https://github.com/maplibre/demotiles/tree/gh-pages/tiles-omt":{"url":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","titleInlineContent":[{"text":"tiles around Innsbruck, Austria","type":"text"}],"type":"link","title":"tiles around Innsbruck, Austria"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/GeoJSON":{"role":"article","kind":"article","abstract