{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"metadata":{"title":"Vector Tile Sources","roleHeading":"Article","modules":[{"name":"MapLibre"}],"role":"article"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/ddscirclelayerexample"]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/DDSCircleLayerExample"},"kind":"article","primaryContentSections":[{"content":[{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This example uses UIKit"}]}],"style":"note","name":"Note"},{"type":"paragraph","inlineContent":[{"text":"This example shows how a vector data source can be added and a style for it can be configured dynamically.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The tiles are ","type":"text"},{"identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","type":"reference","isActive":true},{"text":" that use the OpenMapTiles schema. We are interested in the ","type":"text"},{"identifier":"https:\/\/openmaptiles.org\/schema\/#poi","type":"reference","isActive":true},{"text":" that are in the ","type":"text"},{"type":"codeVoice","code":"poi"},{"text":" layer, and filter this further with an ","type":"text"},{"type":"codeVoice","code":"NSPredicate"},{"text":" to only show POIs with a ","type":"text"},{"type":"codeVoice","code":"class"},{"text":" of shop. Each POI has a ","type":"text"},{"type":"codeVoice","code":"rank"},{"text":" which is normally used to reduce label density. In this example, we use it to demonstrate how a numeric attribute can be used for styling with the ","type":"text"},{"identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","type":"reference","isActive":true},{"text":" expression. POIs with a rank between 0 and 10 get a red color, between 10 and 20 green, etc.","type":"text"}]},{"type":"codeListing","code":["class DDSCircleLayerExample: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds, styleURL: AMERICANA_STYLE)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        mapView.tintColor = .darkGray","","        \/\/ Set the map’s center coordinate and zoom level.","        let innsbruck = CLLocationCoordinate2D(latitude: 47.26497, longitude: 11.4088)","        mapView.setCenter(innsbruck, animated: false)","        mapView.zoomLevel = 14","","        mapView.delegate = self","        view.addSubview(mapView)","    }","","    \/\/ Wait until the style is loaded before modifying the map style.","    func mapView(_: MLNMapView, didFinishLoading style: MLNStyle) {","        let source = MLNVectorTileSource(identifier: \"demotiles\", configurationURL: URL(string: \"https:\/\/demotiles.maplibre.org\/tiles-omt\/tiles.json\")!)","","        style.addSource(source)","","        let layer = MLNCircleStyleLayer(identifier: \"poi-shop-style\", source: source)","","        layer.sourceLayerIdentifier = \"poi\"","        layer.predicate = NSPredicate(format: \"class == %@\", \"shop\")","","        \/\/ Style the circle layer color based on the rank","        layer.circleColor = NSExpression(mglJSONObject: [\"step\", [\"get\", \"rank\"], 0, \"red\", 10, \"green\", 20, \"blue\", 30, \"purple\", 40, \"yellow\"] as [Any])","        layer.circleRadius = NSExpression(forConstantValue: 3)","","        style.addLayer(layer)","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"DDSCircleLayerExample.png"}]},{"type":"paragraph","inlineContent":[{"text":"Map data from OpenStreetMap. Style uses OpenMapTiles.","type":"text"}]}],"kind":"content"}],"seeAlsoSections":[{"anchor":"Styling-and-Dynamic-Data","generated":true,"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles"],"title":"Styling and Dynamic Data"}],"abstract":[{"type":"text","text":"Add and style a vector tile source"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/PMTiles":{"role":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles","title":"PMTiles","type":"topic","url":"\/documentation\/maplibre-native-for-ios\/pmtiles","kind":"article","abstract":[{"text":"Working with PMTiles","type":"text"}]},"https://openmaptiles.org/schema/#poi":{"url":"https:\/\/openmaptiles.org\/schema\/#poi","titleInlineContent":[{"type":"text","text":"POIs"}],"identifier":"https:\/\/openmaptiles.org\/schema\/#poi","type":"link","title":"POIs"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/GeoJSON":{"title":"Working with GeoJSON Data","role":"article","type":"topic","abstract":[],"url":"\/documentation\/maplibre-native-for-ios\/geojson","kind":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON"},"DDSCircleLayerExample.png":{"alt":null,"variants":[{"url":"\/images\/org.swift.MyProject\/DDSCircleLayerExample@2x.png","traits":["2x","light"]}],"identifier":"DDSCircleLayerExample.png","type":"image"},"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic","title":"MapLibre","url":"\/documentation\/maplibre","kind":"symbol","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNLineStyleLayer":{"abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","type":"reference","isActive":true},{"type":"text","text":" is a style layer that renders one or more stroked"},{"type":"text","text":" "},{"type":"text","text":"polylines on the map."}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","url":"\/documentation\/maplibre\/mlnlinestylelayer","fragments":[{"kind":"identifier","text":"MLNLineStyleLayer"}],"type":"topic","title":"MLNLineStyleLayer","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/AnimatedLineExample":{"url":"\/documentation\/maplibre-native-for-ios\/animatedlineexample","abstract":[{"type":"text","text":"Add an animated line to a map"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","kind":"article","role":"article","title":"Animated Line","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/LineStyleLayerExample":{"url":"\/documentation\/maplibre-native-for-ios\/linestylelayerexample","abstract":[{"text":"Adding an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","isActive":true,"type":"reference"},{"text":" to the map using a GeoJSON file.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","kind":"article","role":"article","title":"Using GeoJSON with a line style layer","type":"topic"},"https://github.com/maplibre/demotiles/tree/gh-pages/tiles-omt":{"url":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","titleInlineContent":[{"type":"text","text":"tiles around Innsbruck, Austria"}],"identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","type":"link","title":"tiles around Innsbruck, Austria"},"https://maplibre.org/maplibre-style-spec/expressions/#step":{"url":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","titleInlineContent":[{"type":"text","text":"step"}],"identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","type":"link","title":"step"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/WebAPIDataExample":{"url":"\/documentation\/maplibre-native-for-ios\/webapidataexample","abstract":[{"type":"text","text":"Showing data from an API with custom styling and interaction"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","kind":"article","role":"article","title":"Showing data from an API","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/POIAlongRouteExample":{"kind":"article","type":"topic","abstract":[{"type":"text","text":"Use an "},{"type":"codeVoice","code":"NSPredicate"},{"type":"text","text":" to show POI and road labels along a route."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","role":"article","title":"POI Along a Route","url":"\/documentation\/maplibre-native-for-ios\/poialongrouteexample"}}}