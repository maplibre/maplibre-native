{"kind":"article","metadata":{"title":"Vector Tile Sources","modules":[{"name":"MapLibre"}],"roleHeading":"Article","role":"article"},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"Add and style a vector tile source","type":"text"}],"seeAlsoSections":[{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles"],"title":"Styling and Dynamic Data","generated":true,"anchor":"Styling-and-Dynamic-Data"}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/DDSCircleLayerExample","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/ddscirclelayerexample"]}],"primaryContentSections":[{"content":[{"content":[{"inlineContent":[{"type":"text","text":"This example uses UIKit"}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"},{"type":"paragraph","inlineContent":[{"text":"This example shows how a vector data source can be added and a style for it can be configured dynamically.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The tiles are "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt"},{"type":"text","text":" that use the OpenMapTiles schema. We are interested in the "},{"type":"reference","isActive":true,"identifier":"https:\/\/openmaptiles.org\/schema\/#poi"},{"type":"text","text":" that are in the "},{"type":"codeVoice","code":"poi"},{"type":"text","text":" layer, and filter this further with an "},{"type":"codeVoice","code":"NSPredicate"},{"type":"text","text":" to only show POIs with a "},{"type":"codeVoice","code":"class"},{"type":"text","text":" of shop. Each POI has a "},{"type":"codeVoice","code":"rank"},{"type":"text","text":" which is normally used to reduce label density. In this example, we use it to demonstrate how a numeric attribute can be used for styling with the "},{"type":"reference","isActive":true,"identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step"},{"type":"text","text":" expression. POIs with a rank between 0 and 10 get a red color, between 10 and 20 green, etc."}]},{"code":["class DDSCircleLayerExample: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds, styleURL: AMERICANA_STYLE)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        mapView.tintColor = .darkGray","","        \/\/ Set the map’s center coordinate and zoom level.","        let innsbruck = CLLocationCoordinate2D(latitude: 47.26497, longitude: 11.4088)","        mapView.setCenter(innsbruck, animated: false)","        mapView.zoomLevel = 14","","        mapView.delegate = self","        view.addSubview(mapView)","    }","","    \/\/ Wait until the style is loaded before modifying the map style.","    func mapView(_: MLNMapView, didFinishLoading style: MLNStyle) {","        let source = MLNVectorTileSource(identifier: \"demotiles\", configurationURL: URL(string: \"https:\/\/demotiles.maplibre.org\/tiles-omt\/tiles.json\")!)","","        style.addSource(source)","","        let layer = MLNCircleStyleLayer(identifier: \"poi-shop-style\", source: source)","","        layer.sourceLayerIdentifier = \"poi\"","        layer.predicate = NSPredicate(format: \"class == %@\", \"shop\")","","        \/\/ Style the circle layer color based on the rank","        layer.circleColor = NSExpression(mglJSONObject: [\"step\", [\"get\", \"rank\"], 0, \"red\", 10, \"green\", 20, \"blue\", 30, \"purple\", 40, \"yellow\"] as [Any])","        layer.circleRadius = NSExpression(forConstantValue: 3)","","        style.addLayer(layer)","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"identifier":"DDSCircleLayerExample.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Map data from OpenStreetMap. Style uses OpenMapTiles."}]}],"kind":"content"}],"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNLineStyleLayer":{"role":"symbol","title":"MLNLineStyleLayer","kind":"symbol","type":"topic","fragments":[{"kind":"identifier","text":"MLNLineStyleLayer"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","abstract":[{"type":"text","text":"An "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer"},{"type":"text","text":" is a style layer that renders one or more stroked"},{"type":"text","text":" "},{"type":"text","text":"polylines on the map."}],"url":"\/documentation\/maplibre\/mlnlinestylelayer"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/POIAlongRouteExample":{"type":"topic","kind":"article","url":"\/documentation\/maplibre-native-for-ios\/poialongrouteexample","title":"POI Along a Route","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","role":"article","abstract":[{"type":"text","text":"Use an "},{"code":"NSPredicate","type":"codeVoice"},{"type":"text","text":" to show POI and road labels along a route."}]},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/PMTiles":{"title":"PMTiles","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles","abstract":[{"text":"Working with PMTiles","type":"text"}],"url":"\/documentation\/maplibre-native-for-ios\/pmtiles","role":"article","kind":"article"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/LineStyleLayerExample":{"title":"Using GeoJSON with a line style layer","type":"topic","url":"\/documentation\/maplibre-native-for-ios\/linestylelayerexample","kind":"article","role":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","abstract":[{"text":"Adding an ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","type":"reference"},{"text":" to the map using a GeoJSON file.","type":"text"}]},"DDSCircleLayerExample.png":{"identifier":"DDSCircleLayerExample.png","variants":[{"url":"\/images\/org.swift.MyProject\/DDSCircleLayerExample@2x.png","traits":["2x","light"]}],"alt":null,"type":"image"},"https://openmaptiles.org/schema/#poi":{"identifier":"https:\/\/openmaptiles.org\/schema\/#poi","titleInlineContent":[{"type":"text","text":"POIs"}],"title":"POIs","url":"https:\/\/openmaptiles.org\/schema\/#poi","type":"link"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/AnimatedLineExample":{"title":"Animated Line","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","abstract":[{"text":"Add an animated line to a map","type":"text"}],"url":"\/documentation\/maplibre-native-for-ios\/animatedlineexample","role":"article","kind":"article"},"https://maplibre.org/maplibre-style-spec/expressions/#step":{"identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","title":"step","titleInlineContent":[{"type":"text","text":"step"}],"url":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","type":"link"},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","url":"\/documentation\/maplibre","type":"topic","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/WebAPIDataExample":{"url":"\/documentation\/maplibre-native-for-ios\/webapidataexample","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","kind":"article","type":"topic","role":"article","abstract":[{"text":"Showing data from an API with custom styling and interaction","type":"text"}],"title":"Showing data from an API"},"https://github.com/maplibre/demotiles/tree/gh-pages/tiles-omt":{"identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","titleInlineContent":[{"type":"text","text":"tiles around Innsbruck, Austria"}],"title":"tiles around Innsbruck, Austria","url":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","type":"link"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/GeoJSON":{"role":"article","title":"Working with GeoJSON Data","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","type":"topic","url":"\/documentation\/maplibre-native-for-ios\/geojson","kind":"article","abstract":[]}}}