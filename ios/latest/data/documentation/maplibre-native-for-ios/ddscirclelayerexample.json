":"Animated Line","type":"topic"},"DDSCircleLayerExample.png":{"alt":null,"type":"image","variants":[{"url":"\/images\/org.swift.MyProject\/DDSCircleLayerExample@2x.png","traits":["2x","light"]}],"identifier":"DDSCircleLayerExample.png"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/GeoJSON":{"role":"article","type":"topic","title":"Working with GeoJSON Data","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","url":"\/documentation\/maplibre-native-for-ios\/geojson","kind":"article","abstract":[]},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"kind":"symbol","url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic","role":"collection"},"https://openmaptiles.org/schema/#poi":{"titleInlineContent":[{"type":"text","text":"POIs"}],"identifier":"https:\/\/openmaptiles.org\/schema\/#poi","url":"https:\/\/openmaptiles.org\/schema\/#poi","title":"POIs","type":"link"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/POIAlongRouteExample":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","url":"\/documentation\/maplibre-native-for-ios\/poialongrouteexample","abstract":[{"text":"Use an ","type":"text"},{"type":"codeVoice","code":"NSPredicate"},{"text":" to show POI and road labels along a route.","type":"text"}],"role":"article","kind":"article","title":"POI Along a Route","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNLineStyleLayer":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","url":"\/documentation\/maplibre\/mlnlinestylelayer","type":"topic","role":"symbol","title":"MLNLineStyleLayer","fragments":[{"text":"MLNLineStyleLayer","kind":"identifier"}],"abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","type":"reference","isActive":true},{"type":"text","text":" is a style layer that renders one or more stroked"},{"type":"text","text":" "},{"type":"text","text":"polylines on the map."}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/WebAPIDataExample":{"abstract":[{"type":"text","text":"Showing data from an API with custom styling and interaction"}],"role":"article","title":"Showing data from an API","url":"\/documentation\/maplibre-native-for-ios\/webapidataexample","kind":"article","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample"},"https://maplibre.org/maplibre-style-spec/expressions/#step":{"title":"step","type":"link","titleInlineContent":[{"type":"text","text":"step"}],"url":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/PMTiles":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles","abstract":[{"type":"text","text":"Working with PMTiles"}],"role":"article","url":"\/documentation\/maplibre-native-for-ios\/pmtiles","kind":"article","title":"PMTiles"}}}