{"kind":"article","primaryContentSections":[{"kind":"content","content":[{"type":"aside","name":"Note","style":"note","content":[{"inlineContent":[{"type":"text","text":"This example uses UIKit"}],"type":"paragraph"}]},{"inlineContent":[{"type":"text","text":"This example shows how a vector data source can be added and a style for it can be configured dynamically."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The tiles are "},{"type":"reference","identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","isActive":true},{"type":"text","text":" that use the OpenMapTiles schema. We are interested in the "},{"type":"reference","identifier":"https:\/\/openmaptiles.org\/schema\/#poi","isActive":true},{"type":"text","text":" that are in the "},{"code":"poi","type":"codeVoice"},{"type":"text","text":" layer, and filter this further with an "},{"code":"NSPredicate","type":"codeVoice"},{"type":"text","text":" to only show POIs with a "},{"code":"class","type":"codeVoice"},{"type":"text","text":" of shop. Each POI has a "},{"code":"rank","type":"codeVoice"},{"type":"text","text":" which is normally used to reduce label density. In this example, we use it to demonstrate how a numeric attribute can be used for styling with the "},{"type":"reference","identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","isActive":true},{"type":"text","text":" expression. POIs with a rank between 0 and 10 get a red color, between 10 and 20 green, etc."}],"type":"paragraph"},{"type":"codeListing","code":["class DDSCircleLayerExample: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds, styleURL: AMERICANA_STYLE)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        mapView.tintColor = .darkGray","","        \/\/ Set the map’s center coordinate and zoom level.","        let innsbruck = CLLocationCoordinate2D(latitude: 47.26497, longitude: 11.4088)","        mapView.setCenter(innsbruck, animated: false)","        mapView.zoomLevel = 14","","        mapView.delegate = self","        view.addSubview(mapView)","    }","","    \/\/ Wait until the style is loaded before modifying the map style.","    func mapView(_: MLNMapView, didFinishLoading style: MLNStyle) {","        let source = MLNVectorTileSource(identifier: \"demotiles\", configurationURL: URL(string: \"https:\/\/demotiles.maplibre.org\/tiles-omt\/tiles.json\")!)","","        style.addSource(source)","","        let layer = MLNCircleStyleLayer(identifier: \"poi-shop-style\", source: source)","","        layer.sourceLayerIdentifier = \"poi\"","        layer.predicate = NSPredicate(format: \"class == %@\", \"shop\")","","        \/\/ Style the circle layer color based on the rank","        layer.circleColor = NSExpression(mglJSONObject: [\"step\", [\"get\", \"rank\"], 0, \"red\", 10, \"green\", 20, \"blue\", 30, \"purple\", 40, \"yellow\"] as [Any])","        layer.circleRadius = NSExpression(forConstantValue: 3)","","        style.addLayer(layer)","    }","}"],"syntax":"swift"},{"inlineContent":[{"identifier":"DDSCircleLayerExample.png","type":"image"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Map data from OpenStreetMap. Style uses OpenMapTiles."}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/DDSCircleLayerExample","interfaceLanguage":"occ"},"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"text":"Add and style a vector tile source","type":"text"}],"seeAlsoSections":[{"generated":true,"anchor":"Styling-and-Dynamic-Data","title":"Styling and Dynamic Data","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles"]}],"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/ddscirclelayerexample"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"metadata":{"modules":[{"name":"MapLibre"}],"role":"article","title":"Vector Tile Sources","roleHeading":"Article"},"references":{"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/PMTiles":{"kind":"article","title":"PMTiles","abstract":[{"type":"text","text":"Working with PMTiles"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles","url":"\/documentation\/maplibre-native-for-ios\/pmtiles","type":"topic","role":"article"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/GeoJSON":{"title":"Working with GeoJSON Data","url":"\/documentation\/maplibre-native-for-ios\/geojson","kind":"article","abstract":[],"role":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNLineStyleLayer":{"role":"symbol","url":"\/documentation\/maplibre\/mlnlinestylelayer","type":"topic","fragments":[{"kind":"identifier","text":"MLNLineStyleLayer"}],"kind":"symbol","title":"MLNLineStyleLayer","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","abstract":[{"text":"An ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","type":"reference"},{"text":" is a style layer that renders one or more stroked","type":"text"},{"text":" ","type":"text"},{"text":"polylines on the map.","type":"text"}]},"DDSCircleLayerExample.png":{"type":"image","identifier":"DDSCircleLayerExample.png","alt":null,"variants":[{"url":"\/images\/org.swift.MyProject\/DDSCircleLayerExample@2x.png","traits":["2x","light"]}]},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/AnimatedLineExample":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","abstract":[{"type":"text","text":"Add an animated line to a map"}],"url":"\/documentation\/maplibre-native-for-ios\/animatedlineexample","type":"topic","role":"article","kind":"article","title":"Animated Line"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/POIAlongRouteExample":{"kind":"article","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","abstract":[{"type":"text","text":"Use an "},{"type":"codeVoice","code":"NSPredicate"},{"type":"text","text":" to show POI and road labels along a route."}],"url":"\/documentation\/maplibre-native-for-ios\/poialongrouteexample","title":"POI Along a Route","role":"article"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/WebAPIDataExample":{"url":"\/documentation\/maplibre-native-for-ios\/webapidataexample","abstract":[{"type":"text","text":"Showing data from an API with custom styling and interaction"}],"kind":"article","title":"Showing data from an API","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","type":"topic","role":"article"},"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","url":"\/documentation\/maplibre","title":"MapLibre","kind":"symbol","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/LineStyleLayerExample":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","type":"topic","title":"Using GeoJSON with a line style layer","role":"article","abstract":[{"type":"text","text":"Adding an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","isActive":true},{"type":"text","text":" to the map using a GeoJSON file."}],"kind":"article","url":"\/documentation\/maplibre-native-for-ios\/linestylelayerexample"},"https://github.com/maplibre/demotiles/tree/gh-pages/tiles-omt":{"titleInlineContent":[{"type":"text","text":"tiles around Innsbruck, Austria"}],"identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","url":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","type":"link","title":"tiles around Innsbruck, Austria"},"https://openmaptiles.org/schema/#poi":{"type":"link","title":"POIs","identifier":"https:\/\/openmaptiles.org\/schema\/#poi","titleInlineContent":[{"text":"POIs","type":"text"}],"url":"https:\/\/openmaptiles.org\/schema\/#poi"},"https://maplibre.org/maplibre-style-spec/expressions/#step":{"titleInlineContent":[{"type":"text","text":"step"}],"identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","url":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","type":"link","title":"step"}}}