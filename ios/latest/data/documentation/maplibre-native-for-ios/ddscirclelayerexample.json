{"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/ddscirclelayerexample"]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"abstract":[{"type":"text","text":"Add and style a vector tile source"}],"metadata":{"role":"article","roleHeading":"Article","title":"Vector Tile Sources","modules":[{"name":"MapLibre"}]},"kind":"article","sections":[],"primaryContentSections":[{"kind":"content","content":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This example uses UIKit"}]}],"type":"aside","name":"Note","style":"note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This example shows how a vector data source can be added and a style for it can be configured dynamically."}]},{"type":"paragraph","inlineContent":[{"text":"The tiles are ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","type":"reference"},{"text":" that use the OpenMapTiles schema. We are interested in the ","type":"text"},{"isActive":true,"identifier":"https:\/\/openmaptiles.org\/schema\/#poi","type":"reference"},{"text":" that are in the ","type":"text"},{"code":"poi","type":"codeVoice"},{"text":" layer, and filter this further with an ","type":"text"},{"code":"NSPredicate","type":"codeVoice"},{"text":" to only show POIs with a ","type":"text"},{"code":"class","type":"codeVoice"},{"text":" of shop. Each POI has a ","type":"text"},{"code":"rank","type":"codeVoice"},{"text":" which is normally used to reduce label density. In this example, we use it to demonstrate how a numeric attribute can be used for styling with the ","type":"text"},{"isActive":true,"identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","type":"reference"},{"text":" expression. POIs with a rank between 0 and 10 get a red color, between 10 and 20 green, etc.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class DDSCircleLayerExample: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds, styleURL: AMERICANA_STYLE)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        mapView.tintColor = .darkGray","","        \/\/ Set the map’s center coordinate and zoom level.","        let innsbruck = CLLocationCoordinate2D(latitude: 47.26497, longitude: 11.4088)","        mapView.setCenter(innsbruck, animated: false)","        mapView.zoomLevel = 14","","        mapView.delegate = self","        view.addSubview(mapView)","    }","","    \/\/ Wait until the style is loaded before modifying the map style.","    func mapView(_: MLNMapView, didFinishLoading style: MLNStyle) {","        let source = MLNVectorTileSource(identifier: \"demotiles\", configurationURL: URL(string: \"https:\/\/demotiles.maplibre.org\/tiles-omt\/tiles.json\")!)","","        style.addSource(source)","","        let layer = MLNCircleStyleLayer(identifier: \"poi-shop-style\", source: source)","","        layer.sourceLayerIdentifier = \"poi\"","        layer.predicate = NSPredicate(format: \"class == %@\", \"shop\")","","        \/\/ Style the circle layer color based on the rank","        layer.circleColor = NSExpression(mglJSONObject: [\"step\", [\"get\", \"rank\"], 0, \"red\", 10, \"green\", 20, \"blue\", 30, \"purple\", 40, \"yellow\"] as [Any])","        layer.circleRadius = NSExpression(forConstantValue: 3)","","        style.addLayer(layer)","    }","}"]},{"type":"paragraph","inlineContent":[{"identifier":"DDSCircleLayerExample.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"text":"Map data from OpenStreetMap. Style uses OpenMapTiles.","type":"text"}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/DDSCircleLayerExample","interfaceLanguage":"occ"},"seeAlsoSections":[{"title":"Styling and Dynamic Data","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles"],"generated":true,"anchor":"Styling-and-Dynamic-Data"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/WebAPIDataExample":{"kind":"article","abstract":[{"text":"Showing data from an API with custom styling and interaction","type":"text"}],"type":"topic","title":"Showing data from an API","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","url":"\/documentation\/maplibre-native-for-ios\/webapidataexample","role":"article"},"https://openmaptiles.org/schema/#poi":{"titleInlineContent":[{"text":"POIs","type":"text"}],"title":"POIs","url":"https:\/\/openmaptiles.org\/schema\/#poi","type":"link","identifier":"https:\/\/openmaptiles.org\/schema\/#poi"},"DDSCircleLayerExample.png":{"alt":null,"type":"image","identifier":"DDSCircleLayerExample.png","variants":[{"url":"\/images\/org.swift.MyProject\/DDSCircleLayerExample@2x.png","traits":["2x","light"]}]},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/LineStyleLayerExample":{"type":"topic","url":"\/documentation\/maplibre-native-for-ios\/linestylelayerexample","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","role":"article","kind":"article","abstract":[{"text":"Adding an ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","type":"reference"},{"text":" to the map using a GeoJSON file.","type":"text"}],"title":"Using GeoJSON with a line style layer"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/PMTiles":{"abstract":[{"text":"Working with PMTiles","type":"text"}],"role":"article","kind":"article","type":"topic","url":"\/documentation\/maplibre-native-for-ios\/pmtiles","title":"PMTiles","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles"},"https://maplibre.org/maplibre-style-spec/expressions/#step":{"titleInlineContent":[{"text":"step","type":"text"}],"title":"step","url":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","type":"link","identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/POIAlongRouteExample":{"type":"topic","abstract":[{"type":"text","text":"Use an "},{"type":"codeVoice","code":"NSPredicate"},{"type":"text","text":" to show POI and road labels along a route."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","kind":"article","url":"\/documentation\/maplibre-native-for-ios\/poialongrouteexample","role":"article","title":"POI Along a Route"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/AnimatedLineExample":{"abstract":[{"type":"text","text":"Add an animated line to a map"}],"url":"\/documentation\/maplibre-native-for-ios\/animatedlineexample","role":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","title":"Animated Line","type":"topic","kind":"article"},"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"url":"\/documentation\/maplibre","kind":"symbol","type":"topic","title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection"},"https://github.com/maplibre/demotiles/tree/gh-pages/tiles-omt":{"titleInlineContent":[{"type":"text","text":"tiles around Innsbruck, Austria"}],"title":"tiles around Innsbruck, Austria","url":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","type":"link","identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/GeoJSON":{"url":"\/documentation\/maplibre-native-for-ios\/geojson","type":"topic","title":"Working with GeoJSON Data","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","abstract":[],"kind":"article","role":"article"},"doc://org.swift.MyProject/documentation/MapLibre/MLNLineStyleLayer":{"kind":"symbol","title":"MLNLineStyleLayer","role":"symbol","fragments":[{"text":"MLNLineStyleLayer","kind":"identifier"}],"abstract":[{"type":"text","text":"An "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer"},{"type":"text","text":" is a style layer that renders one or more stroked"},{"type":"text","text":" "},{"type":"text","text":"polylines on the map."}],"url":"\/documentation\/maplibre\/mlnlinestylelayer","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer"}}}