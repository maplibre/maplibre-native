{"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"article","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/DDSCircleLayerExample","interfaceLanguage":"occ"},"metadata":{"roleHeading":"Article","role":"article","modules":[{"name":"MapLibre"}],"title":"Vector Tile Sources"},"abstract":[{"text":"Add and style a vector tile source","type":"text"}],"sections":[],"seeAlsoSections":[{"title":"Styling and Dynamic Data","generated":true,"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles"],"anchor":"Styling-and-Dynamic-Data"}],"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/ddscirclelayerexample"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"kind":"content","content":[{"content":[{"inlineContent":[{"text":"This example uses UIKit","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Note","style":"note"},{"type":"paragraph","inlineContent":[{"text":"This example shows how a vector data source can be added and a style for it can be configured dynamically.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The tiles are "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt"},{"type":"text","text":" that use the OpenMapTiles schema. We are interested in the "},{"type":"reference","isActive":true,"identifier":"https:\/\/openmaptiles.org\/schema\/#poi"},{"type":"text","text":" that are in the "},{"type":"codeVoice","code":"poi"},{"type":"text","text":" layer, and filter this further with an "},{"type":"codeVoice","code":"NSPredicate"},{"type":"text","text":" to only show POIs with a "},{"type":"codeVoice","code":"class"},{"type":"text","text":" of shop. Each POI has a "},{"type":"codeVoice","code":"rank"},{"type":"text","text":" which is normally used to reduce label density. In this example, we use it to demonstrate how a numeric attribute can be used for styling with the "},{"type":"reference","isActive":true,"identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step"},{"type":"text","text":" expression. POIs with a rank between 0 and 10 get a red color, between 10 and 20 green, etc."}]},{"code":["class DDSCircleLayerExample: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: view.bounds, styleURL: AMERICANA_STYLE)","        mapView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        mapView.tintColor = .darkGray","","        \/\/ Set the map’s center coordinate and zoom level.","        let innsbruck = CLLocationCoordinate2D(latitude: 47.26497, longitude: 11.4088)","        mapView.setCenter(innsbruck, animated: false)","        mapView.zoomLevel = 14","","        mapView.delegate = self","        view.addSubview(mapView)","    }","","    \/\/ Wait until the style is loaded before modifying the map style.","    func mapView(_: MLNMapView, didFinishLoading style: MLNStyle) {","        let source = MLNVectorTileSource(identifier: \"demotiles\", configurationURL: URL(string: \"https:\/\/demotiles.maplibre.org\/tiles-omt\/tiles.json\")!)","","        style.addSource(source)","","        let layer = MLNCircleStyleLayer(identifier: \"poi-shop-style\", source: source)","","        layer.sourceLayerIdentifier = \"poi\"","        layer.predicate = NSPredicate(format: \"class == %@\", \"shop\")","","        \/\/ Style the circle layer color based on the rank","        layer.circleColor = NSExpression(mglJSONObject: [\"step\", [\"get\", \"rank\"], 0, \"red\", 10, \"green\", 20, \"blue\", 30, \"purple\", 40, \"yellow\"] as [Any])","        layer.circleRadius = NSExpression(forConstantValue: 3)","","        style.addLayer(layer)","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"DDSCircleLayerExample.png"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Map data from OpenStreetMap. Style uses OpenMapTiles."}]}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"type":"topic","kind":"symbol","role":"collection","title":"MapLibre","url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNLineStyleLayer":{"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","fragments":[{"text":"MLNLineStyleLayer","kind":"identifier"}],"role":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnlinestylelayer","title":"MLNLineStyleLayer","abstract":[{"text":"An ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer"},{"text":" is a style layer that renders one or more stroked","type":"text"},{"text":" ","type":"text"},{"text":"polylines on the map.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/PMTiles":{"title":"PMTiles","kind":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/PMTiles","abstract":[{"type":"text","text":"Working with PMTiles"}],"url":"\/documentation\/maplibre-native-for-ios\/pmtiles","type":"topic","role":"article"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/AnimatedLineExample":{"kind":"article","abstract":[{"text":"Add an animated line to a map","type":"text"}],"type":"topic","role":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","title":"Animated Line","url":"\/documentation\/maplibre-native-for-ios\/animatedlineexample"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/POIAlongRouteExample":{"url":"\/documentation\/maplibre-native-for-ios\/poialongrouteexample","kind":"article","title":"POI Along a Route","role":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/POIAlongRouteExample","abstract":[{"text":"Use an ","type":"text"},{"type":"codeVoice","code":"NSPredicate"},{"text":" to show POI and road labels along a route.","type":"text"}],"type":"topic"},"DDSCircleLayerExample.png":{"variants":[{"url":"\/images\/org.swift.MyProject\/DDSCircleLayerExample@2x.png","traits":["2x","light"]}],"alt":null,"type":"image","identifier":"DDSCircleLayerExample.png"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/GeoJSON":{"role":"article","kind":"article","type":"topic","title":"Working with GeoJSON Data","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","abstract":[],"url":"\/documentation\/maplibre-native-for-ios\/geojson"},"https://maplibre.org/maplibre-style-spec/expressions/#step":{"title":"step","identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","titleInlineContent":[{"text":"step","type":"text"}],"url":"https:\/\/maplibre.org\/maplibre-style-spec\/expressions\/#step","type":"link"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/LineStyleLayerExample":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineStyleLayerExample","kind":"article","role":"article","title":"Using GeoJSON with a line style layer","url":"\/documentation\/maplibre-native-for-ios\/linestylelayerexample","abstract":[{"type":"text","text":"Adding an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer"},{"type":"text","text":" to the map using a GeoJSON file."}]},"https://github.com/maplibre/demotiles/tree/gh-pages/tiles-omt":{"titleInlineContent":[{"text":"tiles around Innsbruck, Austria","type":"text"}],"url":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt","title":"tiles around Innsbruck, Austria","type":"link","identifier":"https:\/\/github.com\/maplibre\/demotiles\/tree\/gh-pages\/tiles-omt"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/WebAPIDataExample":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","url":"\/documentation\/maplibre-native-for-ios\/webapidataexample","role":"article","abstract":[{"type":"text","text":"Showing data from an API with custom styling and interaction"}],"kind":"article","type":"topic","title":"Showing data from an API"},"https://openmaptiles.org/schema/#poi":{"title":"POIs","identifier":"https:\/\/openmaptiles.org\/schema\/#poi","titleInlineContent":[{"text":"POIs","type":"text"}],"url":"https:\/\/openmaptiles.org\/schema\/#poi","type":"link"}}}