{"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/pmtiles"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"abstract":[{"type":"text","text":"Working with PMTiles"}],"primaryContentSections":[{"content":[{"inlineContent":[{"type":"text","text":"Starting MapLibre iOS 6.10.0, using "},{"identifier":"https:\/\/docs.protomaps.com\/pmtiles\/","type":"reference","isActive":true},{"type":"text","text":" as a data source is supported. You can prefix your vector tile source with "},{"code":"pmtiles:\/\/","type":"codeVoice"},{"type":"text","text":" to load a PMTiles file. The rest of the URL continue with be "},{"code":"https:\/\/","type":"codeVoice"},{"type":"text","text":" to load a remote PMTiles file, "},{"code":"asset:\/\/","type":"codeVoice"},{"type":"text","text":" to load an asset or "},{"code":"file:\/\/","type":"codeVoice"},{"type":"text","text":" to load a local PMTiles file."}],"type":"paragraph"},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"text":"PMTiles sources currently do not support caching or offline pack downloads.","type":"text"}],"type":"paragraph"}]},{"inlineContent":[{"type":"text","text":"Oliver Wipfli has made a style available that combines a "},{"isActive":true,"identifier":"","type":"reference"},{"type":"text","text":" basemap togehter with Foursquare’s POI dataset. It is available in the "},{"isActive":true,"identifier":"https:\/\/github.com\/wipfli\/foursquare-os-places-pmtiles","type":"reference"},{"type":"text","text":" repository on GitHub. The style to use is"}],"type":"paragraph"},{"type":"codeListing","code":["https:\/\/raw.githubusercontent.com\/wipfli\/foursquare-os-places-pmtiles\/refs\/heads\/main\/style.json"],"syntax":null},{"inlineContent":[{"text":"The neat thing about this style is that it only uses PMTiles vector sources. PMTiles can be hosted with a relatively simple file server (or file hosting service) instead of a more compl