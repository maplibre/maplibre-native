{"metadata":{"title":"Info.plist Keys","roleHeading":"Article","modules":[{"name":"MapLibre"}],"role":"article"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/info.plist_keys"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"text":"MapLibre Native for iOS supports custom ","type":"text"},{"type":"codeVoice","code":"Info.plist"},{"text":" keys in your application in order to configure various settings.","type":"text"}],"kind":"article","primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"MLNApiKey","anchor":"MLNApiKey","type":"heading"},{"inlineContent":[{"text":"If it is required by the tileserver you use, set the API key to be used by all instances of ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","isActive":true,"type":"reference"},{"text":" in the current application.","type":"text"}],"type":"paragraph"},{"level":2,"text":"MLNAccuracyAuthorizationDescription","anchor":"MLNAccuracyAuthorizationDescription","type":"heading"},{"inlineContent":[{"text":"Set the accuracy authorization description string as an element of ","type":"text"},{"code":"NSLocationTemporaryUsageDescriptionDictionary","type":"codeVoice"},{"text":" to be used by the map to request authorization when the ","type":"text"},{"code":"MLNLocationManager.accuracyAuthorization","type":"codeVoice"},{"text":" is set to ","type":"text"},{"code":"CLAccuracyAuthorizationReducedAccuracy","type":"codeVoice"},{"text":". Requesting accuracy authorization is available for devices running iOS 14.0 and above.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Example:","type":"text"}],"type":"paragraph"},{"syntax":"xml","type":"codeListing","code":["<key>NSLocationTemporaryUsageDescriptionDictionary<\/key>"," <dict>","  <key>MLNAccuracyAuthorizationDescription<\/key>","  <string>We require your precise location to help you navigate the map.<\/string>"," <\/dict>"]},{"inlineContent":[{"text":"Remove ","type":"text"},{"code":"MLNAccuracyAuthorizationDescription","type":"codeVoice"},{"text":" if you want to control when to request for accuracy authorization.","type":"text"}],"type":"paragraph"},{"level":2,"text":"MLNIdeographicFontFamilyName","anchor":"MLNIdeographicFontFamilyName","type":"heading"},{"inlineContent":[{"text":"This key configures a global fallback font or fonts for ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts","isActive":true,"overridingTitle":"client-side text rendering","overridingTitleInlineContent":[{"type":"text","text":"client-side text rendering"}],"type":"reference"},{"text":" of Chinese hanzi, Japanese kana, and Korean hangul characters (CJK) that appear in text labels.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If the fonts you specify in the ","type":"text"},{"code":"MLNSymbolStyleLayer.textFontNames","type":"codeVoice"},{"text":" property are all unavailable or lack a glyph for rendering a given CJK character, the map uses the contents of this key to choose a ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/fonts\/system-fonts\/","isActive":true,"type":"reference"},{"text":" or a font ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/text_display_and_fonts\/adding_a_custom_font_to_your_app","isActive":true,"type":"reference"},{"text":". This key specifies a fallback for all style layers in all map views and map snapshots. If you do not specify this key or none of the font names matches, the map applies a font from the system’s font cascade list, which may vary based on the device model and system language.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This key can either be set to a single string or an array of strings, which the map tries to apply in order from most preferred to least preferred. Each string can be a family name (for example, “PingFang TC”), display name (“PingFang TC Ultralight”), or PostScript name (“PingFangTC-Ultralight”).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To disable client-side rendering of CJK characters in favor of ","type":"text"},{"identifier":"customizing-fonts.html#server-side-fonts","isActive":true,"type":"reference"},{"text":", set this key to the Boolean value ","type":"text"},{"code":"NO","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"text":"MLNOfflineStorageDatabasePath","anchor":"MLNOfflineStorageDatabasePath","type":"heading"},{"inlineContent":[{"text":"This key customizes the file path at which ","type":"text"},{"code":"MLNOfflineStorage","type":"codeVoice"},{"text":" keeps the offline map database, which contains any offline packs as well as the ambient cache. Most applications should not need to customize this path; however, you could customize it to implement a migration path between different versions of your application.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The key is interpreted as either an absolute file path or a file path relative to the main bundle’s resource folder, resolving any tilde or symbolic link. The path must be writable. If a database does not exist at the path you specify, one will be created automatically.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"An offline map database can consume a significant amount of the user’s bandwidth and iCloud storage due to iCloud backups. To exclude the database from backups, set the containing directory’s ","type":"text"},{"code":"NSURLIsExcludedFromBackupKey","type":"codeVoice"},{"text":" resource property to the Boolean value ","type":"text"},{"code":"YES","type":"codeVoice"},{"text":" using the ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/nsurl\/1413819-setresourcevalue","isActive":true,"type":"reference"},{"text":" method. The entire directory will be affected, not just the database file. If the user restores the application from a backup, your application will need to restore any offline packs that had been previously downloaded.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"At runtime, you can obtain the value of this key using the ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databasePath","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databaseURL","isActive":true,"type":"reference"},{"text":" properties.","type":"text"}],"type":"paragraph"},{"level":2,"text":"MLNCollisionBehaviorPre4_0","anchor":"MLNCollisionBehaviorPre40","type":"heading"},{"inlineContent":[{"text":"If this key is set to YES (","type":"text"},{"code":"true","type":"codeVoice"},{"text":"), collision detection is performed only between symbol style layers based on the same source, as in versions 2.0–3.7 of the MapLibre Native iOS. In other words, symbols in an ","type":"text"},{"code":"MLNSymbolStyleLayer","type":"codeVoice"},{"text":" based on one source (for example, an ","type":"text"},{"code":"MLNShapeSource","type":"codeVoice"},{"text":") may overlap with symbols in another layer that is based on a different source. This is the case regardless of the ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconAllowsOverlap","isActive":true,"type":"reference"},{"text":", ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconIgnoresPlacement","isActive":true,"type":"reference"},{"text":", ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textAllowsOverlap","isActive":true,"type":"reference"},{"text":", and ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textIgnoresPlacement","isActive":true,"type":"reference"},{"text":" properties.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Beginning in version 4.0, the SDK also performs collision detection between style layers based on different sources by default. For the default behavior, omit the ","type":"text"},{"code":"MLNCollisionBehaviorPre4_0","type":"codeVoice"},{"text":" key or set it to NO (","type":"text"},{"code":"false","type":"codeVoice"},{"text":").","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This property may also be set using ","type":"text"},{"code":"[[NSUserDefaults standardUserDefaults] setObject:@(YES) forKey:@\"MLNCollisionBehaviorPre4_0\"]","type":"codeVoice"},{"text":"; it will override any value specified in the ","type":"text"},{"code":"Info.plist","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Info.plist_Keys"},"sections":[],"seeAlsoSections":[{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GestureRecognizers","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/MultipleImagesExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Predicates_and_Expressions","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Tile_URL_Templates","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/For_Style_Authors"],"title":"Other Articles","generated":true,"anchor":"Other-Articles"}],"references":{"https://developer.apple.com/fonts/system-fonts/":{"type":"link","url":"https:\/\/developer.apple.com\/fonts\/system-fonts\/","identifier":"https:\/\/developer.apple.com\/fonts\/system-fonts\/","title":"