{"abstract":[{"type":"text","text":"MapLibre Native for iOS supports custom "},{"type":"codeVoice","code":"Info.plist"},{"type":"text","text":" keys in your application in order to configure various settings."}],"kind":"article","schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"modules":[{"name":"MapLibre"}],"roleHeading":"Article","title":"Info.plist Keys","role":"article"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Info.plist_Keys","interfaceLanguage":"occ"},"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GestureRecognizers","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/MultipleImagesExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Predicates_and_Expressions","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Tile_URL_Templates","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/For_Style_Authors"],"title":"Other Articles","anchor":"Other-Articles"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/info.plist_keys"]}],"sections":[],"primaryContentSections":[{"content":[{"level":2,"text":"MLNApiKey","anchor":"MLNApiKey","type":"heading"},{"inlineContent":[{"type":"text","text":"If it is required by the tileserver you use, set the API key to be used by all instances of "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","isActive":true},{"type":"text","text":" in the current application."}],"type":"paragraph"},{"level":2,"text":"MLNAccuracyAuthorizationDescription","anchor":"MLNAccuracyAuthorizationDescription","type":"heading"},{"inlineContent":[{"type":"text","text":"Set the accuracy authorization description string as an element of "},{"code":"NSLocationTemporaryUsageDescriptionDictionary","type":"codeVoice"},{"type":"text","text":" to be used by the map to request authorization when the "},{"code":"MLNLocationManager.accuracyAuthorization","type":"codeVoice"},{"type":"text","text":" is set to "},{"code":"CLAccuracyAuthorizationReducedAccuracy","type":"codeVoice"},{"type":"text","text":". Requesting accuracy authorization is available for devices running iOS 14.0 and above."}],"type":"paragraph"},{"inlineContent":[{"text":"Example:","type":"text"}],"type":"paragraph"},{"code":["<key>NSLocationTemporaryUsageDescriptionDictionary<\/key>"," <dict>","  <key>MLNAccuracyAuthorizationDescription<\/key>","  <string>We require your precise location to help you navigate the map.<\/string>"," <\/dict>"],"type":"codeListing","syntax":"xml"},{"inlineContent":[{"text":"Remove ","type":"text"},{"code":"MLNAccuracyAuthorizationDescription","type":"codeVoice"},{"text":" if you want to control when to request for accuracy authorization.","type":"text"}],"type":"paragraph"},{"level":2,"text":"MLNIdeographicFontFamilyName","anchor":"MLNIdeographicFontFamilyName","type":"heading"},{"inlineContent":[{"text":"This key configures a global fallback font or fonts for ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts","isActive":true,"overridingTitle":"client-side text rendering","overridingTitleInlineContent":[{"text":"client-side text rendering","type":"text"}],"type":"reference"},{"text":" of Chinese hanzi, Japanese kana, and Korean hangul characters (CJK) that appear in text labels.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the fonts you specify in the "},{"type":"codeVoice","code":"MLNSymbolStyleLayer.textFontNames"},{"type":"text","text":" property are all unavailable or lack a glyph for rendering a given CJK character, the map uses the contents of this key to choose a "},{"identifier":"https:\/\/developer.apple.com\/fonts\/system-fonts\/","type":"reference","isActive":true},{"type":"text","text":" or a font "},{"identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/text_display_and_fonts\/adding_a_custom_font_to_your_app","type":"reference","isActive":true},{"type":"text","text":". This key specifies a fallback for all style layers in all map views and map snapshots. If you do not specify this key or none of the font names matches, the map applies a font from the system’s font cascade list, which may vary based on the device model and system language."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This key can either be set to a single string or an array of strings, which the map tries to apply in order from most preferred to least preferred. Each string can be a family name (for example, “PingFang TC”), display name (“PingFang TC Ultralight”), or PostScript name (“PingFangTC-Ultralight”)."}],"type":"paragraph"},{"inlineContent":[{"text":"To disable client-side rendering of CJK characters in favor of ","type":"text"},{"isActive":true,"type":"reference","identifier":"customizing-fonts.html#server-side-fonts"},{"text":", set this key to the Boolean value ","type":"text"},{"code":"NO","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"text":"MLNOfflineStorageDatabasePath","anchor":"MLNOfflineStorageDatabasePath","type":"heading"},{"inlineContent":[{"text":"This key customizes the file path at which ","type":"text"},{"code":"MLNOfflineStorage","type":"codeVoice"},{"text":" keeps the offline map database, which contains any offline packs as well as the ambient cache. Most applications should not need to customize this path; however, you could customize it to implement a migration path between different versions of your application.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The key is interpreted as either an absolute file path or a file path relative to the main bundle’s resource folder, resolving any tilde or symbolic link. The path must be writable. If a database does not exist at the path you specify, one will be created automatically."}],"type":"paragraph"},{"inlineContent":[{"text":"An offline map database can consume a significant amount of the user’s bandwidth and iCloud storage due to iCloud backups. To exclude the database from backups, set the containing directory’s ","type":"text"},{"code":"NSURLIsExcludedFromBackupKey","type":"codeVoice"},{"text":" resource property to the Boolean value ","type":"text"},{"code":"YES","type":"codeVoice"},{"text":" using the ","type":"text"},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/nsurl\/1413819-setresourcevalue","type":"reference"},{"text":" method. The entire directory will be affected, not just the database file. If the user restores the application from a backup, your application will need to restore any offline packs that had been previously downloaded.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"At runtime, you can obtain the value of this key using the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databasePath"},{"type":"text","text":" and "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databaseURL"},{"type":"text","text":" properties."}],"type":"paragraph"},{"level":2,"text":"MLNCollisionBehaviorPre4_0","anchor":"MLNCollisionBehaviorPre40","type":"heading"},{"inlineContent":[{"text":"If this key is set to YES (","type":"text"},{"code":"true","type":"codeVoice"},{"text":"), collision detection is performed only between symbol style layers based on the same source, as in versions 2.0–3.7 of the MapLibre Native iOS. In other words, symbols in an ","type":"text"},{"code":"MLNSymbolStyleLayer","type":"codeVoice"},{"text":" based on one source (for example, an ","type":"text"},{"code":"MLNShapeSource","type":"codeVoice"},{"text":") may overlap with symbols in another layer that is based on a different source. This is the case regardless of the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconAllowsOverlap"},{"text":", ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconIgnoresPlacement"},{"text":", ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textAllowsOverlap"},{"text":", and ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textIgnoresPlacement"},{"text":" properties.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Beginning in version 4.0, the SDK also performs collision detection between style layers based on different sources by default. For the default behavior, omit the ","type":"text"},{"code":"MLNCollisionBehaviorPre4_0","type":"codeVoice"},{"text":" key or set it to NO (","type":"text"},{"code":"false","type":"codeVoice"},{"text":").","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This property may also be set using "},{"type":"codeVoice","code":"[[NSUserDefaults standardUserDefaults] setObject:@(YES) forKey:@\"MLNCollisionBehaviorPre4_0\"]"},{"type":"text","text":"; it will override any value specified in the "},{"type":"codeVoice","code":"Info.plist"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"fragments":[{"kind":"identifier","text":"MLNMapView"}],"url":"\/documentation\/maplibre\/mlnmapview","abstract":[{"text":"An interactive, customizable map view with an interface similar to the one","type":"text"},{"text":" ","type":"text"},{"text":"provided by Apple’s MapKit.","type":"text"}],"title":"MLNMapView","role":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/Predicates_and_Expressions":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Predicates_and_Expressions","url":"\/documentation\/maplibre-native-for-ios\/predicates_and_expressions","type":"topic","role":"article","abstract":[{"type":"text","text":"Using "},{"code":"NSPredicate","type":"codeVoice"},{"type":"text","text":" with MapLibre iOS"}],"title":"Predicates and expressions","kind":"article"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/Customizing_Fonts":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts","kind":"article","type":"topic","title":"Customizing Fonts","role":"article","abstract":[{"text":"Using custom fonts","type":"text"}],"url":"\/documentation\/maplibre-native-for-ios\/customizing_fonts"},"https://developer.apple.com/documentation/foundation/nsurl/1413819-setresourcevalue":{"identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/nsurl\/1413819-setresourcevalue","titleInlineContent":[{"type":"codeVoice","code":"NSURL\/setResourceValue:forKey:error:"}],"type":"link","url":"https:\/\/developer.apple.com\/documentation\/foundation\/nsurl\/1413819-setresourcevalue","title":"NSURL\/setResourceValue:forKey:error:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/databasePath":{"type":"topic","title":"databasePath","kind":"symbol","abstract":[{"type":"text","text":"The file path at which offline packs and the ambient cache are stored."}],"fragments":[{"text":"databasePath","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databasePath","role":"symbol","url":"\/documentation\/maplibre\/mlnofflinestorage\/databasepath"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/databaseURL":{"fragments":[{"text":"databaseURL","kind":"identifier"}],"type":"topic","role":"symbol","kind":"symbol","abstract":[{"text":"The file URL at which offline packs and the ambient cache are stored.","type":"text"}],"url":"\/documentation\/maplibre\/mlnofflinestorage\/databaseurl","title":"databaseURL","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databaseURL"},"https://developer.apple.com/fonts/system-fonts/":{"identifier":"https:\/\/developer.apple.com\/fonts\/system-fonts\/","title":"system font","url":"https:\/\/developer.apple.com\/fonts\/system-fonts\/","type":"link","titleInlineContent":[{"text":"system font","type":"text"}]},"https://developer.apple.com/documentation/uikit/text_display_and_fonts/adding_a_custom_font_to_your_app":{"identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/text_display_and_fonts\/adding_a_custom_font_to_your_app","titleInlineContent":[{"type":"text","text":"bundled with your application"}],"type":"link","url":"https:\/\/developer.apple.com\/documentation\/uikit\/text_display_and_fonts\/adding_a_custom_font_to_your_app","title":"bundled with your application"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/Tile_URL_Templates":{"role":"article","abstract":[{"text":"Using URL Templates when defining tile sources","type":"text"}],"url":"\/documentation\/maplibre-native-for-ios\/tile_url_templates","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Tile_URL_Templates","type":"topic","kind":"article","title":"Tile URL Templates"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/For_Style_Authors":{"abstract":[],"role":"article","kind":"article","url":"\/documentation\/maplibre-native-for-ios\/for_style_authors","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/For_Style_Authors","type":"topic","title":"Information for Style Authors"},"customizing-fonts.html#server-side-fonts":{"identifier":"customizing-fonts.html#server-side-fonts","title":"server-side rendering","url":"customizing-fonts.html#server-side-fonts","type":"link","titleInlineContent":[{"text":"server-side rendering","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/GestureRecognizers":{"type":"topic","url":"\/documentation\/maplibre-native-for-ios\/gesturerecognizers","role":"article","abstract":[{"type":"text","text":"Learn how to work with gesture recognizers"}],"title":"User Interactions","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GestureRecognizers","kind":"article"},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer/textIgnoresPlacement":{"title":"textIgnoresPlacement","abstract":[{"text":"If true, other symbols can be visible even if they collide with the text.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textIgnoresPlacement","url":"\/documentation\/maplibre\/mlnsymbolstylelayer\/textignoresplacement","fragments":[{"kind":"identifier","text":"textIgnoresPlacement"}],"kind":"symbol","type":"topic","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"kind":"symbol","title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/MultipleImagesExample":{"type":"topic","kind":"article","title":"Adding Multiple Images","abstract":[{"type":"text","text":"Adding images to the map and assigning them to POI types"}],"role":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/MultipleImagesExample","url":"\/documentation\/maplibre-native-for-ios\/multipleimagesexample"},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer/textAllowsOverlap":{"url":"\/documentation\/maplibre\/mlnsymbolstylelayer\/textallowsoverlap","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textAllowsOverlap","abstract":[{"type":"text","text":"If true, the text will be visible even if it collides with other previously"},{"type":"text","text":" "},{"type":"text","text":"drawn symbols."}],"role":"symbol","fragments":[{"kind":"identifier","text":"textAllowsOverlap"}],"type":"topic","title":"textAllowsOverlap"},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer/iconAllowsOverlap":{"type":"topic","kind":"symbol","abstract":[{"type":"text","text":"If true, the icon will be visible even if it collides with other previously"},{"type":"text","text":" "},{"type":"text","text":"drawn symbols."}],"url":"\/documentation\/maplibre\/mlnsymbolstylelayer\/iconallowsoverlap","fragments":[{"kind":"identifier","text":"iconAllowsOverlap"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconAllowsOverlap","role":"symbol","title":"iconAllowsOverlap"},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer/iconIgnoresPlacement":{"type":"topic","abstract":[{"type":"text","text":"If true, other symbols can be visible even if they collide with the icon."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconIgnoresPlacement","title":"iconIgnoresPlacement","url":"\/documentation\/maplibre\/mlnsymbolstylelayer\/iconignoresplacement","kind":"symbol","fragments":[{"text":"iconIgnoresPlacement","kind":"identifier"}],"role":"symbol"}}}