{"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Info.plist_Keys","interfaceLanguage":"occ"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/info.plist_keys"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"title":"Info.plist Keys","modules":[{"name":"MapLibre"}],"role":"article","roleHeading":"Article"},"abstract":[{"type":"text","text":"MapLibre Native for iOS supports custom "},{"code":"Info.plist","type":"codeVoice"},{"type":"text","text":" keys in your application in order to configure various settings."}],"primaryContentSections":[{"content":[{"text":"MLNApiKey","level":2,"anchor":"MLNApiKey","type":"heading"},{"inlineContent":[{"text":"If it is required by the tileserver you use, set the API key to be used by all instances of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","type":"reference"},{"text":" in the current application.","type":"text"}],"type":"paragraph"},{"text":"MLNAccuracyAuthorizationDescription","level":2,"anchor":"MLNAccuracyAuthorizationDescription","type":"heading"},{"inlineContent":[{"type":"text","text":"Set the accuracy authorization description string as an element of "},{"code":"NSLocationTemporaryUsageDescriptionDictionary","type":"codeVoice"},{"type":"text","text":" to be used by the map to request authorization when the "},{"code":"MLNLocationManager.accuracyAuthorization","type":"codeVoice"},{"type":"text","text":" is set to "},{"code":"CLAccuracyAuthorizationReducedAccuracy","type":"codeVoice"},{"type":"text","text":". Requesting accuracy authorization is available for devices running iOS 14.0 and above."}],"type":"paragraph"},{"inlineContent":[{"text":"Example:","type":"text"}],"type":"paragraph"},{"syntax":"xml","code":["<key>NSLocationTemporaryUsageDescriptionDictionary<\/key>"," <dict>","  <key>MLNAccuracyAuthorizationDescription<\/key>","  <string>We require your precise location to help you navigate the map.<\/string>"," <\/dict>"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Remove "},{"type":"codeVoice","code":"MLNAccuracyAuthorizationDescription"},{"type":"text","text":" if you want to control when to request for accuracy authorization."}],"type":"paragraph"},{"text":"MLNIdeographicFontFamilyName","level":2,"anchor":"MLNIdeographicFontFamilyName","type":"heading"},{"inlineContent":[{"type":"text","text":"This key configures a global fallback font or fonts for "},{"isActive":true,"overridingTitle":"client-side text rendering","overridingTitleInlineContent":[{"text":"client-side text rendering","type":"text"}],"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts"},{"type":"text","text":" of Chinese hanzi, Japanese kana, and Korean hangul characters (CJK) that appear in text labels."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the fonts you specify in the "},{"code":"MLNSymbolStyleLayer.textFontNames","type":"codeVoice"},{"type":"text","text":" property are all unavailable or lack a glyph for rendering a given CJK character, the map uses the contents of this key to choose a "},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/fonts\/system-fonts\/"},{"type":"text","text":" or a font "},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/text_display_and_fonts\/adding_a_custom_font_to_your_app"},{"type":"text","text":". This key specifies a fallback for all style layers in all map views and map snapshots. If you do not specify this key or none of the font names matches, the map applies a font from the system’s font cascade list, which may vary based on the device model and system language."}],"type":"paragraph"},{"inlineContent":[{"text":"This key can either be set to a single string or an array of strings, which the map tries to apply in order from most preferred to least preferred. Each string can be a family name (for example, “PingFang TC”), display name (“PingFang TC Ultralight”), or PostScript name (“PingFangTC-Ultralight”).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To disable client-side rendering of CJK characters in favor of ","type":"text"},{"isActive":true,"identifier":"customizing-fonts.html#server-side-fonts","type":"reference"},{"text":", set this key to the Boolean value ","type":"text"},{"code":"NO","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"text":"MLNOfflineStorageDatabasePath","level":2,"anchor":"MLNOfflineStorageDatabasePath","type":"heading"},{"inlineContent":[{"type":"text","text":"This key customizes the file path at which "},{"type":"codeVoice","code":"MLNOfflineStorage"},{"type":"text","text":" keeps the offline map database, which contains any offline packs as well as the ambient cache. Most applications should not need to customize this path; however, you could customize it to implement a migration path between different versions of your application."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The key is interpreted as either an absolute file path or a file path relative to the main bundle’s resource folder, resolving any tilde or symbolic link. The path must be writable. If a database does not exist at the path you specify, one will be created automatically."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"An offline map database can consume a significant amount of the user’s bandwidth and iCloud storage due to iCloud backups. To exclude the database from backups, set the containing directory’s "},{"code":"NSURLIsExcludedFromBackupKey","type":"codeVoice"},{"type":"text","text":" resource property to the Boolean value "},{"code":"YES","type":"codeVoice"},{"type":"text","text":" using the "},{"identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/nsurl\/1413819-setresourcevalue","type":"reference","isActive":true},{"type":"text","text":" method. The entire directory will be affected, not just the database file. If the user restores the application from a backup, your application will need to restore any offline packs that had been previously downloaded."}],"type":"paragraph"},{"inlineContent":[{"text":"At runtime, you can obtain the value of this key using the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databasePath"},{"text":" and ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databaseURL"},{"text":" properties.","type":"text"}],"type":"paragraph"},{"text":"MLNCollisionBehaviorPre4_0","level":2,"anchor":"MLNCollisionBehaviorPre40","type":"heading"},{"inlineContent":[{"text":"If this key is set to YES (","type":"text"},{"code":"true","type":"codeVoice"},{"text":"), collision detection is performed only between symbol style layers based on the same source, as in versions 2.0–3.7 of the MapLibre Native iOS. In other words, symbols in an ","type":"text"},{"code":"MLNSymbolStyleLayer","type":"codeVoice"},{"text":" based on one source (for example, an ","type":"text"},{"code":"MLNShapeSource","type":"codeVoice"},{"text":") may overlap with symbols in another layer that is based on a different source. This is the case regardless of the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconAllowsOverlap"},{"text":", ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconIgnoresPlacement"},{"text":", ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textAllowsOverlap"},{"text":", and ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textIgnoresPlacement"},{"text":" properties.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Beginning in version 4.0, the SDK also performs collision detection between style layers based on different sources by default. For the default behavior, omit the "},{"code":"MLNCollisionBehaviorPre4_0","type":"codeVoice"},{"type":"text","text":" key or set it to NO ("},{"code":"false","type":"codeVoice"},{"type":"text","text":")."}],"type":"paragraph"},{"inlineContent":[{"text":"This property may also be set using ","type":"text"},{"code":"[[NSUserDefaults standardUserDefaults] setObject:@(YES) forKey:@\"MLNCollisionBehaviorPre4_0\"]","type":"codeVoice"},{"text":"; it will override any value specified in the ","type":"text"},{"code":"Info.plist","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"kind":"article","sections":[],"seeAlsoSections":[{"anchor":"Other-Articles","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GestureRecognizers","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/MultipleImagesExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Predicates_and_Expressions","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Tile_URL_Templates","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/For_Style_Authors"],"title":"Other Articles","generated":true}],"references":{"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/Customizing_Fonts":{"abstract":[{"text":"Using custom fonts","type":"text"}],"type":"topic","role":"article","url":"\/documentation\/maplibre-native-for-ios\/customizing_fonts","title":"Customizing Fonts","kind":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts"},"https://developer.apple.com/documentation/foundation/nsurl/1413819-setresourcevalue":{"title":"NSURL\/setResourceValue:forKey:error:","titleInlineContent":[{"code":"NSURL\/setResourceValue:forKey:error:","type":"codeVoice"}],"url":"https:\/\/developer.apple.com\/documentation\/foundation\/nsurl\/1413819-setresourcevalue","type":"link","identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/nsurl\/1413819-setresourcevalue"},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer/textAllowsOverlap":{"url":"\/documentation\/maplibre\/mlnsymbolstylelayer\/textallowsoverlap","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"If true, the text will be visible even if it collides with other previously"},{"type":"text","text":" "},{"type":"text","text":"drawn symbols."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textAllowsOverlap","title":"textAllowsOverlap","fragments":[{"kind":"identifier","text":"textAllowsOverlap"}],"role":"symbol"},"https://developer.apple.com/documentation/uikit/text_display_and_fonts/adding_a_custom_font_to_your_app":{"title":"bundled with your application","titleInlineContent":[{"type":"text","text":"bundled with your application"}],"url":"https:\/\/developer.apple.com\/documentation\/uikit\/text_display_and_fonts\/adding_a_custom_font_to_your_app","type":"link","identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/text_display_and_fonts\/adding_a_custom_font_to_your_app"},"https://developer.apple.com/fonts/system-fonts/":{"url":"https:\/\/developer.apple.com\/fonts\/system-fonts\/","type":"link","identifier":"https:\/\/developer.apple.com\/fonts\/system-fonts\/","titleInlineContent":[{"type":"text","text":"system font"}],"title":"system font"},"customizing-font