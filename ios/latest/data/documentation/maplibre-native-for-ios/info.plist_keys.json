":[{"text":"If true, other symbols can be visible even if they collide with the icon.","type":"text"}],"role":"symbol","url":"\/documentation\/maplibre\/mlnsymbolstylelayer\/iconignoresplacement","fragments":[{"text":"iconIgnoresPlacement","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/GestureRecognizers":{"kind":"article","abstract":[{"type":"text","text":"Learn how to work with gesture recognizers"}],"url":"\/documentation\/maplibre-native-for-ios\/gesturerecognizers","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GestureRecognizers","title":"User Interactions","type":"topic","role":"article"},"https://developer.apple.com/fonts/system-fonts/":{"titleInlineContent":[{"type":"text","text":"system font"}],"type":"link","url":"https:\/\/developer.apple.com\/fonts\/system-fonts\/","identifier":"https:\/\/developer.apple.com\/fonts\/system-fonts\/","title":"system font"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/For_Style_Authors":{"kind":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/For_Style_Authors","role":"article","abstract":[],"url":"\/documentation\/maplibre-native-for-ios\/for_style_authors","title":"Information for Style Authors","type":"topic"},"https://developer.apple.com/documentation/uikit/text_display_and_fonts/adding_a_custom_font_to_your_app":{"titleInlineContent":[{"type":"text","text":"bundled with your application"}],"type":"link","url":"https:\/\/developer.apple.com\/documentation\/uikit\/text_display_and_fonts\/adding_a_custom_font_to_your_app","identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/text_display_and_fonts\/adding_a_custom_font_to_your_app","title":"bundled with your application"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/Tile_URL_Templates":{"role":"article","kind":"article","title":"Tile URL Templates","identifier":"doc:\/\/org.swift.MyProject\/documenta