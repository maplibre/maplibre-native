{"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"article","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"seeAlsoSections":[{"title":"Other Articles","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GestureRecognizers","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/MultipleImagesExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Predicates_and_Expressions","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Tile_URL_Templates","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/For_Style_Authors"],"generated":true,"anchor":"Other-Articles"}],"primaryContentSections":[{"content":[{"text":"MLNApiKey","anchor":"MLNApiKey","type":"heading","level":2},{"inlineContent":[{"text":"If it is required by the tileserver you use, set the API key to be used by all instances of ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","isActive":true},{"text":" in the current application.","type":"text"}],"type":"paragraph"},{"text":"MLNAccuracyAuthorizationDescription","anchor":"MLNAccuracyAuthorizationDescription","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Set the accuracy authorization description string as an element of "},{"type":"codeVoice","code":"NSLocationTemporaryUsageDescriptionDictionary"},{"type":"text","text":" to be used by the map to request authorization when the "},{"type":"codeVoice","code":"MLNLocationManager.accuracyAuthorization"},{"type":"text","text":" is set to "},{"type":"codeVoice","code":"CLAccuracyAuthorizationReducedAccuracy"},{"type":"text","text":". Requesting accuracy authorization is available for devices running iOS 14.0 and above."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Example:"}],"type":"paragraph"},{"syntax":"xml","code":["<key>NSLocationTemporaryUsageDescriptionDictionary<\/key>"," <dict>","  <key>MLNAccuracyAuthorizationDescription<\/key>","  <string>We require your precise location to help you navigate the map.<\/string>"," <\/dict>"],"type":"codeListing"},{"inlineContent":[{"text":"Remove ","type":"text"},{"code":"MLNAccuracyAuthorizationDescription","type":"codeVoice"},{"text":" if you want to control when to request for accuracy authorization.","type":"text"}],"type":"paragraph"},{"text":"MLNIdeographicFontFamilyName","anchor":"MLNIdeographicFontFamilyName","type":"heading","level":2},{"inlineContent":[{"text":"This key configures a global fallback font or fonts for ","type":"text"},{"overridingTitleInlineContent":[{"text":"client-side text rendering","type":"text"}],"isActive":true,"type":"reference","overridingTitle":"client-side text rendering","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts"},{"text":" of Chinese hanzi, Japanese kana, and Korean hangul characters (CJK) that appear in text labels.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If the fonts you specify in the ","type":"text"},{"code":"MLNSymbolStyleLayer.textFontNames","type":"codeVoice"},{"text":" property are all unavailable or lack a glyph for rendering a given CJK character, the map uses the contents of this key to choose a ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/fonts\/system-fonts\/","isActive":true,"type":"reference"},{"text":" or a font ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/text_display_and_fonts\/adding_a_custom_font_to_your_app","isActive":true,"type":"reference"},{"text":". This key specifies a fallback for all style layers in all map views and map snapshots. If you do not specify this key or none of the font names matches, the map applies a font from the system’s font cascade list, which may vary based on the device model and system language.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This key can either be set to a single string or an array of strings, which the map tries to apply in order from most preferred to least preferred. Each string can be a family name (for example, “PingFang TC”), display name (“PingFang TC Ultralight”), or PostScript name (“PingFangTC-Ultralight”)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To disable client-side rendering of CJK characters in favor of "},{"type":"reference","identifier":"customizing-fonts.html#server-side-fonts","isActive":true},{"type":"text","text":", set this key to the Boolean value "},{"type":"codeVoice","code":"NO"},{"type":"text","text":"."}],"type":"paragraph"},{"text":"MLNOfflineStorageDatabasePath","anchor":"MLNOfflineStorageDatabasePath","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"This key customizes the file path at which "},{"type":"codeVoice","code":"MLNOfflineStorage"},{"type":"text","text":" keeps the offline map database, which contains any offline packs as well as the ambient cache. Most applications should not need to customize this path; however, you could customize it to implement a migration path between different versions of your application."}],"type":"paragraph"},{"inlineContent":[{"text":"The key is interpreted as either an absolute file path or a file path relative to the main bundle’s resource folder, resolving any tilde or symbolic link. The path must be writable. If a database does not exist at the path you specify, one will be created automatically.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"An offline map database can consume a significant amount of the user’s bandwidth and iCloud storage due to iCloud backups. To exclude the database from backups, set the containing directory’s ","type":"text"},{"type":"codeVoice","code":"NSURLIsExcludedFromBackupKey"},{"text":" resource property to the Boolean value ","type":"text"},{"type":"codeVoice","code":"YES"},{"text":" using the ","type":"text"},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/nsurl\/1413819-setresourcevalue","type":"reference"},{"text":" method. The entire directory will be affected, not just the database file. If the user restores the application from a backup, your application will need to restore any offline packs that had been previously downloaded.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"At runtime, you can obtain the value of this key using the "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databasePath","type":"reference"},{"type":"text","text":" and "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databaseURL","type":"reference"},{"type":"text","text":" properties."}],"type":"paragraph"},{"text":"MLNCollisionBehaviorPre4_0","anchor":"MLNCollisionBehaviorPre40","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"If this key is set to YES ("},{"type":"codeVoice","code":"true"},{"type":"text","text":"), collision detection is performed only between symbol style layers based on the same source, as in versions 2.0–3.7 of the MapLibre Native iOS. In other words, symbols in an "},{"type":"codeVoice","code":"MLNSymbolStyleLayer"},{"type":"text","text":" based on one source (for example, an "},{"type":"codeVoice","code":"MLNShapeSource"},{"type":"text","text":") may overlap with symbols in another layer that is based on a different source. This is the case regardless of the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconAllowsOverlap","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconIgnoresPlacement","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textAllowsOverlap","isActive":true},{"type":"text","text":", and "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textIgnoresPlacement","isActive":true},{"type":"text","text":" properties."}],"type":"paragraph"},{"inlineContent":[{"text":"Beginning in version 4.0, the SDK also performs collision detection between style layers based on different sources by default. For the default behavior, omit the ","type":"text"},{"type":"codeVoice","code":"MLNCollisionBehaviorPre4_0"},{"text":" key or set it to NO (","type":"text"},{"type":"codeVoice","code":"false"},{"text":").","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This property may also be set using "},{"code":"[[NSUserDefaults standardUserDefaults] setObject:@(YES) forKey:@\"MLNCollisionBehaviorPre4_0\"]","type":"codeVoice"},{"type":"text","text":"; it will override any value specified in the "},{"code":"Info.plist","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/info.plist_keys"]}],"abstract":[{"type":"text","text":"MapLibre Native for iOS supports custom "},{"type":"codeVoice","code":"Info.plist"},{"type":"text","text":" keys in your application in order to configure various settings."}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Info.plist_Keys"},"sections":[],"metadata":{"modules":[{"name":"MapLibre"}],"role":"article","title":"Info.plist Keys","roleHeading":"Article"},"references":{"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/Tile_URL_Templates":{"abstract":[{"type":"text","text":"Using URL Templates when defining tile sources"}],"title":"Tile URL Templates","ur