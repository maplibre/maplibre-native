{"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"metadata":{"modules":[{"name":"MapLibre"}],"role":"article","title":"Info.plist Keys","roleHeading":"Article"},"abstract":[{"text":"MapLibre Native for iOS supports custom ","type":"text"},{"code":"Info.plist","type":"codeVoice"},{"text":" keys in your application in order to configure various settings.","type":"text"}],"kind":"article","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/info.plist_keys"]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Info.plist_Keys"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"seeAlsoSections":[{"anchor":"Other-Articles","title":"Other Articles","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GestureRecognizers","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/MultipleImagesExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Predicates_and_Expressions","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Tile_URL_Templates","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/For_Style_Authors"],"generated":true}],"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"MLNApiKey","anchor":"MLNApiKey"},{"inlineContent":[{"text":"If it is required by the tileserver you use, set the API key to be used by all instances of ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","isActive":true,"type":"reference"},{"text":" in the current application.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"MLNAccuracyAuthorizationDescription","anchor":"MLNAccuracyAuthorizationDescription"},{"inlineContent":[{"type":"text","text":"Set the accuracy authorization description string as an element of "},{"type":"codeVoice","code":"NSLocationTemporaryUsageDescriptionDictionary"},{"type":"text","text":" to be used by the map to request authorization when the "},{"type":"codeVoice","code":"MLNLocationManager.accuracyAuthorization"},{"type":"text","text":" is set to "},{"type":"codeVoice","code":"CLAccuracyAuthorizationReducedAccuracy"},{"type":"text","text":". Requesting accuracy authorization is available for devices running iOS 14.0 and above."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Example:"}],"type":"paragraph"},{"type":"codeListing","syntax":"xml","code":["<key>NSLocationTemporaryUsageDescriptionDictionary<\/key>"," <dict>","  <key>MLNAccuracyAuthorizationDescription<\/key>","  <string>We require your precise location to help you navigate the map.<\/string>"," <\/dict>"]},{"inlineContent":[{"text":"Remove ","type":"text"},{"code":"MLNAccuracyAuthorizationDescription","type":"codeVoice"},{"text":" if you want to control when to request for accuracy authorization.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"MLNIdeographicFontFamilyName","anchor":"MLNIdeographicFontFamilyName"},{"inlineContent":[{"type":"text","text":"This key configures a global fallback font or fonts for "},{"type":"reference","isActive":true,"overridingTitle":"client-side text rendering","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts","overridingTitleInlineContent":[{"type":"text","text":"client-side text rendering"}]},{"type":"text","text":" of Chinese hanzi, Japanese kana, and Korean hangul characters (CJK) that appear in text labels."}],"type":"paragraph"},{"inlineContent":[{"text":"If the fonts you specify in the ","type":"text"},{"code":"MLNSymbolStyleLayer.textFontNames","type":"codeVoice"},{"text":" property are all unavailable or lack a glyph for rendering a given CJK character, the map uses the contents of this key to choose a ","type":"text"},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/fonts\/system-fonts\/","type":"reference"},{"text":" or a font ","type":"text"},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/text_display_and_fonts\/adding_a_custom_font_to_your_app","type":"reference"},{"text":". This key specifies a fallback for all style layers in all map views and map snapshots. If you do not specify this key or none of the font names matches, the map applies a font from the system’s font cascade list, which may vary based on the device model and system language.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This key can either be set to a single string or an array of strings, which the map tries to apply in order from most preferred to least preferred. Each string can be a family name (for example, “PingFang TC”), display name (“PingFang TC Ultralight”), or PostScript name (“PingFangTC-Ultralight”).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To disable client-side rendering of CJK characters in favor of "},{"type":"reference","identifier":"customizing-fonts.html#server-side-fonts","isActive":true},{"type":"text","text":", set this key to the Boolean value "},{"type":"codeVoice","code":"NO"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"type":"heading","text":"MLNOfflineStorageDatabasePath","anchor":"MLNOfflineStorageDatabasePath"},{"inlineContent":[{"text":"This key customizes the file path at which ","type":"text"},{"code":"MLNOfflineStorage","type":"codeVoice"},{"text":" keeps the offline map database, which contains any offline packs as well as the ambient cache. Most applications should not need to customize this path; however, you could customize it to implement a migration path between different versions of your application.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The key is interpreted as either an absolute file path or a file path relative to the main bundle’s resource folder, resolving any tilde or symbolic link. The path must be writable. If a database does not exist at the path you specify, one will be created automatically.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"An offline map database can consume a significant amount of the user’s bandwidth and iCloud storage due to iCloud backups. To exclude the database from backups, set the containing directory’s ","type":"text"},{"type":"codeVoice","code":"NSURLIsExcludedFromBackupKey"},{"text":" resource property to the Boolean value ","type":"text"},{"type":"codeVoice","code":"YES"},{"text":" using the ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/nsurl\/1413819-setresourcevalue"},{"text":" method. The entire directory will be affected, not just the database file. If the user restores the application from a backup, your application will need to restore any offline packs that had been previously downloaded.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"At runtime, you can obtain the value of this key using the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databasePath","type":"reference","isActive":true},{"type":"text","text":" and "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databaseURL","type":"reference","isActive":true},{"type":"text","text":" properties."}]},{"type":"heading","level":2,"text":"MLNCollisionBehaviorPre4_0","anchor":"MLNCollisionBehaviorPre40"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If this key is set to YES ("},{"code":"true","type":"codeVoice"},{"type":"text","text":"), collision detection is performed only between symbol style layers based on the same source, as in versions 2.0–3.7 of the MapLibre Native iOS. In other words, symbols in an "},{"code":"MLNSymbolStyleLayer","type":"codeVoice"},{"type":"text","text":" based on one source (for example, an "},{"code":"MLNShapeSource","type":"codeVoice"},{"type":"text","text":") may overlap with symbols in another layer that is based on a different source. This is the case regardless of the "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconAllowsOverlap","type":"reference"},{"type":"text","text":", "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconIgnoresPlacement","type":"reference"},{"type":"text","text":", "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textAllowsOverlap","type":"reference"},{"type":"text","text":", and "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textIgnoresPlacement","type":"reference"},{"type":"text","text":" properties."}]},{"type":"paragraph","inlineContent":[{"text":"Beginning in version 4.0, the SDK also performs collision detection between style layers based on different sources by default. For the default behavior, omit the ","type":"text"},{"code":"MLNCollisionBehaviorPre4_0","type":"codeVoice"},{"text":" key or set it to NO (","type":"text"},{"code":"false","type":"codeVoice"},{"text":").","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property may also be set using "},{"type":"codeVoice","code":"[[NSUserDefaults standardUserDefaults] setObject:@(YES) forKey:@\"MLNCollisionBehaviorPre4_0\"]"},{"type":"text","text":"; it will override any value specified in the "},{"type":"codeVoice","code":"Info.plist"},{"type":"text","text":"."}]}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"url":"\/documentation\/maplibre\/mlnmapview","title":"MLNMapView","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","fragments":[{"text":"MLNMapView","kind":"identifier"}],"type":"topic","role":"symbol","abstract":[{"text":"An interactive, customizable map view with an interface similar to the one","type":"text"},{"text":" ","type":"text"},{"text":"provided by Apple’s MapKit.","type":"text"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/databasePath":{"type":"topic","title":"databasePath","kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinestorage\/databasepath","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databasePath","fragments":[{"kind":"identifier","text":"databasePath"}],"abstract":[{"type":"text","text":"The file path at which offline packs and the ambient cache are stored."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer/textAllowsOverlap":{"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textAllowsOverlap","fragments":[{"kind":"identifier","text":"textAllowsOverlap"}],"url":"\/documentation\/maplibre\/mlnsymbolstylelayer\/textallowsoverlap","abstract":[{"text":"If true, the text will be visible even if it collides with other previously","type":"text"},{"text":" ","type":"text"},{"text":"drawn symbols.","type":"text"}],"type":"topic","title":"textAllowsOverlap","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/GestureRecognizers":{"title":"User Interactions","url":"\/documentation\/maplibre-native-for-ios\/gesturerecognizers","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GestureRecognizers","abstract":[{"type":"text","text":"Learn how to work with gesture recognizers"}],"kind":"article","type":"topic","role":"article"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/Customizing_Fonts":{"type":"topic","abstract":[{"type":"text","text":"Using custom fonts"}],"role":"article","url":"\/documentation\/maplibre-native-for-ios\/customizing_fonts","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts","title":"Customizing Fonts","kind":"article"},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer/textIgnoresPlacement":{"type":"topic","title":"textIgnoresPlacement","url":"\/documentation\/maplibre\/mlnsymbolstylelayer\/textignoresplacement","abstract":[{"text":"If true, other symbols can be visible even if they collide with the text.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textIgnoresPlacement","role":"symbol","fragments":[{"text":"textIgnoresPlacement","kind":"identifier"}]},"https://developer.apple.com/documentation/uikit/text_display_and_fonts/adding_a_custom_font_to_your_app":{"titleInlineContent":[{"type":"text","text":"bundled with your application"}],"type":"link","url":"https:\/\/developer.apple.com\/documentation\/uikit\/text_display_and_fonts\/adding_a_custom_font_to_your_app","identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/text_display_and_fonts\/adding_a_custom_font_to_your_app","title":"bundled with your application"},"customizing-fonts.html#server-side-fonts":{"type":"link","identifier":"customizing-fonts.html#server-side-fonts","titleInlineContent":[{"text":"server-side rendering","type":"text"}],"title":"server-side rendering","url":"customizing-fonts.html#server-side-fonts"},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer/iconAllowsOverlap":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconAllowsOverlap","title":"iconAllowsOverlap","role":"symbol","fragments":[{"text":"iconAllowsOverlap","kind":"identifier"}],"kind":"symbol","abstract":[{"text":"If true, the icon will be visible even if it collides with other previously","type":"text"},{"text":" ","type":"text"},{"text":"drawn symbols.","type":"text"}],"url":"\/documentation\/maplibre\/mlnsymbolstylelayer\/iconallowsoverlap","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/MultipleImagesExample":{"title":"Adding Multiple Images","url":"\/documentation\/maplibre-native-for-ios\/multipleimagesexample","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/MultipleImagesExample","abstract":[{"type":"text","text":"Adding images to the map and assigning them to POI types"}],"kind":"article","type":"topic","role":"article"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/For_Style_Authors":{"url":"\/documentation\/maplibre-native-for-ios\/for_style_authors","title":"Information for Style Authors","role":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/For_Style_Authors","type":"topic","abstract":[],"kind":"article"},"https://developer.apple.com/fonts/system-fonts/":{"title":"system font","url":"https:\/\/developer.apple.com\/fonts\/system-fonts\/","titleInlineContent":[{"text":"system font","type":"text"}],"type":"link","identifier":"https:\/\/developer.apple.com\/fonts\/system-fonts\/"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/Tile_URL_Templates":{"title":"Tile URL Templates","kind":"article","abstract":[{"type":"text","text":"Using URL Templates when defining tile sources"}],"url":"\/documentation\/maplibre-native-for-ios\/tile_url_templates","type":"topic","role":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Tile_URL_Templates"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/Predicates_and_Expressions":{"type":"topic","abstract":[{"type":"text","text":"Using "},{"code":"NSPredicate","type":"codeVoice"},{"type":"text","text":" with MapLibre iOS"}],"url":"\/documentation\/maplibre-native-for-ios\/predicates_and_expressions","kind":"article","title":"Predicates and expressions","role":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Predicates_and_Expressions"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/databaseURL":{"title":"databaseURL","kind":"symbol","abstract":[{"text":"The file URL at which offline packs and the ambient cache are stored.","type":"text"}],"fragments":[{"kind":"identifier","text":"databaseURL"}],"url":"\/documentation\/maplibre\/mlnofflinestorage\/databaseurl","type":"topic","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databaseURL"},"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","kind":"symbol","title":"MapLibre","type":"topic","url":"\/documentation\/maplibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer/iconIgnoresPlacement":{"title":"iconIgnoresPlacement","role":"symbol","kind":"symbol","type":"topic","fragments":[{"kind":"identifier","text":"iconIgnoresPlacement"}],"url":"\/documentation\/maplibre\/mlnsymbolstylelayer\/iconignoresplacement","abstract":[{"type":"text","text":"If true, other symbols can be visible even if they collide with the icon."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconIgnoresPlacement"},"https://developer.apple.com/documentation/foundation/nsurl/1413819-setresourcevalue":{"titleInlineContent":[{"type":"codeVoice","code":"NSURL\/setResourceValue:forKey:error:"}],"type":"link","url":"https:\/\/developer.apple.com\/documentation\/foundation\/nsurl\/1413819-setresourcevalue","title":"NSURL\/setResourceValue:forKey:error:","identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/nsurl\/1413819-setresourcevalue"}}}