"url":"https:\/\/developer.apple.com\/documentation\/uikit\/text_display_and_fonts\/adding_a_custom_font_to_your_app","type":"link","title":"bundled with your application","titleInlineContent":[{"text":"bundled with your application","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/Customizing_Fonts":{"kind":"article","role":"article","abstract":[{"type":"text","text":"Using custom fonts"}],"title":"Customizing Fonts","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts","url":"\/documentation\/maplibre-native-for-ios\/customizing_fonts","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/Tile_URL_Templates":{"role":"article","url":"\/documentation\/maplibre-native-for-ios\/tile_url_templates","title":"Tile URL Templates","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Tile_URL_Templates","abstract":[{"text":"Using URL Templates when defining tile sources","type":"text"}],"type":"topic","kind":"article"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/databasePath":{"fragments":[{"text":"databasePath","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databasePath","url":"\/documentation\/maplibre\/mlnofflinestorage\/databasepath","type":"topic","role":"symbol","title":"databasePath","abstract":[{"text":"The file path at which offline packs and the ambient cache are stored.","type":"text"}],"kind":"symbol"},"https://developer.apple.com/documentation/foundation/nsurl/1413819-setresourcevalue":{"identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/nsurl\/1413819-setresourcevalue","url":"https:\/\/developer.apple.com\/documentation\/foundation\/nsurl\/1413819-setresourcevalue","type":"link","title":"NSURL\/setResourceValue:forKey:error:","titleInlineContent":[{"code":"NSURL\/setResourceValue:forKey:error:","type":"codeVoice"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer/textAllowsOverlap":{"abstract":[{"text":"If true, the text will be visible even if it collides with other previously","type":"text"},{"text":" ","type":"text"},{"text":"drawn symbols.","type":"text"}],"role":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnsymbolstylelayer\/textallowsoverlap","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textAllowsOverlap","kind":"symbol","title":"textAllowsOverlap","fragments":[{"text":"textAllowsOverlap","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/For_Style_Authors":{"role":"article","url":"\/documentation\/maplibre-native-for-ios\/for_style_authors","title":"Information for Style Authors","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/For_Style_Authors","abstract":[],"type":"topic","kind":"article"},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer/iconAllowsOverlap":{"type":"topic","fragments":[{"kind":"identifier","text":"iconAllowsOverlap"}],"title":"iconAllowsOverlap","role":"symbol","kind":"symbol","abstract":[{"text":"If true, the icon will be visible even if it collides with other previously","type":"text"},{"text":" ","type":"text"},{"text":"drawn symbols.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconAllowsOverlap","url":"\/documentation\/maplibre\/mlnsymbolstylelayer\/iconallowsoverlap"},"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"url":"\/documentation\/maplibre","kind":"symbol","role":"collection","type":"topic"}}}