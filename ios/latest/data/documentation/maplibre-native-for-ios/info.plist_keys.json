{"sections":[],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Info.plist_Keys","interfaceLanguage":"occ"},"abstract":[{"type":"text","text":"MapLibre Native for iOS supports custom "},{"code":"Info.plist","type":"codeVoice"},{"type":"text","text":" keys in your application in order to configure various settings."}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"seeAlsoSections":[{"generated":true,"anchor":"Other-Articles","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GestureRecognizers","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/MultipleImagesExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Predicates_and_Expressions","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Tile_URL_Templates","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/For_Style_Authors"],"title":"Other Articles"}],"kind":"article","primaryContentSections":[{"content":[{"text":"MLNApiKey","anchor":"MLNApiKey","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"If it is required by the tileserver you use, set the API key to be used by all instances of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"},{"type":"text","text":" in the current application."}],"type":"paragraph"},{"text":"MLNAccuracyAuthorizationDescription","anchor":"MLNAccuracyAuthorizationDescription","level":2,"type":"heading"},{"inlineContent":[{"text":"Set the accuracy authorization description string as an element of ","type":"text"},{"type":"codeVoice","code":"NSLocationTemporaryUsageDescriptionDictionary"},{"text":" to be used by the map to request authorization when the ","type":"text"},{"type":"codeVoice","code":"MLNLocationManager.accuracyAuthorization"},{"text":" is set to ","type":"text"},{"type":"codeVoice","code":"CLAccuracyAuthorizationReducedAccuracy"},{"text":". Requesting accuracy authorization is available for devices running iOS 14.0 and above.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Example:","type":"text"}],"type":"paragraph"},{"syntax":"xml","code":["<key>NSLocationTemporaryUsageDescriptionDictionary<\/key>"," <dict>","  <key>MLNAccuracyAuthorizationDescription<\/key>","  <string>We require your precise location to help you navigate the map.<\/string>"," <\/dict>"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Remove "},{"type":"codeVoice","code":"MLNAccuracyAuthorizationDescription"},{"type":"text","text":" if you want to control when to request for accuracy authorization."}],"type":"paragraph"},{"text":"MLNIdeographicFontFamilyName","anchor":"MLNIdeographicFontFamilyName","level":2,"type":"heading"},{"inlineContent":[{"text":"This key configures a global fallback font or fonts for ","type":"text"},{"overridingTitleInlineContent":[{"text":"client-side text rendering","type":"text"}],"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts","isActive":true,"overridingTitle":"client-side text rendering"},{"text":" of Chinese hanzi, Japanese kana, and Korean hangul characters (CJK) that appear in text labels.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the fonts you specify in the "},{"code":"MLNSymbolStyleLayer.textFontNames","type":"codeVoice"},{"type":"text","text":" property are all unavailable or lack a glyph for rendering a given CJK character, the map uses the contents of this key to choose a "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/fonts\/system-fonts\/","isActive":true},{"type":"text","text":" or a font "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/text_display_and_fonts\/adding_a_custom_font_to_your_app","isActive":true},{"type":"text","text":". This key specifies a fallback for all style layers in all map views and map snapshots. If you do not specify this key or none of the font names matches, the map applies a font from the system’s font cascade list, which may vary based on the device model and system language."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This key can either be set to a single string or an array of strings, which the map tries to apply in order from most preferred to least preferred. Each string can be a family name (for example, “PingFang TC”), display name (“PingFang TC Ultralight”), or PostScript name (“PingFangTC-Ultralight”)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To disable client-side rendering of CJK characters in favor of "},{"identifier":"customizing-fonts.html#server-side-fonts","type":"reference","isActive":true},{"type":"text","text":", set this key to the Boolean value "},{"type":"codeVoice","code":"NO"},{"type":"text","text":"."}],"type":"paragraph"},{"text":"MLNOfflineStorageDatabasePath","anchor":"MLNOfflineStorageDatabasePath","level":2,"type":"heading"},{"inlineContent":[{"text":"This key customizes the file path at which ","type":"text"},{"code":"MLNOfflineStorage","type":"codeVoice"},{"text":" keeps the offline map database, which contains any offline packs as well as the ambient cache. Most applications should not need to customize this path; however, you could customize it to implement a migration path between different versions of your application.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The key is interpreted as either an absolute file path or a file path relative to the main bundle’s resource folder, resolving any tilde or symbolic link. The path must be writable. If a database does not exist at the path you specify, one will be created automatically.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"An offline map database can consume a significant amount of the user’s bandwidth and iCloud storage due to iCloud backups. To exclude the database from backups, set the containing directory’s ","type":"text"},{"code":"NSURLIsExcludedFromBackupKey","type":"codeVoice"},{"text":" resource property to the Boolean value ","type":"text"},{"code":"YES","type":"codeVoice"},{"text":" using the ","type":"text"},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/nsurl\/1413819-setresourcevalue","isActive":true},{"text":" method. The entire directory will be affected, not just the database file. If the user restores the application from a backup, your application will need to restore any offline packs that had been previously downloaded.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"At runtime, you can obtain the value of this key using the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databasePath","isActive":true},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databaseURL","isActive":true},{"type":"text","text":" properties."}],"type":"paragraph"},{"text":"MLNCollisionBehaviorPre4_0","anchor":"MLNCollisionBehaviorPre40","level":2,"type":"heading"},{"inlineContent":[{"text":"If this key is set to YES (","type":"text"},{"type":"codeVoice","code":"true"},{"text":"), collision detection is performed only between symbol style layers based on the same source, as in versions 2.0–3.7 of the MapLibre Native iOS. In other words, symbols in an ","type":"text"},{"type":"codeVoice","code":"MLNSymbolStyleLayer"},{"text":" based on one source (for example, an ","type":"text"},{"type":"codeVoice","code":"MLNShapeSource"},{"text":") may overlap with symbols in another layer that is based on a different source. This is the case regardless of the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconAllowsOverlap"},{"text":", ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconIgnoresPlacement"},{"text":", ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textAllowsOverlap"},{"text":", and ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textIgnoresPlacement"},{"text":" properties.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Beginning in version 4.0, the SDK also performs collision detection between style layers based on different sources by default. For the default behavior, omit the "},{"code":"MLNCollisionBehaviorPre4_0","type":"codeVoice"},{"type":"text","text":" key or set it to NO ("},{"code":"false","type":"codeVoice"},{"type":"text","text":")."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This property may also be set using "},{"code":"[[NSUserDefaults standardUserDefaults] setObject:@(YES) forKey:@\"MLNCollisionBehaviorPre4_0\"]","type":"codeVoice"},{"type":"text","text":"; it will override any value specified in the "},{"code":"Info.plist","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/info.plist_keys"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"role":"article","modules":[{"name":"MapLibre"}],"roleHeading":"Article","title":"Info.plist Keys"},"references":{"https://developer.apple.com/documentation/foundation/nsurl/1413819-setresourcevalue":{"titleInlineContent":[{"type":"codeVoice","code":"NSURL\/setResourceValue:forKey:error:"}],"type":"link","url":"https:\/\/developer.apple.com\/documentation\/foundation\/nsurl\/1413819-setresourcevalue","identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/nsurl\/1413819-setresourcevalue","title":"NSURL\/setResourceValue:forKey:error:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer/iconAllowsOverlap":{"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconAllowsOverlap","type":"topic","title":"iconAllowsOverlap","abstract":[{"text":"If true, the icon will be visible even if it collides with other previously","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"drawn symbols."}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnsymbolstylelayer\/iconallowsoverlap","fragments":[{"text":"iconAllowsOverlap","kind":"identifier"}]},"customizing-fonts.html#server-side-fonts":{"titleInlineContent":[{"type":"text","text":"server-side rendering"}],"type":"link","url":"customizing-fonts.html#server-side-fonts","identifier":"customizing-fonts.html#server-side-fonts","title":"server-side rendering"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/Predicates_and_Expressions":{"title":"Predicates and expressions","kind":"article","url":"\/documentation\/maplibre-native-for-ios\/predicates_and_expressions","role":"article","abstract":[{"text":"Using ","type":"text"},{"type":"codeVoice","code":"NSPredicate"},{"text":" with MapLibre iOS","type":"text"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Predicates_and_Expressions"},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer/textIgnoresPlacement":{"kind":"symbol","role":"symbol","type":"topic","title":"textIgnoresPlacement","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textIgnoresPlacement","fragments":[{"kind":"identifier","text":"textIgnoresPlacement"}],"url":"\/documentation\/maplibre\/mlnsymbolstylelayer