","title":"Adding Multiple Images","type":"topic","url":"\/documentation\/maplibre-native-for-ios\/multipleimagesexample","role":"article"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/For_Style_Authors":{"type":"topic","url":"\/documentation\/maplibre-native-for-ios\/for_style_authors","title":"Information for Style Authors","kind":"article","role":"article","abstract":[],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/For_Style_Authors"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/GestureRecognizers":{"title":"User Interactions","url":"\/documentation\/maplibre-native-for-ios\/gesturerecognizers","abstract":[{"type":"text","text":"Learn how to work with gesture recognizers"}],"role":"article","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GestureRecognizers","kind":"article"},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer/textIgnoresPlacement":{"url":"\/documentation\/maplibre\/mlnsymbolstylelayer\/textignoresplacement","kind":"symbol","title":"textIgnoresPlacement","fragments":[{"text":"textIgnoresPlacement","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textIgnoresPlacement","abstract":[{"type":"text","text":"If true, other symbols can be visible even if they collide with the text."}],"type":"topic"},"https://developer.apple.com/documentation/foundation/nsurl/1413819-setresourcevalue":{"title":"NSURL\/setResourceValue:forKey:error:","type":"link","titleInlineContent":[{"type":"codeVoice","code":"NSURL\/setResourceValue:forKey:error:"}],"url":"https:\/\/developer.apple.com\/documentation\/foundation\/nsurl\/1413819-setresourcevalue","identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/nsurl\/1413819-setresourcevalue"}}}