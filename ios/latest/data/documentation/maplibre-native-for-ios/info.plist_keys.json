{"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Info.plist_Keys","interfaceLanguage":"occ"},"seeAlsoSections":[{"title":"Other Articles","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GestureRecognizers","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/MultipleImagesExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Predicates_and_Expressions","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Tile_URL_Templates","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/For_Style_Authors"],"generated":true,"anchor":"Other-Articles"}],"metadata":{"modules":[{"name":"MapLibre"}],"roleHeading":"Article","role":"article","title":"Info.plist Keys"},"kind":"article","abstract":[{"type":"text","text":"MapLibre Native for iOS supports custom "},{"code":"Info.plist","type":"codeVoice"},{"type":"text","text":" keys in your application in order to configure various settings."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/info.plist_keys"]}],"sections":[],"primaryContentSections":[{"kind":"content","content":[{"anchor":"MLNApiKey","level":2,"text":"MLNApiKey","type":"heading"},{"inlineContent":[{"text":"If it is required by the tileserver you use, set the API key to be used by all instances of ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","type":"reference","isActive":true},{"text":" in the current application.","type":"text"}],"type":"paragraph"},{"anchor":"MLNAccuracyAuthorizationDescription","level":2,"text":"MLNAccuracyAuthorizationDescription","type":"heading"},{"inlineContent":[{"text":"Set the accuracy authorization description string as an element of ","type":"text"},{"code":"NSLocationTemporaryUsageDescriptionDictionary","type":"codeVoice"},{"text":" to be used by the map to request authorization when the ","type":"text"},{"code":"MLNLocationManager.accuracyAuthorization","type":"codeVoice"},{"text":" is set to ","type":"text"},{"code":"CLAccuracyAuthorizationReducedAccuracy","type":"codeVoice"},{"text":". Requesting accuracy authorization is available for devices running iOS 14.0 and above.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Example:","type":"text"}],"type":"paragraph"},{"syntax":"xml","code":["<key>NSLocationTemporaryUsageDescriptionDictionary<\/key>"," <dict>","  <key>MLNAccuracyAuthorizationDescription<\/key>","  <string>We require your precise location to help you navigate the map.<\/string>"," <\/dict>"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Remove "},{"type":"codeVoice","code":"MLNAccuracyAuthorizationDescription"},{"type":"text","text":" if you want to control when to request for accuracy authorization."}],"type":"paragraph"},{"anchor":"MLNIdeographicFontFamilyName","level":2,"text":"MLNIdeographicFontFamilyName","type":"heading"},{"inlineContent":[{"text":"This key configures a global fallback font or fonts for ","type":"text"},{"overridingTitle":"client-side text rendering","overridingTitleInlineContent":[{"text":"client-side text rendering","type":"text"}],"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts","type":"reference"},{"text":" of Chinese hanzi, Japanese kana, and Korean hangul characters (CJK) that appear in text labels.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the fonts you specify in the "},{"type":"codeVoice","code":"MLNSymbolStyleLayer.textFontNames"},{"type":"text","text":" property are all unavailable or lack a glyph for rendering a given CJK character, the map uses the contents of this key to choose a "},{"identifier":"https:\/\/developer.apple.com\/fonts\/system-fonts\/","isActive":true,"type":"reference"},{"type":"text","text":" or a font "},{"identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/text_display_and_fonts\/adding_a_custom_font_to_your_app","isActive":true,"type":"reference"},{"type":"text","text":". This key specifies a fallback for all style layers in all map views and map snapshots. If you do not specify this key or none of the font names matches, the map applies a font from the system’s font cascade list, which may vary based on the device model and system language."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This key can either be set to a single string or an array of strings, which the map tries to apply in order from most preferred to least preferred. Each string can be a family name (for example, “PingFang TC”), display name (“PingFang TC Ultralight”), or PostScript name (“PingFangTC-Ultralight”)."}],"type":"paragraph"},{"inlineContent":[{"text":"To disable client-side rendering of CJK characters in favor of ","type":"text"},{"isActive":true,"type":"reference","identifier":"customizing-fonts.html#server-side-fonts"},{"text":", set this key to the Boolean value ","type":"text"},{"type":"codeVoice","code":"NO"},{"text":".","type":"text"}],"type":"paragraph"},{"anchor":"MLNOfflineStorageDatabasePath","level":2,"text":"MLNOfflineStorageDatabasePath","type":"heading"},{"inlineContent":[{"text":"This key customizes the file path at which ","type":"text"},{"code":"MLNOfflineStorage","type":"codeVoice"},{"text":" keeps the offline map database, which contains any offline packs as well as the ambient cache. Most applications should not need to customize this path; however, you could customize it to implement a migration path between different versions of your application.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The key is interpreted as either an absolute file path or a file path relative to the main bundle’s resource folder, resolving any tilde or symbolic link. The path must be writable. If a database does not exist at the path you specify, one will be created automatically."}],"type":"paragraph"},{"inlineContent":[{"text":"An offline map database can consume a significant amount of the user’s bandwidth and iCloud storage due to iCloud backups. To exclude the database from backups, set the containing directory’s ","type":"text"},{"type":"codeVoice","code":"NSURLIsExcludedFromBackupKey"},{"text":" resource property to the Boolean value ","type":"text"},{"type":"codeVoice","code":"YES"},{"text":" using the ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/nsurl\/1413819-setresourcevalue","isActive":true,"type":"reference"},{"text":" method. The entire directory will be affected, not just the database file. If the user restores the application from a backup, your application will need to restore any offline packs that had been previously downloaded.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"At runtime, you can obtain the value of this key using the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databasePath"},{"type":"text","text":" and "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databaseURL"},{"type":"text","text":" properties."}],"type":"paragraph"},{"anchor":"MLNCollisionBehaviorPre40","level":2,"text":"MLNCollisionBehaviorPre4_0","type":"heading"},{"inlineContent":[{"type":"text","text":"If this key is set to YES ("},{"code":"true","type":"codeVoice"},{"type":"text","text":"), collision detection is performed only between symbol style layers based on the same source, as in versions 2.0–3.7 of the MapLibre Native iOS. In other words, symbols in an "},{"code":"MLNSymbolStyleLayer","type":"codeVoice"},{"type":"text","text":" based on one source (for example, an "},{"code":"MLNShapeSource","type":"codeVoice"},{"type":"text","text":") may overlap with symbols in another layer that is based on a different source. This is the case regardless of the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconAllowsOverlap","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconIgnoresPlacement","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textAllowsOverlap","isActive":true},{"type":"text","text":", and "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textIgnoresPlacement","isActive":true},{"type":"text","text":" properties."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Beginning in version 4.0, the SDK also performs collision detection between style layers based on different sources by default. For the default behavior, omit the "},{"type":"codeVoice","code":"MLNCollisionBehaviorPre4_0"},{"type":"text","text":" key or set it to NO ("},{"type":"codeVoice","code":"false"},{"type":"text","text":")."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This property may also be set using "},{"type":"codeVoice","code":"[[NSUserDefaults standardUserDefaults] setObject:@(YES) forKey:@\"MLNCollisionBehaviorPre4_0\"]"},{"type":"text","text":"; it will override any value specified in the "},{"type":"codeVoice","code":"Info.plist"},{"type":"text","text":"."}],"type":"paragraph"}]}],"references":{"https://developer.apple.com/documentation/uikit/text_display_and_fonts/adding_a_custom_font_to_your_app":{"url":"https:\/\/developer.apple.com\/documentation\/uikit\/text_display_and_fonts\/adding_a_custom_font_to_your_app","type":"link","titleInlineContent":[{"type":"text","text":"bundled with your application"}],"title":"bundled with your application","identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/text_display_and_fonts\/adding_a_custom_font_to_your_app"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/databasePath":{"fragments":[{"text":"databasePath","kind":"identifier"}],"title":"databasePath","kind":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databasePath","role":"symbol","url":"\/documentation\/maplibre\/mlnofflinestorage\/databasepath","abstract":[{"type":"text","text":"The file path at which offline packs and the ambient cache are stored."}]},"customizing-fonts.html#server-side-fonts":{"title":"server-side rendering","type":"link","titleInlineContent":[{"type":"text","text":"server-side rendering"}],"url":"customizing-fonts.html#server-side-fonts","identifier":"customizing-fonts.html#server-side-fonts"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/Predicates_and_Expressions":{"kind":"article","type":"topic","abstract":[{"text":"Using ","type":"text"},{"code":"NSPredicate","type":"codeVoice"},{"text":" with MapLibre iOS","type":"text"}],"title":"Predicates and expressions","url":"\/documentation\/maplibre-native-for-ios\/predicates_and_expressions","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Predicates_and_Expressions","role":"article"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/Customizing_Fonts":{"type":"topic","url":"\/documentation\/maplibre-native-for-ios\/customizing_fonts","abstract":[{"type":"text","text":"Using custom fonts"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts","title":"Customizing Fonts","kind":"article","role":"article"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"url":"\/documentation\/maplibre\/mlnmapview","abstract":[{"text":"An interactive, customizable map view with an interface similar to the one","type":"text"},{"text":" ","type":"text"},{"text":"provided by Apple’s MapKit.","type":"text"}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","fragments":[{"kind":"identifier","text":"MLNMapView"}],"kind":"symbol","title":"MLNMapView","type":"topic"},"https://developer.apple.com/fonts/system-fonts/":{"url":"https:\/\/developer.apple.com\/fonts\/system-fonts\/","type":"link","titleInlineContent":[{"type":"text","text":"system font"}],"title":"system font","identifier":"https:\/\/developer.apple.com\/fonts\/system-fonts\/"},"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","kind":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer/textAllowsOverlap":{"title":"textAllowsOverlap","url":"\/documentation\/maplibre\/mlnsymbolstylelayer\/textallowsoverlap","type":"topic","kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textAllowsOverlap","fragments":[{"text":"textAllowsOverlap","kind":"identifier"}],"abstract":[{"text":"If true, the text will be visible even if it collides with other previously","type":"text"},{"text":" ","type":"text"},{"text":"drawn symbols.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/databaseURL":{"kind":"symbol","title":"databaseURL","abstract":[{"text":"The file URL at which offline packs and the ambient cache are stored.","type":"text"}],"url":"\/documentation\/maplibre\/mlnofflinestorage\/databaseurl","identifier":"doc:\/\/org.swift.MyProject\/doc