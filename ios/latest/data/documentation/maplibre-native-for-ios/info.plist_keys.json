{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"sections":[],"metadata":{"title":"Info.plist Keys","role":"article","modules":[{"name":"MapLibre"}],"roleHeading":"Article"},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Info.plist_Keys","interfaceLanguage":"occ"},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"MapLibre Native for iOS supports custom "},{"type":"codeVoice","code":"Info.plist"},{"type":"text","text":" keys in your application in order to configure various settings."}],"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"MLNApiKey","anchor":"MLNApiKey"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If it is required by the tileserver you use, set the API key to be used by all instances of "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","isActive":true,"type":"reference"},{"type":"text","text":" in the current application."}]},{"level":2,"type":"heading","text":"MLNAccuracyAuthorizationDescription","anchor":"MLNAccuracyAuthorizationDescription"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Set the accuracy authorization description string as an element of "},{"code":"NSLocationTemporaryUsageDescriptionDictionary","type":"codeVoice"},{"type":"text","text":" to be used by the map to request authorization when the "},{"code":"MLNLocationManager.accuracyAuthorization","type":"codeVoice"},{"type":"text","text":" is set to "},{"code":"CLAccuracyAuthorizationReducedAccuracy","type":"codeVoice"},{"type":"text","text":". Requesting accuracy authorization is available for devices running iOS 14.0 and above."}]},{"type":"paragraph","inlineContent":[{"text":"Example:","type":"text"}]},{"type":"codeListing","code":["<key>NSLocationTemporaryUsageDescriptionDictionary<\/key>"," <dict>","  <key>MLNAccuracyAuthorizationDescription<\/key>","  <string>We require your precise location to help you navigate the map.<\/string>"," <\/dict>"],"syntax":"xml"},{"type":"paragraph","inlineContent":[{"text":"Remove ","type":"text"},{"code":"MLNAccuracyAuthorizationDescription","type":"codeVoice"},{"text":" if you want to control when to request for accuracy authorization.","type":"text"}]},{"level":2,"type":"heading","text":"MLNIdeographicFontFamilyName","anchor":"MLNIdeographicFontFamilyName"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This key configures a global fallback font or fonts for "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts","type":"reference","isActive":true,"overridingTitle":"client-side text rendering","overridingTitleInlineContent":[{"text":"client-side text rendering","type":"text"}]},{"type":"text","text":" of Chinese hanzi, Japanese kana, and Korean hangul characters (CJK) that appear in text labels."}]},{"type":"paragraph","inlineContent":[{"text":"If the fonts you specify in the ","type":"text"},{"code":"MLNSymbolStyleLayer.textFontNames","type":"codeVoice"},{"text":" property are all unavailable or lack a glyph for rendering a given CJK character, the map uses the contents of this key to choose a ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/fonts\/system-fonts\/"},{"text":" or a font ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/text_display_and_fonts\/adding_a_custom_font_to_your_app"},{"text":". This key specifies a fallback for all style layers in all map views and map snapshots. If you do not specify this key or none of the font names matches, the map applies a font from the system’s font cascade list, which may vary based on the device model and system language.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This key can either be set to a single string or an array of strings, which the map tries to apply in order from most preferred to least preferred. Each string can be a family name (for example, “PingFang TC”), display name (“PingFang TC Ultralight”), or PostScript name (“PingFangTC-Ultralight”).","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To disable client-side rendering of CJK characters in favor of ","type":"text"},{"isActive":true,"identifier":"customizing-fonts.html#server-side-fonts","type":"reference"},{"text":", set this key to the Boolean value ","type":"text"},{"code":"NO","type":"codeVoice"},{"text":".","type":"text"}]},{"level":2,"type":"heading","text":"MLNOfflineStorageDatabasePath","anchor":"MLNOfflineStorageDatabasePath"},{"type":"paragraph","inlineContent":[{"text":"This key customizes the file path at which ","type":"text"},{"code":"MLNOfflineStorage","type":"codeVoice"},{"text":" keeps the offline map database, which contains any offline packs as well as the ambient cache. Most applications should not need to customize this path; however, you could customize it to implement a migration path between different versions of your application.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The key is interpreted as either an absolute file path or a file path relative to the main bundle’s resource folder, resolving any tilde or symbolic link. The path must be writable. If a database does not exist at the path you specify, one will be created automatically."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"An offline map database can consume a significant amount of the user’s bandwidth and iCloud storage due to iCloud backups. To exclude the database from backups, set the containing directory’s "},{"code":"NSURLIsExcludedFromBackupKey","type":"codeVoice"},{"type":"text","text":" resource property to the Boolean value "},{"code":"YES","type":"codeVoice"},{"type":"text","text":" using the "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/nsurl\/1413819-setresourcevalue","isActive":true},{"type":"text","text":" method. The entire directory will be affected, not just the database file. If the user restores the application from a backup, your application will need to restore any offline packs that had been previously downloaded."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"At runtime, you can obtain the value of this key using the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databasePath","isActive":true},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databaseURL","isActive":true},{"type":"text","text":" properties."}]},{"level":2,"type":"heading","text":"MLNCollisionBehaviorPre4_0","anchor":"MLNCollisionBehaviorPre40"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If this key is set to YES ("},{"code":"true","type":"codeVoice"},{"type":"text","text":"), collision detection is performed only between symbol style layers based on the same source, as in versions 2.0–3.7 of the MapLibre Native iOS. In other words, symbols in an "},{"code":"MLNSymbolStyleLayer","type":"codeVoice"},{"type":"text","text":" based on one source (for example, an "},{"code":"MLNShapeSource","type":"codeVoice"},{"type":"text","text":") may overlap with symbols in another layer that is based on a different source. This is the case regardless of the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconAllowsOverlap"},{"type":"text","text":", "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconIgnoresPlacement"},{"type":"text","text":", "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textAllowsOverlap"},{"type":"text","text":", and "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textIgnoresPlacement"},{"type":"text","text":" properties."}]},{"type":"paragraph","inlineContent":[{"text":"Beginning in version 4.0, the SDK also performs collision detection between style layers based on different sources by default. For the default behavior, omit the ","type":"text"},{"code":"MLNCollisionBehaviorPre4_0","type":"codeVoice"},{"text":" key or set it to NO (","type":"text"},{"code":"false","type":"codeVoice"},{"text":").","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This property may also be set using ","type":"text"},{"code":"[[NSUserDefaults standardUserDefaults] setObject:@(YES) forKey:@\"MLNCollisionBehaviorPre4_0\"]","type":"codeVoice"},{"text":"; it will override any value specified in the ","type":"text"},{"code":"Info.plist","type":"codeVoice"},{"text":".","type":"text"}]}],"kind":"content"}],"kind":"article","variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/info.plist_keys"],"traits":[{"interfaceLanguage":"occ"}]}],"seeAlsoSections":[{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GestureRecognizers","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/MultipleImagesExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Predicates_and_Expressions","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Tile_URL_Templates","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/For_Style_Authors"],"anchor":"Other-Articles","title":"Other Articles","generated":true}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer/iconIgnoresPlacement":{"abstract":[{"type":"text","text":"If true, other symbols can be visible even if they collide with the icon."}],"url":"\/documentation\/maplibre\/mlnsymbolstylelayer\/iconignoresplacement","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconIgnoresPlacement","title":"iconIgnoresPlacement","type":"topic","role":"symbol","fragments":[{"kind":"identifier","text":"iconIgnoresPlacement"}]},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/Tile_URL_Templates":{"title":"Tile URL Templates","role":"article","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Tile_URL_Templates","kind":"article","url":"\/documentation\/maplibre-native-for-ios\/tile_url_templates","abstract":[{"text":"Using URL Templates when defining tile sources","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/For_Style_Authors":{"abstract":[],"kind":"article","role":"article","url":"\/documentation\/maplibre-native-for-ios\/for_style_authors","title":"Information for Style Authors","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/For_Style_Authors","type":"topic"},"https://developer.apple.com/documentation/uikit/text_display_and_fonts/adding_a_custom_font_to_your_app":{"url":"https:\/\/developer.apple.com\/documentation\/uikit\/text_display_and_fonts\/adding_a_custom_font_to_your_app","type":"link","titleInlineContent":[{"type":"text","text":"bundled with your application"}],"title":"bundled with your application","identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/text_display_and_fonts\/adding_a_custom_font_to_your_app"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/databaseURL":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databaseURL","url":"\/documentation\/maplibre\/mlnofflinestorage\/databaseurl","kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"The file URL at which offline packs and the ambient cache are stored."}],"fragments":[