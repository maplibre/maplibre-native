{"metadata":{"role":"article","title":"Info.plist Keys","modules":[{"name":"MapLibre"}],"roleHeading":"Article"},"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Info.plist_Keys"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"sections":[],"seeAlsoSections":[{"anchor":"Other-Articles","title":"Other Articles","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GestureRecognizers","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/MultipleImagesExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Predicates_and_Expressions","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Tile_URL_Templates","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/For_Style_Authors"],"generated":true}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"MLNApiKey","level":2,"text":"MLNApiKey"},{"type":"paragraph","inlineContent":[{"text":"If it is required by the tileserver you use, set the API key to be used by all instances of ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","isActive":true,"type":"reference"},{"text":" in the current application.","type":"text"}]},{"type":"heading","anchor":"MLNAccuracyAuthorizationDescription","level":2,"text":"MLNAccuracyAuthorizationDescription"},{"type":"paragraph","inlineContent":[{"text":"Set the accuracy authorization description string as an element of ","type":"text"},{"code":"NSLocationTemporaryUsageDescriptionDictionary","type":"codeVoice"},{"text":" to be used by the map to request authorization when the ","type":"text"},{"code":"MLNLocationManager.accuracyAuthorization","type":"codeVoice"},{"text":" is set to ","type":"text"},{"code":"CLAccuracyAuthorizationReducedAccuracy","type":"codeVoice"},{"text":". Requesting accuracy authorization is available for devices running iOS 14.0 and above.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example:"}]},{"type":"codeListing","syntax":"xml","code":["<key>NSLocationTemporaryUsageDescriptionDictionary<\/key>"," <dict>","  <key>MLNAccuracyAuthorizationDescription<\/key>","  <string>We require your precise location to help you navigate the map.<\/string>"," <\/dict>"]},{"type":"paragraph","inlineContent":[{"text":"Remove ","type":"text"},{"type":"codeVoice","code":"MLNAccuracyAuthorizationDescription"},{"text":" if you want to control when to request for accuracy authorization.","type":"text"}]},{"type":"heading","anchor":"MLNIdeographicFontFamilyName","level":2,"text":"MLNIdeographicFontFamilyName"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This key configures a global fallback font or fonts for "},{"overridingTitleInlineContent":[{"text":"client-side text rendering","type":"text"}],"type":"reference","isActive":true,"overridingTitle":"client-side text rendering","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts"},{"type":"text","text":" of Chinese hanzi, Japanese kana, and Korean hangul characters (CJK) that appear in text labels."}]},{"type":"paragraph","inlineContent":[{"text":"If the fonts you specify in the ","type":"text"},{"type":"codeVoice","code":"MLNSymbolStyleLayer.textFontNames"},{"text":" property are all unavailable or lack a glyph for rendering a given CJK character, the map uses the contents of this key to choose a ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/fonts\/system-fonts\/"},{"text":" or a font ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/text_display_and_fonts\/adding_a_custom_font_to_your_app"},{"text":". This key specifies a fallback for all style layers in all map views and map snapshots. If you do not specify this key or none of the font names matches, the map applies a font from the system’s font cascade list, which may vary based on the device model and system language.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This key can either be set to a single string or an array of strings, which the map tries to apply in order from most preferred to least preferred. Each string can be a family name (for example, “PingFang TC”), display name (“PingFang TC Ultralight”), or PostScript name (“PingFangTC-Ultralight”).","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To disable client-side rendering of CJK characters in favor of ","type":"text"},{"isActive":true,"type":"reference","identifier":"customizing-fonts.html#server-side-fonts"},{"text":", set this key to the Boolean value ","type":"text"},{"code":"NO","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"heading","anchor":"MLNOfflineStorageDatabasePath","level":2,"text":"MLNOfflineStorageDatabasePath"},{"type":"paragraph","inlineContent":[{"text":"This key customizes the file path at which ","type":"text"},{"code":"MLNOfflineStorage","type":"codeVoice"},{"text":" keeps the offline map database, which contains any offline packs as well as the ambient cache. Most applications should not need to customize this path; however, you could customize it to implement a migration path between different versions of your application.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The key is interpreted as either an absolute file path or a file path relative to the main bundle’s resource folder, resolving any tilde or symbolic link. The path must be writable. If a database does not exist at the path you specify, one will be created automatically."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"An offline map database can consume a significant amount of the user’s bandwidth and iCloud storage due to iCloud backups. To exclude the database from backups, set the containing directory’s "},{"type":"codeVoice","code":"NSURLIsExcludedFromBackupKey"},{"type":"text","text":" resource property to the Boolean value "},{"type":"codeVoice","code":"YES"},{"type":"text","text":" using the "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/nsurl\/1413819-setresourcevalue","isActive":true},{"type":"text","text":" method. The entire directory will be affected, not just the database file. If the user restores the application from a backup, your application will need to restore any offline packs that had been previously downloaded."}]},{"type":"paragraph","inlineContent":[{"text":"At runtime, you can obtain the value of this key using the ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databasePath","type":"reference","isActive":true},{"text":" and ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/databaseURL","type":"reference","isActive":true},{"text":" properties.","type":"text"}]},{"type":"heading","anchor":"MLNCollisionBehaviorPre40","level":2,"text":"MLNCollisionBehaviorPre4_0"},{"type":"paragraph","inlineContent":[{"text":"If this key is set to YES (","type":"text"},{"code":"true","type":"codeVoice"},{"text":"), collision detection is performed only between symbol style layers based on the same source, as in versions 2.0–3.7 of the MapLibre Native iOS. In other words, symbols in an ","type":"text"},{"code":"MLNSymbolStyleLayer","type":"codeVoice"},{"text":" based on one source (for example, an ","type":"text"},{"code":"MLNShapeSource","type":"codeVoice"},{"text":") may overlap with symbols in another layer that is based on a different source. This is the case regardless of the ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconAllowsOverlap","isActive":true,"type":"reference"},{"text":", ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconIgnoresPlacement","isActive":true,"type":"reference"},{"text":", ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textAllowsOverlap","isActive":true,"type":"reference"},{"text":", and ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textIgnoresPlacement","isActive":true,"type":"reference"},{"text":" properties.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Beginning in version 4.0, the SDK also performs collision detection between style layers based on different sources by default. For the default behavior, omit the ","type":"text"},{"code":"MLNCollisionBehaviorPre4_0","type":"codeVoice"},{"text":" key or set it to NO (","type":"text"},{"code":"false","type":"codeVoice"},{"text":").","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property may also be set using "},{"type":"codeVoice","code":"[[NSUserDefaults standardUserDefaults] setObject:@(YES) forKey:@\"MLNCollisionBehaviorPre4_0\"]"},{"type":"text","text":"; it will override any value specified in the "},{"type":"codeVoice","code":"Info.plist"},{"type":"text","text":"."}]}]}],"kind":"article","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/info.plist_keys"]}],"abstract":[{"text":"MapLibre Native for iOS supports custom ","type":"text"},{"type":"codeVoice","code":"Info.plist"},{"text":" keys in your application in order to configure various settings.","type":"text"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/databasePath":{"title":"databasePath","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineSto