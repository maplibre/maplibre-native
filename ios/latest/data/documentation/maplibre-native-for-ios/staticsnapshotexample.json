{"seeAlsoSections":[{"anchor":"Features","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LocationPrivacyExample"],"title":"Features","generated":true}],"primaryContentSections":[{"content":[{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This example uses UIKit."}]}],"type":"aside","name":"Note"},{"inlineContent":[{"type":"text","text":"This example demonstrates how snapshots can be made of the map. The result is an "},{"type":"codeVoice","code":"UIImage"},{"type":"text","text":" that you can let the user save to their camera roll or share with a friend. In this demo, the resulting image is shown back with an "},{"type":"codeVoice","code":"UIImageView"},{"type":"text","text":". Attribution is read from the sources and added to the snapshot (when applicable). By default a MapLibre logo is included on the image, but it is not required to show it. You can use "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotOptions\/showsLogo","isActive":true},{"type":"text","text":" to configure whether to include the logo. Check with your tile provider if you need to show their logo."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class StaticSnapshotExample: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","    var button: UIButton!","    var imageView: UIImageView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: CGRect(x: 0, y: 0, width: view.bounds.width, height: view.bounds.height \/ 2), styleURL: AMERICANA_STYLE)","        mapView.autoresizingMask = [.flexibleHeight, .flexibleWidth]","","        \/\/ Center map on the Giza Pyramid Complex in Egypt.","        let center = CLLocationCoordinate2D(latitude: 29.9773, longitude: 31.1325)","        mapView.setCenter(center, zoomLevel: 14, animated: false)","        view.addSubview(mapView)","","        \/\/ Create a button to take a map snapshot.","        button = UIButton(frame: CGRect(x: mapView.bounds.width \/ 2 - 40, y: mapView.bounds.height - 40, width: 80, height: 30))","        button.layer.cornerRadius = 15","        button.backgroundColor = UIColor(red: 0.96, green: 0.65, blue: 0.14, alpha: 1.0)","        button.setImage(UIImage(named: \"camera\"), for: .normal)","        button.addTarget(self, action: #selector(createSnapshot), for: .touchUpInside)","        view.addSubview(button)","","        \/\/ Create a UIImageView that will store the map snapshot.","        imageView = UIImageView(frame: CGRect(x: 0, y: view.bounds.height \/ 2, width: view.bounds.width, height: view.bounds.height \/ 2))","        imageView.backgroundColor = .black","        imageView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(imageView)","    }","","    @objc func createSnapshot() {","        \/\/ Use the map's style, camera, size, and zoom level to set the snapshot's options.","        let options = MLNMapSnapshotOptions(styleURL: mapView.styleURL, camera: mapView.camera, size: mapView.bounds.size)","        options.zoomLevel = mapView.zoomLevel","","        \/\/ Add an activity indicator to show that the snapshot is loading.","        let indicator = UIActivityIndicatorView(frame: CGRect(x: imageView.center.x - 30, y: imageView.center.y - 30, width: 60, height: 60))","        view.addSubview(indicator)","        indicator.startAnimating()","","        \/\/ Create the map snapshot.","        let snapshotter: MLNMapSnapshotter? = MLNMapSnapshotter(options: options)","        snapshotter?.start { snapshot, error in","            if error != nil {","                print(\"Unable to create a map snapshot.\")","            } else if let snapshot {","                \/\/ Add the map snapshot's image to the image view.","                indicator.stopAnimating()","                self.imageView.image = snapshot.image","            }","        }","    }","}"]}],"kind":"content"}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/StaticSnapshotExample","interfaceLanguage":"occ"},"kind":"article","schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"abstract":[{"text":"Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","type":"reference"},{"text":" to create snapshots of the map.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/staticsnapshotexample"]}],"sections":[],"metadata":{"roleHeading":"Article","modules":[{"name":"MapLibre"}],"role":"article","title":"Making Snapshots"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshot":{"kind":"symbol","abstract":[{"text":"An image generated by a snapshotter object.","type":"text"}],"type":"topic","title":"MLNMapSnapshot","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshot","url":"\/documentation\/maplibre\/mlnmapsnapshot","fragments":[{"text":"MLNMapSnapshot","kind":"identifier"}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/LocationPrivacyExample":{"role":"article","title":"User Location & Location Privacy","type":"topic","abstract":[{"text":"Requesting precise location with ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLocationManager","isActive":true},{"text":".","type":"text"}],"kind":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LocationPrivacyExample","url":"\/documentation\/maplibre-native-for-ios\/locationprivacyexample"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshotOptions/showsLogo":{"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotOptions\/showsLogo","abstract":[{"type":"text","text":"Whether to include the MapLibre logo. Note this is not required."}],"type":"topic","title":"showsLogo","url":"\/documentation\/maplibre\/mlnmapsnapshotoptions\/showslogo","fragments":[{"text":"showsLogo","kind":"identifier"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","title":"MapLibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"url":"\/documentation\/maplibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshotterDelegate":{"fragments":[{"kind":"identifier","text":"MLNMapSnapshotterDelegate"}],"role":"symbol","kind":"symbol","url":"\/documentation\/maplibre\/mlnmapsnapshotterdelegate","type":"topic","abstract":[{"text":"Optional methods about significant events when creating a snapshot using an","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter"},{"text":" object.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotterDelegate","title":"MLNMapSnapshotterDelegate"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshotter":{"title":"MLNMapSnapshotter","kind":"symbol","abstract":[{"text":"An ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","type":"reference"},{"text":" generates static raster images of the map. Each snapshot","type":"text"},{"text":" ","type":"text"},{"text":"image depicts a portion of a map defined by an ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotOptions","type":"reference"},{"text":" object","type":"text"},{"text":" ","type":"text"},{"text":"you provide. The snapshotter generates an ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshot","type":"reference"},{"text":" object","type":"text"},{"text":" ","type":"text"},{"text":"asynchronously, calling ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotterDelegate"},{"text":" methods if defined, then","type":"text"},{"text":" ","type":"text"},{"text":"passing it into a completion handler once tiles and other resources needed for","type":"text"},{"text":" ","type":"text"},{"text":"the snapshot are finished loading.","type":"text"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","url":"\/documentation\/maplibre\/mlnmapsnapshotter","role":"symbol","fragments":[{"text":"MLNMapSnapshotter","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshotOptions":{"type":"topic","fragments":[{"kind":"identifier","text":"MLNMapSnapshotOptions"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotOptions","abstract":[{"type":"text","text":"The options to use when creating images with the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter"},{"type":"text","text":"."}],"url":"\/documentation\/maplibre\/mlnmapsnapshotoptions","title":"MLNMapSnapshotOptions","kind":"symbol","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNLocationManager":{"role":"symbol","title":"MLNLocationManager","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLocationManager","kind":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnlocationmanager","abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLocationManager"},{"type":"text","text":" protocol defines a set of methods that a class must"},{"type":"text","text":" "},{"type":"text","text":"implement in order to serve as the location manager of an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"},{"type":"text","text":". A location"},{"type":"text","text":" "},{"type":"text","text":"manager is responsible for notifying the map view about location-related events,"},{"type":"text","text":" "},{"type":"text","text":"such as a change in the user’s location. This protocol is similar to the"},{"type":"text","text":" "},{"type":"text","text":"Core Location framework’s "},{"type":"codeVoice","code":"CLLocationManager"},{"type":"text","text":" class, but your implementation"},{"type":"text","text":" "},{"type":"text","text":"does not need to be based on "},{"type":"codeVoice","code":"CLLocationManager"},{"type":"text","text":"."}],"fragments":[{"text":"MLNLocationManager","kind":"identifier"}]}}}