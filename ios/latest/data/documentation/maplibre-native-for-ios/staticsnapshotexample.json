{"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/StaticSnapshotExample","interfaceLanguage":"occ"},"sections":[],"abstract":[{"text":"Use ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","type":"reference","isActive":true},{"text":" to create snapshots of the map.","type":"text"}],"kind":"article","metadata":{"roleHeading":"Article","title":"Making Snapshots","role":"article","modules":[{"name":"MapLibre"}]},"seeAlsoSections":[{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LocationPrivacyExample"],"title":"Features","generated":true,"anchor":"Features"}],"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/staticsnapshotexample"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"kind":"content","content":[{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"This example uses UIKit.","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"text":"This example demonstrates how snapshots can be made of the map. The result is an ","type":"text"},{"code":"UIImage","type":"codeVoice"},{"text":" that you can let the user save to their camera roll or share with a friend. In this demo, the resulting image is shown back with an ","type":"text"},{"code":"UIImageView","type":"codeVoice"},{"text":". Attribution is read from the sources and added to the snapshot (when applicable). By default a MapLibre logo is included on the image, but it is not required to show it. You can use ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotOptions\/showsLogo","isActive":true},{"text":" to configure whether to include the logo. Check with your tile provider if you need to show their logo.","type":"text"}]},{"type":"codeListing","code":["class StaticSnapshotExample: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","    var button: UIButton!","    var imageView: UIImageView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: CGRect(x: 0, y: 0, width: view.bounds.width, height: view.bounds.height \/ 2), styleURL: AMERICANA_STYLE)","        mapView.autoresizingMask = [.flexibleHeight, .flexibleWidth]","","        \/\/ Center map on the Giza Pyramid Complex in Egypt.","        let center = CLLocationCoordinate2D(latitude: 29.9773, longitude: 31.1325)","        mapView.setCenter(center, zoomLevel: 14, animated: false)","        view.addSubview(mapView)","","        \/\/ Create a button to take a map snapshot.","        button = UIButton(frame: CGRect(x: mapView.bounds.width \/ 2 - 40, y: mapView.bounds.height - 40, width: 80, height: 30))","        button.layer.cornerRadius = 15","        button.backgroundColor = UIColor(red: 0.96, green: 0.65, blue: 0.14, alpha: 1.0)","        button.setImage(UIImage(named: \"camera\"), for: .normal)","        button.addTarget(self, action: #selector(createSnapshot), for: .touchUpInside)","        view.addSubview(button)","","        \/\/ Create a UIImageView that will store the map snapshot.","        imageView = UIImageView(frame: CGRect(x: 0, y: view.bounds.height \/ 2, width: view.bounds.width, height: view.bounds.height \/ 2))","        imageView.backgroundColor = .black","        imageView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(imageView)","    }","","    @objc func createSnapshot() {","        \/\/ Use the map's style, camera, size, and zoom level to set the snapshot's options.","        let options = MLNMapSnapshotOptions(styleURL: mapView.styleURL, camera: mapView.camera, size: mapView.bounds.size)","        options.zoomLevel = mapView.zoomLevel","","        \/\/ Add an activity indicator to show that the snapshot is loading.","        let indicator = UIActivityIndicatorView(frame: CGRect(x: imageView.center.x - 30, y: imageView.center.y - 30, width: 60, height: 60))","        view.addSubview(indicator)","        indicator.startAnimating()","","        \/\/ Create the map snapshot.","        let snapshotter: MLNMapSnapshotter? = MLNMapSnapshotter(options: options)","        snapshotter?.start { snapshot, error in","            if error != nil {","                print(\"Unable to create a map snapshot.\")","            } else if let snapshot {","                \/\/ Add the map snapshot's image to the image view.","                indicator.stopAnimating()","                self.imageView.image = snapshot.image","            }","        }","    }","}"],"syntax":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshotter":{"kind":"symbol","type":"topic","fragments":[{"text":"MLNMapSnapshotter","kind":"identifier"}],"abstract":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","type":"reference","isActive":true},{"text":" generates static raster images of the map. Each snapshot","type":"text"},{"text":" ","type":"text"},{"text":"image depicts a portion of a map defined by an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotOptions","type":"reference","isActive":true},{"text":" object","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"you provide. The snapshotter generates an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshot","type":"reference","isActive":true},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"asynchronously, calling "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotterDelegate","type":"reference","isActive":true},{"type":"text","text":" methods if defined, then"},{"type":"text","text":" "},{"type":"text","text":"passing it into a completion handler once tiles and other resources needed for"},{"type":"text","text":" "},{"type":"text","text":"the snapshot are finished loading."}],"url":"\/documentation\/maplibre\/mlnmapsnapshotter","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","title":"MLNMapSnapshotter"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/LocationPrivacyExample":{"type":"topic","url":"\/documentation\/maplibre-native-for-ios\/locationprivacyexample","kind":"article","title":"User Location & Location Privacy","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LocationPrivacyExample","abstract":[{"type":"text","text":"Requesting precise location with "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLocationManager","type":"reference","isActive":true},{"type":"text","text":"."}],"role":"article"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshot":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshot","abstract":[{"type":"text","text":"An image generated by a snapshotter object."}],"kind":"symbol","title":"MLNMapSnapshot","fragments":[{"text":"MLNMapSnapshot","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnmapsnapshot","role":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"url":"\/documentation\/maplibre","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshotOptions/showsLogo":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotOptions\/showsLogo","abstract":[{"text":"Whether to include the MapLibre logo. Note this is not required.","type":"text"}],"kind":"symbol","title":"showsLogo","fragments":[{"kind":"identifier","text":"showsLogo"}],"url":"\/documentation\/maplibre\/mlnmapsnapshotoptions\/showslogo","role":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshotterDelegate":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotterDelegate","abstract":[{"text":"Optional methods about significant events when creating a snapshot using an","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","type":"reference"},{"type":"text","text":" object."}],"kind":"symbol","title":"MLNMapSnapshotterDelegate","fragments":[{"text":"MLNMapSnapshotterDelegate","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnmapsnapshotterdelegate","role":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNLocationManager":{"type":"topic","url":"\/documentation\/maplibre\/mlnlocationmanager","kind":"symbol","title":"MLNLocationManager","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLocationManager","fragments":[{"kind":"identifier","text":"MLNLocationManager"}],"abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLocationManager","type":"reference","isActive":true},{"type":"text","text":" protocol defines a set of methods that a class must"},{"type":"text","text":" "},{"type":"text","text":"implement in order to serve as the location manager of an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","type":"reference","isActive":true},{"type":"text","text":". A location"},{"type":"text","text":" "},{"type":"text","text":"manager is responsible for notifying the map view about location-related events,"},{"type":"text","text":" "},{"type":"text","text":"such as a change in the user’s location. This protocol is similar to the"},{"type":"text","text":" "},{"type":"text","text":"Core Location framework’s "},{"type":"codeVoice","code":"CLLocationManager"},{"type":"text","text":" class, but your implementation"},{"type":"text","text":" "},{"type":"text","text":"does not need to be based on "},{"type":"codeVoice","code":"CLLocationManager"},{"type":"text","text":"."}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshotOptions":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotOptions","abstract":[{"text":"The options to use when creating images with the ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","type":"reference","isActive":true},{"text":".","type":"text"}],"kind":"symbol","title":"MLNMapSnapshotOptions","fragments":[{"text":"MLNMapSnapshotOptions","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnmapsnapshotoptions","role":"symbol","type":"topic"}}}