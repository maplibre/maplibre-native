{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/StaticSnapshotExample"},"metadata":{"modules":[{"name":"MapLibre"}],"roleHeading":"Article","role":"article","title":"Making Snapshots"},"primaryContentSections":[{"kind":"content","content":[{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This example uses UIKit."}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This example demonstrates how snapshots can be made of the map. The result is an "},{"type":"codeVoice","code":"UIImage"},{"type":"text","text":" that you can let the user save to their camera roll or share with a friend. In this demo, the resulting image is shown back with an "},{"type":"codeVoice","code":"UIImageView"},{"type":"text","text":". Attribution is read from the sources and added to the snapshot (when applicable). By default a MapLibre logo is included on the image, but it is not required to show it. You can use "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotOptions\/showsLogo","isActive":true},{"type":"text","text":" to configure whether to include the logo. Check with your tile provider if you need to show their logo."}]},{"code":["class StaticSnapshotExample: UIViewController, MLNMapViewDelegate {","    var mapView: MLNMapView!","    var button: UIButton!","    var imageView: UIImageView!","","    override func viewDidLoad() {","        super.viewDidLoad()","","        mapView = MLNMapView(frame: CGRect(x: 0, y: 0, width: view.bounds.width, height: view.bounds.height \/ 2), styleURL: AMERICANA_STYLE)","        mapView.autoresizingMask = [.flexibleHeight, .flexibleWidth]","","        \/\/ Center map on the Giza Pyramid Complex in Egypt.","        let center = CLLocationCoordinate2D(latitude: 29.9773, longitude: 31.1325)","        mapView.setCenter(center, zoomLevel: 14, animated: false)","        view.addSubview(mapView)","","        \/\/ Create a button to take a map snapshot.","        button = UIButton(frame: CGRect(x: mapView.bounds.width \/ 2 - 40, y: mapView.bounds.height - 40, width: 80, height: 30))","        button.layer.cornerRadius = 15","        button.backgroundColor = UIColor(red: 0.96, green: 0.65, blue: 0.14, alpha: 1.0)","        button.setImage(UIImage(named: \"camera\"), for: .normal)","        button.addTarget(self, action: #selector(createSnapshot), for: .touchUpInside)","        view.addSubview(button)","","        \/\/ Create a UIImageView that will store the map snapshot.","        imageView = UIImageView(frame: CGRect(x: 0, y: view.bounds.height \/ 2, width: view.bounds.width, height: view.bounds.height \/ 2))","        imageView.backgroundColor = .black","        imageView.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(imageView)","    }","","    @objc func createSnapshot() {","        \/\/ Use the map's style, camera, size, and zoom level to set the snapshot's options.","        let options = MLNMapSnapshotOptions(styleURL: mapView.styleURL, camera: mapView.camera, size: mapView.bounds.size)","        options.zoomLevel = mapView.zoomLevel","","        \/\/ Add an activity indicator to show that the snapshot is loading.","        let indicator = UIActivityIndicatorView(frame: CGRect(x: imageView.center.x - 30, y: imageView.center.y - 30, width: 60, height: 60))","        view.addSubview(indicator)","        indicator.startAnimating()","","        \/\/ Create the map snapshot.","        let snapshotter: MLNMapSnapshotter? = MLNMapSnapshotter(options: options)","        snapshotter?.start { snapshot, error in","            if error != nil {","                print(\"Unable to create a map snapshot.\")","            } else if let snapshot {","                \/\/ Add the map snapshot's image to the image view.","                indicator.stopAnimating()","                self.imageView.image = snapshot.image","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"}]}],"seeAlsoSections":[{"anchor":"Features","title":"Features","generated":true,"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LocationPrivacyExample"]}],"kind":"article","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"abstract":[{"type":"text","text":"Use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter"},{"type":"text","text":" to create snapshots of the map."}],"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/staticsnapshotexample"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshotter":{"kind":"symbol","url":"\/documentation\/maplibre\/mlnmapsnapshotter","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","type":"reference","isActive":true},{"type":"text","text":" generates static raster images of the map. Each snapshot"},{"type":"text","text":" "},{"type":"text","text":"image depicts a portion of a map defined by an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotOptions","type":"reference","isActive":true},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"you provide. The snapshotter generates an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshot","type":"reference","isActive":true},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"asynchronously, calling "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotterDelegate","type":"reference","isActive":true},{"type":"text","text":" methods if defined, then"},{"type":"text","text":" "},{"type":"text","text":"passing it into a completion handler once tiles and other resources needed for"},{"type":"text","text":" "},{"type":"text","text":"the snapshot are finished loading."}],"role":"symbol","fragments":[{"kind":"identifier","text":"MLNMapSnapshotter"}],"title":"MLNMapSnapshotter"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshot":{"title":"MLNMapSnapshot","kind":"symbol","fragments":[{"text":"MLNMapSnapshot","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshot","role":"symbol","url":"\/documentation\/maplibre\/mlnmapsnapshot","abstract":[{"text":"An image generated by a snapshotter object.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshotterDelegate":{"type":"topic","fragments":[{"kind":"identifier","text":"MLNMapSnapshotterDelegate"}],"title":"MLNMapSnapshotterDelegate","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotterDelegate","abstract":[{"type":"text","text":"Optional methods about significant events when creating a snapshot using an"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","type":"reference","isActive":true},{"type":"text","text":" object."}],"url":"\/documentation\/maplibre\/mlnmapsnapshotterdelegate","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNLocationManager":{"abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLocationManager"},{"type":"text","text":" protocol defines a set of methods that a class must"},{"type":"text","text":" "},{"type":"text","text":"implement in order to serve as the location manager of an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"},{"type":"text","text":". A location"},{"type":"text","text":" "},{"type":"text","text":"manager is responsible for notifying the map view about location-related events,"},{"type":"text","text":" "},{"type":"text","text":"such as a change in the user’s location. This protocol is similar to the"},{"text":" ","type":"text"},{"text":"Core Location framework’s ","type":"text"},{"code":"CLLocationManager","type":"codeVoice"},{"text":" class, but your implementation","type":"text"},{"text":" ","type":"text"},{"text":"does not need to be based on ","type":"text"},{"code":"CLLocationManager","type":"codeVoice"},{"text":".","type":"text"}],"role":"symbol","fragments":[{"kind":"identifier","text":"MLNLocationManager"}],"title":"MLNLocationManager","type":"topic","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLocationManager","url":"\/documentation\/maplibre\/mlnlocationmanager"},"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshotOptions":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotOptions","title":"MLNMapSnapshotOptions","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"The options to use when creating images with the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","type":"reference","isActive":true},{"type":"text","text":"."}],"role":"symbol","fragments":[{"kind":"identifier","text":"MLNMapSnapshotOptions"}],"url":"\/documentation\/maplibre\/mlnmapsnapshotoptions"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshotOptions/showsLogo":{"type":"topic","role":"symbol","url":"\/documentation\/maplibre\/mlnmapsnapshotoptions\/showslogo","kind":"symbol","abstract":[{"type":"text","text":"Whether to include the MapLibre logo. Note this is not required."}],"title":"showsLogo","fragments":[{"kind":"identifier","text":"showsLogo"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotOptions\/showsLogo"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/LocationPrivacyExample":{"abstract":[{"text":"Requesting precise location with ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLocationManager","type":"reference"},{"text":".","type":"text"}],"kind":"article","type":"topic","role":"article","title":"User Location & Location Privacy","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LocationPrivacyExample","url":"\/documentation\/maplibre-native-for-ios\/locationprivacyexample"}}}