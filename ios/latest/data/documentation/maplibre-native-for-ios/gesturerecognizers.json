re\/MLNMapView\/zoomEnabled","isActive":true,"type":"reference"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Rotation","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Changes the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"},{"type":"text","text":" direction based on the user rotating two fingers in a circular motion"}]}],[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/rotateEnabled","isActive":true}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Single tap"}]}],[{"type":"paragraph","inlineContent":[{"text":"Selects\/deselects the annotation that you tap.","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Double tap"}]}],[{"type":"paragraph","inlineContent":[{"text":"Zooms in on the map’s anchor point","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/zoomEnabled"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Two-finger tap"}]}],[{"type":"paragraph","inlineContent":[{"text":"Zooms out with the map’s anchor point centered","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/zoomEnabled"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Pan","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Scrolls across mapView ("},{"type":"emphasis","inlineContent":[{"text":"note: if","type":"text"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"MLNUserTrackingModeFollow"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"is being used, it will be disabled once the user pans","type":"text"}]},{"text":")","type":"text"}]}],[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/scrollEnabled"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Two-finger drag"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Adjusts the pitch of the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"}],"type":"paragraph"}],[{"inlineContent":[{"code":"pitchEnabled","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"One-finger zoom","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Tap twice; on second tap, hold your finger on the map and pan up to zoom in, or down to zoom out"}],"type":"paragraph"}],[{"inlineContent":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/zoomEnabled","isActive":true,"type":"reference"}],"type":"paragraph"}]]]},{"identifier":"rotation.mp4","metadata":{"abstract":[{"text":"Rotation with two fingers.","type":"text"}]},"type":"video"},{"identifier":"quickzoom.mp4","metadata":{"abstract":[{"type":"text","text":"One finger zoom with a double tap."}]},"type":"video"},{"text":"Adding custom gesture recognizers","level":2,"anchor":"Adding-custom-gesture-recognizers","type":"heading"},{"inlineContent":[{"type":"text","text":"You can add "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/uigesturerecognizer","isActive":true},{"type":"text","text":" to your map programmatically or via storyboard. Adding custom responses to gesture recognizers can enhance your user’s experience, but try to use standard gestures where possible."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The gesture recognizers that you add will take priority over the built-in gesture recognizer. You can also set up your own gesture recognizer to work simult