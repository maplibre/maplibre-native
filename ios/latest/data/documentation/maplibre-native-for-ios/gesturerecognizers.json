{"type":"text","text":", or "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDecelerationRateImmediate","isActive":true},{"type":"text","text":" constants."}]}]}]},{"type":"heading","text":"Individual gestures","anchor":"Individual-gestures","level":2},{"alignments":["center","unset","unset"],"type":"table","rows":[[[{"inlineContent":[{"text":"Gesture","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Related Property","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Pinch"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Zooms in or out on the map’s anchor point"}],"type":"paragraph"}],[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/zoomEnabled"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Rotation","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Changes the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","type":"reference","isActive":true},{"type":"text","text":" direction based on the user rotating two fingers in a circular motion"}],"type":"paragraph"}],[{"inlineContent":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/rotateEnabled","isActive":true,"type":"reference"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Single tap","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Selects\/deselects the annotation that you tap.","type":"text"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Double tap"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Zooms in on the map’s anchor point"}],"type":"paragraph"}],[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/docume