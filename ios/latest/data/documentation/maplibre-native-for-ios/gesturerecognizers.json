mentation\/MapLibre\/MLNMapViewDecelerationRateFast","isActive":true,"type":"reference"},{"type":"text","text":", or "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDecelerationRateImmediate","isActive":true,"type":"reference"},{"type":"text","text":" constants."}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Individual-gestures","type":"heading","text":"Individual gestures","level":2},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Gesture"}]}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Related Property","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Pinch"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Zooms in or out on the map’s anchor point","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/zoomEnabled","type":"reference"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Rotation"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Changes the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","isActive":true},{"type":"text","text":" direction based on the user rotating two fingers in a circular motion"}],"type":"paragraph"}],[{"inlineContent":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/rotateEnabled","isActive":true,"type":"reference"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Single tap","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Selects\/deselects the annotation that you tap."}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Double tap"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Zooms in on the map’s anchor point","type":"text"}],