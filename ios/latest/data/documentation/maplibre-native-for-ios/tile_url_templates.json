{"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"Using URL Templates when defining tile sources","type":"text"}],"primaryContentSections":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSource","type":"reference"},{"text":" objects, specifically ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","type":"reference"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","type":"reference"},{"text":" objects, can be created using an initializer that accepts","type":"text"},{"text":" ","type":"text"},{"text":"an array of tile URL templates. Tile URL templates are strings that specify the","type":"text"},{"text":" ","type":"text"},{"text":"URLs of the vector tiles or raster tile images to load. A template resembles an","type":"text"},{"text":" ","type":"text"},{"text":"absolute URL, but with any number of placeholder strings that the source","type":"text"},{"text":" ","type":"text"},{"text":"evaluates based on the tile it needs to load. For example:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"http:\/\/www.example.com\/tiles\/{z}\/{x}\/{y}.pbf"},{"type":"text","text":" could be"},{"type":"text","text":" "},{"type":"text","text":"evaluated as "},{"type":"codeVoice","code":"http:\/\/www.example.com\/tiles\/14\/6\/9.pbf"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"http:\/\/www.example.com\/tiles\/{z}\/{x}\/{y}{ratio}.png"},{"type":"text","text":" could be"},{"type":"text","text":" "},{"type":"text","text":"evaluated as "},{"type":"codeVoice","code":"http:\/\/www.example.com\/tiles\/14\/6\/9@2x.png"},{"type":"text","text":"."}]}]}]},{"type":"paragraph","inlineContent":[{"text":"Tile URL templates are also used to define tilesets in TileJSON manifests or","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/sources\/#raster"},{"text":" ","type":"text"},{"text":"and","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/sources\/#vector-tiles"},{"text":" ","type":"text"},{"text":"sources in style JSON files. See the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/mapbox\/tilejson-spec\/tree\/master\/2.2.0"},{"text":" ","type":"text"},{"text":"for information about tile URL templates in the context of a TileJSON or style","type":"text"},{"text":" ","type":"text"},{"text":"JSON file.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Tile sources support the following placeholder strings in tile URL templates,"},{"type":"text","text":" "},{"type":"text","text":"all of which are optional:"}]},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Placeholder string"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"{x}"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"The index of the tile along the map’s x axis according to Spherical Mercator projection. If the value is 0, the tile’s left edge corresponds to the 180th meridian west. If the value is 2^z−1, the tile’s right edge corresponds to the 180th meridian east."}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"{y}"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"The index of the tile along the map’s y axis according to Spherical Mercator projection. If the value is 0, the tile’s tile edge corresponds to arctan(sinh(π)), or approximately 85.0511 degrees north. If the value is 2^z−1, the tile’s bottom edge corresponds to −arctan(sinh(π)), or approximately 85.0511 degrees south. The y axis is inverted if the options parameter contains "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileCoordinateSystem","isActive":true},{"type":"text","text":" with a value of "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileCoordinateSystem\/MLNTileCoordinateSystemTMS","isActive":true},{"type":"text","text":"."}]}]],[[{"type":"paragraph","inlineContent":[{"code":"{z}","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"The tile’s zoom level. At zoom level 0, each tile covers the entire world map; at zoom level 1, it covers ¼ of the world; at zoom level 2, 1⁄16 of the world, and so on. For tiles loaded by a "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","type":"reference","isActive":true},{"type":"text","text":" object, whether the tile zoom level matches the map’s current zoom level depends on the value of the source’s tile size as specified in the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize","type":"reference","isActive":true},{"type":"text","text":" key of the options parameter."}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"{bbox-epsg-3857}"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"The tile’s bounding box, expressed as a comma-separated list of the tile’s western, southern, eastern, and northern extents according to Spherical Mercator (EPSG:3857) projection. The bounding box is typically used with map services conforming to the "},{"type":"text","text":"Web Map Service"},{"type":"text","text":" protocol."}]}]],[[{"type":"paragraph","inlineContent":[{"code":"{quadkey}","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"A quadkey indicating both the tile’s location and its zoom level. The quadkey is typically used with ","type":"text"},{"text":"Bing Maps","type":"text"},{"text":".","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"{ratio}","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"A suffix indicating the resolution of the tile image. The suffix is the empty string for standard resolution displays and "},{"type":"codeVoice","code":"@2x"},{"type":"text","text":" for Retina displays, including displays for which "},{"type":"codeVoice","code":"UIScreen.scale"},{"type":"text","text":" is 3."}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"{prefix}"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Two hexadecimal digits chosen such that each visible tile has a different prefix. The prefix is typically used for domain sharding."}]}]]],"header":"row"},{"type":"paragraph","inlineContent":[{"text":"For more information about the ","type":"text"},{"code":"{x}","type":"codeVoice"},{"text":", ","type":"text"},{"code":"{y}","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"{z}","type":"codeVoice"},{"text":" placeholder strings,","type":"text"},{"text":" ","type":"text"},{"text":"consult the","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/wiki.openstreetmap.org\/wiki\/Slippy_map_tilenames","isActive":true,"type":"reference"},{"text":".","type":"text"}]}],"kind":"content"}],"metadata":{"modules":[{"name":"MapLibre"}],"roleHeading":"Article","title":"Tile URL Templates","role":"article"},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Tile_URL_Templates","interfaceLanguage":"occ"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/tile_url_templates"]}],"seeAlsoSections":[{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLib