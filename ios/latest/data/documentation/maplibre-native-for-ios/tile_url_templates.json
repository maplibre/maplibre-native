{"primaryContentSections":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSource","isActive":true,"type":"reference"},{"text":" objects, specifically ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","isActive":true,"type":"reference"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","isActive":true,"type":"reference"},{"text":" objects, can be created using an initializer that accepts","type":"text"},{"text":" ","type":"text"},{"text":"an array of tile URL templates. Tile URL templates are strings that specify the","type":"text"},{"text":" ","type":"text"},{"text":"URLs of the vector tiles or raster tile images to load. A template resembles an","type":"text"},{"text":" ","type":"text"},{"text":"absolute URL, but with any number of placeholder strings that the source","type":"text"},{"text":" ","type":"text"},{"text":"evaluates based on the tile it needs to load. For example:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"http:\/\/www.example.com\/tiles\/{z}\/{x}\/{y}.pbf"},{"text":" could be","type":"text"},{"text":" ","type":"text"},{"text":"evaluated as ","type":"text"},{"type":"codeVoice","code":"http:\/\/www.example.com\/tiles\/14\/6\/9.pbf"},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"http:\/\/www.example.com\/tiles\/{z}\/{x}\/{y}{ratio}.png","type":"codeVoice"},{"text":" could be","type":"text"},{"text":" ","type":"text"},{"text":"evaluated as ","type":"text"},{"code":"http:\/\/www.example.com\/tiles\/14\/6\/9@2x.png","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Tile URL templates are also used to define tilesets in TileJSON manifests or","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/sources\/#raster","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"and","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/sources\/#vector-tiles","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"sources in style JSON files. See the","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/github.com\/mapbox\/tilejson-spec\/tree\/master\/2.2.0","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"for information about tile URL templates in the context of a TileJSON or style","type":"text"},{"text":" ","type":"text"},{"text":"JSON file.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Tile sources support the following placeholder strings in tile URL templates,"},{"type":"text","text":" "},{"type":"text","text":"all of which are optional:"}]},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Placeholder string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"{x}","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"The index of the tile along the map’s x axis according to Spherical Mercator projection. If the value is 0, the tile’s left edge corresponds to the 180th meridian west. If the value is 2^z−1, the tile’s right edge corresponds to the 180th meridian east.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"{y}"}],"type":"paragraph"}],[{"inlineContent":[{"text":"The index of the tile along the map’s y axis according to Spherical Mercator projection. If the value is 0, the tile’s tile edge corresponds to arctan(sinh(π)), or approximately 85.0511 degrees north. If the value is 2^z−1, the tile’s bottom edge corresponds to −arctan(sinh(π)), or approximately 85.0511 degrees south. The y axis is inverted if the options parameter contains ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileCoordinateSystem","isActive":true,"type":"reference"},{"text":" with a value of ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileCoordinateSystem\/MLNTileCoordinateSystemTMS","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"{z}"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"The tile’s zoom level. At zoom level 0, each tile covers the entire world map; at zoom level 1, it covers ¼ of the world; at zoom level 2, 1⁄16 of the world, and so on. For tiles loaded by a "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","type":"reference","isActive":true},{"type":"text","text":" object, whether the tile zoom level matches the map’s current zoom level depends on the value of the source’s tile size as specified in the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize","type":"reference","isActive":true},{"type":"text","text":" key of the options parameter."}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"{bbox-epsg-3857}","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"The tile’s bounding box, expressed as a comma-separated list of the tile’s western, southern, eastern, and northern extents according to Spherical Mercator (EPSG:3857) projection. The bounding box is typically used with map services conforming to the ","type":"text"},{"text":"Web Map Service","type":"text"},{"text":" protocol.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"{quadkey}","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"A quadkey indicating both the tile’s location and its zoom level. The quadkey is typically used with "},{"type":"text","text":"Bing Maps"},{"type":"text","text":"."}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"{ratio}"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"A suffix indicating the resolution of the tile image. The suffix is the empty string for standard resolution displays and "},{"code":"@2x","type":"codeVoice"},{"type":"text","text":" for Retina displays, including displays for which "},{"code":"UIScreen.scale","type":"codeVoice"},{"type":"text","text":" is 3."}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"{prefix}","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Two hexadecimal digits chosen such that each visible tile has a different prefix. The prefix is typically used for domain sharding."}],"type":"paragraph"}]]]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For more information about the "},{"code":"{x}","type":"codeVoice"},{"type":"text","text":", "},{"code":"{y}","type":"codeVoice"},{"type":"text","text":", and "},{"code":"{z}","type":"codeVoice"},{"type":"text","text":" placeholder strings,"},{"type":"text","text":" "},{"type":"text","text":"consult the"},{"type":"text","text":" "},{"identifier":"https:\/\/wiki.openstreetmap.org\/wiki\/Slippy_map_tilenames","type":"reference","isActive":true},{"type":"text","text":"."}]}],"kind":"content"}],"metadata":{"modules":[{"name":"MapLibre"}],"roleHeading":"Article","title":"Tile URL Templates","role":"article"},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"Using URL Templates when defining tile sources","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre-native-for-ios\/tile_url_templates"]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Tile_URL_Templates"},"sections":[],"kind":"article","seeAlsoSections":[{"anchor":"Other-Articles","identifi