{"primaryContentSections":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSource","type":"reference","isActive":true},{"text":" objects, specifically ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","type":"reference","isActive":true},{"text":" and","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","type":"reference","isActive":true},{"text":" objects, can be created using an initializer that accepts","type":"text"},{"text":" ","type":"text"},{"text":"an array of tile URL templates. Tile URL templates are strings that specify the","type":"text"},{"text":" ","type":"text"},{"text":"URLs of the vector tiles or raster tile images to load. A template resembles an","type":"text"},{"text":" ","type":"text"},{"text":"absolute URL, but with any number of placeholder strings that the source","type":"text"},{"text":" ","type":"text"},{"text":"evaluates based on the tile it needs to load. For example:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"http:\/\/www.example.com\/tiles\/{z}\/{x}\/{y}.pbf"},{"type":"text","text":" could be"},{"type":"text","text":" "},{"type":"text","text":"evaluated as "},{"type":"codeVoice","code":"http:\/\/www.example.com\/tiles\/14\/6\/9.pbf"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"http:\/\/www.example.com\/tiles\/{z}\/{x}\/{y}{ratio}.png"},{"type":"text","text":" could be"},{"type":"text","text":" "},{"type":"text","text":"evaluated as "},{"type":"codeVoice","code":"http:\/\/www.example.com\/tiles\/14\/6\/9@2x.png"},{"type":"text","text":"."}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"Tile URL templates are also used to define tilesets in TileJSON manifests or","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/sources\/#raster","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"and","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/sources\/#vector-tiles","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"sources in style JSON files. See the","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/github.com\/mapbox\/tilejson-spec\/tree\/master\/2.2.0","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"for information about tile URL templates in the context of a TileJSON or style","type":"text"},{"text":" ","type":"text"},{"text":"JSON file.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Tile sources support the following placeholder strings in tile URL templates,"},{"type":"text","text":" "},{"type":"text","text":"all of which are optional:"}],"type":"paragraph"},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Placeholder string"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"{x}"}],"type":"paragraph"}],[{"inlineContent":[{"text":"The index of the tile along the map’s x axis according to Spherical Mercator projection. If the value is 0, the tile’s left edge corresponds to the 180th meridian west. If the value is 2^z−1, the tile’s right edge corresponds to the 180th meridian east.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"{y}","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"The index of the tile along the map’s y axis according to Spherical Mercator projection. If the value is 0, the tile’s tile edge corresponds to arctan(sinh(π)), or approximately 85.0511 degrees north. If the value is 2^z−1, the tile’s bottom edge corresponds to −arctan(sinh(π)), or approximately 85.0511 degrees south. The y axis is inverted if the options parameter contains ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileCoordinateSystem","type":"reference"},{"text":" with a value of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileCoordinateSystem\/MLNTileCoordinateSystemTMS","type":"reference"},{"text":".","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"{z}","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"The tile’s zoom level. At zoom level 0, each tile covers the entire world map; at zoom level 1, it covers ¼ of the world; at zoom level 2, 1⁄16 of the world, and so on. For tiles loaded by a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource"},{"type":"text","text":" object, whether the tile zoom level matches the map’s current zoom level depends on the value of the source’s tile size as specified in the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize"},{"type":"text","text":" key of the options parameter."}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"{bbox-epsg-3857}","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"The tile’s bounding box, expressed as a comma-separated list of the tile’s western, southern, eastern, and northern extents according to Spherical Mercator (EPSG:3857) projection. The bounding box is typically used with map services conforming to the "},{"type":"text","text":"Web Map Service"},{"type":"text","text":" protocol."}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"{quadkey}","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"A quadkey indicating both the tile’s location and its zoom level. The quadkey is typically used with ","type":"text"},{"text":"Bing Maps","type":"text"},{"text":".","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"{ratio}"}],"type":"paragraph"}],[{"inlineContent":[{"text":"A suffix indicating the resolution of the tile image. The suffix is the empty string for standard resolution displays and ","type":"text"},{"type":"codeVoice","code":"@2x"},{"text":" for Retina displays, including displays for which ","type":"text"},{"type":"codeVoice","code":"UIScreen.scale"},{"text":" is 3.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"{prefix}"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Two hexadecimal digits chosen such that each visible tile has a different prefix. The prefix is typically used for domain sharding."}],"type":"paragraph"}]]]},{"inlineContent":[{"type":"text","text":"For more information about the "},{"type":"codeVoice","code":"{x}"},{"type":"text","text":", "},{"type":"codeVoice","code":"{y}"},{"type":"text","text":", and "},{"type":"codeVoice","code":"{z}"},{"type":"text","text":" placeholder strings,"},{"type":"text","text":" "},{"type":"text","text":"consult the"},{"type":"text","text":" "},{"identifier":"https:\/\/wiki.openstreetmap.org\/wiki\/Slippy_map_tilenames","type":"reference","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"type":"text","text":"Using URL Templates when defining tile sources"}],"metadata":{"roleHeading":"Article","title":"Tile URL Templates","role":"article","modules":[{"name":"MapLibre"}]},"sections":[],"kind":"article","schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"seeAlsoSections":[{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Info.plist_Keys","doc:\/\/org.swift.MyProjec