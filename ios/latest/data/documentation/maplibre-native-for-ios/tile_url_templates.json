{"metadata":{"role":"article","roleHeading":"Article","modules":[{"name":"MapLibre"}],"title":"Tile URL Templates"},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Tile_URL_Templates"},"abstract":[{"type":"text","text":"Using URL Templates when defining tile sources"}],"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/tile_url_templates"],"traits":[{"interfaceLanguage":"occ"}]}],"seeAlsoSections":[{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Info.plist_Keys","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GestureRecognizers","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/MultipleImagesExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Predicates_and_Expressions","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/For_Style_Authors"],"title":"Other Articles","anchor":"Other-Articles","generated":true}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"primaryContentSections":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSource"},{"text":" objects, specifically ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource"},{"text":" objects, can be created using an initializer that accepts","type":"text"},{"text":" ","type":"text"},{"text":"an array of tile URL templates. Tile URL templates are strings that specify the","type":"text"},{"text":" ","type":"text"},{"text":"URLs of the vector tiles or raster tile images to load. A template resembles an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"absolute URL, but with any number of placeholder strings that the source"},{"type":"text","text":" "},{"type":"text","text":"evaluates based on the tile it needs to load. For example:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"http:\/\/www.example.com\/tiles\/{z}\/{x}\/{y}.pbf"},{"type":"text","text":" could be"},{"type":"text","text":" "},{"type":"text","text":"evaluated as "},{"type":"codeVoice","code":"http:\/\/www.example.com\/tiles\/14\/6\/9.pbf"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"http:\/\/www.example.com\/tiles\/{z}\/{x}\/{y}{ratio}.png","type":"codeVoice"},{"text":" could be","type":"text"},{"text":" ","type":"text"},{"text":"evaluated as ","type":"text"},{"code":"http:\/\/www.example.com\/tiles\/14\/6\/9@2x.png","type":"codeVoice"},{"text":".","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Tile URL templates are also used to define tilesets in TileJSON manifests or","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/sources\/#raster"},{"text":" ","type":"text"},{"text":"and","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/sources\/#vector-tiles"},{"text":" ","type":"text"},{"text":"sources in style JSON files. See the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/mapbox\/tilejson-spec\/tree\/master\/2.2.0"},{"text":" ","type":"text"},{"text":"for information about tile URL templates in the context of a TileJSON or style","type":"text"},{"text":" ","type":"text"},{"text":"JSON file.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Tile sources support the following placeholder strings in tile URL templates,","type":"text"},{"text":" ","type":"text"},{"text":"all of which are optional:","type":"text"}]},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Placeholder string"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"{x}"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"The index of the tile along the map’s x axis according to Spherical Mercator projection. If the value is 0, the tile’s left edge corresponds to the 180th meridian west. If the value is 2^z−1, the tile’s right edge corresponds to the 180th meridian east."}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"{y}"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"The index of the tile along the map’s y axis according to Spherical Mercator projection. If the value is 0, the tile’s tile edge corresponds to arctan(sinh(π)), or approximately 85.0511 degrees north. If the value is 2^z−1, the tile’s bottom edge corresponds to −arctan(sinh(π)), or approximately 85.0511 degrees south. The y axis is inverted if the options parameter contains "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileCoordinateSystem","isActive":true},{"type":"text","text":" with a value of "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileCoordinateSystem\/MLNTileCoordinateSystemTMS","isActive":true},{"type":"text","text":"."}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"{z}"}]}],[{"type":"paragraph","inlineContent":[{"text":"The tile’s zoom level. At zoom level 0, each tile covers the entire world map; at zoom level 1, it covers ¼ of the world; at zoom level 2, 1⁄16 of the world, and so on. For tiles loaded by a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource"},{"text":" object, whether the tile zoom level matches the map’s current zoom level depends on the value of the source’s tile size as specified in the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize"},{"text":" key of the options parameter.","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"{bbox-epsg-3857}"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"The tile’s bounding box, expressed as a comma-separated list of the tile’s western, southern, eastern, and northern extents according to Spherical Mercator (EPSG:3857) projection. The bounding box is typically used with map services conforming to the "},{"type":"text","text":"Web Map Service"},{"type":"text","text":" protocol."}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"{quadkey}"}]}],[{"type":"paragraph","inlineContent":[{"text":"A quadkey indicating both the tile’s location and its zoom level. The quadkey is typically used with ","type":"text"},{"text":"Bing Maps","type":"text"},{"text":".","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"{ratio}"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"A suffix indicating the resolution of the tile image. The suffix is the empty string for standard resolution displays and "},{"code":"@2x","type":"codeVoice"},{"type":"text","text":" for Retina displays, including displays for which "},{"code":"UIScreen.scale","type":"codeVoice"},{"type":"text","text":" is 3."}]}]],[[{"type":"paragraph","inlineContent":[{"code":"{prefix}","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Two hexadecimal digits chosen such that each visib