{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"metadata":{"modules":[{"name":"MapLibre"}],"title":"Tile URL Templates","roleHeading":"Article","role":"article"},"abstract":[{"text":"Using URL Templates when defining tile sources","type":"text"}],"sections":[],"kind":"article","seeAlsoSections":[{"generated":true,"anchor":"Other-Articles","title":"Other Articles","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Customizing_Fonts","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Info.plist_Keys","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GestureRecognizers","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/MultipleImagesExample","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Predicates_and_Expressions","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/For_Style_Authors"]}],"primaryContentSections":[{"content":[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSource","type":"reference"},{"text":" objects, specifically ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","type":"reference"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","type":"reference"},{"text":" objects, can be created using an initializer that accepts","type":"text"},{"text":" ","type":"text"},{"text":"an array of tile URL templates. Tile URL templates are strings that specify the","type":"text"},{"text":" ","type":"text"},{"text":"URLs of the vector tiles or raster tile images to load. A template resembles an","type":"text"},{"text":" ","type":"text"},{"text":"absolute URL, but with any number of placeholder strings that the source","type":"text"},{"text":" ","type":"text"},{"text":"evaluates based on the tile it needs to load. For example:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"code":"http:\/\/www.example.com\/tiles\/{z}\/{x}\/{y}.pbf","type":"codeVoice"},{"type":"text","text":" could be"},{"type":"text","text":" "},{"type":"text","text":"evaluated as "},{"code":"http:\/\/www.example.com\/tiles\/14\/6\/9.pbf","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"http:\/\/www.example.com\/tiles\/{z}\/{x}\/{y}{ratio}.png","type":"codeVoice"},{"text":" could be","type":"text"},{"text":" ","type":"text"},{"text":"evaluated as ","type":"text"},{"code":"http:\/\/www.example.com\/tiles\/14\/6\/9@2x.png","type":"codeVoice"},{"text":".","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Tile URL templates are also used to define tilesets in TileJSON manifests or"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/sources\/#raster","isActive":true},{"type":"text","text":" "},{"type":"text","text":"and"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/maplibre.org\/maplibre-style-spec\/sources\/#vector-tiles","isActive":true},{"type":"text","text":" "},{"type":"text","text":"sources in style JSON files. See the"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/github.com\/mapbox\/tilejson-spec\/tree\/master\/2.2.0","isActive":true},{"type":"text","text":" "},{"type":"text","text":"for information about tile URL templates in the context of a TileJSON or style"},{"type":"text","text":" "},{"type":"text","text":"JSON file."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Tile sources support the following placeholder strings in tile URL templates,"},{"type":"text","text":" "},{"type":"text","text":"all of which are optional:"}],"type":"paragraph"},{"header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Placeholder string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"{x}","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"The index of the tile along the map’s x axis according to Spherical Mercator projection. If the value is 0, the tile’s left edge corresponds to the 180th meridian west. If the value is 2^z−1, the tile’s right edge corresponds to the 180th meridian east.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"{y}","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"The index of the tile along the map’s y axis according to Spherical Mercator projection. If the value is 0, the tile’s tile edge corresponds to arctan(sinh(π)), or approximately 85.0511 degrees north. If the value is 2^z−1, the tile’s bottom edge corresponds to −arctan(sinh(π)), or approximately 85.0511 degrees south. The y axis is inverted if the options parameter contains "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileCoordinateSystem","type":"reference","isActive":true},{"type":"text","text":" with a value of "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileCoordinateSystem\/MLNTileCoordinateSystemTMS","type":"reference","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"{z}","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"The tile’s zoom level. At zoom level 0, each tile covers the entire world map; at zoom level 1, it covers ¼ of the world; at zoom level 2, 1⁄16 of the world, and so on. For tiles loaded by a "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","type":"reference","isActive":true},{"type":"text","text":" object, whether the tile zoom level matches the map’s current zoom level depends on the value of the source’s tile size as specified in the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize","type":"reference","isActive":true},{"type":"text","text":" key of the options parameter."}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"{bbox-epsg-3857}","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"The tile’s bounding box, expressed as a comma-separated list of the tile’s western, southern, eastern, and northern extents according to Spherical Mercator (EPSG:3857) projection. The bounding box is typically used with map services conforming to the ","type":"text"},{"text":"Web Map Service","type":"text"},{"text":" protocol.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"{quadkey}"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"A quadkey indicating both the tile’s location and its zoom level. The quadkey is typically used with "},{"type":"text","text":"Bing Maps"},{"type":"text","text":"."}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"{ratio}"}],"type":"paragraph"}],[{"inlineContent":[{"text":"A suffix indicating the resolution of the tile image. The suffix is the empty string for standard resolution displays and ","type":"text"},{"code":"@2x","type":"codeVoice"},{"text":" for Retina displays, including displays for which ","type":"text"},{"code":"UIScreen.scale","type":"codeVoice"},{"text":" is 3.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"{prefix}","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Two hexadecimal digits chosen such that each visible tile has a different prefix. The prefix is typically used for domain sharding."}],"type":"paragraph"}]]],"type":"table"},{"inlineContent":[{"text":"For more information about the ","type":"text"},{"code":"{x}","type":"codeVoice"},{"text":", ","type":"text"},{"code":"{y}","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"{z}","type":"codeVoice"},{"text":" placeholder strings,","type":"text"},{"text":" ","type":"text"},{"text":"consult the","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/wiki.openstreetmap.org\/wiki\/Slippy_map_tilenames","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Tile_URL_Templates","interfaceLanguage":"occ"},"variants":[{"paths":["\/documentation\/maplibre-native-for-ios\/tile_url_templates"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/Predicates_and_Expressions":{"abstract":[{"type":"text","text":"Using "},{"code":"NSPredicate","type":"codeVoice"},{"type":"text","text":" with MapLibre iOS"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Predicates_and_Expressions","url":"\/documentation\/maplibre-native-for-ios\/predicates_and_expressions","type":"topic","role":"article","title":"Predicates and expressions","kind":"article"},"https://wiki.openstreetmap.org/wiki/Slippy_map_tilenames":{"type":"link","titleInlineContent":[{"type":"text","text":"OpenStreetMap Wiki"}],"title":"OpenStreetMap Wiki","identifier":"https:\/\/wiki.openstreetmap.org\/wiki\/Slippy_map_tilenames","url":"https:\/\/wiki.openstreetmap.org\/wiki\/Slippy_map_tilenames"},"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorTileSource":{"type":"topic","role":"symbol","fragments":[{"kind":"identifier","text":"MLNVectorTileSource"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","title":"MLNVectorTileSource","kind":"symbol","url":"\/documentation\/maplibre\/mlnvectortilesource","abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","isActive":tr