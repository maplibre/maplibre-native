{"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown","interfaceLanguage":"occ"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"identifier","text":"MLNOfflinePackStateUnknown"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is the initial state of a pack. The state of a pack becomes known by"},{"type":"text","text":" "},{"type":"text","text":"the time the shared "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"},{"type":"text","text":" object sends the first"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification"},{"type":"text","text":" about the pack. For inactive"},{"type":"text","text":" "},{"type":"text","text":"packs, you must explicitly request a progress update using the"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/requestProgress","isActive":true,"type":"reference"},{"text":" method.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"An invalid pack always has a state of ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateInvalid"},{"text":", never","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown"},{"text":".","type":"text"}]}],"kind":"content"}],"metadata":{"role":"symbol","fragments":[{"kind":"identifier","text":"MLNOfflinePackStateUnknown"}],"title":"MLNOfflinePackStateUnknown","ext