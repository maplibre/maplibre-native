:" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}]}],"abstract":[{"text":"It is unknown whether the pack is inactive, active, or complete.","type":"text"}],"metadata":{"externalID":"c:@E@MLNOfflinePackState@MLNOfflinePackStateUnknown","symbolKind":"case","roleHeading":"Enumeration Case","modules":[{"name":"MapLibre"}],"title":"MLNOfflinePackStateUnknown","role":"symbol","navigatorTitle":[{"text":"MLNOfflinePackStateUnknown","kind":"identifier"}],"fragments":[{"kind":"identifier","text":"MLNOfflinePackStateUnknown"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/removePack:withCompletionHandler:":{"url":"\/documentation\/maplibre\/mlnofflinestorage\/removepack:withcompletionhandler:","fragments":[{"text":"- ","kind":"text"},{"text":"removePack:withCompletionHandler:","kind":"identifier"}],"abstract":[{"type":"text","text":"Unregisters the given offline pack and allows resources that are no longer"},{"type":"text","text":" "},{"type":"text","text":"required by any remaining packs to be potentially freed."}],"kind":"symbol","role":"symbol","type":"topic","title":"removePack:withCompletionHandler:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/removePack:withCompletionHandler:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"url":"\/documentation\/maplibre\/mlnofflinestorage","fragments":[{"text":"MLNOfflineStorage","kind":"identifier"}],"abstract":[{"type":"text","text":"MLNOfflineStorage implements a singleton (shared object) that manages offline"},{"type":"text","text":" "},{"type":"text","text":"packs and ambient caching. All of this class’s instance methods are asynchronous,"},{"type":"text","text":" "},{"type":"text","text":"reflecting the fact that offline reso