tifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown","type":"reference"},{"type":"text","text":"."}]}],"kind":"content"}],"sections":[],"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown"},"metadata":{"roleHeading":"Enumeration Case","title":"MLNOfflinePackStateUnknown","externalID":"c:@E@MLNOfflinePackState@MLNOfflinePackStateUnknown","navigatorTitle":[{"kind":"identifier","text":"MLNOfflinePackStateUnknown"}],"symbolKind":"case","role":"symbol","fragments":[{"kind":"identifier","text":"MLNOfflinePackStateUnknown"}],"modules":[{"name":"MapLibre"}]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/requestProgress":{"role":"symbol","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"requestProgress"}],"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Request an asynchronous update to the pack’s "},{"code":"state","type":"codeVoice"},{"type":"text","text":" and "},{"code":"progress","type":"codeVoice"},{"type":"text","text":" properties."}],"url":"\/documentation\/maplibre\/mlnofflinepack\/requestprogress","title":"requestProgress","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/requestProgress"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackState/MLNOfflinePackStateUnknown":{"title":"MLNOfflinePackStateUnknown","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown","type":"topic","abstract":[{"text":"It is unknown whether the pack is inactive, active, or complete.","type":"text"}],"role":"symbol","kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinepackstate\/mlnofflinepackstateunknown","fragments":[{"text":"MLNOfflinePackStateUnknown","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOff