oad that more"},{"type":"text","text":" "},{"type":"text","text":"resources are required for offline viewing. This notification is posted"},{"type":"text","text":" "},{"type":"text","text":"whenever any field in the "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" property changes."}],"type":"topic","fragments":[{"text":"MLNOfflinePackProgressChangedNotification","kind":"identifier"}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackState/MLNOfflinePackStateInvalid":{"fragments":[{"text":"MLNOfflinePackStateInvalid","kind":"identifier"}],"abstract":[{"type":"text","text":"The pack has been removed using the"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/removePack:withCompletionHandler:"},{"type":"text","text":" method. Sending"},{"type":"text","text":" "},{"type":"text","text":"any message to the pack will raise an exception."}],"title":"MLNOfflinePackStateInvalid","type":"topic","url":"\/documentation\/maplibre\/mlnofflinepackstate\/mlnofflinepackstateinvalid","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateInvalid","role":"symbol","kind":"symbol"}}}