oc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNBackgroundStyleLayer","role":"symbol","fragments":[{"kind":"identifier","text":"MLNBackgroundStyleLayer"}],"url":"\/documentation\/maplibre\/mlnbackgroundstylelayer","kind":"symbol","title":"MLNBackgroundStyleLayer","abstract":[{"type":"text","text":"An "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNBackgroundStyleLayer","type":"reference"},{"type":"text","text":" is a style layer that covers the entire map. Use"},{"type":"text","text":" "},{"type":"text","text":"a background style layer to configure a color or pattern to show below all"},{"type":"text","text":" "},{"type":"text","text":"other map content. If the style’s other layers use the Mapbox Streets source,"},{"type":"text","text":" "},{"type":"text","text":"the background style layer is responsible for drawing land, whereas the oceans"},{"type":"text","text":" "},{"type":"text","text":"and other bodies of water are drawn by "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNBackgroundStyleLayer","type":"reference"},{"type":"text","text":" objects."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNFillExtrusionStyleLayer":{"abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFillExtrusionStyleLayer","isActive":true},{"type":"text","text":" is a style layer that renders one or more 3D"},{"type":"text","text":" "},{"type":"text","text":"extruded polygons on the map."}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFillExtrusionStyleLayer","kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlnfillextrusionstylelayer","fragments":[{"text":"MLNFillExtrusionStyleLayer","kind":"identifier"}],"title":"MLNFillExtrusionStyleLayer"},"doc://org.swift.MyProject/documentation/MapLibre/MLNCircleStyleLayer/circleBlurTransition":{"type":"topic","frag