ct base class for style layers. A style layer"},{"type":"text","text":" "},{"type":"text","text":"manages the layout and appearance of content at a specific z-index in a style."},{"type":"text","text":" "},{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object consists of one or more "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" objects."}],"url":"\/documentation\/maplibre\/mlnstylelayer"},"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyleLayer":{"kind":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","title":"MLNHillshadeStyleLayer","role":"symbol","fragments":[{"text":"MLNHillshadeStyleLayer","kind":"identifier"}],"abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","isActive":true},{"type":"text","text":" is a style layer that renders raster "},{"type":"text","text":"digital elevation"},{"type":"text","text":" "},{"type":"text","text":"model"},{"text":" (DEM) tiles on the map.","type":"text"}],"url":"\/documentation\/maplibre\/mlnhillshadestylelayer"},"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorStyleLayer":{"kind":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","title":"MLNVectorStyleLayer","role":"symbol","fragments":[{"text":"MLNVectorStyleLayer","kind":"identifier"}],"abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer"},{"type":"text","text":" is an abstract superclass for style layers whose content"},{"type":"text","text":" "},{"type":"text","text":"is defined by an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":" or "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":" object."}],"url":"\/documentation\/maplibre\/mlnvectorstylelayer"},"doc://org.swift.MyProject/documentation/MapLibre/MLNBackgroundStyleLayer":{"abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNBackgroundStyleLayer","isActive":true},{"type":"text","text":" is a style layer that covers the entire map. Use"},{"type":"text","text":" "},{"type":"text","text":"a background style layer to configure a color or pattern to show below all"},{"type":"text","text":" "},{"type":"text","text":"other map content. If the style’s other layers use the Mapbox Streets source,"},{"type":"text","text":" "},{"type":"text","text":"the background style layer is responsible for drawing land, whereas the oceans"},{"type":"text","text":" "},{"type":"text","text":"and other bodies of water are drawn by "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNBackgroundStyleLayer","isActive":true},{"type":"text","text":" objects."}],"url":"\/documentation\/maplibre\/mlnbackgroundstylelayer","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNBackgroundStyleLayer","kind":"symbol","fragments":[{"text":"MLNBackgroundStyleLayer","kind":"identifier"}],"title":"MLNBackgroundStyleLayer","role":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/layerWithIdentifier:":{"kind":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/layerWithIdentifier:","title":"layerWithIdentifier:","role":"symbol","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"layerWithIdentifier:"}],"abstract":[{"text":"Returns a style layer with the given identifier in the current style.","type":"text"}],"url":"\/documentation\/maplibre\/mlnstyle\/layerwithidentifier:"}}}