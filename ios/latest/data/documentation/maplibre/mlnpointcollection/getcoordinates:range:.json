{"abstract":[{"type":"text","text":"Retrieves one or more coordinates associated with the shape."}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection"]]},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"- (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"getCoordinates:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:@S@CLLocationCoordinate2D","text":"CLLocationCoordinate2D","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"coords","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"range:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:@S@_NSRange","text":"NSRange","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"range","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"On input, you must provide a C array of structures large enough"},{"type":"text","text":" "},{"type":"text","text":"to hold the desired number of coordinates. On output, this structure"},{"type":"text","text":" "},{"type":"text","text":"contains the requested coordinate data."}],"type":"paragraph"}],"name":"coords"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The range of points you want. The "},{"type":"codeVoice","code":"location"},{"type":"text","text":" field indicates the"},{"type":"text","text":" "},{"type":"text","text":"first point you are requesting, with "},{"type":"codeVoice","code":"0"},{"type":"text","text":" being the first point, "},{"type":"codeVoice","code":"1"},{"type":"text","text":" being"},{"type":"text","text":" "},{"type":"text","text":"the second point, and so on. The "},{"type":"codeVoice","code":"length"},{"type"