 ","type":"text"},{"text":"contains the requested coordinate data.","type":"text"}]}],"name":"coords"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The range of points you want. The "},{"type":"codeVoice","code":"location"},{"type":"text","text":" field indicates the"},{"type":"text","text":" "},{"type":"text","text":"first point you are requesting, with "},{"type":"codeVoice","code":"0"},{"type":"text","text":" being the first point, "},{"type":"codeVoice","code":"1"},{"type":"text","text":" being"},{"type":"text","text":" "},{"type":"text","text":"the second point, and so on. The "},{"type":"codeVoice","code":"length"},{"type":"text","text":" field indicates the number of"},{"type":"text","text":" "},{"type":"text","text":"points you want. The array in "},{"type":"emphasis","inlineContent":[{"type":"codeVoice","code":"coords"}]},{"type":"text","text":" must be large enough to accommodate"},{"type":"text","text":" "},{"type":"text","text":"the number of requested coordinates."}]}],"name":"range"}]}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNPointCollection/getCoordinates:range:":{"navigatorTitle":[{"text":"getCoordinates:range:","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnpointcollection\/getcoordinates:range:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection\/getCoordinates:range:","fragments":[{"text":"- ","kind":"text"},{"text":"getCoordinates:range:","kind":"identifier"}],"kind":"symbol","type":"topic","title":"getCoordinates:range:","abstract":[{"type":"text","text":"Retrieves one or more coordinates associated with the shape."}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNPointCollection":{"url":"\/documentation\/maplibre\/mlnpointcollection","kind":"symbol","abstract":[{"type":"text","text":"An "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection"},{"type":"text","text":" object represents a shape consisting of one or more"},{"type":"text","text":" "},{"type":"text","text":"disconnected vertices, specified as "},{"code":"CLLocationCoordinate2D","type":"codeVoice"},{"type":"text","text":" instances. The"},{"type":"text","text":" "},{"type":"text","text":"points in the collection may be related but are not connected spatially. For"},{"type":"text","text":" "},{"type":"text","text":"example, you could use a point collection to represent all the trees in an"},{"type":"text","text":" "},{"type":"text","text":"orchard."}],"title":"MLNPointCollection","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection","fragments":[{"text":"MLNPointCollection","kind":"identifier"}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"kind":"symbol","title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic","url":"\/documentation\/maplibre"}}}