\/documentation\/MapLibre\/MLNFeature"},{"type":"text","text":"  protocol is used to provide details about geographic features"},{"type":"text","text":" "},{"type":"text","text":"contained in an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":" or "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource"},{"type":"text","text":" object. Each concrete"},{"type":"text","text":" "},{"type":"text","text":"subclass of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":" in turn has a subclass that conforms to this protocol. A"},{"type":"text","text":" "},{"type":"text","text":"feature object associates a shape with an optional identifier and attributes."}],"role":"symbol","title":"MLNFeature","type":"topic","url":"\/documentation\/maplibre\/mlnfeature"},"doc://org.swift.MyProject/documentation/MapLibre/MLNPointFeatureCluster":{"title":"MLNPointFeatureCluster","fragments":[{"kind":"identifier","text":"MLNPointFeatureCluster"}],"role":"symbol","abstract":[{"text":"An ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointFeatureCluster"},{"text":" object associates a point shape (with an optional","type":"text"},{"text":" ","type":"text"},{"text":"identifier and attributes) and represents a point cluster.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointFeatureCluster","url":"\/documentation\/maplibre\/mlnpointfeaturecluster","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","fragments":[{"text":"MLNShape","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"reference","isActive":