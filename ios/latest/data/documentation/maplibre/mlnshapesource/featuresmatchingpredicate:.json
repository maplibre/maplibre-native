{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"]]},"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnshapesource\/featuresmatchingpredicate:"]}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"- ("},{"kind":"typeIdentifier","text":"NSArray<id<MLNFeature>>","preciseIdentifier":"c:Q$objc(cs)NSArray"},{"kind":"text","text":" *) "},{"kind":"identifier","text":"featuresMatchingPredicate:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"NSPredicate","preciseIdentifier":"c:objc(cs)NSPredicate"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"predicate"},{"kind":"text","text":";"}],"languages":["occ"]}],"kind":"declarations"},{"parameters":[{"name":"predicate","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A predicate to filter the returned features. Use "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"include all features in the source."}]}]}],"kind":"parameters"},{"content":[{"level":2,"text":"Return Value","anchor":"return-value","type":"heading"},{"inlineContent":[{"type":"text","text":"An array of objects conforming to the "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature","type":"reference"},{"type":"text","text":" protocol that"},{"type":"text","text":" "},{"type":"text","text":"represent features in the source that match the predicate."}],"type":"paragraph"}],"kind":"content"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each object in the returned array represents a feature for the current style"},{"type":"text","text":" "},{"type":"text","text":"and provides access to attributes specified via the "},{"code":"shape","type":"codeVoice"},{"type":"text","text":" property."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Features come from tiled GeoJSON data that is converted to tiles internally,"},{"type":"text","text":" "},{"type":"text","text":"so feature geometries are clipped at tile boundaries and features"},{"type":"text","text":" "},{"type":"text","text":"may appear duplicated across tiles. For example, suppose this source contains a"},{"type":"text","text":" "},{"type":"text","text":"long polyline representing a road. The resulting array includes those parts of"},{"type":"text","text":" "},{"type":"text","text":"the road that lie within the map tiles that the source has loaded, even if the"},{"type":"text","text":" "},{"type":"text","text":"road extends into other tiles. The portion of the road within each map tile is"},{"type":"text","text":" "},{"type":"text","text":"included individually."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Returned features may not necessarily be visible to the user at the time they"},{"type":"text","text":" "},{"type":"text","text":"are loaded: the style may lack a layer that draws the features in question. To"},{"type":"text","text":" "},{"type":"text","text":"obtain only "},{"inlineContent":[{"type":"text","text":"visible"}],"type":"emphasis"},{"type":"text","text":" features, use the"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/visibleFeaturesAtPoint:inStyleLayersWithIdentifiers:predicate:","isActive":true},{"type":"text","text":" "},{"type":"text","text":"or"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/visibleFeaturesInRect:inStyleLayersWithIdentifiers:predicate:","isActive":true},{"type":"text","text":" "},{"type":"text","text":"method."}]}],"kind":"content"}],"metadata":{"role":"symbol","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"featuresMatchingPredicate:"}],"roleHeading":"Instance Method","externalID":"c:objc(cs)MLNShapeSource(im)featuresMatchingPredicate:","title":"featuresMatchingPredicate:","navigatorTitle":[{"text":"featuresMatchingPredicate:","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"symbolKind":"method"},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/featuresMatchingPredicate:","interfaceLanguage":"occ"},"abstract":[{"text":"Returns an array of map features for this source, filtered by the given","type":"text"},{"text":" ","type":"text"},{"text":"predicate.","type":"text"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"kind":"symbol","url":"\/documentation\/maplibre\/mlnstyle","abstract":[{"text":"The proxy object for the current map style.","type":"text"}],"title":"MLNStyle","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","role":"symbol","type":"topic","fragments":[{"kind":"identifier","text":"MLNStyle"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNFeature":{"title":"MLNFeature","fragments":[{"kind":"identifier","text":"MLNFeature"}],"type":"topic","abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature"},{"type":"text","text":"  protocol is used to provide details about geographic features"},{"type":"text","text":" "},{"type":"text","text":"contained in an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":" or "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource"},{"type":"text","text":" object. Each concrete"},{"type":"text","text":" "},{"type":"text","text":"subclass of "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true,"type":"reference"},{"text":" in turn has a subclass that conforms to this protocol. A","type":"text"},{"text":" ","type":"text"},{"text":"feature object associates a shape with an optional identifier and attributes.","type":"text"}],"url":"\/documentation\/maplibre\/mlnfeature","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"url":"\/documentation\/maplibre","kind":"symbol","role":"collection","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorTileSource":{"abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","isActive":true,"type":"reference"},{"text":" is a map content source that supplies tiled vector data","type":"text"},{"text":" ","type":"text"},{"text":"in ","type":"text"},{"text":"Mapbox Vector Tile","type":"text"},{"text":" format","type":"text"},{"text":" ","type":"text"},{"text":"to be shown on the map. The location of and metadata about the tiles are","type":"text"},{"text":" ","type":"text"},{"text":"defined either by an option dictionary or by an external file that conforms to","type":"text"},{"text":" ","type":"text"},{"text":"the","type":"text"},{"text":" ","type":"text"},{"text":"TileJSON specification","type":"text"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"A vector tile source is added to an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true,"type":"reference"},{"text":" object along with one or more","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","isActive":true,"type":"reference"},{"text":" objects. A vector style layer defines the appearance of","type":"text"},{"text":" ","type":"text"},{"text":"any content supplied by the vector tile source.","type":"text"}],"url":"\/documentation\/maplibre\/mlnvectortilesource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","kind":"symbol","type":"topic","role":"symbol","fragments":[{"kind":"identifier","text":"MLNVectorTileSource"}],"title":"MLNVectorTileSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/visibleFeaturesAtPoint:inStyleLayersWithIdentifiers:predicate:":{"url":"\/documentation\/maplibre\/mlnmapview\/visiblefeaturesatpoint:instylelayerswithidentifiers:predicate:","abstract":[{"type":"text","text":"Returns an array of rendered map features that intersect with a given point,"},{"type":"text","text":" "},{"type":"text","text":"restricted to the given style layers and filtered by the given predicate."}],"role":"symbol","navigatorTitle":[{"text":"visibleFeaturesAtPoint:inStyleLayersWithIdentifiers:predicate:","kind":"identifier"}],"kind":"symbol","title":"visibleFeaturesAtPoint:inStyleLayersWithIdentifiers:predicate:","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/visibleFeaturesAtPoint:inStyleLayersWithIdentifiers:predicate:","fragments":[{"text":"- ","kind":"text"},{"text":"visibleFeaturesAtPoint:inStyleLayersWithIdentifiers:predicate:","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/featuresMatchingPredicate:":{"kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesource\/featuresmatchingpredicate:","role":"symbol","type":"topic","navigatorTitle":[{"text":"featuresMatchingPredicate:","kind":"identifier"}],"abstract":[{"text":"Returns an array of map features for this source, filtered by the given","type":"text"},{"text":" ","type":"text"},{"text":"predicate.","type":"text"}],"title":"featuresMatchingPredicate:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/featuresMatchingPredicate:","fragments":[{"text":"- ","kind":"text"},{"text":"featuresMatchingPredicate:","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/visibleFeaturesInRect:inStyleLayersWithIdentifiers:predicate:":{"url":"\/documentation\/maplibre\/mlnmapview\/visiblefeaturesinrect:instylelayerswithidentifiers:predicate:","navigatorTitle":[{"text":"visibleFeaturesInRect:inStyleLayersWithIdentifiers:predicate:","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/visibleFeaturesInRect:inStyleLayersWithIdentifiers:predicate:","abstract":[{"type":"text","text":"Returns an array of rendered map features that intersect with the given"},{"type":"text","text":" "},{"type":"text","text":"rectangle, restricted to the given style layers and filtered by the given"},{"type":"text","text":" "},{"type":"text","text":"predicate."}],"title":"visibleFeaturesInRect:inStyleLayersWithIdentifiers:predicate:","fragments":[{"text":"- ","kind":"text"},{"text":"visibleFeaturesInRect:inStyleLayersWithIdentifiers:predicate:","kind":"identifier"}],"type":"topic","kind":"symbol","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"title":"MLNShape","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true,"type":"reference"},{"type":"text","text":" is an abstract class that represents a shape or annotation. Shapes"},{"type":"text","text":" "},{"type":"text","text":"constitute the content of a map — not only the overlays atop the map, but also"},{"type":"text","text":" "},{"type":"text","text":"the content that forms the base map."}],"url":"\/documentation\/maplibre\/mlnshape","kind":"symbol","role":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","fragments":[{"kind":"identifier","text":"MLNShape"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","title":"MLNShapeSource","type":"topic","fragments":[{"text":"MLNShapeSource","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnshapesource","kind":"symbol","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true,"type":"reference"},{"type":"text","text":" is a map content source that supplies vector shapes to be"},{"type":"text","text":" "},{"type":"text","text":"shown on the map. The shapes may be instances of "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true,"type":"reference"},{"type":"text","text":" or "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true,"type":"reference"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or they may be defined by local or external"},{"type":"text","text":" "},{"text":"GeoJSON","type":"text"},{"text":" code. A shape source is added to an","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true,"type":"reference"},{"text":" object along with an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true,"type":"reference"},{"text":" object. The vector style","type":"text"},{"text":" ","type":"text"},{"text":"layer defines the appearance of any content supplied by the shape source. You","type":"text"},{"text":" ","type":"text"},{"text":"can update a shape source by setting its ","type":"text"},{"code":"shape","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"URL","type":"codeVoice"},{"text":" property.","type":"text"}],"role":"symbol"}}}