":"text","text":"feature object associates a shape with an optional identifier and attributes."}],"fragments":[{"kind":"identifier","text":"MLNFeature"}],"title":"MLNFeature","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature","role":"symbol","url":"\/documentation\/maplibre\/mlnfeature"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/initWithIdentifier:shape:options:":{"type":"topic","abstract":[{"type":"text","text":"Returns a shape source with an identifier, a shape, and dictionary of options"},{"type":"text","text":" "},{"type":"text","text":"for the source."}],"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"initWithIdentifier:shape:options:"}],"title":"initWithIdentifier:shape:options:","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/initWithIdentifier:shape:options:","role":"symbol","url":"\/documentation\/maplibre\/mlnshapesource\/initwithidentifier:shape:options:"},"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","title":"MapLibre","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol","url":"\/documentation\/maplibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMaximumZoomLevel":{"type":"topic","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the maximum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to create vector tiles. A greater value produces greater detail at high"},{"type":"text","text":" "},{"type":"text","text":"zoom levels. The default value is 18."}],"fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionMaximumZoomLevel"}],"title":"MLNShapeSourceOptionMaximumZoom