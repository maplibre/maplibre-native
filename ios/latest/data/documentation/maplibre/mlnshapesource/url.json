n\/MapLibre\/MLNShape"},{"type":"text","text":" is an abstract class that represents a shape or annotation. Shapes"},{"type":"text","text":" "},{"type":"text","text":"constitute the content of a map — not only the overlays atop the map, but also"},{"type":"text","text":" "},{"type":"text","text":"the content that forms the base map."}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","role":"symbol","title":"MLNShape","fragments":[{"text":"MLNShape","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnshape"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"kind":"symbol","abstract":[{"type":"text","text":"The proxy object for the current map style."}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","role":"symbol","title":"MLNStyle","fragments":[{"text":"MLNStyle","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnstyle"},"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"type":"topic","kind":"symbol","role":"collection","title":"MapLibre","url":"\/documentation\/maplibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/URL":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/URL","kind":"symbol","role":"symbol","type":"topic","fragments":[{"kind":"identifier","text":"URL"}],"abstract":[{"type":"text","text":"The URL to the GeoJSON document that specifies the contents of the source."}],"url":"\/documentation\/maplibre\/mlnshapesource\/url","title":"URL"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"type":"topic","fragments":[{"kind":"identifier","text":"MLNShapeSource"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","role":"symbol","abstract