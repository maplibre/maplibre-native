e and open-source mapping toolkit with full control over data sources and styling."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"type":"topic","role":"symbol","url":"\/documentation\/maplibre\/mlnshape","title":"MLNShape","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","kind":"symbol","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":" is an abstract class that represents a shape or annotation. Shapes"},{"type":"text","text":" "},{"type":"text","text":"constitute the content of a map — not only the overlays atop the map, but also"},{"type":"text","text":" "},{"type":"text","text":"the content that forms the base map."}],"fragments":[{"kind":"identifier","text":"MLNShape"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"fragments":[{"text":"MLNStyle","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnstyle","role":"symbol","abstract":[{"type":"text","text":"The proxy object for the current map style."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","title":"MLNStyle","kind":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/URL":{"abstract":[{"type":"text","text":"The URL to the GeoJSON document that specifies the contents of the source."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/URL","title":"URL","kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlnshapesource\/url","fragments":[{"kind":"identifier","text":"URL"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"fragments":[{"text":"MLNShapeSource","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnshapesource","title":"MLNShapeSource","type":"topic","kind":"symbol","role":"symbol","identifier":"doc:\/\/org.