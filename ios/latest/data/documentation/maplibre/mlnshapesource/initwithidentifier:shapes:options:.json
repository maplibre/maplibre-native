ibre\/MLNVectorTileSource","isActive":true,"type":"reference"},{"text":" object. Each concrete","type":"text"},{"text":" ","type":"text"},{"text":"subclass of ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true,"type":"reference"},{"text":" in turn has a subclass that conforms to this protocol. A","type":"text"},{"text":" ","type":"text"},{"text":"feature object associates a shape with an optional identifier and attributes.","type":"text"}],"url":"\/documentation\/maplibre\/mlnfeature"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/initWithIdentifier:shapes:options:":{"title":"initWithIdentifier:shapes:options:","url":"\/documentation\/maplibre\/mlnshapesource\/initwithidentifier:shapes:options:","kind":"symbol","type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"initWithIdentifier:shapes:options:"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/initWithIdentifier:shapes:options:","abstract":[{"type":"text","text":"Returns a shape source with an identifier, an array of shapes, and a dictionary of"},{"type":"text","text":" "},{"type":"text","text":"options for the source."}],"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"initWithIdentifier:shapes:options:"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMinimumZoomLevel":{"kind":"symbol","role":"symbol","abstract":[{"text":"An ","type":"text"},{"type":"codeVoice","code":"NSNumber"},{"text":" object containing an integer; specifies the minimum zoom level at","type":"text"},{"text":" ","type":"text"},{"text":"which to create vector tiles. The default value is 0.","type":"text"}],"type":"topic","title":"MLNShapeSourceOptionMinimumZoomLevel","fragments":[{"text":"MLNShapeSourceOptionMinimumZoomLevel","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnshapesourceoptionminimumzoomlevel","identifier":"doc:\/\/org.swift.MyProject