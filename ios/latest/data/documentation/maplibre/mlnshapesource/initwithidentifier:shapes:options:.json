 at","type":"text"},{"text":" ","type":"text"},{"text":"which to create vector tiles. A greater value produces greater detail at high","type":"text"},{"text":" ","type":"text"},{"text":"zoom levels. The default value is 18.","type":"text"}],"url":"\/documentation\/maplibre\/mlnshapesourceoptionmaximumzoomlevel","role":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionMaximumZoomLevel"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMaximumZoomLevelForClustering":{"abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the maximum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to cluster points if clustering is enabled. Defaults to one zoom level"},{"type":"text","text":" "},{"type":"text","text":"less than the value of "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevel","isActive":true},{"type":"text","text":" so that, at the"},{"type":"text","text":" "},{"type":"text","text":"maximum zoom level, the shapes are not clustered."}],"title":"MLNShapeSourceOptionMaximumZoomLevelForClustering","type":"topic","role":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionmaximumzoomlevelforclustering","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevelForClustering","kind":"symbol","fragments":[{"text":"MLNShapeSourceOptionMaximumZoomLevelForClustering","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/initWithIdentifier:shapes:options:":{"role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"Returns a shape source with an identifier, an array of shapes, and a dictionary of"},{"type":"text","text":" "},{"type":"text","text":"options for the source."}],"title":"initWithIdentifier:shapes:options:","fragments":[{"text":"- ","kind":"text