\/MLNShapeSourceOptionBuffer"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionSimplificationTolerance"},{"text":". Shapes provided by a shape","type":"text"},{"text":" ","type":"text"},{"text":"source are not clipped or wrapped automatically.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Any "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature","isActive":true},{"type":"text","text":" instance passed into this initializer is treated as an ordinary"},{"type":"text","text":" "},{"type":"text","text":"shape, causing any attributes to be inaccessible to an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","isActive":true},{"type":"text","text":" when"},{"type":"text","text":" "},{"type":"text","text":"evaluating a predicate or configuring certain layout or paint attributes. To"},{"type":"text","text":" "},{"type":"text","text":"preserve the attributes associated with each feature, use the"},{"type":"text","text":" "},{"type":"codeVoice","code":"-initWithIdentifier:features:options:"},{"type":"text","text":" method instead."}],"type":"paragraph"},{"inlineContent":[{"text":"To create a shape from GeoJSON source code, use the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape\/shapeWithData:encoding:error:","isActive":true,"type":"reference"},{"text":" method.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnshapesource\/initwithidentifier:shapes:options:"]}],"kind":"symbol","references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionClusterRadius":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClusterRadius","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the radius of each"},{"type":"text","text":" "},{"type":"text","text":"cluster if clustering is enabled. A value of 512 produces a radius equal to"},{"type":"text","text":" "},{"type":"text","text":"the width of a tile. The default value is 50."}],"kind":"symbol","fragments":[{"text":"MLNShapeSourceOptionClusterRadius","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnshapesourceoptionclusterradius","title":"MLNShapeSourceOptionClusterRadius","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMaximumZoomLevelForClustering":{"abstract":[{"type":"text","text":"An "},{"code":"NSNumber","type":"codeVoice"},{"type":"text","text":" object containing an integer; specifies the maximum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to cluster points if clustering is enabled. Defaults to one zoom level"},{"type":"text","text":" "},{"type":"text","text":"less than the value of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevel"},{"type":"text","text":" so that, at the"},{"type":"text","text":" "},{"type":"text","text":"maximum zoom level, the shapes are not clustered."}],"role":"symbol","kind":"symbol","title":"MLNShapeSourceOptionMaximumZoomLevelForClustering","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevelForClustering","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionMaximumZoomLevelForClustering"}],"url":"\/documentation\/maplibre\/mlnshapesourceoptionmaximumzoomlevelforclustering","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/initWithIdentifier:shapes:options:":{"type":"topic","kind":"symbol","identifier":"doc:\