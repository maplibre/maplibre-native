nternalParam","text":"options"},{"text":";","kind":"text"}]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"A string that uniquely identifies the source."}],"type":"paragraph"}],"name":"identifier"},{"content":[{"inlineContent":[{"type":"text","text":"An array of shapes; each shape is a member of a concrete subclass of MLNShape."}],"type":"paragraph"}],"name":"shapes"},{"content":[{"inlineContent":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSDictionary"},{"type":"text","text":" of options for this source."}],"type":"paragraph"}],"name":"options"}]},{"kind":"content","content":[{"type":"heading","text":"Return Value","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"text":"An initialized shape source.","type":"text"}]}]},{"kind":"mentions","mentions":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON"]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"This class supports the following options: "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClustered","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClusterRadius","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevelForClustering","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMinimumZoomLevel","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMinimumZoomLevel","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionBuffer","isActive":true},{"type":"text","text":", and"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionSimplificationTolerance","isActive":true},{"type":"text","text":". Shapes provided by a shape"},{"type":"text","text":" "},{"type":"text","text":"source are not clipped or wrapped automatically."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Any "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature"},{"type":"text","text":" instance passed into this initializer is treated as an ordinary"},{"type":"text","text":" "},{"type":"text","text":"shape, causing any attributes to be inaccessible to an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer"},{"type":"text","text":" when"},{"type":"text","text":" "},{"type":"text","text":"evaluating a predicate or configuring certain layout or paint attributes. To"},{"type":"text","text":" "},{"type":"text","text":"preserve the attributes associated with each feature, use the"},{"type":"text","text":" "},{"type":"codeVoice","code":"-initWithIdentifier:features:options:"},{"type":"text","text":" method instead."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To create a shape from GeoJSON source code, use the"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape\/shapeWithData:encoding:error:"},{"type":"text","text":" method."}],"type":"paragraph"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"type":"topic","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":" is an abstract class that represents a shape or annotation. Shapes"},{"type":"text","text":" "},{"type":"text","text":"constitute the content of a map — not only the overlays atop the map, but also"},{"type":"text","text":" "},{"type":"text","text":"the content that forms the base map."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","kind":"symbol","title":"MLNShape","url":"\/documentation\/maplibre\/mlnshape","role":"symbol","fragments":[{"text":"MLNShape","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionClusterRadius":{"type":"topic","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the radius of each"},{"type":"text","text":" "},{"type":"text","text":"cluster if clustering is enabled. A value of 512 produces a radius equal to"},{"type":"text","text":" "},{"type":"text","text":"the width of a tile. The default value is 50."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClusterRadius","kind":"symbol","title":"MLNShapeSourceOptionClusterRadius","url":"\/documentation\/maplibre\/mlnshapesourceoptionclusterradius","role":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionClusterRadius"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorStyleLayer":{"type":"topic","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer"},{"type":"text","text":" is an abstract superclass for style layers whose content"},{"type":"text","text":" "},{"type":"text","text":"is defined by an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":" or "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":" object."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","kind":"symbol","title":"MLNVectorStyleLayer","url":"\/documentation\/maplibre\/mlnvectorstylelayer","role":"symbol","fragments":[{"text":"MLNVectorStyleLayer","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMaximumZoomLevelForClustering":{"role":"symbol","title":"MLNShapeSourceOptionMaximumZoomLevelForClustering","type":"topic","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the maximum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to cluster points if clustering is enabled. Defaults to one zoom level"},{"type":"text","text":" "},{"type":"text","text":"less than the value of "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevel","isActive":true},{"type":"text","text":" so that, at the"},{"type":"text","text":" "},{"type":"text","text":"maximum zoom level, the shapes are not clustered."}],"fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionMaximumZoomLevelForClustering"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionmaximumzoomlevelforclustering","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevelForClustering"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMinimumZoomLevel":{"role":"symbol","title":"MLNShapeSourceOptionMinimumZoomLevel","type":"topic","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the minimum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to create vector tiles. The default value is 0."}],"fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionMinimumZoomLevel"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionminimumzoomlevel","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMinimumZoomLevel"},"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorTileSource":{"type":"topic","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource"},{"type":"text","text":" is a map content source that supplies tiled vector data"},{"type":"text","text":" "},{"type":"text","text":"in "},{"type":"text","text":"Mapbox Vector Tile"},{"type":"text","text":" format"},{"type":"text","text":" "},{"type":"text","text":"to be shown on the map. The location of and metadata about the tiles are"},{"type":"text","text":" "},{"type":"text","text":"defined either by an option dictionary or by an external file that conforms to"},{"type":"text","text":" "},{"type":"text","text":"the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A vector tile source is added to an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer"},{"type":"text","text":" objects. A vector style layer defines the appearance of"},{"type":"text","text":" "},{"type":"text","text":"any content supplied by the vector tile source."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","kind":"symbol","title":"MLNVectorTileSource","url":"\/documentation\/maplibre\/mlnvectortilesource","role":"symbol","fragments":[{"text":"MLNVectorTileSource","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNFeature":{"type":"topic","abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature"},{"type":"text","text":"  protocol is used to provide details about geographic features"},{"type":"text","text":" "},{"type":"text","text":"contained in an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":" or "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource"},{"type":"text","text":" object. Each concrete"},{"type":"text","text":" "},{"type":"text","text":"subclass of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":" in turn has a subclass that conforms to this protocol. A"},{"type":"text","text":" "},{"type":"text","text":"feature object associates a shape with an optional identifier and attributes."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature","kind":"symbol","title":"MLNFeature","url":"\/documentation\/maplibre\/mlnfeature","role":"symbol","fragments":[{"text":"MLNFeature","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/initWithIdentifier:shapes:options:":{"role":"symbol","title":"initWithIdentifier:shapes:options:","type":"topic","abstract":[{"type":"text","text":"Returns a shape source with an identifier, an array of shapes, and a dictionary of"},{"type":"text","text":" "},{"type":"text","text":"options for the source."}],"fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:shapes:options:","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesource\/initwithidentifier:shapes:options:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/initWithIdentifier:shapes:options:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionClustered":{"type":"topic","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing a Boolean enabling or disabling clustering."},{"type":"text","text":" "},{"type":"text","text":"If the "},{"type":"codeVoice","code":"shape"},{"type":"text","text":" property contains point shapes, setting this option to"},{"type":"text","text":" "},{"type":"codeVoice","code":"YES"},{"text":" clusters the points by radius into groups. The default value is ","type":"text"},{"type":"codeVoice","code":"NO"},{"type":"text","text":"."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClustered","kind":"symbol","title":"MLNShapeSourceOptionClustered","url":"\/documentation\/maplibre\/mlnshapesourceoptionclustered","role":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionClustered"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape/shapeWithData:encoding:error:":{"role":"symbol","title":"shapeWithData:encoding:error:","type":"topic","abstract":[{"type":"text","text":"Returns an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":" object initialized with the given data interpreted as a"},{"type":"text","text":" "},{"type":"text","text":"string containing a GeoJSON object."}],"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"shapeWithData:encoding:error:"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnshape\/shapewithdata:encoding:error:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape\/shapeWithData:encoding:error:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionSimplificationTolerance":{"role":"symbol","title":"MLNShapeSourceOptionSimplificationTolerance","type":"topic","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing a double; specifies the Douglas-Peucker"},{"type":"text","text":" "},{"type":"text","text":"simplification tolerance. A greater value produces simpler geometries and"},{"type":"text","text":" "},{"type":"text","text":"improves performance. The default value is 0.375."}],"fragments":[{"text":"MLNShapeSourceOptionSimplificationTolerance","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionsimplificationtolerance","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionSimplificationTolerance"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/GeoJSON":{"type":"topic","abstract":[],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","kind":"article","title":"Working with GeoJSON Data","url":"\/documentation\/maplibre-native-for-ios\/geojson","role":"article"},"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","title":"MapLibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol","url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"type":"topic","abstract":[{"type":"text","text":"The proxy object for the current map style."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","kind":"symbol","title":"MLNStyle","url":"\/documentation\/maplibre\/mlnstyle","role":"symbol","fragments":[{"kind":"identifier","text":"MLNStyle"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"type":"topic","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":" is a map content source that supplies vector shapes to be"},{"type":"text","text":" "},{"type":"text","text":"shown on the map. The shapes may be instances of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":" or "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or they may be defined by local or external"},{"type":"text","text":" "},{"type":"text","text":"GeoJSON"},{"type":"text","text":" code. A shape source is added to an"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object along with an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the shape source. You"},{"type":"text","text":" "},{"type":"text","text":"can update a shape source by setting its "},{"type":"codeVoice","code":"shape"},{"type":"text","text":" or "},{"type":"codeVoice","code":"URL"},{"type":"text","text":" property."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","kind":"symbol","title":"MLNShapeSource","url":"\/documentation\/maplibre\/mlnshapesource","role":"symbol","fragments":[{"text":"MLNShapeSource","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMaximumZoomLevel":{"role":"symbol","title":"MLNShapeSourceOptionMaximumZoomLevel","type":"topic","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the maximum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to create vector tiles. A greater value produces greater detail at high"},{"type":"text","text":" "},{"type":"text","text":"zoom levels. The default value is 18."}],"fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionMaximumZoomLevel"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionmaximumzoomlevel","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevel"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionBuffer":{"abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the size of the tile"},{"type":"text","text":" "},{"type":"text","text":"buffer on each side. A value of 0 produces no buffer. A value of 512 produces a"},{"type":"text","text":" "},{"type":"text","text":"buffer as wide as the tile itself. Larger values produce fewer rendering"},{"type":"text","text":" "},{"type":"text","text":"artifacts near tile edges and slower performance. The default value is 128."}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionbuffer","title":"MLNShapeSourceOptionBuffer","fragments":[{"text":"MLNShapeSourceOptionBuffer","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionBuffer","role":"symbol","type":"topic"}}}