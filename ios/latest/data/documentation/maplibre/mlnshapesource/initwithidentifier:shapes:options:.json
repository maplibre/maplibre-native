tionMinimumZoomLevel"},{"type":"text","text":","},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionBuffer"},{"type":"text","text":", and"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionSimplificationTolerance"},{"type":"text","text":". Shapes provided by a shape"},{"type":"text","text":" "},{"type":"text","text":"source are not clipped or wrapped automatically."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature","isActive":true},{"type":"text","text":" instance passed into this initializer is treated as an ordinary"},{"type":"text","text":" "},{"type":"text","text":"shape, causing any attributes to be inaccessible to an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","isActive":true},{"type":"text","text":" when"},{"type":"text","text":" "},{"type":"text","text":"evaluating a predicate or configuring certain layout or paint attributes. To"},{"type":"text","text":" "},{"type":"text","text":"preserve the attributes associated with each feature, use the"},{"type":"text","text":" "},{"type":"codeVoice","code":"-initWithIdentifier:features:options:"},{"type":"text","text":" method instead."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To create a shape from GeoJSON source code, use the"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape\/shapeWithData:encoding:error:"},{"type":"text","text":" method."}]}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/initWithIdentifier:shapes:options:":{"fragments":[{"kind":"text","text":"- "},{"ki