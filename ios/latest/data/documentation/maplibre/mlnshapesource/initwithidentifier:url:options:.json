nce","isActive":true},{"text":" object. The vector style","type":"text"},{"text":" ","type":"text"},{"text":"layer defines the appearance of any content supplied by the shape source. You","type":"text"},{"text":" ","type":"text"},{"text":"can update a shape source by setting its ","type":"text"},{"code":"shape","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"URL","type":"codeVoice"},{"text":" property.","type":"text"}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","kind":"symbol","type":"topic","title":"MLNShapeSource","fragments":[{"text":"MLNShapeSource","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnshapesource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/initWithIdentifier:URL:options:":{"abstract":[{"type":"text","text":"Returns a shape source with an identifier, URL, and dictionary of options for"},{"type":"text","text":" "},{"type":"text","text":"the source."}],"role":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:URL:options:","kind":"identifier"}],"navigatorTitle":[{"text":"initWithIdentifier:URL:options:","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/initWithIdentifier:URL:options:","type":"topic","kind":"symbol","title":"initWithIdentifier:URL:options:","url":"\/documentation\/maplibre\/mlnshapesource\/initwithidentifier:url:options:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionSimplificationTolerance":{"url":"\/documentation\/maplibre\/mlnshapesourceoptionsimplificationtolerance","type":"topic","abstract":[{"text":"An ","type":"text"},{"type":"codeVoice","code":"NSNumber"},{"text":" object containing a double; specifies the Douglas-Peucker","type":"text"},{"text":" ","type":"text"},{"text":"simplification tolerance. A greater value produces simpler geometries and","type":"text"},{"text":" ","type":"text"},{"text":"improves performance. The d