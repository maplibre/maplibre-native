e"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the shape source. You"},{"type":"text","text":" "},{"type":"text","text":"can update a shape source by setting its "},{"code":"shape","type":"codeVoice"},{"type":"text","text":" or "},{"code":"URL","type":"codeVoice"},{"type":"text","text":" property."}],"title":"MLNShapeSource","kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/initWithIdentifier:URL:options:":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/initWithIdentifier:URL:options:","kind":"symbol","role":"symbol","type":"topic","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"initWithIdentifier:URL:options:"}],"abstract":[{"type":"text","text":"Returns a shape source with an identifier, URL, and dictionary of options for"},{"type":"text","text":" "},{"type":"text","text":"the source."}],"url":"\/documentation\/maplibre\/mlnshapesource\/initwithidentifier:url:options:","title":"initWithIdentifier:URL:options:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionSimplificationTolerance":{"type":"topic","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionSimplificationTolerance","kind":"symbol","abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing a double; specifies the Douglas-Peucker","type":"text"},{"text":" ","type":"text"},{"text":"simplification tolerance. A greater value produces simpler geometries and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"improves performance. The default value is 0.375."}],"fragments":[{"text":"MLNShapeSourceOptionSimplificationTolerance","kind":"identifier"}],"title":"MLNShapeSourceOptionSimplificationTolerance","url":"\/documentation\/maplibre\/mlnshapesourceoptionsimplificationtolerance