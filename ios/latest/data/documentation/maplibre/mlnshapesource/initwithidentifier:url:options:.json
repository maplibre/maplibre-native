NStyle","isActive":true,"type":"reference"},{"text":" object along with an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true,"type":"reference"},{"text":" object. The vector style","type":"text"},{"text":" ","type":"text"},{"text":"layer defines the appearance of any content supplied by the shape source. You","type":"text"},{"text":" ","type":"text"},{"text":"can update a shape source by setting its ","type":"text"},{"code":"shape","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"URL","type":"codeVoice"},{"text":" property.","type":"text"}],"title":"MLNShapeSource","role":"symbol","fragments":[{"text":"MLNShapeSource","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionBuffer":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionBuffer","kind":"symbol","title":"MLNShapeSourceOptionBuffer","url":"\/documentation\/maplibre\/mlnshapesourceoptionbuffer","abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing an integer; specifies the size of the tile","type":"text"},{"text":" ","type":"text"},{"text":"buffer on each side. A value of 0 produces no buffer. A value of 512 produces a","type":"text"},{"text":" ","type":"text"},{"text":"buffer as wide as the tile itself. Larger values produce fewer rendering","type":"text"},{"text":" ","type":"text"},{"text":"artifacts near tile edges and slower performance. The default value is 128.","type":"text"}],"type":"topic","role":"symbol","fragments":[{"text":"MLNShapeSourceOptionBuffer","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/initWithIdentifier:URL:options:":{"url":"\/documentation\/maplibre\/mlnshapesource\/initwithidentifier:url:options:","abstract":[{"text":"Returns a shape source with an identifier, URL, and dictionary of options for","type":"text"},{"text":" ","type":"text"},{"text":