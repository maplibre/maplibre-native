:" ","type":"text"},{"text":"less than the value of ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevel","isActive":true},{"text":" so that, at the","type":"text"},{"text":" ","type":"text"},{"text":"maximum zoom level, the shapes are not clustered.","type":"text"}],"type":"topic","title":"MLNShapeSourceOptionMaximumZoomLevelForClustering","url":"\/documentation\/maplibre\/mlnshapesourceoptionmaximumzoomlevelforclustering","role":"symbol","fragments":[{"text":"MLNShapeSourceOptionMaximumZoomLevelForClustering","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionClustered":{"abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing a Boolean enabling or disabling clustering."},{"type":"text","text":" "},{"type":"text","text":"If the "},{"type":"codeVoice","code":"shape"},{"type":"text","text":" property contains point shapes, setting this option to"},{"type":"text","text":" "},{"type":"codeVoice","code":"YES"},{"type":"text","text":" clusters the points by radius into groups. The default value is "},{"type":"codeVoice","code":"NO"},{"type":"text","text":"."}],"fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionClustered"}],"url":"\/documentation\/maplibre\/mlnshapesourceoptionclustered","title":"MLNShapeSourceOptionClustered","role":"symbol","type":"topic","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClustered"}}}