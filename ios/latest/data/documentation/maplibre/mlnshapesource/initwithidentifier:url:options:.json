Project\/documentation\/MapLibre\/MLNShapeSource","kind":"symbol","title":"MLNShapeSource","type":"topic","fragments":[{"kind":"identifier","text":"MLNShapeSource"}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"type":"topic","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":" is an abstract class that represents a shape or annotation. Shapes"},{"type":"text","text":" "},{"type":"text","text":"constitute the content of a map — not only the overlays atop the map, but also"},{"type":"text","text":" "},{"type":"text","text":"the content that forms the base map."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","kind":"symbol","title":"MLNShape","role":"symbol","fragments":[{"kind":"identifier","text":"MLNShape"}],"url":"\/documentation\/maplibre\/mlnshape"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionClusterRadius":{"kind":"symbol","abstract":[{"type":"text","text":"An "},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing an integer; specifies the radius of each","type":"text"},{"text":" ","type":"text"},{"text":"cluster if clustering is enabled. A value of 512 produces a radius equal to","type":"text"},{"text":" ","type":"text"},{"text":"the width of a tile. The default value is 50.","type":"text"}],"title":"MLNShapeSourceOptionClusterRadius","role":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionclusterradius","type":"topic","fragments":[{"text":"MLNShapeSourceOptionClusterRadius","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClusterRadius"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMinimumZoomLevel":{"abstract":[{"type":"text","text":"An "},{"code":"NSNumber","type":"codeVoice"},{"type":"text","text":" object containing an integer; specifies the minimum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to create vector tiles. The default value is 0."}],"url":"\/documentation\/maplibre\/mlnshapesourceoptionminimumzoomlevel","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMinimumZoomLevel","fragments":[{"text":"MLNShapeSourceOptionMinimumZoomLevel","kind":"identifier"}],"type":"topic","role":"symbol","title":"MLNShapeSourceOptionMinimumZoomLevel"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"title":"MLNStyle","url":"\/documentation\/maplibre\/mlnstyle","role":"symbol","type":"topic","fragments":[{"kind":"identifier","text":"MLNStyle"}],"kind":"symbol","abstract":[{"text":"The proxy object for the current map style.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionClustered":{"role":"symbol","fragments":[{"text":"MLNShapeSourceOptionClustered","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClustered","type":"topic","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing a Boolean enabling or disabling clustering."},{"type":"text","text":" "},{"type":"text","text":"If the "},{"type":"codeVoice","code":"shape"},{"type":"text","text":" property contains point shapes, setting this option to"},{"type":"text","text":" "},{"type":"codeVoice","code":"YES"},{"type":"text","text":" clusters the points by radius into groups. The default value is "},{"type":"codeVoice","code":"NO"},{"type":"text","text":"."}],"title":"MLNShapeSourceOptionClustered","kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionclustered"},"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"kind":"symbol","url":"\/documentation\/maplibre","type":"topic","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionBuffer":{"fragments":[{"text":"MLNShapeSourceOptionBuffer","kind":"identifier"}],"title":"MLNShapeSourceOptionBuffer","url":"\/documentation\/maplibre\/mlnshapesourceoptionbuffer","role":"symbol","kind":"symbol","abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing an integer; specifies the size of the tile","type":"text"},{"text":" ","type":"text"},{"text":"buffer on each side. A value of 0 produces no buffer. A value of 512 produces a","type":"text"},{"text":" ","type":"text"},{"text":"buffer as wide as the tile itself. Larger values produce fewer rendering","type":"text"},{"text":" ","type":"text"},{"text":"artifacts near tile edges and slower performance. The default value is 128.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionBuffer","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMaximumZoomLevel":{"role":"symbol","type":"topic","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the maximum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to create vector tiles. A greater value produces greater detail at high"},{"type":"text","text":" "},{"type":"text","text":"zoom levels. The default value is 18."}],"url":"\/documentation\/maplibre\/mlnshapesourceoptionmaximumzoomlevel","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionMaximumZoomLevel"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevel","kind":"symbol","title":"MLNShapeSourceOptionMaximumZoomLevel"},"doc://org.swift.MyProject/docum