cifies the Douglas-Peucker"},{"type":"text","text":" "},{"type":"text","text":"simplification tolerance. A greater value produces simpler geometries and"},{"type":"text","text":" "},{"type":"text","text":"improves performance. The default value is 0.375."}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMaximumZoomLevel":{"title":"MLNShapeSourceOptionMaximumZoomLevel","url":"\/documentation\/maplibre\/mlnshapesourceoptionmaximumzoomlevel","abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing an integer; specifies the maximum zoom level at","type":"text"},{"text":" ","type":"text"},{"text":"which to create vector tiles. A greater value produces greater detail at high","type":"text"},{"text":" ","type":"text"},{"text":"zoom levels. The default value is 18.","type":"text"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevel","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionMaximumZoomLevel"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/initWithIdentifier:URL:options:":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/initWithIdentifier:URL:options:","fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:URL:options:","kind":"identifier"}],"type":"topic","role":"symbol","abstract":[{"type":"text","text":"Returns a shape source with an identifier, URL, and dictionary of options for"},{"type":"text","text":" "},{"type":"text","text":"the source."}],"kind":"symbol","title":"initWithIdentifier:URL:options:","navigatorTitle":[{"text":"initWithIdentifier:URL:options:","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnshapesource\/initwithidentifier:url:options:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"type":"topic","abstract":[{"identifier":"doc:\/\/org.swift.MyProj