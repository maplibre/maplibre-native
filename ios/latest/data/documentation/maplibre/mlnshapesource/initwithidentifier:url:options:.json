SourceOptionMaximumZoomLevel":{"kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionmaximumzoomlevel","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevel","abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing an integer; specifies the maximum zoom level at","type":"text"},{"text":" ","type":"text"},{"text":"which to create vector tiles. A greater value produces greater detail at high","type":"text"},{"text":" ","type":"text"},{"text":"zoom levels. The default value is 18.","type":"text"}],"role":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionMaximumZoomLevel"}],"title":"MLNShapeSourceOptionMaximumZoomLevel"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionClustered":{"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClustered","role":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionclustered","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionClustered"}],"title":"MLNShapeSourceOptionClustered","type":"topic","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing a Boolean enabling or disabling clustering."},{"type":"text","text":" "},{"type":"text","text":"If the "},{"type":"codeVoice","code":"shape"},{"type":"text","text":" property contains point shapes, setting this option to"},{"type":"text","text":" "},{"type":"codeVoice","code":"YES"},{"type":"text","text":" clusters the points by radius into groups. The default value is "},{"type":"codeVoice","code":"NO"},{"type":"text","text":"."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","title":"MLNShape","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"text":" is an abstract class that represents a shape or annotation. Shapes","type":"text"},{"text":" ","type":"text"},{"text":"constitute the content of a map — not only the overlays atop the map, but also","type":"text"},{"text":" ","type":"text"},{"text":"the content that forms the base map.","type":"text"}],"url":"\/documentation\/maplibre\/mlnshape","fragments":[{"text":"MLNShape","kind":"identifier"}],"type":"topic","kind":"symbol","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMinimumZoomLevel":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMinimumZoomLevel","fragments":[{"text":"MLNShapeSourceOptionMinimumZoomLevel","kind":"identifier"}],"role":"symbol","title":"MLNShapeSourceOptionMinimumZoomLevel","kind":"symbol","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the minimum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to create vector tiles. The default value is 0."}],"type":"topic","url":"\/documentation\/maplibre\/mlnshapesourceoptionminimumzoomlevel"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMaximumZoomLevelForClustering":{"kind":"symbol","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the maximum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to cluster points if clustering is enabled. Defaults to one zoom level"},{"type":"text","text":" "},{"type":"text","text":"less than the value of "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevel","type":"reference","isActive":true},{"type":"text","text":" so that, at the"},{"type":"text","text":" "},{"type":"text","text":"maximum zoom level, the shapes are not clustered."}],"ti