,"type":"text"},{"text":"can update a shape source by setting its ","type":"text"},{"type":"codeVoice","code":"shape"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"URL"},{"text":" property.","type":"text"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","fragments":[{"text":"MLNShapeSource","kind":"identifier"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMinimumZoomLevel":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMinimumZoomLevel","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the minimum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to create vector tiles. The default value is 0."}],"title":"MLNShapeSourceOptionMinimumZoomLevel","kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionminimumzoomlevel","type":"topic","fragments":[{"text":"MLNShapeSourceOptionMinimumZoomLevel","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionClusterRadius":{"kind":"symbol","title":"MLNShapeSourceOptionClusterRadius","abstract":[{"text":"An ","type":"text"},{"type":"codeVoice","code":"NSNumber"},{"text":" object containing an integer; specifies the radius of each","type":"text"},{"text":" ","type":"text"},{"text":"cluster if clustering is enabled. A value of 512 produces a radius equal to","type":"text"},{"text":" ","type":"text"},{"text":"the width of a tile. The default value is 50.","type":"text"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClusterRadius","fragments":[{"text":"MLNShapeSourceOptionClusterRadius","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnshapesourceoptionclusterradius","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSo