ar tile edges and slower performance. The default value is 128."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionBuffer","role":"symbol","type":"topic","kind":"symbol","title":"MLNShapeSourceOptionBuffer"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMaximumZoomLevel":{"abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the maximum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to create vector tiles. A greater value produces greater detail at high"},{"type":"text","text":" "},{"type":"text","text":"zoom levels. The default value is 18."}],"title":"MLNShapeSourceOptionMaximumZoomLevel","url":"\/documentation\/maplibre\/mlnshapesourceoptionmaximumzoomlevel","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevel","type":"topic","role":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionMaximumZoomLevel"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionClustered":{"role":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionclustered","kind":"symbol","abstract":[{"type":"text","text":"An "},{"code":"NSNumber","type":"codeVoice"},{"type":"text","text":" object containing a Boolean enabling or disabling clustering."},{"type":"text","text":" "},{"type":"text","text":"If the "},{"code":"shape","type":"codeVoice"},{"type":"text","text":" property contains point shapes, setting this option to"},{"type":"text","text":" "},{"code":"YES","type":"codeVoice"},{"type":"text","text":" clusters the points by radius into groups. The default value is "},{"code":"NO","type":"codeVoice"},{"type":"text","text":"."}],"type":"topic","title":"MLNShapeSourceOptionClustered","fragments":[{"text":"MLNShapeSourceOptionClustered","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/docum