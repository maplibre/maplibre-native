codeVoice","code":"shape"},{"type":"text","text":" property contains point shapes, setting this option to"},{"type":"text","text":" "},{"type":"codeVoice","code":"YES"},{"type":"text","text":" clusters the points by radius into groups. The default value is "},{"type":"codeVoice","code":"NO"},{"type":"text","text":"."}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionSimplificationTolerance":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionSimplificationTolerance","url":"\/documentation\/maplibre\/mlnshapesourceoptionsimplificationtolerance","title":"MLNShapeSourceOptionSimplificationTolerance","role":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionSimplificationTolerance"}],"type":"topic","kind":"symbol","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing a double; specifies the Douglas-Peucker"},{"type":"text","text":" "},{"type":"text","text":"simplification tolerance. A greater value produces simpler geometries and"},{"type":"text","text":" "},{"type":"text","text":"improves performance. The default value is 0.375."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"type":"topic","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","abstract":[{"type":"text","text":"The proxy object for the current map style."}],"url":"\/documentation\/maplibre\/mlnstyle","title":"MLNStyle","role":"symbol","fragments":[{"kind":"identifier","text":"MLNStyle"}]}}}