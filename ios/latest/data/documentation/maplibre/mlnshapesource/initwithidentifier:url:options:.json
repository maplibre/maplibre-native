Voice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the minimum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to create vector tiles. The default value is 0."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMinimumZoomLevel","role":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionBuffer":{"role":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionbuffer","type":"topic","abstract":[{"text":"An ","type":"text"},{"type":"codeVoice","code":"NSNumber"},{"text":" object containing an integer; specifies the size of the tile","type":"text"},{"text":" ","type":"text"},{"text":"buffer on each side. A value of 0 produces no buffer. A value of 512 produces a","type":"text"},{"text":" ","type":"text"},{"text":"buffer as wide as the tile itself. Larger values produce fewer rendering","type":"text"},{"text":" ","type":"text"},{"text":"artifacts near tile edges and slower performance. The default value is 128.","type":"text"}],"kind":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionBuffer"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionBuffer","title":"MLNShapeSourceOptionBuffer"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"title":"MLNShape","kind":"symbol","fragments":[{"kind":"identifier","text":"MLNShape"}],"url":"\/documentation\/maplibre\/mlnshape","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":" is an abstract class that represents a shape or annotation. Shapes"},{"type":"text","text":" "},{"type":"text","text":"constitute the content of a map — not only the overlays atop the map, but also"},{"type":"text","text":" "},{"type":"text","text":"the content that forms the base map."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","role":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionClustered":{"role":"symbol","abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing a Boolean enabling or disabling clustering.","type":"text"},{"text":" ","type":"text"},{"text":"If the ","type":"text"},{"code":"shape","type":"codeVoice"},{"text":" property contains point shapes, setting this option to","type":"text"},{"text":" ","type":"text"},{"code":"YES","type":"codeVoice"},{"text":" clusters the points by radius into groups. The default value is ","type":"text"},{"code":"NO","type":"codeVoice"},{"text":".","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClustered","title":"MLNShapeSourceOptionClustered","url":"\/documentation\/maplibre\/mlnshapesourceoptionclustered","type":"topic","fragments":[{"text":"MLNShapeSourceOptionClustered","kind":"identifier"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionSimplificationTolerance":{"role":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionsimplificationtolerance","type":"topic","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing a double; specifies the Douglas-Peucker"},{"type":"text","text":" "},{"type":"text","text":"simplification tolerance. A greater value produces simpler geometries and"},{"type":"text","text":" "},{"type":"text","text":"improves performance. The default value is 0.375."}],"kind":"symbol","fragments":[{"text":"MLNShapeSourceOptionSimplificationTolerance","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionSimplificationTolerance","title":"MLNShapeSourceOptionSimplificationTolerance"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"role":"symbol","abstract":[{"identifie