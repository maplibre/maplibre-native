nce"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":" is an abstract class that represents a shape or annotation. Shapes"},{"type":"text","text":" "},{"type":"text","text":"constitute the content of a map — not only the overlays atop the map, but also"},{"type":"text","text":" "},{"type":"text","text":"the content that forms the base map."}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","url":"\/documentation\/maplibre\/mlnshape","role":"symbol","fragments":[{"kind":"identifier","text":"MLNShape"}],"title":"MLNShape","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionClustered":{"url":"\/documentation\/maplibre\/mlnshapesourceoptionclustered","type":"topic","title":"MLNShapeSourceOptionClustered","abstract":[{"type":"text","text":"An "},{"code":"NSNumber","type":"codeVoice"},{"type":"text","text":" object containing a Boolean enabling or disabling clustering."},{"type":"text","text":" "},{"type":"text","text":"If the "},{"code":"shape","type":"codeVoice"},{"type":"text","text":" property contains point shapes, setting this option to"},{"type":"text","text":" "},{"code":"YES","type":"codeVoice"},{"type":"text","text":" clusters the points by radius into groups. The default value is "},{"code":"NO","type":"codeVoice"},{"type":"text","text":"."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClustered","role":"symbol","kind":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionClustered"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionClusterRadius":{"abstract":[{"type":"text","text":"An "},{"code":"NSNumber","type":"codeVoice"},{"type":"text","text":" object containing an integer; specifies the radius of each"},{"type":"text","text":" "},{"type":"text","text":"cluster if clustering is enabled. A value of 512 produces a radius equal to"},{"type":"text","text":" "},{"type":"text","text":"the width of a tile. The default value is 50."}],"kind":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClusterRadius","role":"symbol","title":"MLNShapeSourceOptionClusterRadius","fragments":[{"text":"MLNShapeSourceOptionClusterRadius","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnshapesourceoptionclusterradius"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/initWithIdentifier:URL:options:":{"role":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:URL:options:","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/initWithIdentifier:URL:options:","kind":"symbol","title":"initWithIdentifier:URL:options:","navigatorTitle":[{"text":"initWithIdentifier:URL:options:","kind":"identifier"}],"abstract":[{"text":"Returns a shape source with an identifier, URL, and dictionary of options for","type":"text"},{"text":" ","type":"text"},{"text":"the source.","type":"text"}],"url":"\/documentation\/maplibre\/mlnshapesource\/initwithidentifier:url:options:","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMaximumZoomLevelForClustering":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevelForClustering","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionMaximumZoomLevelForClustering"}],"abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the maximum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to cluster points if clustering is enabled. Defaults to one zoom level"},{"type":"text","text":" "},{"type":"text","text":"less than the value of "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevel","isActive":true},{"type":"text","text":" so that, at the"},{"type":"text","text":" "},{"type":"text","text":"maximum zoom level, the shapes are not clustered."}],"url":"\/documentation\/maplibre\/mlnshapesourceoptionmaximumzoomlevelforclustering","kind":"symbol","title":"MLNShapeSourceOptionMaximumZoomLevelForClustering","role":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","fragments":[{"text":"MLNShapeSource","kind":"identifier"}],"abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true},{"type":"text","text":" is a map content source that supplies vector shapes to be"},{"type":"text","text":" "},{"type":"text","text":"shown on the map. The shapes may be instances of "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or they may be defined by local or external"},{"type":"text","text":" "},{"type":"text","text":"GeoJSON"},{"type":"text","text":" code. A shape source is added to an"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object along with an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the shape source. You"},{"type":"text","text":" "},{"type":"text","text":"can update a shape source by setting its "},{"type":"codeVoice","code":"shape"},{"type":"text","text":" or "},{"type":"codeVoice","code":"URL"},{"type":"text","text":" property."}],"kind":"symbol","title":"MLNShapeSource","type":"topic","url":"\/documentation\/maplibre\/mlnshapesource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMinimumZoomLevel":{"kind":"symbol","title":"MLNShapeSourceOptionMinimumZoomLevel","fragments":[{"text":"MLNShapeSourceOptionMinimumZoomLevel","kind":"identifier"}],"type":"topic","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the minimum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to create vector tiles. The default value is 0."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMinimumZoomLevel","role":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionminimumzoomlevel"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMaximumZoomLevel":{"url":"\/documentation\/maplibre\/mlnshapesourceoptionmaximumzoomlevel","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevel","title":"MLNShapeSourceOptionMaximumZoomLevel","kind":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionMaximumZoomLevel"}],"abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the maximum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to create vector tiles. A greater value produces greater detail at high"},{"type":"text","text":" "},{"type":"text","text":"zoom levels. The default value is 18."}],"role":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionBuffer":{"title":"MLNShape