ject\/documentation\/MapLibre\/MLNStyle"},{"text":" object. The vector style","type":"text"},{"text":" ","type":"text"},{"text":"layer defines the appearance of any content supplied by the shape source. You","type":"text"},{"text":" ","type":"text"},{"text":"can update a shape source by setting its ","type":"text"},{"code":"shape","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"URL","type":"codeVoice"},{"text":" property.","type":"text"}],"url":"\/documentation\/maplibre\/mlnshapesource","role":"symbol","type":"topic","kind":"symbol","fragments":[{"text":"MLNShapeSource","kind":"identifier"}],"title":"MLNShapeSource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/initWithIdentifier:URL:options:":{"title":"initWithIdentifier:URL:options:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/initWithIdentifier:URL:options:","role":"symbol","abstract":[{"text":"Returns a shape source with an identifier, URL, and dictionary of options for","type":"text"},{"text":" ","type":"text"},{"text":"the source.","type":"text"}],"type":"topic","kind":"symbol","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"initWithIdentifier:URL:options:"}],"url":"\/documentation\/maplibre\/mlnshapesource\/initwithidentifier:url:options:","navigatorTitle":[{"kind":"identifier","text":"initWithIdentifier:URL:options:"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMaximumZoomLevel":{"url":"\/documentation\/maplibre\/mlnshapesourceoptionmaximumzoomlevel","fragments":[{"text":"MLNShapeSourceOptionMaximumZoomLevel","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevel","abstract":[{"text":"An ","type":"text"},{"type":"codeVoice","code":"NSNumber"},{"text":" object containing an integer; specifies the maximum zoom level at","type":"text"},{"