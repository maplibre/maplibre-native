ater detail at high"},{"type":"text","text":" "},{"type":"text","text":"zoom levels. The default value is 18."}],"fragments":[{"text":"MLNShapeSourceOptionMaximumZoomLevel","kind":"identifier"}],"title":"MLNShapeSourceOptionMaximumZoomLevel","url":"\/documentation\/maplibre\/mlnshapesourceoptionmaximumzoomlevel","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevel","kind":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionClustered":{"role":"symbol","abstract":[{"type":"text","text":"An "},{"code":"NSNumber","type":"codeVoice"},{"type":"text","text":" object containing a Boolean enabling or disabling clustering."},{"type":"text","text":" "},{"type":"text","text":"If the "},{"code":"shape","type":"codeVoice"},{"type":"text","text":" property contains point shapes, setting this option to"},{"type":"text","text":" "},{"code":"YES","type":"codeVoice"},{"type":"text","text":" clusters the points by radius into groups. The default value is "},{"code":"NO","type":"codeVoice"},{"type":"text","text":"."}],"fragments":[{"text":"MLNShapeSourceOptionClustered","kind":"identifier"}],"title":"MLNShapeSourceOptionClustered","url":"\/documentation\/maplibre\/mlnshapesourceoptionclustered","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClustered","kind":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"fragments":[{"text":"MLNShape","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"topic","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":" is an abstract class that represents a shape or annotation. Shapes"},{"type":"text","text":" "},{"type":"text","text":"constitute the content of a map — not only the overlays atop the map, but also"},{"type":"text","text":