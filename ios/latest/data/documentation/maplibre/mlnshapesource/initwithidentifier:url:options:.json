ift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true,"type":"reference"},{"text":" object. The vector style","type":"text"},{"text":" ","type":"text"},{"text":"layer defines the appearance of any content supplied by the shape source. You","type":"text"},{"text":" ","type":"text"},{"text":"can update a shape source by setting its ","type":"text"},{"code":"shape","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"URL","type":"codeVoice"},{"text":" property.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","fragments":[{"kind":"identifier","text":"MLNShapeSource"}],"title":"MLNShapeSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMinimumZoomLevel":{"role":"symbol","title":"MLNShapeSourceOptionMinimumZoomLevel","abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing an integer; specifies the minimum zoom level at","type":"text"},{"text":" ","type":"text"},{"text":"which to create vector tiles. The default value is 0.","type":"text"}],"fragments":[{"text":"MLNShapeSourceOptionMinimumZoomLevel","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMinimumZoomLevel","url":"\/documentation\/maplibre\/mlnshapesourceoptionminimumzoomlevel","type":"topic","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"type":"topic","url":"\/documentation\/maplibre\/mlnstyle","role":"symbol","title":"MLNStyle","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","kind":"symbol","fragments":[{"kind":"identifier","text":"MLNStyle"}],"abstract":[{"text":"The proxy object for the current map style.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionBuffer":{"role":"symbol","title":"MLNShapeSourceOptionBuffer","abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoi