xt"},{"text":" ","type":"text"},{"text":"which to cluster points if clustering is enabled. Defaults to one zoom level","type":"text"},{"text":" ","type":"text"},{"text":"less than the value of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevel","type":"reference"},{"text":" so that, at the","type":"text"},{"text":" ","type":"text"},{"text":"maximum zoom level, the shapes are not clustered.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevelForClustering","type":"topic","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionBuffer":{"title":"MLNShapeSourceOptionBuffer","kind":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionBuffer"}],"abstract":[{"type":"text","text":"An "},{"code":"NSNumber","type":"codeVoice"},{"type":"text","text":" object containing an integer; specifies the size of the tile"},{"type":"text","text":" "},{"type":"text","text":"buffer on each side. A value of 0 produces no buffer. A value of 512 produces a"},{"type":"text","text":" "},{"type":"text","text":"buffer as wide as the tile itself. Larger values produce fewer rendering"},{"type":"text","text":" "},{"type":"text","text":"artifacts near tile edges and slower performance. The default value is 128."}],"type":"topic","url":"\/documentation\/maplibre\/mlnshapesourceoptionbuffer","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionBuffer","role":"symbol"}}}