ject along with an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true,"type":"reference"},{"text":" object. The vector style","type":"text"},{"text":" ","type":"text"},{"text":"layer defines the appearance of any content supplied by the shape source. You","type":"text"},{"text":" ","type":"text"},{"text":"can update a shape source by setting its ","type":"text"},{"type":"codeVoice","code":"shape"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"URL"},{"text":" property.","type":"text"}],"type":"topic","title":"MLNShapeSource","role":"symbol","fragments":[{"text":"MLNShapeSource","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnshapesource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMaximumZoomLevelForClustering":{"fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionMaximumZoomLevelForClustering"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevelForClustering","title":"MLNShapeSourceOptionMaximumZoomLevelForClustering","role":"symbol","kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionmaximumzoomlevelforclustering","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the maximum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to cluster points if clustering is enabled. Defaults to one zoom level"},{"type":"text","text":" "},{"type":"text","text":"less than the value of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevel"},{"type":"text","text":" so that, at the"},{"type":"text","text":" "},{"type":"text","text":"maximum zoom level, the shapes are not clustered."}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionBuffer":{"fragments":[{"text":"MLNShapeSourceOptionBuffer","kind":"identifier"}],"title":"MLNShapeSourceOptionBuffer","url":"\/documentation\/maplibre\/mlnshapesourceoptionbuffer","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionBuffer","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the size of the tile"},{"type":"text","text":" "},{"type":"text","text":"buffer on each side. A value of 0 produces no buffer. A value of 512 produces a"},{"type":"text","text":" "},{"type":"text","text":"buffer as wide as the tile itself. Larger values produce fewer rendering"},{"type":"text","text":" "},{"type":"text","text":"artifacts near tile edges and slower performance. The default value is 128."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","kind":"symbol","type":"topic","title":"MLNShape","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":" is an abstract class that represents a shape or annotation. Shapes"},{"type":"text","text":" "},{"type":"text","text":"constitute the content of a map — not only the overlays atop the map, but also"},{"type":"text","text":" "},{"type":"text","text":"the content that forms the base map."}],"fragments":[{"text":"MLNShape","kind":"identifier"}],"role":"symbol","url":"\/documentation\/maplibre\/mlnshape"}}}