bol","title":"MLNShapeSourceOptionClustered","url":"\/documentation\/maplibre\/mlnshapesourceoptionclustered","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing a Boolean enabling or disabling clustering."},{"type":"text","text":" "},{"type":"text","text":"If the "},{"type":"codeVoice","code":"shape"},{"type":"text","text":" property contains point shapes, setting this option to"},{"type":"text","text":" "},{"type":"codeVoice","code":"YES"},{"type":"text","text":" clusters the points by radius into groups. The default value is "},{"type":"codeVoice","code":"NO"},{"type":"text","text":"."}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClustered","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionClustered"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":" is an abstract class that represents a shape or annotation. Shapes"},{"type":"text","text":" "},{"type":"text","text":"constitute the content of a map — not only the overlays atop the map, but also"},{"type":"text","text":" "},{"type":"text","text":"the content that forms the base map."}],"kind":"symbol","fragments":[{"text":"MLNShape","kind":"identifier"}],"role":"symbol","type":"topic","title":"MLNShape","url":"\/documentation\/maplibre\/mlnshape"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionBuffer":{"role":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnshapesourceoptionbuffer","abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing an integer; specifies the size of the tile","type":"text"},{"text":" ","type":"text"},{"text":"buffer on each side. A value of 0 produces no buffer. A value of 512 produces a","type":"text"},{"text":" ","type":"text"},{"text":"buffer as wide as the tile itself. Larger values produce fewer rendering","type":"text"},{"text":" ","type":"text"},{"text":"artifacts near tile edges and slower performance. The default value is 128.","type":"text"}],"fragments":[{"text":"MLNShapeSourceOptionBuffer","kind":"identifier"}],"title":"MLNShapeSourceOptionBuffer","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionBuffer","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"title":"MLNShapeSource","url":"\/documentation\/maplibre\/mlnshapesource","fragments":[{"text":"MLNShapeSource","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","kind":"symbol","type":"topic","role":"symbol","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"type":"text","text":" is a map content source that supplies vector shapes to be"},{"type":"text","text":" "},{"type":"text","text":"shown on the map. The shapes may be instances of "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":" or "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or they may be defined by local or external"},{"type":"text","text":" "},{"type":"text","text":"GeoJSON"},{"type":"text","text":" code. A shape source is added to an"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"type":"text","text":" object along with an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the shape source. You"},{"type":"text","text":" "},{"type":"text","text":"can update a shape source by setting its "},{"type":"codeVoice","code":"shape"},{"type":"text","text":" or "},{"type":"codeVoice","code":"URL"},{"type":"text","text":" property."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMinimumZoomLevel":{"type":"topic","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionMinimumZoomLevel"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMinimumZoomLevel","title":"MLNShapeSourceOptionMinimumZoomLevel","url":"\/documentation\/maplibre\/mlnshapesourceoptionminimumzoomlevel","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the minimum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to create vector tiles. The default value is 0."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","role":"symbol","fragments":[{"text":"MLNStyle","kind":"identifier"}],"title":"MLNStyle","abstract":[{"text":"The proxy object for the current map style.","type":"text"}],"kind":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnstyle"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionSimplificationTolerance":{"type":"topic","kind":"symbol","fragments":[{"text":"MLNShapeSourceOptionSimplificationTolerance","kind":"identifier"}],"abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing a double; specifies the Douglas-Peucker"},{"type":"text","text":" "},{"type":"text","text":"simplification tolerance. A greater value produces simpler geometries and"},{"type":"text","text":" "},{"type":"text","text":"improves performance. The default value is 0.375."}],"title":"MLNShapeSourceOptionSimplificationTolerance","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionSimplificationTolerance","url":"\/documentation\/maplibre\/mlnshapesourceoptionsimplificationtolerance","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMaximumZoomLevelForClustering":{"title":"MLNShapeSourceOptionMaximumZoomLevelForClustering","url":"\/documentation\/maplibre\/mlnshapesourceoptionmaximumzoomlevelforclustering","abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing an integer; specifies the maximum zoom level at","type":"text"},{"text":" ","type":"text"},{"text":"which to cluster points if clustering is enabled. Defaults to one zoom level","type":"text"},{"text":" ","type":"text"},{"text":"less than the value of ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevel","isActive":true,"type":"reference"},{"text":" so that, at the","type":"text"},{"text":" ","type":"text"},{"text":"maximum zoom level, the shapes are not clustered.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMaximumZoomLevelForClustering","type":"topic","kind":"symbol","role":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionMaximumZoomLevelForClustering"}]}}}