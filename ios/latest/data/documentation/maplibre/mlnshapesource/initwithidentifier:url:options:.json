ract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing an integer; specifies the maximum zoom level at","type":"text"},{"text":" ","type":"text"},{"text":"which to create vector tiles. A greater value produces greater detail at high","type":"text"},{"text":" ","type":"text"},{"text":"zoom levels. The default value is 18.","type":"text"}],"role":"symbol","kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionmaximumzoomlevel","title":"MLNShapeSourceOptionMaximumZoomLevel","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true,"type":"reference"},{"type":"text","text":" is a map content source that supplies vector shapes to be"},{"type":"text","text":" "},{"type":"text","text":"shown on the map. The shapes may be instances of "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true,"type":"reference"},{"type":"text","text":" or "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true,"type":"reference"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or they may be defined by local or external"},{"type":"text","text":" "},{"type":"text","text":"GeoJSON"},{"type":"text","text":" code. A shape source is added to an"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true,"type":"reference"},{"type":"text","text":" object along with an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true,"type":"reference"},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the shape source. You"},{"type":"text","text":" "},{"type":"text","text":"can update a shape source by setting its "},{"code":"shape","type":"codeVoice"},{"type":"text","text":" or "},{"code":"URL","type":"codeVoice"},{"type":"text","text":" property."}],"title":"MLNShapeSource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","role":"symbol","url":"\/documentation\/maplibre\/mlnshapesource","type":"topic","fragments":[{"kind":"identifier","text":"MLNShapeSource"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionBuffer":{"title":"MLNShapeSourceOptionBuffer","abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing an integer; specifies the size of the tile","type":"text"},{"text":" ","type":"text"},{"text":"buffer on each side. A value of 0 produces no buffer. A value of 512 produces a","type":"text"},{"text":" ","type":"text"},{"text":"buffer as wide as the tile itself. Larger values produce fewer rendering","type":"text"},{"text":" ","type":"text"},{"text":"artifacts near tile edges and slower performance. The default value is 128.","type":"text"}],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"MLNShapeSourceOptionBuffer","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnshapesourceoptionbuffer","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionBuffer"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMaximumZoomLevelForClustering":{"url":"\/documentation\/maplibre\/mlnshapesourceoptionmaximumzoomlevelforclustering","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the maximum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to cluster points if clustering is enabled. Defaults to one zoom level"},{"type":"text","text":" "},{"type":"text","text":"less than the value of "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProje