h an optional"},{"type":"text","text":" "},{"type":"text","text":"identifier and attributes."}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointFeature","fragments":[{"kind":"identifier","text":"MLNPointFeature"}],"url":"\/documentation\/maplibre\/mlnpointfeature","type":"topic","kind":"symbol","title":"MLNPointFeature"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMinimumZoomLevel":{"url":"\/documentation\/maplibre\/mlnshapesourceoptionminimumzoomlevel","kind":"symbol","title":"MLNShapeSourceOptionMinimumZoomLevel","role":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionMinimumZoomLevel"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMinimumZoomLevel","type":"topic","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the minimum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to create vector tiles. The default value is 0."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/initWithIdentifier:features:options:":{"role":"symbol","kind":"symbol","title":"initWithIdentifier:features:options:","type":"topic","abstract":[{"type":"text","text":"Returns a shape source with an identifier, an array of features, and a dictionary"},{"type":"text","text":" "},{"type":"text","text":"of options for the source."}],"navigatorTitle":[{"kind":"identifier","text":"initWithIdentifier:features:options:"}],"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"initWithIdentifier:features:options:"}],"url":"\/documentation\/maplibre\/mlnshapesource\/initwithidentifier:features:options:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/initWithIdentifier:features:options:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionBuffer":{"type":"topic","kind":"sym