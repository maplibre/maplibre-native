.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionBuffer","type":"reference"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionSimplificationTolerance","type":"reference"},{"text":". Shapes provided by a shape","type":"text"},{"text":" ","type":"text"},{"text":"source are not clipped or wrapped automatically.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unlike "},{"code":"-initWithIdentifier:shapes:options:","type":"codeVoice"},{"type":"text","text":", this method accepts "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"instances, such as "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointFeature","type":"reference","isActive":true},{"type":"text","text":" objects, whose attributes you can use when"},{"type":"text","text":" "},{"type":"text","text":"applying a predicate to "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","type":"reference","isActive":true},{"type":"text","text":" or configuring a style layer’s"},{"type":"text","text":" "},{"type":"text","text":"appearance."}]},{"type":"paragraph","inlineContent":[{"text":"To create a shape from GeoJSON source code, use the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape\/shapeWithData:encoding:error:","isActive":true,"type":"reference"},{"text":" method.","type":"text"}]}]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/initWithIdentifier:features:options:","interfaceLanguage":"occ"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMaximumZoomLevelForClustering":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapL