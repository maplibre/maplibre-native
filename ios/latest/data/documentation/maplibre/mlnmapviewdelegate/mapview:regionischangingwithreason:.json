ifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCameraChangeReason","abstract":[{"text":"Bitmask values that describe why a camera move occurred.","type":"text"}],"type":"topic","fragments":[{"text":"MLNCameraChangeReason","kind":"identifier"}],"kind":"symbol","title":"MLNCameraChangeReason","role":"symbol","url":"\/documentation\/maplibre\/mlncamerachangereason"}}}