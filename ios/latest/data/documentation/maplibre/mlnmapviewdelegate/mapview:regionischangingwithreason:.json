nt":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method is called as the currently displayed map camera changes as part of"},{"type":"text","text":" "},{"type":"text","text":"an animation, whether due to a user gesture or due to a call to a method such"},{"type":"text","text":" "},{"type":"text","text":"as "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setCamera:animated:"},{"type":"text","text":". This method can be called before"},{"type":"text","text":" "},{"type":"codeVoice","code":"-mapViewDidFinishLoadingMap:"},{"type":"text","text":" is called."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"During the animation, this method may be called many times to report updates to"},{"type":"text","text":" "},{"type":"text","text":"the viewpoint. Therefore, your implementation of this method should be as lightweight"},{"type":"text","text":" "},{"type":"text","text":"as possible to avoid affecting performance."}]},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If this method is implemented "},{"type":"codeVoice","code":"-mapViewRegionIsChanging:"},{"type":"text","text":" will not be called."}]}]}]}],"metadata":{"title":"mapView:regionIsChangingWithReason:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"mapView:regionIsChangingWithReason:"}],"remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapViewDelegate.h#L152","fileName":"MLNMapViewDelegate.h"},"externalID":"c:objc(pl)MLNMapViewDelegate(im)mapView:regionIsChangingWithReason:","roleHeading":"Instance Method","role":"symbol","symbolKind":"method","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"kind":"identifier","text":"mapView:regionIsChangingWithReason:"}]},"references":{"doc://org.swift.My