":2},{"type":"paragraph","inlineContent":[{"text":"This method is called as the currently displayed map camera changes as part of","type":"text"},{"text":" ","type":"text"},{"text":"an animation, whether due to a user gesture or due to a call to a method such","type":"text"},{"text":" ","type":"text"},{"text":"as ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setCamera:animated:","type":"reference","isActive":true},{"text":". This method can be called before","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"-mapViewDidFinishLoadingMap:"},{"text":" is called.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"During the animation, this method may be called many times to report updates to","type":"text"},{"text":" ","type":"text"},{"text":"the viewpoint. Therefore, your implementation of this method should be as lightweight","type":"text"},{"text":" ","type":"text"},{"text":"as possible to avoid affecting performance.","type":"text"}]},{"type":"aside","name":"Note","content":[{"inlineContent":[{"text":"If this method is implemented ","type":"text"},{"code":"-mapViewRegionIsChanging:","type":"codeVoice"},{"text":" will not be called.","type":"text"}],"type":"paragraph"}],"style":"note"}],"kind":"content"}],"kind":"symbol","metadata":{"roleHeading":"Instance Method","role":"symbol","navigatorTitle":[{"text":"- ","kind":"text"},{"text":"mapView:regionIsChangingWithReason:","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"fragments":[{"text":"- ","kind":"text"},{"text":"mapView:regionIsChangingWithReason:","kind":"identifier"}],"remoteSource":{"fileName":"MLNMapViewDelegate.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapViewDelegate.h#L152"},"externalID":"c:objc(pl)MLNMapViewDelegate(im)mapView:regionIsChangingWithReason:","title":"mapView:regionIsChangingWithReason:","symbolKind":"method"},"sections":[],"schemaVersion":{"major":0,"p