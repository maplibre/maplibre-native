angeReason"},{"text":") ","kind":"text"},{"text":"reason","kind":"internalParam"},{"text":";","kind":"text"}],"platforms":["iOS","iPadOS","Mac Catalyst"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The map view whose viewpoint is changing."}]}],"name":"mapView"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The reason for the camera change."}]}],"name":"reason"}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"This method is called as the currently displayed map camera changes as part of"},{"type":"text","text":" "},{"type":"text","text":"an animation, whether due to a user gesture or due to a call to a method such"},{"type":"text","text":" "},{"type":"text","text":"as "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setCamera:animated:","isActive":true},{"type":"text","text":". This method can be called before"},{"type":"text","text":" "},{"type":"codeVoice","code":"-mapViewDidFinishLoadingMap:"},{"type":"text","text":" is called."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"During the animation, this method may be called many times to report updates to"},{"type":"text","text":" "},{"type":"text","text":"the viewpoint. Therefore, your implementation of this method should be as lightweight"},{"type":"text","text":" "},{"type":"text","text":"as possible to avoid affecting performance."}],"type":"paragraph"},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If this method is implemented "},{"code":"-mapViewRegionIsChanging:","type":"codeVoice"},{"type":"text","text":" will not be called."}]}],"name":"Note"}]}],"abstract":[{"type":"text","text":":nodoc:"},{"type":"text","text":" "},{"type":"text","text":"Tells the delegate that the viewpoint depicted by the map vi