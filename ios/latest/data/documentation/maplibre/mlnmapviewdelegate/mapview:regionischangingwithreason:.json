Project/documentation/MapLibre":{"type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","kind":"symbol","role":"collection","url":"\/documentation\/maplibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/setCamera:animated:":{"kind":"symbol","title":"setCamera:animated:","abstract":[{"type":"text","text":"Moves the viewpoint to a different location with respect to the map with an"},{"type":"text","text":" "},{"type":"text","text":"optional transition animation. For animated changes, wait until the map view has"},{"type":"text","text":" "},{"type":"text","text":"finished loading before calling this method."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setCamera:animated:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"setCamera:animated:"}],"type":"topic","role":"symbol","url":"\/documentation\/maplibre\/mlnmapview\/setcamera:animated:","navigatorTitle":[{"kind":"identifier","text":"setCamera:animated:"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNCameraChangeReason":{"type":"topic","fragments":[{"kind":"identifier","text":"MLNCameraChangeReason"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCameraChangeReason","abstract":[{"type":"text","text":"Bitmask values that describe why a camera move occurred."}],"title":"MLNCameraChangeReason","url":"\/documentation\/maplibre\/mlncamerachangereason","kind":"symbol","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate/mapView:regionIsChangingWithReason:":{"title":"mapView:regionIsChangingWithReason:","type":"topic","kind":"symbol","role":"symbol","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"mapView:regionIsChangingWithReason:"}],"url":"\/documentation\/maplibre\/mlnmapviewdelegat