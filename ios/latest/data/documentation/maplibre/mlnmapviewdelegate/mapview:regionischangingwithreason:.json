ed loading before calling this method."}],"type":"topic","role":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"setCamera:animated:","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setCamera:animated:","navigatorTitle":[{"text":"setCamera:animated:","kind":"identifier"}],"kind":"symbol","title":"setCamera:animated:"}}}