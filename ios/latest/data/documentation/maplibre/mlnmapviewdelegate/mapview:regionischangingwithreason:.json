,{"text":" ","type":"text"},{"text":"an animation, whether due to a user gesture or due to a call to a method such","type":"text"},{"text":" ","type":"text"},{"text":"as ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setCamera:animated:"},{"text":". This method can be called before","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"-mapViewDidFinishLoadingMap:"},{"text":" is called.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"During the animation, this method may be called many times to report updates to","type":"text"},{"text":" ","type":"text"},{"text":"the viewpoint. Therefore, your implementation of this method should be as lightweight","type":"text"},{"text":" ","type":"text"},{"text":"as possible to avoid affecting performance.","type":"text"}],"type":"paragraph"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If this method is implemented "},{"code":"-mapViewRegionIsChanging:","type":"codeVoice"},{"type":"text","text":" will not be called."}]}],"type":"aside"}]}],"variants":[{"paths":["\/documentation\/maplibre\/mlnmapviewdelegate\/mapview:regionischangingwithreason:"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"symbolKind":"method","navigatorTitle":[{"kind":"identifier","text":"mapView:regionIsChangingWithReason:"}],"roleHeading":"Instance Method","role":"symbol","remoteSource":{"fileName":"MLNMapViewDelegate.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapViewDelegate.h#L152"},"modules":[{"name":"MapLibre"}],"title":"mapView:regionIsChangingWithReason:","externalID":"c:objc(pl)MLNMapViewDelegate(im)mapView:regionIsChangingWithReason:","fragments":[{"text":"- ","kind":"text"},{"text":"mapView:regionIsChangingWithReason:","kind":"identifier"}]},"references":{"doc://org.swift.My