Project/documentation/MapLibre/MLNCameraChangeReason":{"title":"MLNCameraChangeReason","fragments":[{"kind":"identifier","text":"MLNCameraChangeReason"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCameraChangeReason","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Bitmask values that describe why a camera move occurred."}],"url":"\/documentation\/maplibre\/mlncamerachangereason","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/setCamera:animated:":{"role":"symbol","title":"setCamera:animated:","abstract":[{"type":"text","text":"Moves the viewpoint to a different location with respect to the map with an"},{"type":"text","text":" "},{"type":"text","text":"optional transition animation. For animated changes, wait until the map view has"},{"type":"text","text":" "},{"type":"text","text":"finished loading before calling this method."}],"url":"\/documentation\/maplibre\/mlnmapview\/setcamera:animated:","kind":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"setCamera:animated:","kind":"identifier"}],"type":"topic","navigatorTitle":[{"text":"setCamera:animated:","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setCamera:animated:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","url":"\/documentation\/maplibre\/mlnmapview","fragments":[{"kind":"identifier","text":"MLNMapView"}],"role":"symbol","title":"MLNMapView","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate/mapView:regionIsChangingWithReason:":{"navigatorTitle":[{"text":"mapView:regionIsChangingWithReason:","kind":"identifier"}],"identifier":"doc:\