ussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method is called as the currently displayed map camera changes as part of"},{"type":"text","text":" "},{"type":"text","text":"an animation, whether due to a user gesture or due to a call to a method such"},{"type":"text","text":" "},{"type":"text","text":"as "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setCamera:animated:","type":"reference","isActive":true},{"type":"text","text":". This method can be called before"},{"type":"text","text":" "},{"code":"-mapViewDidFinishLoadingMap:","type":"codeVoice"},{"type":"text","text":" is called."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"During the animation, this method may be called many times to report updates to"},{"type":"text","text":" "},{"type":"text","text":"the viewpoint. Therefore, your implementation of this method should be as lightweight"},{"type":"text","text":" "},{"type":"text","text":"as possible to avoid affecting performance."}]},{"type":"aside","name":"Note","style":"note","content":[{"inlineContent":[{"type":"text","text":"If this method is implemented "},{"code":"-mapViewRegionIsChanging:","type":"codeVoice"},{"type":"text","text":" will not be called."}],"type":"paragraph"}]}],"kind":"content"}],"kind":"symbol","sections":[],"metadata":{"roleHeading":"Instance Method","title":"mapView:regionIsChangingWithReason:","externalID":"c:objc(pl)MLNMapViewDelegate(im)mapView:regionIsChangingWithReason:","symbolKind":"method","modules":[{"name":"MapLibre"}],"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"mapView:regionIsChangingWithReason:"}],"remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapViewDelegate.h#L152","fileName":"MLNMapViewDelegate.h"},"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"mapView:regionIsChangingWithReason:"}]},"references":{"doc://org.swift.My