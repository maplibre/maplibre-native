"text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"This method is called as the currently displayed map camera changes as part of"},{"type":"text","text":" "},{"type":"text","text":"an animation, whether due to a user gesture or due to a call to a method such"},{"type":"text","text":" "},{"type":"text","text":"as "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setCamera:animated:","type":"reference","isActive":true},{"type":"text","text":". This method can be called before"},{"type":"text","text":" "},{"code":"-mapViewDidFinishLoadingMap:","type":"codeVoice"},{"type":"text","text":" is called."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"During the animation, this method may be called many times to report updates to"},{"type":"text","text":" "},{"type":"text","text":"the viewpoint. Therefore, your implementation of this method should be as lightweight"},{"type":"text","text":" "},{"type":"text","text":"as possible to avoid affecting performance."}],"type":"paragraph"},{"style":"note","name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"If this method is implemented ","type":"text"},{"code":"-mapViewRegionIsChanging:","type":"codeVoice"},{"text":" will not be called.","type":"text"}]}]}]}],"variants":[{"paths":["\/documentation\/maplibre\/mlnmapviewdelegate\/mapview:regionischangingwithreason:"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:regionIsChangingWithReason:","interfaceLanguage":"occ"},"abstract":[{"type":"text","text":":nodoc:"},{"type":"text","text":" "},{"type":"text","text":"Tells the delegate that the viewpoint depicted by the map vi