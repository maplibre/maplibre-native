"type":"text"},{"text":"view dedicated to display the callout. The returned view will be configured by","type":"text"},{"text":" ","type":"text"},{"text":"the map view.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If this method is absent from the delegate, or if it returns "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", a standard,"},{"type":"text","text":" "},{"type":"text","text":"two-line, bubble-like callout view is displayed by default."}],"type":"paragraph"},{"level":4,"anchor":"Related-examples","text":"Related examples","type":"heading"},{"inlineContent":[{"text":"TODO: Display custom views as callouts, learn how to customize an","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","isActive":true,"type":"reference"},{"text":" object’s ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"}]}],"sections":[],"abstract":[{"type":"text","text":"Returns a callout view to display for the given annotation."}],"kind":"symbol","metadata":{"externalID":"c:objc(pl)MLNMapViewDelegate(im)mapView:calloutViewForAnnotation:","navigatorTitle":[{"kind":"identifier","text":"mapView:calloutViewForAnnotation:"}],"role":"symbol","roleHeading":"Instance Method","modules":[{"name":"MapLibre"}],"fragments":[{"text":"- ","kind":"text"},{"text":"mapView:calloutViewForAnnotation:","kind":"identifier"}],"title":"mapView:calloutViewForAnnotation:","symbolKind":"method","remoteSource":{"fileName":"MLNMapViewDelegate.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapViewDelegate.h#L890"}},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:calloutViewForAnnotation:"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapviewdelegate\/mapview:calloutviewforannotation:"]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"fragments":[{"text":"MLNMapView","kind":"identifier"}],"title":"MLNMapView","url":"\/documentation\/maplibre\/mlnmapview","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","abstract":[{"text":"An interactive, customizable map view with an interface similar to the one","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"provided by Apple’s MapKit."}],"role":"symbol","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotation":{"abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","isActive":true,"type":"reference"},{"text":" protocol is used to provide annotation-related information","type":"text"},{"text":" ","type":"text"},{"text":"to a map view. To use this protocol, you adopt it in any custom objects that","type":"text"},{"text":" ","type":"text"},{"text":"store or represent annotation data. Each object then serves as the source of","type":"text"},{"text":" ","type":"text"},{"text":"information about a single map annotation and provides critical information,","type":"text"},{"text":" ","type":"text"},{"text":"such as the annotation’s location on the map. Annotation objects do not provide","type":"text"},{"text":" ","type":"text"},{"text":"the visual representation of the annotation but typically coordinate (in","type":"text"},{"text":" ","type":"text"},{"text":"conjunction with the map view’s delegate) the creation of an appropriate","type":"text"},{"text":" ","type":"text"},{"text":"objects to handle the display.","type":"text"}],"kind":"symbol","role":"symbol","type":"topic","title":"MLNAnnotation","fragments":[{"text":"MLNAnnotation","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnannotation","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate":{"fragments":[{"kind":"identifier","text":"MLNMapViewDelegate"}],"type":"topic","kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate","isActive":true},{"type":"text","text":" protocol defines a set of optional methods that you"},{"type":"text","text":" "},{"type":"text","text":"can use to receive map-related update messages. Because many map operations"},{"type":"text","text":" "},{"type":"text","text":"require the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","isActive":true},{"type":"text","text":" class to load data asynchronously, the map view calls"},{"type":"text","text":" "},{"type":"text","text":"these methods to notify your application when specific operations complete. The"},{"type":"text","text":" "},{"type":"text","text":"map view also uses these methods to request information about annotations"},{"type":"text","text":" "},{"type":"text","text":"displayed on the map, such as the styles and interaction modes to apply to"},{"type":"text","text":" "},{"type":"text","text":"individual annotations."}],"title":"MLNMapViewDelegate","url":"\/documentation\/maplibre\/mlnmapviewdelegate","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate"},"doc://org.swift.MyProject/documentation/MapLibre/MLNCalloutView":{"abstract":[{"type":"text","text":"A protocol for a "},{"code":"UIView","type":"codeVoice"},{"type":"text","text":" subclass that displays information about a selected"},{"type":"text","text":" "},{"type":"text","text":"annotation near that annotation."}],"url":"\/documentation\/maplibre\/mlncalloutview","type":"topic","role":"symbol","title":"MLNCalloutView","fragments":[{"text":"MLNCalloutView","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCalloutView","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","url":"\/documentation\/maplibre","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate/mapView:calloutViewForAnnotation:":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:calloutViewForAnnotation:","title":"mapView:calloutViewForAnnotation:","role":"symbol","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Returns a callout view to display for the given annotation."}],"navigatorTitle":[{"kind":"identifier","text":"mapView:calloutViewForAnnotation:"}],"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"mapView:calloutViewForAnnotation:"}],"url":"\/documentation\/maplibre\/mlnmapviewdelegate\/mapview:calloutviewforannotation:"}}}