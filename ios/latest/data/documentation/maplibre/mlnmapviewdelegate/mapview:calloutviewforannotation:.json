yst"],"languages":["occ"]}]},{"parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The map view that requested the callout view."}],"type":"paragraph"}],"name":"mapView"},{"content":[{"inlineContent":[{"type":"text","text":"The object representing the annotation."}],"type":"paragraph"}],"name":"annotation"}],"kind":"parameters"},{"content":[{"anchor":"return-value","type":"heading","text":"Return Value","level":2},{"type":"paragraph","inlineContent":[{"text":"A view conforming to the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCalloutView","type":"reference"},{"text":" protocol, or ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" to use the","type":"text"},{"text":" ","type":"text"},{"text":"default callout view.","type":"text"}]}],"kind":"content"},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"If this method is present in the delegate, it must return a new instance of a","type":"text"},{"text":" ","type":"text"},{"text":"view dedicated to display the callout. The returned view will be configured by","type":"text"},{"text":" ","type":"text"},{"text":"the map view.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If this method is absent from the delegate, or if it returns ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", a standard,","type":"text"},{"text":" ","type":"text"},{"text":"two-line, bubble-like callout view is displayed by default.","type":"text"}]},{"anchor":"Related-examples","type":"heading","text":"Related examples","level":4},{"type":"paragraph","inlineContent":[{"text":"TODO: Display custom views as callouts, learn how to customize an","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","type":"reference"},{"text":" object’s ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","type":"reference"},{"text":".","type":"text"}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:calloutViewForAnnotation:","interfaceLanguage":"occ"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate":{"role":"symbol","type":"topic","fragments":[{"kind":"identifier","text":"MLNMapViewDelegate"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate","kind":"symbol","title":"MLNMapViewDelegate","abstract":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate"},{"type":"text","text":" protocol defines a set of optional methods that you"},{"type":"text","text":" "},{"type":"text","text":"can use to receive map-related update messages. Because many map operations"},{"type":"text","text":" "},{"type":"text","text":"require the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"},{"type":"text","text":" class to load data asynchronously, the map view calls"},{"type":"text","text":" "},{"type":"text","text":"these methods to notify your application when specific operations complete. The"},{"type":"text","text":" "},{"type":"text","text":"map view also uses these methods to request information about annotations"},{"type":"text","text":" "},{"type":"text","text":"displayed on the map, such as the styles and interaction modes to apply to"},{"type":"text","text":" "},{"type":"text","text":"individual annotations."}],"url":"\/documentation\/maplibre\/mlnmapviewdelegate"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate/mapView:calloutViewForAnnotation:":{"kind":"symbol","abstract":[{"text":"Returns a callout view to display for the given annotation.","type":"text"}],"identifier":"do