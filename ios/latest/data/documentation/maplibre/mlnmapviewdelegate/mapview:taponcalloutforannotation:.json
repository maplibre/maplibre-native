],"type":"paragraph"}]},{"name":"annotation","content":[{"inlineContent":[{"type":"text","text":"The annotation whose callout was tapped."}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"This method is called when the user taps on the body of the callout view, as","type":"text"},{"text":" ","type":"text"},{"text":"opposed to the callout’s left or right accessory view. If the annotation has a","type":"text"},{"text":" ","type":"text"},{"text":"custom callout view via the ","type":"text"},{"type":"codeVoice","code":"-mapView:calloutViewForAnnotation:"},{"text":" method, this","type":"text"},{"text":" ","type":"text"},{"text":"method is only called whenever the callout view calls its delegate’s","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCalloutViewDelegate\/calloutViewTapped:"},{"text":" method.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If this method is present on the delegate, the standard callout view’s body","type":"text"},{"text":" ","type":"text"},{"text":"momentarily highlights when the user taps it, whether or not this method does","type":"text"},{"text":" ","type":"text"},{"text":"anything in response to the tap.","type":"text"}],"type":"paragraph"},{"level":4,"anchor":"Related-examples","text":"Related examples","type":"heading"},{"inlineContent":[{"text":"TODO: Display custom views as callouts, learn how to trigger an","type":"text"},{"text":" ","type":"text"},{"text":"action when an ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation"},{"text":"s ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation"},{"text":" is tapped.","type":"text"}],"type":"paragraph"}],"kin