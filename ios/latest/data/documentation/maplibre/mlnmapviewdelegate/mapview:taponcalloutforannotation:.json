outViewDelegate\/calloutViewTapped:"},{"text":" method.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If this method is present on the delegate, the standard callout view’s body","type":"text"},{"text":" ","type":"text"},{"text":"momentarily highlights when the user taps it, whether or not this method does","type":"text"},{"text":" ","type":"text"},{"text":"anything in response to the tap.","type":"text"}]},{"level":4,"text":"Related examples","type":"heading","anchor":"Related-examples"},{"type":"paragraph","inlineContent":[{"type":"text","text":"TODO: Display custom views as callouts, learn how to trigger an"},{"type":"text","text":" "},{"type":"text","text":"action when an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","isActive":true},{"type":"text","text":"s "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","isActive":true},{"type":"text","text":" is tapped."}]}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate"]]},"sections":[],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:tapOnCalloutForAnnotation:","interfaceLanguage":"occ"},"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"paths":["\/documentation\/maplibre\/mlnmapviewdelegate\/mapview:taponcalloutforannotation:"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"text":"Tells the delegate that the user tapped on an annotation’s callout view.","type":"text"}],"metadata":{"title":"mapView:tapOnCalloutForAnnotation:","modules":[{"name":"MapLibre"}],"role":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"mapView:tapOnCalloutForAnnotation:","kind":"identifier"}],"navigatorTitle":[{"text":"mapView:tapOnCalloutForAnnotation:","kind":"identifier"}],"externalID":"c:objc(pl)MLNMapViewD