"text":"The annotation whose callout was tapped.","type":"text"}]}]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"text":"This method is called when the user taps on the body of the callout view, as","type":"text"},{"text":" ","type":"text"},{"text":"opposed to the callout’s left or right accessory view. If the annotation has a","type":"text"},{"text":" ","type":"text"},{"text":"custom callout view via the ","type":"text"},{"type":"codeVoice","code":"-mapView:calloutViewForAnnotation:"},{"text":" method, this","type":"text"},{"text":" ","type":"text"},{"text":"method is only called whenever the callout view calls its delegate’s","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCalloutViewDelegate\/calloutViewTapped:"},{"text":" method.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If this method is present on the delegate, the standard callout view’s body"},{"type":"text","text":" "},{"type":"text","text":"momentarily highlights when the user taps it, whether or not this method does"},{"type":"text","text":" "},{"type":"text","text":"anything in response to the tap."}],"type":"paragraph"},{"text":"Related examples","type":"heading","anchor":"Related-examples","level":4},{"inlineContent":[{"type":"text","text":"TODO: Display custom views as callouts, learn how to trigger an"},{"type":"text","text":" "},{"type":"text","text":"action when an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","type":"reference","isActive":true},{"type":"text","text":"s "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","type":"reference","isActive":true},{"type":"text","text":" is tapped."}],"type":"paragraph"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"paths":["\/documentation\/maplibre\/m