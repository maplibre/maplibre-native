alls its delegate’s"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCalloutViewDelegate\/calloutViewTapped:","type":"reference","isActive":true},{"type":"text","text":" method."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If this method is present on the delegate, the standard callout view’s body"},{"type":"text","text":" "},{"type":"text","text":"momentarily highlights when the user taps it, whether or not this method does"},{"type":"text","text":" "},{"type":"text","text":"anything in response to the tap."}],"type":"paragraph"},{"text":"Related examples","level":4,"anchor":"Related-examples","type":"heading"},{"inlineContent":[{"type":"text","text":"TODO: Display custom views as callouts, learn how to trigger an"},{"type":"text","text":" "},{"type":"text","text":"action when an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","type":"reference","isActive":true},{"type":"text","text":"s "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","type":"reference","isActive":true},{"type":"text","text":" is tapped."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"externalID":"c:objc(pl)MLNMapViewDelegate(im)mapView:tapOnCalloutForAnnotation:","modules":[{"name":"MapLibre"}],"symbolKind":"method","fragments":[{"kind":"text","text":"- "},{"text":"mapView:tapOnCalloutForAnnotation:","kind":"identifier"}],"remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapViewDelegate.h#L1017","fileName":"MLNMapViewDelegate.h"},"navigatorTitle":[{"text":"- ","kind":"text"},{"text":"mapView:tapOnCalloutForAnnotation:","kind":"identifier"}],"roleHeading":"Instance Method","role":"symbol","title":"mapView:tapOnCalloutForAnnotation:"},"abstract":[{"type":"text","text":"Tells the delegate that the user tapped on an annotation’s callout view."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapviewdelegate\/mapview:taponcalloutforannotation:"]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:tapOnCalloutForAnnotation:","interfaceLanguage":"occ"},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate/mapView:tapOnCalloutForAnnotation:":{"abstract":[{"text":"Tells the delegate that the user tapped on an annotation’s callout view.","type":"text"}],"role":"symbol","title":"mapView:tapOnCalloutForAnnotation:","kind":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnmapviewdelegate\/mapview:taponcalloutforannotation:","fragments":[{"text":"- ","kind":"text"},{"kind":"identifier","text":"mapView:tapOnCalloutForAnnotation:"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:tapOnCalloutForAnnotation:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate":{"role":"symbol","url":"\/documentation\/maplibre\/mlnmapviewdelegate","title":"MLNMapViewDelegate","kind":"symbol","fragments":[{"kind":"identifier","text":"MLNMapViewDelegate"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate","type":"topic","abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate","isActive":true,"type":"reference"},{"type":"text","text":" protocol defines a set of optional methods that you"},{"type":"text","text":" "},{"type":"text","text":"can use to receive map-related update messages. Because many map operations"},{"type":"text","text":" "},{"type":"text","text":"require the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","isActive":true,"type":"reference"},{"type":"text","text":" class to load data asynchronously, the map view calls"},{"type":"text","text":" "},{"type":"text","text":"these methods to notify your application when specific operations complete. The"},{"type":"text","text":" "},{"type":"text","text":"map view also uses these methods to request information about annotations"},{"type":"text","text":" "},{"type":"text","text":"displayed on the map, such as the styles and interaction modes to apply to"},{"type":"text","text":" "},{"text":"individual annotations.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotation":{"role":"symbol","url":"\/documentation\/maplibre\/mlnannotation","title":"MLNAnnotation","kind":"symbol","fragments":[{"text":"MLNAnnotation","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","type":"topic","abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","type":"reference","isActive":true},{"type":"text","text":" protocol is used to provide annotation-related information"},{"type":"text","text":" "},{"type":"text","text":"to a map view. To use this protocol, you adopt it in any custom objects that"},{"type":"text","text":" "},{"type":"text","text":"store or represent annotation data. Each object then serves as the source of"},{"type":"text","text":" "},{"type":"text","text":"information about a single map annotation and provides critical information,"},{"type":"text","text":" "},{"type":"text","text":"such as the annotation’s location on the map. Annotation objects do not provide"},{"type":"text","text":" "},{"type":"text","text":"the visual representation of the annotation but typically coordinate (in"},{"type":"text","text":" "},{"type":"text","text":"conjunction with the map view’s delegate) the creation of an appropriate"},{"type":"text","text":" "},{"type":"text","text":"objects to handle the display."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNCalloutViewDelegate/calloutViewTapped:":{"abstract":[{"text":"Tells the delegate that the callout view has been tapped.","type":"text"}],"role":"symbol","title":"calloutViewTapped:","kind":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlncalloutviewdelegate\/calloutviewtapped:","fragments":[{"text":"- ","kind":"text"},{"kind":"identifier","text":"calloutViewTapped:"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCalloutViewDelegate\/calloutViewTapped:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"role":"symbol","url":"\/documentation\/maplibre\/mlnmapview","title":"MLNMapView","kind":"symbol","fragments":[{"text":"MLNMapView","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","type":"topic","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}]},"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","url":"\/documentation\/maplibre","title":"MapLibre","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}]}}}