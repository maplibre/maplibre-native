ssion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default fill color is the map view’s tint color. If a pattern color is"},{"type":"text","text":" "},{"type":"text","text":"specified, the result is undefined."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Opacity may be set by specifying an alpha component. The default alpha value is"},{"type":"text","text":" "},{"type":"codeVoice","code":"1.0"},{"type":"text","text":" and results in a completely opaque shape."}]},{"anchor":"Related-examples","type":"heading","level":4,"text":"Related examples"},{"type":"paragraph","inlineContent":[{"type":"text","text":"TODO: Add a polygon annotation, learn how to modify the color of a an"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon","type":"reference","isActive":true},{"type":"text","text":" at runtime."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapviewdelegate\/mapview:fillcolorforpolygonannotation:"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","sections":[],"metadata":{"remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapViewDelegate.h#L705","fileName":"MLNMapViewDelegate.h"},"externalID":"c:objc(pl)MLNMapViewDelegate(im)mapView:fillColorForPolygonAnnotation:","title":"mapView:fillColorForPolygonAnnotation:","role":"symbol","symbolKind":"method","navigatorTitle":[{"kind":"text","text":"- "},{"kind":"identifier","text":"mapView:fillColorForPolygonAnnotation:"}],"modules":[{"name":"MapLibre"}],"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"mapView:fillColorForPolygonAnnotation:"}],"roleHeading":"Instance Method"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate/mapView:fillColorForPolygonAnnotation:":{"title":"mapView:fillColorForPolygonAnnotation:","identifier":"doc:\/\/org