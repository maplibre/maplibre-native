es to"},{"type":"text","text":" "},{"type":"text","text":"the viewpoint. Therefore, your implementation of this method should be as lightweight"},{"type":"text","text":" "},{"type":"text","text":"as possible to avoid affecting performance."}],"type":"paragraph"},{"anchor":"Related-examples","text":"Related examples","type":"heading","level":4},{"inlineContent":[{"type":"text","text":"TODO: Cluster point data, learn how to trigger an action whenever"},{"type":"text","text":" "},{"type":"text","text":"the map region changes."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapviewdelegate\/mapviewregionischanging:"]}],"kind":"symbol","abstract":[{"type":"text","text":"Tells the delegate that the viewpoint depicted by the map view is changing."}],"metadata":{"role":"symbol","roleHeading":"Instance Method","fragments":[{"text":"- ","kind":"text"},{"text":"mapViewRegionIsChanging:","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"externalID":"c:objc(pl)MLNMapViewDelegate(im)mapViewRegionIsChanging:","symbolKind":"method","title":"mapViewRegionIsChanging:","remoteSource":{"fileName":"MLNMapViewDelegate.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapViewDelegate.h#L132"},"navigatorTitle":[{"text":"mapViewRegionIsChanging:","kind":"identifier"}]},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","title":"MapLibre","type":"topic","role":"collection","kind":"symbol","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","role":"symbol","title":"MLNMapView","abstract":[{"text":"An interactive, customizable map view with