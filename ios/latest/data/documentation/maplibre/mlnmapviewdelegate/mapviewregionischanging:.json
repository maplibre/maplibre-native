:"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method is called as the currently displayed map camera changes as part of"},{"type":"text","text":" "},{"type":"text","text":"an animation, whether due to a user gesture or due to a call to a method such"},{"type":"text","text":" "},{"type":"text","text":"as "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setCamera:animated:","type":"reference"},{"type":"text","text":". This method can be called before"},{"type":"text","text":" "},{"code":"-mapViewDidFinishLoadingMap:","type":"codeVoice"},{"type":"text","text":" is called."}]},{"inlineContent":[{"type":"text","text":"During the animation, this method may be called many times to report updates to"},{"type":"text","text":" "},{"type":"text","text":"the viewpoint. Therefore, your implementation of this method should be as lightweight"},{"type":"text","text":" "},{"type":"text","text":"as possible to avoid affecting performance."}],"type":"paragraph"},{"text":"Related examples","anchor":"Related-examples","type":"heading","level":4},{"inlineContent":[{"text":"TODO: Cluster point data, learn how to trigger an action whenever","type":"text"},{"text":" ","type":"text"},{"text":"the map region changes.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/setCamera:animated:":{"url":"\/documentation\/maplibre\/mlnmapview\/setcamera:animated:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"setCamera:animated:"}],"role":"symbol","type":"topic","kind":"symbol","title":"setCamera:animated:","abstract":[{"text":"Moves the viewpoint to a different location with respect to the map with an","type":"text"},{"text":" ","type":"text"},{"text":"optional transition animation. For animated changes, wait until the map view has","type":"text"},{"text":" ","type":"text"},{"text":"