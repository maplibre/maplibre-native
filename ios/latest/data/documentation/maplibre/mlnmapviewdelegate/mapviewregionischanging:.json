":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method is called as the currently displayed map camera changes as part of"},{"type":"text","text":" "},{"type":"text","text":"an animation, whether due to a user gesture or due to a call to a method such"},{"type":"text","text":" "},{"type":"text","text":"as "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setCamera:animated:","type":"reference","isActive":true},{"type":"text","text":". This method can be called before"},{"type":"text","text":" "},{"type":"codeVoice","code":"-mapViewDidFinishLoadingMap:"},{"type":"text","text":" is called."}]},{"type":"paragraph","inlineContent":[{"text":"During the animation, this method may be called many times to report updates to","type":"text"},{"text":" ","type":"text"},{"text":"the viewpoint. Therefore, your implementation of this method should be as lightweight","type":"text"},{"text":" ","type":"text"},{"text":"as possible to avoid affecting performance.","type":"text"}]},{"level":4,"anchor":"Related-examples","type":"heading","text":"Related examples"},{"type":"paragraph","inlineContent":[{"text":"TODO: Cluster point data, learn how to trigger an action whenever","type":"text"},{"text":" ","type":"text"},{"text":"the map region changes.","type":"text"}]}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/setCamera:animated:":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"setCamera:animated:"}],"title":"setCamera:animated:","role":"symbol","url":"\/documentation\/maplibre\/mlnmapview\/setcamera:animated:","abstract":[{"type":"text","text":"Moves the viewpoint to a different location with respect to the map with an"},{"type":"text","text":" "},{"type":"text","text":"optional transition animation. For animated changes, wait until the map view has"},{"type":"text","text":" "},{"type":"text","text":"finished loading before c