cussion","type":"heading","text":"Discussion"},{"inlineContent":[{"text":"This method is called any time the map view needs to redraw due to a change in","type":"text"},{"text":" ","type":"text"},{"text":"the viewpoint or style property transition. This method may be called very","type":"text"},{"text":" ","type":"text"},{"text":"frequently, even moreso than ","type":"text"},{"type":"codeVoice","code":"-mapViewRegionIsChanging:"},{"text":". Therefore, your","type":"text"},{"text":" ","type":"text"},{"text":"implementation of this method should be as lightweight as possible to avoid","type":"text"},{"text":" ","type":"text"},{"text":"affecting performance.","type":"text"}],"type":"paragraph"}]}],"abstract":[{"type":"text","text":"Tells the delegate that the map view is about to redraw."}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"url":"\/documentation\/maplibre\/mlnmapview","title":"MLNMapView","kind":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","role":"symbol","fragments":[{"text":"MLNMapView","kind":"identifier"}],"abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}]},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol","type":"topic","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate/mapViewWillStartRenderingFrame:":{"type":"topic","abstract":[{"type":"text","text":"Tells the delegate that the map view is about to redraw."}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapV