 view needs to redraw due to a change in","type":"text"},{"text":" ","type":"text"},{"text":"the viewpoint or style property transition. This method may be called very","type":"text"},{"text":" ","type":"text"},{"text":"frequently, even moreso than ","type":"text"},{"code":"-mapViewRegionIsChanging:","type":"codeVoice"},{"text":". Therefore, your","type":"text"},{"text":" ","type":"text"},{"text":"implementation of this method should be as lightweight as possible to avoid","type":"text"},{"text":" ","type":"text"},{"text":"affecting performance.","type":"text"}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapViewWillStartRenderingFrame:","interfaceLanguage":"occ"},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"title":"MapLibre","kind":"symbol","type":"topic","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","type":"topic","url":"\/documentation\/maplibre\/mlnmapview","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"title":"MLNMapView","fragments":[{"text":"MLNMapView","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate/mapViewWillStartRenderingFrame:":{"role":"symbol","url":"\/documentation\/maplibre\/mlnmapviewdelegate\/mapviewwillstartrenderingframe:","fragments":[{"text":"- ","kind":"text"},{"text":"mapViewWillStartRenderingFrame:","kind":"identifier"}],"abstract":[{"type":"text","text":"Tells the delegate that the