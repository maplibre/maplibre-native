ontent","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method is called any time the map view needs to redraw due to a change in"},{"type":"text","text":" "},{"type":"text","text":"the viewpoint or style property transition. This method may be called very"},{"type":"text","text":" "},{"type":"text","text":"frequently, even moreso than "},{"type":"codeVoice","code":"-mapViewRegionIsChanging:"},{"type":"text","text":". Therefore, your"},{"type":"text","text":" "},{"type":"text","text":"implementation of this method should be as lightweight as possible to avoid"},{"type":"text","text":" "},{"type":"text","text":"affecting performance."}]}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"fragments":[{"text":"MLNMapView","kind":"identifier"}],"type":"topic","kind":"symbol","url":"\/documentation\/maplibre\/mlnmapview","title":"MLNMapView","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate/mapViewWillStartRenderingFrame:":{"url":"\/documentation\/maplibre\/mlnmapviewdelegate\/mapviewwillstartrenderingframe:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapViewWillStartRenderingFrame:","abstract":[{"text":"Tells the delegate that the map view is about to redraw.","type":"text"}],"navigatorTitle":[{"text":"mapViewWillStartRenderingFrame:","kind":"identifier"}],"title":"mapViewWillStartRenderingFrame:","kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"mapViewWillStartRenderingFrame:","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre