od is called any time the map view needs to redraw due to a change in","type":"text"},{"text":" ","type":"text"},{"text":"the viewpoint or style property transition. This method may be called very","type":"text"},{"text":" ","type":"text"},{"text":"frequently, even moreso than ","type":"text"},{"type":"codeVoice","code":"-mapViewRegionIsChanging:"},{"text":". Therefore, your","type":"text"},{"text":" ","type":"text"},{"text":"implementation of this method should be as lightweight as possible to avoid","type":"text"},{"text":" ","type":"text"},{"text":"affecting performance.","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/maplibre\/mlnmapviewdelegate\/mapviewwillstartrenderingframe:"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","type":"topic","abstract":[{"text":"An interactive, customizable map view with an interface similar to the one","type":"text"},{"text":" ","type":"text"},{"text":"provided by Apple’s MapKit.","type":"text"}],"fragments":[{"kind":"identifier","text":"MLNMapView"}],"title":"MLNMapView","kind":"symbol","url":"\/documentation\/maplibre\/mlnmapview","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection","kind":"symbol","url":"\/documentation\/maplibre","title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate/mapViewWillStartRenderingFrame:":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapViewWillStartRenderingFrame:","abstract":[{"text":"Tells the delegate that the map view is about to redraw.","type":"text"}],"url":"\/documentation\/maplibre\/mlnmapviewdelegate\/