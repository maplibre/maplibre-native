ut to redraw."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"This method is called any time the map view needs to redraw due to a change in"},{"type":"text","text":" "},{"type":"text","text":"the viewpoint or style property transition. This method may be called very"},{"type":"text","text":" "},{"type":"text","text":"frequently, even moreso than "},{"type":"codeVoice","code":"-mapViewRegionIsChanging:"},{"type":"text","text":". Therefore, your"},{"type":"text","text":" "},{"type":"text","text":"implementation of this method should be as lightweight as possible to avoid"},{"type":"text","text":" "},{"type":"text","text":"affecting performance."}],"type":"paragraph"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"url":"\/documentation\/maplibre\/mlnmapview","title":"MLNMapView","role":"symbol","fragments":[{"text":"MLNMapView","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","type":"topic","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate/mapViewWillStartRenderingFrame:":{"url":"\/documentation\/maplibre\/mlnmapviewdelegate\/mapviewwillstartrenderingframe:","title":"mapViewWillStartRenderingFrame:","role":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"mapViewWillStartRenderingFrame:","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapViewWillStartRenderingFrame:","type":"topic","abstract":[{"type":"text","text":"Tells the delegate that the map view is about to redraw."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate":{"url":"\