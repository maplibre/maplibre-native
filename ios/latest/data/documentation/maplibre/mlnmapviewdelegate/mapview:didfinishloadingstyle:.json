 called during the initialization of the map view and after any","type":"text"},{"text":" ","type":"text"},{"text":"subsequent loading of a new style. This method is called between the","type":"text"},{"text":" ","type":"text"},{"code":"-mapViewWillStartRenderingMap:","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"-mapViewDidFinishRenderingMap:","type":"codeVoice"},{"text":" delegate","type":"text"},{"text":" ","type":"text"},{"text":"methods. Changes to sources or layers of the current style do not cause this","type":"text"},{"text":" ","type":"text"},{"text":"method to be called.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This method is the earliest opportunity to modify the layout or appearance of","type":"text"},{"text":" ","type":"text"},{"text":"the current style before the map view is displayed to the user.","type":"text"}],"type":"paragraph"},{"type":"heading","anchor":"Related-examples","level":4,"text":"Related examples"},{"inlineContent":[{"text":"TODO: Dynamically style interactive points","type":"text"},{"text":" ","type":"text"},{"text":"TODO: Add multiple shapes from a single shape source examples, learn how to","type":"text"},{"text":" ","type":"text"},{"text":"ensure a map’s style has loaded before modifying it at runtime","type":"text"}],"type":"paragraph"}],"kind":"content"}],"metadata":{"modules":[{"name":"MapLibre"}],"role":"symbol","roleHeading":"Instance Method","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"mapView:didFinishLoadingStyle:"}],"symbolKind":"method","navigatorTitle":[{"kind":"text","text":"- "},{"kind":"identifier","text":"mapView:didFinishLoadingStyle:"}],"externalID":"c:objc(pl)MLNMapViewDelegate(im)mapView:didFinishLoadingStyle:","remoteSource":{"fileName":"MLNMapViewDelegate.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapViewDelegate.h#L321"},"title":"mapView:didFinishLoadingStyle:"},"references":{"doc://org.swift.MyProj