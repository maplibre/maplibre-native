ring the initialization of the map view and after any"},{"type":"text","text":" "},{"type":"text","text":"subsequent loading of a new style. This method is called between the"},{"type":"text","text":" "},{"code":"-mapViewWillStartRenderingMap:","type":"codeVoice"},{"type":"text","text":" and "},{"code":"-mapViewDidFinishRenderingMap:","type":"codeVoice"},{"type":"text","text":" delegate"},{"type":"text","text":" "},{"type":"text","text":"methods. Changes to sources or layers of the current style do not cause this"},{"type":"text","text":" "},{"type":"text","text":"method to be called."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This method is the earliest opportunity to modify the layout or appearance of"},{"type":"text","text":" "},{"type":"text","text":"the current style before the map view is displayed to the user."}],"type":"paragraph"},{"type":"heading","level":4,"text":"Related examples","anchor":"Related-examples"},{"inlineContent":[{"type":"text","text":"TODO: Dynamically style interactive points"},{"type":"text","text":" "},{"type":"text","text":"TODO: Add multiple shapes from a single shape source examples, learn how to"},{"type":"text","text":" "},{"type":"text","text":"ensure a map’s style has loaded before modifying it at runtime"}],"type":"paragraph"}],"kind":"content"}],"metadata":{"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"mapView:didFinishLoadingStyle:"}],"role":"symbol","modules":[{"name":"MapLibre"}],"roleHeading":"Instance Method","symbolKind":"method","title":"mapView:didFinishLoadingStyle:","externalID":"c:objc(pl)MLNMapViewDelegate(im)mapView:didFinishLoadingStyle:","remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapViewDelegate.h#L321","fileName":"MLNMapViewDelegate.h"},"navigatorTitle":[{"kind":"identifier","text":"mapView:didFinishLoadingStyle:"}]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"fragments":