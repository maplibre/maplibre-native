nd":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"This method is called during the initialization of the map view and after any","type":"text"},{"text":" ","type":"text"},{"text":"subsequent loading of a new style. This method is called between the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"-mapViewWillStartRenderingMap:"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"-mapViewDidFinishRenderingMap:"},{"text":" delegate","type":"text"},{"text":" ","type":"text"},{"text":"methods. Changes to sources or layers of the current style do not cause this","type":"text"},{"text":" ","type":"text"},{"text":"method to be called.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This method is the earliest opportunity to modify the layout or appearance of","type":"text"},{"text":" ","type":"text"},{"text":"the current style before the map view is displayed to the user.","type":"text"}]},{"type":"heading","level":4,"text":"Related examples","anchor":"Related-examples"},{"type":"paragraph","inlineContent":[{"text":"TODO: Dynamically style interactive points","type":"text"},{"text":" ","type":"text"},{"text":"TODO: Add multiple shapes from a single shape source examples, learn how to","type":"text"},{"text":" ","type":"text"},{"text":"ensure a map’s style has loaded before modifying it at runtime","type":"text"}]}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate"]]},"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:didFinishLoadingStyle:"},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Tells the delegate that the map has just finished loading a style."}],"references":{"doc://org.swift.MyProj