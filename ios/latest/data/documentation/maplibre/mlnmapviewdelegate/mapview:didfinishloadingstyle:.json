"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"This method is called during the initialization of the map view and after any","type":"text"},{"text":" ","type":"text"},{"text":"subsequent loading of a new style. This method is called between the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"-mapViewWillStartRenderingMap:"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"-mapViewDidFinishRenderingMap:"},{"text":" delegate","type":"text"},{"text":" ","type":"text"},{"text":"methods. Changes to sources or layers of the current style do not cause this","type":"text"},{"text":" ","type":"text"},{"text":"method to be called.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This method is the earliest opportunity to modify the layout or appearance of"},{"type":"text","text":" "},{"type":"text","text":"the current style before the map view is displayed to the user."}],"type":"paragraph"},{"text":"Related examples","type":"heading","level":4,"anchor":"Related-examples"},{"inlineContent":[{"type":"text","text":"TODO: Dynamically style interactive points"},{"type":"text","text":" "},{"type":"text","text":"TODO: Add multiple shapes from a single shape source examples, learn how to"},{"type":"text","text":" "},{"type":"text","text":"ensure a map’s style has loaded before modifying it at runtime"}],"type":"paragraph"}]}],"abstract":[{"type":"text","text":"Tells the delegate that the map has just finished loading a style."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:didFinishLoadingStyle:","interfaceLanguage":"occ"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapviewdelegate\/mapview:didfinishloadingstyle:"]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate":{"tit