ram","text":"style"},{"kind":"text","text":";"}],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"mapView","content":[{"inlineContent":[{"text":"The map view that has just loaded a style.","type":"text"}],"type":"paragraph"}]},{"name":"style","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The style that was loaded."}]}]}]},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"This method is called during the initialization of the map view and after any"},{"type":"text","text":" "},{"type":"text","text":"subsequent loading of a new style. This method is called between the"},{"type":"text","text":" "},{"code":"-mapViewWillStartRenderingMap:","type":"codeVoice"},{"type":"text","text":" and "},{"code":"-mapViewDidFinishRenderingMap:","type":"codeVoice"},{"type":"text","text":" delegate"},{"type":"text","text":" "},{"type":"text","text":"methods. Changes to sources or layers of the current style do not cause this"},{"type":"text","text":" "},{"type":"text","text":"method to be called."}],"type":"paragraph"},{"inlineContent":[{"text":"This method is the earliest opportunity to modify the layout or appearance of","type":"text"},{"text":" ","type":"text"},{"text":"the current style before the map view is displayed to the user.","type":"text"}],"type":"paragraph"},{"level":4,"type":"heading","text":"Related examples","anchor":"Related-examples"},{"inlineContent":[{"type":"text","text":"TODO: Dynamically style interactive points"},{"type":"text","text":" "},{"type":"text","text":"TODO: Add multiple shapes from a single shape source examples, learn how to"},{"type":"text","text":" "},{"type":"text","text":"ensure a map’s style has loaded before modifying it at runtime"}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"role":"symb