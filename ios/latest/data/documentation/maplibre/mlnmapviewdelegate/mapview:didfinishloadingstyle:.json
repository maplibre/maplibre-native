"type":"text","text":"The style that was loaded."}],"type":"paragraph"}],"name":"style"}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"This method is called during the initialization of the map view and after any"},{"type":"text","text":" "},{"type":"text","text":"subsequent loading of a new style. This method is called between the"},{"type":"text","text":" "},{"type":"codeVoice","code":"-mapViewWillStartRenderingMap:"},{"type":"text","text":" and "},{"type":"codeVoice","code":"-mapViewDidFinishRenderingMap:"},{"type":"text","text":" delegate"},{"type":"text","text":" "},{"type":"text","text":"methods. Changes to sources or layers of the current style do not cause this"},{"type":"text","text":" "},{"type":"text","text":"method to be called."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This method is the earliest opportunity to modify the layout or appearance of"},{"type":"text","text":" "},{"type":"text","text":"the current style before the map view is displayed to the user."}],"type":"paragraph"},{"anchor":"Related-examples","text":"Related examples","level":4,"type":"heading"},{"inlineContent":[{"type":"text","text":"TODO: Dynamically style interactive points"},{"type":"text","text":" "},{"type":"text","text":"TODO: Add multiple shapes from a single shape source examples, learn how to"},{"type":"text","text":" "},{"type":"text","text":"ensure a map’s style has loaded before modifying it at runtime"}],"type":"paragraph"}]}],"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:didFinishLoadingStyle:"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate/mapVie