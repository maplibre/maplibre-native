nsition. This method may be called very","type":"text"},{"text":" ","type":"text"},{"text":"frequently, even moreso than ","type":"text"},{"code":"-mapViewRegionIsChanging:","type":"codeVoice"},{"text":". Therefore, your","type":"text"},{"text":" ","type":"text"},{"text":"implementation of this method should be as lightweight as possible to avoid","type":"text"},{"text":" ","type":"text"},{"text":"affecting performance.","type":"text"}]}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","title":"MapLibre","role":"collection","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}]},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/ObserverExample":{"url":"\/documentation\/maplibre-native-for-ios\/observerexample","title":"Observe Low-Level Events","role":"article","kind":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/ObserverExample","type":"topic","abstract":[{"type":"text","text":"Learn about the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate"},{"type":"text","text":" methods for observing map events."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate/mapViewDidFinishRenderingFrame:fullyRendered:frameEncodingTime:frameRenderingTime:":{"url":"\/documentation\/maplibre\/mlnmapviewdelegate\/mapviewdidfinishrenderingframe:fullyrendered:frameencodingtime:framerenderingtime:","title":"mapViewDidFinishRenderingFrame:fullyRendered:frameEncodingTime:frameRenderingTime:","role":"symbol","fragments":[{"text":"- ","kind":"text"},{"kind":"identifier","text":"mapViewDidFinishRenderingFrame:fullyRendered:frameEncodingTime:frameRenderingTime:"}],"kind":"symbol","identifier":"doc: