pView","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","title":"MLNMapView","type":"topic","url":"\/documentation\/maplibre\/mlnmapview"}}}