xt"},{"code":"-mapView:calloutViewForAnnotation:","type":"codeVoice"},{"text":" is present in","type":"text"},{"text":" ","type":"text"},{"text":"the delegate.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To display a view on the callout’s left side, implement the","type":"text"},{"text":" ","type":"text"},{"code":"-mapView:leftCalloutAccessoryViewForAnnotation:","type":"codeVoice"},{"text":" method.","type":"text"}]},{"type":"heading","level":4,"anchor":"Related-examples","text":"Related examples"},{"type":"paragraph","inlineContent":[{"type":"text","text":"TODO: Default callout usage, learn how to modify the view that is"},{"type":"text","text":" "},{"type":"text","text":"displayed on the right side of the standard callout bubble."}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/maplibre\/mlnmapviewdelegate\/mapview:rightcalloutaccessoryviewforannotation:"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"text":"Returns the view to display on the right side of the standard callout bubble.","type":"text"}],"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate/mapView:rightCalloutAccessoryViewForAnnotation:":{"abstract":[{"type":"text","text":"Returns the view to display on the right side of the standard callout bubble."}],"navigatorTitle":[{"kind":"identifier","text":"mapView:rightCalloutAccessoryViewForAnnotation:"}],"url":"\/documentation\/maplibre\/mlnmapviewdelegate\/mapview:rightcalloutaccessoryviewforannotation:","type":"topic","kind":"symbol","role":"symbol","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"mapView:rightCalloutAccessoryViewForAnnotation:"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:rightCalloutAccessoryViewForAnnotation:","title":"mapView:rightCalloutAccessoryViewForAnnotation:"},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","role":"collection","type":"topic","ur