ype":"text","text":"the delegate."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To display a view on the callout’s left side, implement the"},{"type":"text","text":" "},{"code":"-mapView:leftCalloutAccessoryViewForAnnotation:","type":"codeVoice"},{"type":"text","text":" method."}],"type":"paragraph"},{"text":"Related examples","level":4,"anchor":"Related-examples","type":"heading"},{"inlineContent":[{"type":"text","text":"TODO: Default callout usage, learn how to modify the view that is"},{"type":"text","text":" "},{"type":"text","text":"displayed on the right side of the standard callout bubble."}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"type":"text","text":"Returns the view to display on the right side of the standard callout bubble."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapviewdelegate\/mapview:rightcalloutaccessoryviewforannotation:"]}],"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:rightCalloutAccessoryViewForAnnotation:"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate/mapView:rightCalloutAccessoryViewForAnnotation:":{"type":"topic","url":"\/documentation\/maplibre\/mlnmapviewdelegate\/mapview:rightcalloutaccessoryviewforannotation:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"mapView:rightCalloutAccessoryViewForAnnotation:"}],"role":"symbol","abstract":[{"type":"text","text":"Returns the view to display on the right side of the standard callout bubble."}],"title":"mapView:rightCalloutAccessoryViewForAnnotation:","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:rightCalloutAccessoryViewForAnnotation:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"type":"topic","url":"\/documentation\/maplibre\/mlnmapview","fragments":[{"text":"MLNMapVie