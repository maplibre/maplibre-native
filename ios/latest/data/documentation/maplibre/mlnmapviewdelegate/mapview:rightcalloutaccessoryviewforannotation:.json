code":"-mapView:leftCalloutAccessoryViewForAnnotation:"},{"type":"text","text":" method."}],"type":"paragraph"},{"text":"Related examples","anchor":"Related-examples","level":4,"type":"heading"},{"inlineContent":[{"text":"TODO: Default callout usage, learn how to modify the view that is","type":"text"},{"text":" ","type":"text"},{"text":"displayed on the right side of the standard callout bubble.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapviewdelegate\/mapview:rightcalloutaccessoryviewforannotation:"]}],"abstract":[{"type":"text","text":"Returns the view to display on the right side of the standard callout bubble."}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:rightCalloutAccessoryViewForAnnotation:"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"fragments":[{"kind":"identifier","text":"MLNMapView"}],"url":"\/documentation\/maplibre\/mlnmapview","abstract":[{"text":"An interactive, customizable map view with an interface similar to the one","type":"text"},{"text":" ","type":"text"},{"text":"provided by Apple’s MapKit.","type":"text"}],"title":"MLNMapView","role":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate/mapView:rightCalloutAccessoryViewForAnnotation:":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:rightCalloutAccessoryViewForAnnotation:","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"mapView:rightCalloutAccessoryViewForAnnotation:"}],"fragments":[{"kind":"text","tex