xt"},{"text":"callout.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"text":"This method is called after an annotation is selected, before any callout is","type":"text"},{"text":" ","type":"text"},{"text":"displayed for the annotation.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If the return value is ","type":"text"},{"type":"codeVoice","code":"YES"},{"text":", a callout view is shown when the user taps on an","type":"text"},{"text":" ","type":"text"},{"text":"annotation, selecting it. The default callout displays the annotation’s title","type":"text"},{"text":" ","type":"text"},{"text":"and subtitle. You can add accessory views to either end of the callout by","type":"text"},{"text":" ","type":"text"},{"text":"implementing the ","type":"text"},{"type":"codeVoice","code":"-mapView:leftCalloutAccessoryViewForAnnotation:"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"-mapView:rightCalloutAccessoryViewForAnnotation:"},{"text":" methods. You can further","type":"text"},{"text":" ","type":"text"},{"text":"customize the callout’s contents by implementing the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"-mapView:calloutViewForAnnotation:"},{"text":" method.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If the return value is ","type":"text"},{"code":"NO","type":"codeVoice"},{"text":", or if this method is absent from the delegate, or","type":"text"},{"text":" ","type":"text"},{"text":"if the annotation lacks a title, the annotation will not show a callout even","type":"text"},{"text":" ","type":"text"},{"text":"when selected.","type":"text"}],"type":"paragraph"},{"anchor":"Related-examples","text":"Related examples","type":"heading","level":4},{"inlineContent":[{"type":"text","text":"TODO: Add annotation views and images"},{"type":"text","text":" "},{"type":"t