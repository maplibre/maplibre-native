ram"},{"text":";","kind":"text"}],"platforms":["iOS"]}]},{"parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The map view that has just redrawn."}],"type":"paragraph"}],"name":"mapView"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A Boolean value indicating whether the map is fully rendered or not.","type":"text"}]}],"name":"fullyRendered"}],"kind":"parameters"},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"This method is called any time the map view needs to redraw due to a change in"},{"type":"text","text":" "},{"type":"text","text":"the viewpoint or style property transition. This method may be called very"},{"type":"text","text":" "},{"type":"text","text":"frequently, even moreso than "},{"type":"codeVoice","code":"-mapViewRegionIsChanging:"},{"type":"text","text":". Therefore, your"},{"type":"text","text":" "},{"type":"text","text":"implementation of this method should be as lightweight as possible to avoid"},{"type":"text","text":" "},{"type":"text","text":"affecting performance."}],"type":"paragraph"}]}],"abstract":[{"text":"Tells the delegate that the map view has just redrawn.","type":"text"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate/mapViewDidFinishRenderingFrame:fullyRendered:":{"navigatorTitle":[{"kind":"identifier","text":"mapViewDidFinishRenderingFrame:fullyRendered:"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapViewDidFinishRenderingFrame:fullyRendered:","url":"\/documentation\/maplibre\/mlnmapviewdelegate\/mapviewdidfinishrenderingframe:fullyrendered:","role":"symbol","kind":"symbol","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"mapViewDidFinishRenderingFrame:fullyRendered:"}],"abstract":[{"type":"text","text":"Tells the delegate that the map view has just redrawn."}],"type":"topic","title":"mapViewDidFinishRenderin