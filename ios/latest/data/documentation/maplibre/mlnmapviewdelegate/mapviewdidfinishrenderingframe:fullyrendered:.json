meters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The map view that has just redrawn.","type":"text"}]}],"name":"mapView"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A Boolean value indicating whether the map is fully rendered or not.","type":"text"}]}],"name":"fullyRendered"}],"kind":"parameters"},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method is called any time the map view needs to redraw due to a change in"},{"type":"text","text":" "},{"type":"text","text":"the viewpoint or style property transition. This method may be called very"},{"type":"text","text":" "},{"type":"text","text":"frequently, even moreso than "},{"type":"codeVoice","code":"-mapViewRegionIsChanging:"},{"type":"text","text":". Therefore, your"},{"type":"text","text":" "},{"type":"text","text":"implementation of this method should be as lightweight as possible to avoid"},{"type":"text","text":" "},{"type":"text","text":"affecting performance."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate/mapViewDidFinishRenderingFrame:fullyRendered:":{"url":"\/documentation\/maplibre\/mlnmapviewdelegate\/mapviewdidfinishrenderingframe:fullyrendered:","navigatorTitle":[{"text":"mapViewDidFinishRenderingFrame:fullyRendered:","kind":"identifier"}],"kind":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"mapViewDidFinishRenderingFrame:fullyRendered:","kind":"identifier"}],"role":"symbol","title":"mapViewDidFinishRenderingFrame:fullyRendered:","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapViewDidFinishRenderingFrame:fullyRendered:","abstract":[{"text":"Tells the delegate that the map view has just red