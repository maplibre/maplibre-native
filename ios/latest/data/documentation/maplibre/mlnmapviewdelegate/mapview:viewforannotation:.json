MyProject\/documentation\/MapLibre\/MLNUserLocation","kind":"symbol","abstract":[{"type":"text","text":"The MLNUserLocation class defines a specific type of annotation that identifies"},{"text":" ","type":"text"},{"text":"the user’s current location. You do not create instances of this class","type":"text"},{"text":" ","type":"text"},{"text":"directly. Instead, you retrieve an existing ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocation","isActive":true},{"text":" object from the","type":"text"},{"text":" ","type":"text"},{"code":"userLocation","type":"codeVoice"},{"text":" property of the map view displayed in your application.","type":"text"}],"role":"symbol","fragments":[{"kind":"identifier","text":"MLNUserLocation"}],"title":"MLNUserLocation","url":"\/documentation\/maplibre\/mlnuserlocation","type":"topic"}}}