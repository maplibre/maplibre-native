nd interaction modes to apply to","type":"text"},{"text":" ","type":"text"},{"text":"individual annotations.","type":"text"}],"title":"MLNMapViewDelegate"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserTrackingMode/MLNUserTrackingModeFollowWithCourse":{"abstract":[{"type":"text","text":"The map follows the user location and rotates when the course changes."},{"type":"text","text":" "},{"type":"text","text":"Course represents the direction in which the device is traveling."},{"type":"text","text":" "},{"type":"text","text":"The default user location annotation shows a puck-shaped indicator"},{"type":"text","text":" "},{"type":"text","text":"that rotates as the course changes."}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnusertrackingmode\/mlnusertrackingmodefollowwithcourse","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse","fragments":[{"kind":"identifier","text":"MLNUserTrackingModeFollowWithCourse"}],"title":"MLNUserTrackingModeFollowWithCourse","type":"topic","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserTrackingMode/MLNUserTrackingModeFollowWithHeading":{"fragments":[{"text":"MLNUserTrackingModeFollowWithHeading","kind":"identifier"}],"title":"MLNUserTrackingModeFollowWithHeading","role":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithHeading","url":"\/documentation\/maplibre\/mlnusertrackingmode\/mlnusertrackingmodefollowwithheading","kind":"symbol","abstract":[{"type":"text","text":"The map follows the user location and rotates when the heading changes."},{"type":"text","text":" "},{"type":"text","text":"The default user location annotation displays a fan-shaped indicator with"},{"type":"text","text":" "},{"type":"text","text":"the current heading. The heading indicator represents the direction the"},{"type":"text","text":" "},{"type":"text","te