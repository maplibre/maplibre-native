":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"While the "},{"type":"codeVoice","code":"showsUserLocation"},{"type":"text","text":" property is set to "},{"type":"codeVoice","code":"YES"},{"type":"text","text":", this method is called"},{"type":"text","text":" "},{"type":"text","text":"whenever a new location update is received by the map view. This method is also"},{"type":"text","text":" "},{"type":"text","text":"called if the map view’s user tracking mode is set to"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithHeading","type":"reference","isActive":true},{"type":"text","text":" and the heading changes, or if it is"},{"type":"text","text":" "},{"type":"text","text":"set to "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse","type":"reference","isActive":true},{"type":"text","text":" and the course changes."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method is not called if the application is currently running in the"},{"type":"text","text":" "},{"type":"text","text":"background. If you want to receive location updates while running in the"},{"type":"text","text":" "},{"type":"text","text":"background, you must use the Core Location framework."}]}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:didUpdateUserLocation:"},"metadata":{"roleHeading":"Instance Method","remoteSource":{"fileName":"MLNMapViewDelegate.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapViewDelegate.h#L567"},"role":"symbol","title":"mapView:didUpdateUserLocation:","symbolKind":"method","externalID":"c:objc(pl)MLNMapViewDelegate(im)mapView:didUpdateUserLocation:","fragments":[{"text":"- ","kind":"text"},{"text":"mapView:didUpdateUserLocation:","kin