":"text","text":"these methods to notify your application when specific operations complete. The"},{"type":"text","text":" "},{"type":"text","text":"map view also uses these methods to request information about annotations"},{"type":"text","text":" "},{"type":"text","text":"displayed on the map, such as the styles and interaction modes to apply to"},{"type":"text","text":" "},{"type":"text","text":"individual annotations."}],"url":"\/documentation\/maplibre\/mlnmapviewdelegate","title":"MLNMapViewDelegate","kind":"symbol","role":"symbol","fragments":[{"text":"MLNMapViewDelegate","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserTrackingMode/MLNUserTrackingModeFollowWithHeading":{"kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlnusertrackingmode\/mlnusertrackingmodefollowwithheading","abstract":[{"type":"text","text":"The map follows the user location and rotates when the heading changes."},{"type":"text","text":" "},{"type":"text","text":"The default user location annotation displays a fan-shaped indicator with"},{"type":"text","text":" "},{"type":"text","text":"the current heading. The heading indicator represents the direction the"},{"type":"text","text":" "},{"type":"text","text":"device is facing, which is sized according to the reported accuracy."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithHeading","title":"MLNUserTrackingModeFollowWithHeading","type":"topic","fragments":[{"kind":"identifier","text":"MLNUserTrackingModeFollowWithHeading"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"url":"\/documentation\/maplibre\/mlnmapview","title"