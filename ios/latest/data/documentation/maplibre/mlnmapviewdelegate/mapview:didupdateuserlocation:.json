me":"mapView","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The map view that is tracking the user’s location."}]}]},{"name":"userLocation","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The location object representing the user’s latest"},{"type":"text","text":" "},{"type":"text","text":"location. This property may be "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}]}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"While the "},{"type":"codeVoice","code":"showsUserLocation"},{"type":"text","text":" property is set to "},{"type":"codeVoice","code":"YES"},{"type":"text","text":", this method is called"},{"type":"text","text":" "},{"type":"text","text":"whenever a new location update is received by the map view. This method is also"},{"type":"text","text":" "},{"type":"text","text":"called if the map view’s user tracking mode is set to"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithHeading","type":"reference","isActive":true},{"type":"text","text":" and the heading changes, or if it is"},{"type":"text","text":" "},{"type":"text","text":"set to "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse","type":"reference","isActive":true},{"type":"text","text":" and the course changes."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This method is not called if the application is currently running in the"},{"type":"text","text":" "},{"type":"text","text":"background. If you want to receive location updates while running in the"},{"type":"text","text":" "},{"type":"text","text":"background, you must use the Core Location framework."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate"]]},"abstract":[{"type":"text","text":"Tells the delegate that the location of the user was updated."}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNUserTrackingMode/MLNUserTrackingModeFollowWithCourse":{"fragments":[{"kind":"identifier","text":"MLNUserTrackingModeFollowWithCourse"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse","type":"topic","title":"MLNUserTrackingModeFollowWithCourse","abstract":[{"text":"The map follows the user location and rotates when the course changes.","type":"text"},{"text":" ","type":"text"},{"text":"Course represents the direction in which the device is traveling.","type":"text"},{"text":" ","type":"text"},{"text":"The default user location annotation shows a puck-shaped indicator","type":"text"},{"text":" ","type":"text"},{"text":"that rotates as the course changes.","type":"text"}],"url":"\/documentation\/maplibre\/mlnusertrackingmode\/mlnusertrackingmodefollowwithcourse"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate/mapView:didUpdateUserLocation:":{"title":"mapView:didUpdateUserLocation:","role":"symbol","url":"\/documentation\/maplibre\/mlnmapviewdelegate\/mapview:didupdateuserlocation:","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Tells the delegate that the location of the user was updated."}],"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"mapView:didUpdateUserLocation:"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:didUpdateUserLocation:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocation":{"fragments":[{"kind":"identifier","text":"MLNUserLocation"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocation","type":"topic","title":"MLNUserLocation","abstract":[{"type":"text","text":"The MLNUserLocation class defines a specific type of annotation that identifies"},{"type":"text","text":" "},{"type":"text","text":"the user’s current location. You do not create instances of this class"},{"type":"text","text":" "},{"type":"text","text":"directly. Instead, you retrieve an existing "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocation","isActive":true},{"type":"text","text":" object from the"},{"type":"text","text":" "},{"code":"userLocation","type":"codeVoice"},{"type":"text","text":" property of the map view displayed in your application."}],"url":"\/documentation\/maplibre\/mlnuserlocation"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserTrackingMode/MLNUserTrackingModeFollowWithHeading":{"fragments":[{"kind":"identifier","text":"MLNUserTrackingModeFollowWithHeading"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithHeading","type":"topic","title":"MLNUserTrackingModeFollowWithHeading","abstract":[{"type":"text","text":"The map follows the user location and rotates when the heading changes."},{"type":"text","text":" "},{"type":"text","text":"The default user location annotation displays a fan-shaped indicator with"},{"type":"text","text":" "},{"type":"text","text":"the current heading. The heading indicator represents the direction the"},{"type":"text","text":" "},{"type":"text","text":"device is facing, which is sized according to the reported accuracy."}],"url":"\/documentation\/maplibre\/mlnusertrackingmode\/mlnusertrackingmodefollowwithheading"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate":{"kind":"symbol","title":"MLNMapViewDelegate","type":"topic","abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate","isActive":true},{"type":"text","text":" protocol defines a set of optional methods that you"},{"type":"text","text":" "},{"type":"text","text":"can use to receive map-related update messages. Because many map operations"},{"type":"text","text":" "},{"type":"text","text":"require the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","isActive":true},{"type":"text","text":" class to load data asynchronously, the map view calls"},{"type":"text","text":" "},{"type":"text","text":"these methods to notify your application when specific operations complete. The"},{"type":"text","text":" "},{"type":"text","text":"map view also uses these methods to request information about annotations"},{"type":"text","text":" "},{"type":"text","text":"displayed on the map, such as the styles and interaction modes to apply to"},{"type":"text","text":" "},{"type":"text","text":"individual annotations."}],"url":"\/documentation\/maplibre\/mlnmapviewdelegate","role":"symbol","fragments":[{"kind":"identifier","text":"MLNMapViewDelegate"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","role":"symbol","url":"\/documentation\/maplibre\/mlnmapview","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"fragments":[{"kind":"identifier","text":"MLNMapView"}],"title":"MLNMapView"},"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"url":"\/documentation\/maplibre","role"