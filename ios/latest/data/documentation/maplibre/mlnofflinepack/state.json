gedNotification","title":"MLNOfflinePackProgressChangedNotification","kind":"symbol","type":"topic","role":"symbol","abstract":[{"type":"text","text":"Posted by the shared "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","isActive":true,"type":"reference"},{"type":"text","text":" object when an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"object’s progress changes. The progress may change due to a resource being"},{"type":"text","text":" "},{"type":"text","text":"downloaded or because the pack discovers during the download that more"},{"type":"text","text":" "},{"type":"text","text":"resources are required for offline viewing. This notification is posted"},{"type":"text","text":" "},{"type":"text","text":"whenever any field in the "},{"code":"progress","type":"codeVoice"},{"type":"text","text":" property changes."}],"url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/state":{"type":"topic","role":"symbol","abstract":[{"text":"The pack’s current state.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/state","title":"state","url":"\/documentation\/maplibre\/mlnofflinepack\/state","kind":"symbol","fragments":[{"text":"state","kind":"identifier"}]}}}