osted"},{"type":"text","text":" "},{"type":"text","text":"whenever any field in the "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" property changes."}],"fragments":[{"text":"MLNOfflinePackProgressChangedNotification","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackState/MLNOfflinePackStateUnknown":{"title":"MLNOfflinePackStateUnknown","abstract":[{"type":"text","text":"It is unknown whether the pack is inactive, active, or complete."}],"kind":"symbol","role":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnofflinepackstate\/mlnofflinepackstateunknown","fragments":[{"text":"MLNOfflinePackStateUnknown","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/state":{"type":"topic","title":"state","role":"symbol","fragments":[{"text":"state","kind":"identifier"}],"abstract":[{"type":"text","text":"The pack’s current state."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/state","url":"\/documentation\/maplibre\/mlnofflinepack\/state","kind":"symbol"}}}