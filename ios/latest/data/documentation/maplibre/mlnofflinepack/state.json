. Alternatively, you can add an observer for"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","type":"reference"},{"type":"text","text":"s about this pack that come from the"},{"type":"text","text":" "},{"type":"text","text":"default notification center."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinepack\/state"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/state":{"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/state","fragments":[{"kind":"identifier","text":"state"}],"url":"\/documentation\/maplibre\/mlnofflinepack\/state","title":"state","type":"topic","abstract":[{"text":"The pack’s current state.","type":"text"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"type":"topic","title":"MLNOfflineStorage","url":"\/documentation\/maplibre\/mlnofflinestorage","kind":"symbol","abstract":[{"type":"text","text":"MLNOfflineStorage implements a singleton (shared object) that manages offline"},{"type":"text","text":" "},{"type":"text","text":"packs and ambient caching. All of this class’s instance methods are asynchronous,"},{"type":"text","text":" "},{"type":"text","text":"reflecting the fact that offline resources are stored in a database. The shared"},{"text":" ","type":"text"},{"text":"object maintains a canonical collection of offline packs in its ","type":"text"},{"code":"packs","type":"codeVoice"},{"text":" property.","type":"text"}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","fragments":[{"kind":"identifier","text":"MLNOfflineStorage"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackState/MLNOfflinePackStateUnknown":{"role":"symbol","kind":"symbol","title":"MLNOfflinePackStateUnknown","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown","url":"\/documentation\/maplibre\/mlnofflinepackstate\/mlnofflinepackstateunknown","abstract":[{"text":"It is unknown whether the pack is inactive, active, or complete.","type":"text"}],"fragments":[{"kind":"identifier","text":"MLNOfflinePackStateUnknown"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol","role":"collection","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"url":"\/documentation\/maplibre","title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackState":{"abstract":[{"type":"text","text":"The state an offline pack is currently in."}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState","title":"MLNOfflinePackState","kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinepackstate","type":"topic","fragments":[{"kind":"identifier","text":"MLNOfflinePackState"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"role":"symbol","fragments":[{"kind":"identifier","text":"MLNOfflinePack"}],"url":"\/documentation\/maplibre\/mlnofflinepack","abstract":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"},{"type":"text","text":" represents a collection of resources necessary for viewing"},{"type":"text","text":" "},{"type":"text","text":"a region offline to a local database."}],"kind":"symbol","title":"MLNOfflinePack","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgressChangedNotification":{"url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification","title":"MLNOfflinePackProgressChangedNotification","type":"topic","abstract":[{"type":"text","text":"Posted by the shared "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"},{"type":"text","text":" object when an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"},{"type":"text","text":" "},{"type":"text","text":"object’s progress changes. The progress may change due to a resource being"},{"type":"text","text":" "},{"type":"text","text":"downloaded or because the pack discovers during the download that more"},{"type":"text","text":" "},{"type":"text","text":"resources are required for offline viewing. This notification is posted"},{"type":"text","text":" "},{"type":"text","text":"whenever any field in the "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" property changes."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","fragments":[{"text":"MLNOfflinePackProgressChangedNotification","kind":"identifier"}],"role":"symbol","kind":"symbol"}}}