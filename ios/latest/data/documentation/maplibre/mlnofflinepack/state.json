{"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"readonly"},{"kind":"text","text":") "},{"kind":"typeIdentifier","text":"MLNOfflinePackState","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState","preciseIdentifier":"c:@E@MLNOfflinePackState"},{"kind":"text","text":" "},{"kind":"identifier","text":"state"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The state of an inactive or completed pack is computed lazily and is set to"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown"},{"type":"text","text":" by default. To request the pack’s status, use"},{"type":"text","text":" "},{"type":"text","text":"the"},{"type":"text","text":" "},{"code":"-requestProgress","type":"codeVoice"},{"type":"text","text":" method. To get notified when the state becomes known and"},{"type":"text","text":" "},{"type":"text","text":"when it changes, observe KVO change notifications on this pack’s "},{"code":"state","type":"codeVoice"},{"type":"text","text":" key"},{"type":"text","text":" "},{"type":"text","text":"path. Alternatively, you can add an observer for"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification"},{"type":"text","text":"s about this pack that come from the"},{"type":"text","text":" "},{"type":"text","text":"default notification center."}],"type":"paragraph"}],"kind":"content"}],"sections":[],"kind":"symbol","identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/state","interfaceLanguage":"occ"},"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinepack\/state"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"symbolKind":"property","navigatorTitle":[{"text":"state","kind":"identifier"}],"title":"state","externalID":"c:objc(cs)MLNOfflinePack(py)state","fragments":[{"kind":"identifier","text":"state"}],"modules":[{"name":"MapLibre"}],"role":"symbol","roleHeading":"Instance Property"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"abstract":[{"text":"The pack’s current state.","type":"text"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackState/MLNOfflinePackStateUnknown":{"title":"MLNOfflinePackStateUnknown","role":"symbol","type":"topic","fragments":[{"text":"MLNOfflinePackStateUnknown","kind":"identifier"}],"kind":"symbol","abstract":[{"text":"It is unknown whether the pack is inactive, active, or complete.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown","url":"\/documentation\/maplibre\/mlnofflinepackstate\/mlnofflinepackstateunknown"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackState":{"role":"symbol","kind":"symbol","title":"MLNOfflinePackState","abstract":[{"type":"text","text":"The state an offline pack is currently in."}],"fragments":[{"text":"MLNOfflinePackState","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState","url":"\/documentation\/maplibre\/mlnofflinepackstate","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"type":"topic","role":"symbol","fragments":[{"text":"MLNOfflinePack","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnofflinepack","identifier":"doc:\/\/org.swift.MyProject\