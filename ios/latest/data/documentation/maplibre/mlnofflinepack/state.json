text","text":" "},{"type":"text","text":"path. Alternatively, you can add an observer for"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification"},{"type":"text","text":"s about this pack that come from the"},{"type":"text","text":" "},{"type":"text","text":"default notification center."}]}],"kind":"content"}],"sections":[],"metadata":{"role":"symbol","externalID":"c:objc(cs)MLNOfflinePack(py)state","title":"state","symbolKind":"property","fragments":[{"text":"state","kind":"identifier"}],"navigatorTitle":[{"text":"state","kind":"identifier"}],"roleHeading":"Instance Property","modules":[{"name":"MapLibre"}]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackState/MLNOfflinePackStateUnknown":{"url":"\/documentation\/maplibre\/mlnofflinepackstate\/mlnofflinepackstateunknown","abstract":[{"type":"text","text":"It is unknown whether the pack is inactive, active, or complete."}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown","fragments":[{"kind":"identifier","text":"MLNOfflinePackStateUnknown"}],"type":"topic","title":"MLNOfflinePackStateUnknown"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackState":{"fragments":[{"kind":"identifier","text":"MLNOfflinePackState"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState","abstract":[{"text":"The state an offline pack is currently in.","type":"text"}],"kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlnofflinepackstate","type":"topic","title":"MLNOfflinePackState"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinepack","role":"symbol","t