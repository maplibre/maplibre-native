ibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinepack\/state"]}],"metadata":{"fragments":[{"kind":"identifier","text":"state"}],"modules":[{"name":"MapLibre"}],"roleHeading":"Instance Property","role":"symbol","title":"state","symbolKind":"property","externalID":"c:objc(cs)MLNOfflinePack(py)state","navigatorTitle":[{"text":"state","kind":"identifier"}]},"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/state","interfaceLanguage":"occ"},"sections":[],"abstract":[{"text":"The pack’s current state.","type":"text"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","abstract":[{"text":"An ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","type":"reference"},{"text":" represents a collection of resources necessary for viewing","type":"text"},{"text":" ","type":"text"},{"text":"a region offline to a local database.","type":"text"}],"kind":"symbol","role":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnofflinepack","fragments":[{"text":"MLNOfflinePack","kind":"identifier"}],"title":"MLNOfflinePack"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackState/MLNOfflinePackStateUnknown":{"kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinepackstate\/mlnofflinepackstateunknown","title":"MLNOfflinePackStateUnknown","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown","role":"symbol","abstract":[{"type":"text","text":"It is unknown whether the pack is inactive, active, or complete."}],"type":"topic","fragments":[{"kind":"identifier","text":"MLNOfflinePackStateUnknown"}]},"doc://org.swift.M