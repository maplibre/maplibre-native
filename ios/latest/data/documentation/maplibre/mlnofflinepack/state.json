ibre\/mlnofflinestorage","role":"symbol","abstract":[{"type":"text","text":"MLNOfflineStorage implements a singleton (shared object) that manages offline"},{"type":"text","text":" "},{"type":"text","text":"packs and ambient caching. All of this class’s instance methods are asynchronous,"},{"type":"text","text":" "},{"type":"text","text":"reflecting the fact that offline resources are stored in a database. The shared"},{"type":"text","text":" "},{"type":"text","text":"object maintains a canonical collection of offline packs in its "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/state":{"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/state","role":"symbol","type":"topic","fragments":[{"text":"state","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnofflinepack\/state","title":"state","abstract":[{"text":"The pack’s current state.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackState":{"fragments":[{"text":"MLNOfflinePackState","kind":"identifier"}],"type":"topic","kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlnofflinepackstate","abstract":[{"type":"text","text":"The state an offline pack is currently in."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState","title":"MLNOfflinePackState"}}}