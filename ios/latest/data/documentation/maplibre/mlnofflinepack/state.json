e."}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinepack\/state"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/state","interfaceLanguage":"occ"},"metadata":{"role":"symbol","title":"state","externalID":"c:objc(cs)MLNOfflinePack(py)state","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"text":"state","kind":"identifier"}],"roleHeading":"Instance Property","fragments":[{"kind":"identifier","text":"state"}],"symbolKind":"property"},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol","role":"collection","type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackState":{"abstract":[{"text":"The state an offline pack is currently in.","type":"text"}],"role":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnofflinepackstate","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState","title":"MLNOfflinePackState","kind":"symbol","fragments":[{"kind":"identifier","text":"MLNOfflinePackState"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackState/MLNOfflinePackStateUnknown":{"abstract":[{"type":"text","text":"It is unknown whether the pack is inactive, active, or complete."}],"role":"symbol","type":"topic","title":"MLNOfflinePackStateUnknown","url":"\/documentation\/maplibre\/mlnofflinepackstate\/mlnofflinepackstateunknown","kind":"symbol","fragments":[{"kind":"identifier","text":"MLNOfflinePackStateUnknown"}],"identifi