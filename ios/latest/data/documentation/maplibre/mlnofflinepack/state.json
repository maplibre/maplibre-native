":"text","text":"downloaded or because the pack discovers during the download that more"},{"type":"text","text":" "},{"type":"text","text":"resources are required for offline viewing. This notification is posted"},{"type":"text","text":" "},{"type":"text","text":"whenever any field in the "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" property changes."}],"type":"topic","role":"symbol","url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackState":{"url":"\/documentation\/maplibre\/mlnofflinepackstate","fragments":[{"kind":"identifier","text":"MLNOfflinePackState"}],"kind":"symbol","title":"MLNOfflinePackState","abstract":[{"type":"text","text":"The state an offline pack is currently in."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState","role":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/state":{"kind":"symbol","abstract":[{"text":"The pack’s current state.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/state","type":"topic","title":"state","url":"\/documentation\/maplibre\/mlnofflinepack\/state","role":"symbol","fragments":[{"text":"state","kind":"identifier"}]}}}