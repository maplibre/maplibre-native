{"metadata":{"externalID":"c:objc(cs)MLNOfflinePack(py)state","fragments":[{"text":"state","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"text":"state","kind":"identifier"}],"symbolKind":"property","roleHeading":"Instance Property","modules":[{"name":"MapLibre"}],"title":"state"},"abstract":[{"type":"text","text":"The pack’s current state."}],"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/state","interfaceLanguage":"occ"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"readonly","kind":"keyword"},{"text":") ","kind":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState","text":"MLNOfflinePackState","preciseIdentifier":"c:@E@MLNOfflinePackState","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"state","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The state of an inactive or completed pack is computed lazily and is set to"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown","isActive":true},{"type":"text","text":" by default. To request the pack’s status, use"},{"type":"text","text":" "},{"type":"text","text":"the"},{"type":"text","text":" "},{"type":"codeVoice","code":"-requestProgress"},{"type":"text","text":" method. To get notified when the state becomes known and"},{"type":"text","text":" "},{"type":"text","text":"when it changes, observe KVO change notifications on this pack’s "},{"type":"codeVoice","code":"state"},{"type":"text","text":" key"},{"type":"text","text":" "},{"type":"text","text":"path. Alternatively, you can add an observer for"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","isActive":true},{"type":"text","text":"s about this pack that come from the"},{"type":"text","text":" "},{"type":"text","text":"default notification center."}]}],"kind":"content"}],"kind":"symbol","variants":[{"paths":["\/documentation\/maplibre\/mlnofflinepack\/state"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/state":{"fragments":[{"text":"state","kind":"identifier"}],"abstract":[{"type":"text","text":"The pack’s current state."}],"url":"\/documentation\/maplibre\/mlnofflinepack\/state","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/state","role":"symbol","title":"state","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","url":"\/documentation\/maplibre","kind":"symbol","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackState":{"kind":"symbol","title":"MLNOfflinePackState","type":"topic","url":"\/documentation\/maplibre\/mlnofflinepackstate","role":"symbol","fragments":[{"text":"MLNOfflinePackState","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState","abstract":[{"type":"text","text":"The state an offline pack is currently in."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgressChangedNotification":{"kind":"symbol","title":"MLNOfflinePackProgressChangedNotification","type":"topic","url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification","role":"symbol","fragments":[{"text":"MLNOfflinePackProgressChangedNotification","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","abstract":[{"type":"text","text":"Posted by the shared "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","isActive":true},{"type":"text","text":" object when an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true},{"type":"text","text":" "},{"type":"text","text":"object’s progress changes. The progress may change due to a resource being"},{"type":"text","text":" "},{"type":"text","text":"downloaded or because the pack discovers during the download that more"},{"type":"text","text":" "},{"type":"text","text":"resources are required for offline viewing. This notification is posted"},{"type":"text","text":" "},{"type":"text","text":"whenever any field in the "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" property changes."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"kind":"symbol","title":"MLNOfflinePack","type":"topic","url":"\/documentation\/maplibre\/mlnofflinepack","role":"symbol","fragments":[{"text":"MLNOfflinePack","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true},{"type":"text","text":" represents a collection of resources necessary for viewing"},{"type":"text","text":" "},{"type":"text","text":"a region offline to a local database."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackState/MLNOfflinePackStateUnknown":{"kind":"symbol","title":"MLNOfflinePackStateUnknown","type":"topic","url":"\/documentation\/maplibre\/mlnofflinepackstate\/mlnofflinepackstateunknown","role":"symbol","fragments":[{"text":"MLNOfflinePackStateUnknown","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown","abstract":[{"type":"text","text":"It is unknown whether the pack is inactive, active, or complete."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"type":"topic","abstract":[{"type":"text","text":"MLNOfflineStorage implements a singleton (shared object) that manages offline"},{"type":"text","text":" "},{"type":"text","text":"packs and ambient caching. All of this class’s instance methods are asynchronous,"},{"type":"text","text":" "},{"type":"text","text":"reflecting the fact that offline resources are stored in a database. The shared"},{"type":"text","text":" "},{"type":"text","text":"object maintains a canonical collection of offline packs in its "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","title":"MLNOfflineStorage","url":"\/documentation\/maplibre\/mlnofflinestorage","fragments":[{"text":"MLNOfflineStorage","kind":"identifier"}],"kind":"symbol","role":"symbol"}}}