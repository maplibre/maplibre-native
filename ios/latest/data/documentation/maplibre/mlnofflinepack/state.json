ely, you can add an observer for"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","type":"reference","isActive":true},{"type":"text","text":"s about this pack that come from the"},{"type":"text","text":" "},{"type":"text","text":"default notification center."}]}]}],"abstract":[{"type":"text","text":"The pack’s current state."}],"metadata":{"roleHeading":"Instance Property","symbolKind":"property","externalID":"c:objc(cs)MLNOfflinePack(py)state","modules":[{"name":"MapLibre"}],"title":"state","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"state"}],"fragments":[{"kind":"identifier","text":"state"}]},"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"url":"\/documentation\/maplibre\/mlnofflinestorage","fragments":[{"text":"MLNOfflineStorage","kind":"identifier"}],"abstract":[{"type":"text","text":"MLNOfflineStorage implements a singleton (shared object) that manages offline"},{"type":"text","text":" "},{"type":"text","text":"packs and ambient caching. All of this class’s instance methods are asynchronous,"},{"type":"text","text":" "},{"type":"text","text":"reflecting the fact that offline resources are stored in a database. The shared"},{"type":"text","text":" "},{"type":"text","text":"object maintains a canonical collection of offline packs in its "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property."}],"kind":"symbol","role":"symbol","type":"topic","title":"MLNOfflineStorage","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgressChangedNotification":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","fragments":[{"text":"MLNOfflinePackProgressChangedNotification","kind":"identifier"}],"abstract":[{