ut this pack that come from the"},{"type":"text","text":" "},{"type":"text","text":"default notification center."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinepack\/state"]}],"metadata":{"modules":[{"name":"MapLibre"}],"role":"symbol","symbolKind":"property","externalID":"c:objc(cs)MLNOfflinePack(py)state","fragments":[{"kind":"identifier","text":"state"}],"navigatorTitle":[{"text":"state","kind":"identifier"}],"roleHeading":"Instance Property","title":"state"},"abstract":[{"type":"text","text":"The pack’s current state."}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/state":{"type":"topic","url":"\/documentation\/maplibre\/mlnofflinepack\/state","title":"state","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/state","abstract":[{"type":"text","text":"The pack’s current state."}],"fragments":[{"kind":"identifier","text":"state"}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","type":"reference","isActive":true},{"type":"text","text":" represents a collection of resources necessary for viewing"},{"type":"text","text":" "},{"type":"text","text":"a region offline to a local database."}],"type":"topic","url":"\/documentation\/maplibre\/mlnofflinepack","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","role":"symbol","fragments":[{"kind":"identifier","text":"MLNOfflinePack"}],"title":"MLNOfflinePack"},"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","url":"\/documentation\/maplibre","title":"MapLibre","kind":"symbol","identifier":"doc