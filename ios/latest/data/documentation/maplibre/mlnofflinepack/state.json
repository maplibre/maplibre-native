k’s "},{"type":"codeVoice","code":"state"},{"type":"text","text":" key"},{"type":"text","text":" "},{"type":"text","text":"path. Alternatively, you can add an observer for"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification"},{"type":"text","text":"s about this pack that come from the"},{"type":"text","text":" "},{"type":"text","text":"default notification center."}]}]}],"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinepack\/state"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/state","interfaceLanguage":"occ"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackState/MLNOfflinePackStateUnknown":{"fragments":[{"kind":"identifier","text":"MLNOfflinePackStateUnknown"}],"title":"MLNOfflinePackStateUnknown","role":"symbol","abstract":[{"type":"text","text":"It is unknown whether the pack is inactive, active, or complete."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown","type":"topic","url":"\/documentation\/maplibre\/mlnofflinepackstate\/mlnofflinepackstateunknown","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/state":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/state","fragments":[{"kind":"identifier","text":"state"}],"kind":"symbol","title":"state","url":"\/documentation\/maplibre\/mlnofflinepack\/state","type":"topic","abstract":[{"type":"text","text":"The pack’s current state."}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","url":"\/documentation\/maplibre","kind":"symbol","type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control 