documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","abstract":[{"text":"Posted by the shared ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","type":"reference"},{"text":" object when an ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"},{"text":" ","type":"text"},{"type":"text","text":"object’s progress changes. The progress may change due to a resource being"},{"type":"text","text":" "},{"text":"downloaded or because the pack discovers during the download that more","type":"text"},{"type":"text","text":" "},{"type":"text","text":"resources are required for offline viewing. This notification is posted"},{"text":" ","type":"text"},{"type":"text","text":"whenever any field in the "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" property changes."}],"fragments":[{"kind":"identifier","text":"MLNOfflinePackProgressChangedNotification"}],"url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification","type":"topic","title":"MLNOfflinePackProgressChangedNotification","kind":"symbol","role":"symbol"}}}