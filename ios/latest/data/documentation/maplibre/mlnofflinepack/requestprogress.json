Voice","code":"progress"},{"type":"text","text":" property changes."}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","title":"MapLibre","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","kind":"symbol","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/requestProgress":{"url":"\/documentation\/maplibre\/mlnofflinepack\/requestprogress","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"requestProgress"}],"title":"requestProgress","role":"symbol","abstract":[{"type":"text","text":"Request an asynchronous update to the pack’s "},{"type":"codeVoice","code":"state"},{"type":"text","text":" and "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" properties."}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/requestProgress","type":"topic"}}}