:"text","text":"observer for "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","isActive":true},{"type":"text","text":" about this pack that"},{"type":"text","text":" "},{"type":"text","text":"come from the default notification center."}]}],"kind":"content"}],"abstract":[{"text":"Request an asynchronous update to the pack’s ","type":"text"},{"code":"state","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"progress","type":"codeVoice"},{"text":" properties.","type":"text"}],"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinepack\/requestprogress"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/requestProgress":{"abstract":[{"type":"text","text":"Request an asynchronous update to the pack’s "},{"code":"state","type":"codeVoice"},{"type":"text","text":" and "},{"code":"progress","type":"codeVoice"},{"type":"text","text":" properties."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/requestProgress","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"requestProgress"}],"role":"symbol","title":"requestProgress","url":"\/documentation\/maplibre\/mlnofflinepack\/requestprogress","kind":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","url":"\/documentation\/maplibre\/mlnofflinepack","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","type":"reference","isActive":true},{"type":"text","text":" represents a collection of resources necessary for viewing"},{"type":"text","text":" "},{"type":"text","text":"a region offline to a local database."}],"title":"MLNOfflinePack","kind":"symbol","role":"symbol","fragments":[{"text":"MLNOfflinePack","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackState/MLNOfflinePackStateUnknown":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown","url":"\/documentation\/maplibre\/mlnofflinepackstate\/mlnofflinepackstateunknown","abstract":[{"type":"text","text":"It is unknown whether the pack is inactive, active, or complete."}],"title":"MLNOfflinePackStateUnknown","kind":"symbol","role":"symbol","fragments":[{"text":"MLNOfflinePackStateUnknown","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgressChangedNotification":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification","type":"topic","abstract":[{"type":"text","text":"Posted by the shared "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","isActive":true,"type":"reference"},{"type":"text","text":" object when an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"object’s progress changes. The progress may change due to a resource being"},{"type":"text","text":" "},{"type":"text","text":"downloaded or because the pack discovers during the download that more"},{"type":"text","text":" "},{"type":"text","text":"resources are required for offline viewing. This notification is posted"},{"type":"text","text":" "},{"type":"text","text":"whenever any field in the "},{"code":"progress","type":"codeVoice"},{"type":"text","text":" property changes."}],"title":"MLNOfflinePackProgressChangedNotification","kind":"symbol","role":"symbol","fragments":[{"kind":"identifier","text":"MLNOfflinePackProgressChangedNotification"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","role":"collection","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"title":"MLNOfflineStorage","role":"symbol","fragments":[{"text":"MLNOfflineStorage","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","url":"\/documentation\/maplibre\/mlnofflinestorage","abstract":[{"text":"MLNOfflineStorage implements a singleton (shared object) that manages offline","type":"text"},{"text":" ","type":"text"},{"text":"packs and ambient caching. All of this class’s instance methods are asynchronous,","type":"text"},{"text":" ","type":"text"},{"text":"reflecting the fact that offline resources are stored in a database. The shared","type":"text"},{"text":" ","type":"text"},{"text":"object maintains a canonical collection of offline packs in its ","type":"text"},{"code":"packs","type":"codeVoice"},{"text":" property.","type":"text"}],"kind":"symbol"}}}