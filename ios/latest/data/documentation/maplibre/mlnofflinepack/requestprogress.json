{"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","sections":[],"abstract":[{"text":"Request an asynchronous update to the pack’s ","type":"text"},{"code":"state","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"progress"},{"type":"text","text":" properties."}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"text","text":"- ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"requestProgress"},{"kind":"text","text":";"}],"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The state and progress of an inactive or completed pack are computed lazily. If"},{"type":"text","text":" "},{"type":"text","text":"you need the state or progress of a pack whose "},{"code":"state","type":"codeVoice"},{"type":"text","text":" property is currently"},{"type":"text","text":" "},{"type":"text","text":"set to "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown","type":"reference","isActive":true},{"type":"text","text":", observe KVO change notifications on this"},{"type":"text","text":" "},{"type":"text","text":"pack’s "},{"code":"state","type":"codeVoice"},{"type":"text","text":" key path, then call this method. Alternatively, you can add an"},{"type":"text","text":" "},{"type":"text","text":"observer for "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","type":"reference","isActive":true},{"type":"text","text":" about this pack that"},{"type":"text","text":" "},{"type":"text","text":"come from the default notification center."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflin