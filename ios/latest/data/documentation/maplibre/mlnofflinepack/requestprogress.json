":"text"}]}],"kind":"content"}],"sections":[],"kind":"symbol","abstract":[{"text":"Request an asynchronous update to the pack’s ","type":"text"},{"code":"state","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"progress","type":"codeVoice"},{"text":" properties.","type":"text"}],"metadata":{"role":"symbol","roleHeading":"Instance Method","externalID":"c:objc(cs)MLNOfflinePack(im)requestProgress","fragments":[{"text":"- ","kind":"text"},{"text":"requestProgress","kind":"identifier"}],"title":"requestProgress","navigatorTitle":[{"text":"requestProgress","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"symbolKind":"method"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"type":"topic","role":"symbol","url":"\/documentation\/maplibre\/mlnofflinestorage","kind":"symbol","title":"MLNOfflineStorage","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","abstract":[{"type":"text","text":"MLNOfflineStorage implements a singleton (shared object) that manages offline"},{"type":"text","text":" "},{"type":"text","text":"packs and ambient caching. All of this class’s instance methods are asynchronous,"},{"type":"text","text":" "},{"type":"text","text":"reflecting the fact that offline resources are stored in a database. The shared"},{"type":"text","text":" "},{"type":"text","text":"object maintains a canonical collection of offline packs in its "},{"code":"packs","type":"codeVoice"},{"type":"text","text":" property."}],"fragments":[{"kind":"identifier","text":"MLNOfflineStorage"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgressChangedNotification":{"kind":"symbol","abstract":[{"type":"text","text":"Posted by the shared "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"},{"type":"text","text":" object when an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documen