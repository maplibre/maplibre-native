rces are stored in a database. The shared"},{"type":"text","text":" "},{"type":"text","text":"object maintains a canonical collection of offline packs in its "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property."}],"url":"\/documentation\/maplibre\/mlnofflinestorage","title":"MLNOfflineStorage","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","fragments":[{"text":"MLNOfflineStorage","kind":"identifier"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/requestProgress":{"title":"requestProgress","navigatorTitle":[{"text":"requestProgress","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/requestProgress","url":"\/documentation\/maplibre\/mlnofflinepack\/requestprogress","kind":"symbol","abstract":[{"text":"Request an asynchronous update to the pack’s ","type":"text"},{"type":"codeVoice","code":"state"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"progress"},{"text":" properties.","type":"text"}],"fragments":[{"text":"- ","kind":"text"},{"text":"requestProgress","kind":"identifier"}],"type":"topic","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true},{"type":"text","text":" represents a collection of resources necessary for viewing"},{"type":"text","text":" "},{"type":"text","text":"a region offline to a local database."}],"fragments":[{"kind":"identifier","text":"MLNOfflinePack"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","title":"MLNOfflinePack","url":"\/documentation\/maplibre\/mlnofflinepack","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgressChangedNotification":{"identifier":"doc:\/\/org.swi