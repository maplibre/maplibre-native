{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"text":"- (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"requestProgress","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"]}]},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The state and progress of an inactive or completed pack are computed lazily. If"},{"type":"text","text":" "},{"type":"text","text":"you need the state or progress of a pack whose "},{"code":"state","type":"codeVoice"},{"type":"text","text":" property is currently"},{"type":"text","text":" "},{"type":"text","text":"set to "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown"},{"type":"text","text":", observe KVO change notifications on this"},{"type":"text","text":" "},{"type":"text","text":"pack’s "},{"code":"state","type":"codeVoice"},{"type":"text","text":" key path, then call this method. Alternatively, you can add an"},{"type":"text","text":" "},{"type":"text","text":"observer for "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification"},{"type":"text","text":" about this pack that"},{"type":"text","text":" "},{"type":"text","text":"come from the default notification center."}]}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinepack\/requestprogress"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"symbol","metadata":{"navigatorTitle":[{"text":"requestProgress","kind":"identifier"}],"roleHead