MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","type":"reference"},{"text":" about this pack that","type":"text"},{"text":" ","type":"text"},{"text":"come from the default notification center.","type":"text"}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"abstract":[{"type":"text","text":"Request an asynchronous update to the pack’s "},{"type":"codeVoice","code":"state"},{"type":"text","text":" and "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" properties."}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackState/MLNOfflinePackStateUnknown":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown","url":"\/documentation\/maplibre\/mlnofflinepackstate\/mlnofflinepackstateunknown","abstract":[{"type":"text","text":"It is unknown whether the pack is inactive, active, or complete."}],"title":"MLNOfflinePackStateUnknown","role":"symbol","fragments":[{"kind":"identifier","text":"MLNOfflinePackStateUnknown"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"type":"topic","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"role":"symbol","title":"MLNOfflineStorage","fragments":[{"kind":"identifier","text":"MLNOfflineStorage"}],"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"MLNOfflineStorage implements a singleton (shared object) that manages offline"},{"type":"text","text":" "},{"type":"text","text":"packs and ambient caching. All of this class’s ins