{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/requestProgress"},"metadata":{"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"requestProgress"}],"modules":[{"name":"MapLibre"}],"roleHeading":"Instance Method","role":"symbol","symbolKind":"method","navigatorTitle":[{"kind":"identifier","text":"requestProgress"}],"externalID":"c:objc(cs)MLNOfflinePack(im)requestProgress","title":"requestProgress"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"- ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"requestProgress"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The state and progress of an inactive or completed pack are computed lazily. If"},{"type":"text","text":" "},{"type":"text","text":"you need the state or progress of a pack whose "},{"type":"codeVoice","code":"state"},{"type":"text","text":" property is currently"},{"type":"text","text":" "},{"type":"text","text":"set to "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown","isActive":true,"type":"reference"},{"type":"text","text":", observe KVO change notifications on this"},{"type":"text","text":" "},{"type":"text","text":"pack’s "},{"type":"codeVoice","code":"state"},{"type":"text","text":" key path, then call this method. Alternatively, you can add an"},{"type":"text","text":" "},{"type":"text","text":"observer for "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","isActive":true,"type":"reference"},{"type":"text","text":" about this pack that"},{"type":"text","text":" "},{"type":"text","text":"come from the default notification center."}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinepack\/requestprogress"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"abstract":[{"type":"text","text":"Request an asynchronous update to the pack’s "},{"code":"state","type":"codeVoice"},{"type":"text","text":" and "},{"code":"progress","type":"codeVoice"},{"type":"text","text":" properties."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackState/MLNOfflinePackStateUnknown":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown","abstract":[{"type":"text","text":"It is unknown whether the pack is inactive, active, or complete."}],"type":"topic","role":"symbol","url":"\/documentation\/maplibre\/mlnofflinepackstate\/mlnofflinepackstateunknown","fragments":[{"kind":"identifier","text":"MLNOfflinePackStateUnknown"}],"title":"MLNOfflinePackStateUnknown","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic","url":"\/documentation\/maplibre","title":"MapLibre","kind":"symbol","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgressChangedNotification":{"kind":"symbol","abstract":[{"type":"text","text":"Posted by the shared "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","isActive":true},{"type":"text","text":" object when an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true},{"type":"text","text":" "},{"type":"text","text":"object’s progress changes. The progress may change due to a resource being"},{"type":"text","text":" "},{"type":"text","text":"downloaded or because the pack discovers during the download that more"},{"type":"text","text":" "},{"type":"text","text":"resources are required for offline viewing. This notification is posted"},{"type":"text","text":" "},{"type":"text","text":"whenever any field in the "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" property changes."}],"title":"MLNOfflinePackProgressChangedNotification","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","role":"symbol","fragments":[{"kind":"identifier","text":"MLNOfflinePackProgressChangedNotification"}],"url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"url":"\/documentation\/maplibre\/mlnofflinestorage","fragments":[{"text":"MLNOfflineStorage","kind":"identifier"}],"kind":"symbol","type":"topic","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","abstract":[{"type":"text","text":"MLNOfflineStorage implements a singleton (shared object) that manages offline"},{"type":"text","text":" "},{"type":"text","text":"packs and ambient caching. All of this class’s instance methods are asynchronous,"},{"type":"text","text":" "},{"type":"text","text":"reflecting the fact that offline resources are stored in a database. The shared"},{"type":"text","text":" "},{"type":"text","text":"object maintains a canonical collection of offline packs in its "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property."}],"title":"MLNOfflineStorage"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/requestProgress":{"url":"\/documentation\/maplibre\/mlnofflinepack\/requestprogress","