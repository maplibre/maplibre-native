{"kind":"symbol","metadata":{"modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNOfflinePack(im)requestProgress","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"requestProgress"}],"title":"requestProgress","roleHeading":"Instance Method","navigatorTitle":[{"kind":"text","text":"- "},{"kind":"identifier","text":"requestProgress"}],"symbolKind":"method","role":"symbol"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"abstract":[{"type":"text","text":"Request an asynchronous update to the pack’s "},{"type":"codeVoice","code":"state"},{"type":"text","text":" and "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" properties."}],"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinepack\/requestprogress"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"text","text":"- ("},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"kind":"identifier","text":"requestProgress"},{"kind":"text","text":";"}],"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The state and progress of an inactive or completed pack are computed lazily. If"},{"type":"text","text":" "},{"type":"text","text":"you need the state or progress of a pack whose "},{"type":"codeVoice","code":"state"},{"type":"text","text":" property is currently"},{"type":"text","text":" "},{"type":"text","text":"set to "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown","isActive":true},{"type":"text","text":", observe KVO change notifications on this"},{"type":"text","text":" "},{"type":"text","text":"pack’s "},{"t