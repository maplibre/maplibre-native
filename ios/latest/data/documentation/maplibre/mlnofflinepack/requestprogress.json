{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/requestProgress"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinepack\/requestprogress"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"- (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"requestProgress"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS","iPadOS","Mac Catalyst"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"The state and progress of an inactive or completed pack are computed lazily. If"},{"type":"text","text":" "},{"type":"text","text":"you need the state or progress of a pack whose "},{"code":"state","type":"codeVoice"},{"text":" property is currently","type":"text"},{"type":"text","text":" "},{"type":"text","text":"set to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown"},{"type":"text","text":", observe KVO change notifications on this"},{"text":" ","type":"text"},{"text":"pack’s ","type":"text"},{"type":"codeVoice","code":"state"},{"type":"text","text":" key path, then call this method. Alternatively, you can add an"},{"text":" ","type":"text"},{"type":"text","text":"observer for "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification"},{"text":" about this pack that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"come from the default notification center."}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"type":"text","text":"Request an asynchronous update to the pack’s "},{"type":"codeVoice","code":"state"},{"type":"text","text":" and "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" properties."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"roleHeading":"Instance Method","role":"symbol","title":"requestProgress","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"kind":"text","text":"- "},{"kind":"identifier","text":"requestProgress"}],"externalID":"c:objc(cs)MLNOfflinePack(im)requestProgress","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"requestProgress"}],"symbolKind":"method"},"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"kind":"symbol","references":{"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","title":"MapLibre","url":"\/documentation\/maplibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","abstract":[{"text":"MLNOfflineStorage implements a singleton (shared object) that manages offline","type":"text"},{"text":" ","type":"text"},{"text":"packs and ambient caching. All of this class’s instance methods are asynchronous,","type":"text"},{"text":" ","type":"text"},{"text":"reflecting the fact that offline resources are stored in a database. The shared","type":"text"},{"text":" ","type":"text"},{"text":"object maintains a canonical collection of offline packs in its ","type":"text"},{"code":"packs","type":"codeVoice"},{"text":" property.","type":"text"}],"fragments":[{"kind":"identifier","text":"MLNOfflineStorage"}],"kind":"symbol","title":"MLNOfflineStorage","type":"topic","url":"\/documentation\/maplibre\/mlnofflinestorage","role":"symbol"},"doc://org