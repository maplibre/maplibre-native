,"text":" "},{"type":"text","text":"downloaded or because the pack discovers during the download that more"},{"type":"text","text":" "},{"type":"text","text":"resources are required for offline viewing. This notification is posted"},{"type":"text","text":" "},{"type":"text","text":"whenever any field in the "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" property changes."}],"kind":"symbol","role":"symbol","type":"topic","title":"MLNOfflinePackProgressChangedNotification","url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/requestProgress":{"title":"requestProgress","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/requestProgress","type":"topic","url":"\/documentation\/maplibre\/mlnofflinepack\/requestprogress","fragments":[{"text":"- ","kind":"text"},{"text":"requestProgress","kind":"identifier"}],"abstract":[{"type":"text","text":"Request an asynchronous update to the pack’s "},{"code":"state","type":"codeVoice"},{"type":"text","text":" and "},{"code":"progress","type":"codeVoice"},{"type":"text","text":" properties."}],"role":"symbol","kind":"symbol"}}}