type":"text","text":" "},{"type":"text","text":"whenever any field in the "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" property changes."}]},"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","url":"\/documentation\/maplibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/requestProgress":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/requestProgress","fragments":[{"text":"- ","kind":"text"},{"text":"requestProgress","kind":"identifier"}],"title":"requestProgress","navigatorTitle":[{"text":"requestProgress","kind":"identifier"}],"type":"topic","abstract":[{"text":"Request an asynchronous update to the pack’s ","type":"text"},{"code":"state","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"progress","type":"codeVoice"},{"text":" properties.","type":"text"}],"url":"\/documentation\/maplibre\/mlnofflinepack\/requestprogress","role":"symbol","kind":"symbol"}}}