{"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/requestProgress","interfaceLanguage":"occ"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinepack\/requestprogress"]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"abstract":[{"type":"text","text":"Request an asynchronous update to the pack’s "},{"type":"codeVoice","code":"state"},{"type":"text","text":" and "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" properties."}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"- (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"requestProgress","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The state and progress of an inactive or completed pack are computed lazily. If"},{"type":"text","text":" "},{"type":"text","text":"you need the state or progress of a pack whose "},{"type":"codeVoice","code":"state"},{"type":"text","text":" property is currently"},{"type":"text","text":" "},{"type":"text","text":"set to "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackState\/MLNOfflinePackStateUnknown","isActive":true},{"type":"text","text":", observe KVO change notifications on this"},{"type":"text","text":" "},{"type":"text","text":"pack’s "},{"type":"codeVoice","code":"state"},{"type":"text","text":" key path, then call this method. Alternatively, you can add an"},{"type":"text","text":" "},{"type":"text","text":"observer for "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNo