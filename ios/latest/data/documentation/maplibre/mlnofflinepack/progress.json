{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinepack\/progress"]}],"primaryContentSections":[{"declarations":[{"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"readonly","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:@S@MLNOfflinePackProgress","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","text":"MLNOfflinePackProgress","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"progress","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"text":"The progress of an inactive or completed pack is computed lazily, and all its","type":"text"},{"text":" ","type":"text"},{"text":"fields are set to 0 by default. To request the pack’s progress, use the","type":"text"},{"text":" ","type":"text"},{"code":"-requestProgress","type":"codeVoice"},{"text":" method. To get notified when the progress becomes","type":"text"},{"text":" ","type":"text"},{"text":"known and when it changes, observe KVO change notifications on this pack’s","type":"text"},{"text":" ","type":"text"},{"code":"state","type":"codeVoice"},{"text":" key path. Alternatively, you can add an observer for","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","type":"reference","isActive":true},{"text":"s about this pack that come from the","type":"text"},{"text":" ","type":"text"},{"text":"default notification center.","type":"text"}],"type":"paragraph"}]}],"abstract":[{"type":"text","text":"The pack’s current progress."}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"sections":[],"metadata":{"roleHeading":"Instance Property","role":"symbol","externalID":"c:objc(cs)MLNOfflinePack(py)progress","modules":[{"name":"MapLibre"}],"symbolKind":"property","navigatorTitle":[{"kind":"identifier","text":"progress"}],"title":"progress","fragments":[{"kind":"identifier","text":"progress"}]},"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/progress":{"title":"progress","abstract":[{"type":"text","text":"The pack’s current progress."}],"type":"topic","url":"\/documentation\/maplibre\/mlnofflinepack\/progress","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress","role":"symbol","fragments":[{"text":"progress","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"url":"\/documentation\/maplibre\/mlnofflinepack","kind":"symbol","abstract":[{"text":"An ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","type":"reference"},{"text":" represents a collection of resources necessary for viewing","type":"text"},{"text":" ","type":"text"},{"text":"a region offline to a local database.","type":"text"}],"role":"symbol","title":"MLNOfflinePack","fragments":[{"text":"MLNOfflinePack","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgressChangedNotification":{"title":"MLNOfflinePackProgressChangedNotification","role":"symbol","kind":"symbol","type":"topic","fragments":[{"text":"MLNOfflinePackProgressChangedNotification","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documenta