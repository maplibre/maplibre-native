"},{"text":"default notification center.","type":"text"}]}],"kind":"content"}],"metadata":{"externalID":"c:objc(cs)MLNOfflinePack(py)progress","roleHeading":"Instance Property","symbolKind":"property","role":"symbol","fragments":[{"kind":"identifier","text":"progress"}],"modules":[{"name":"MapLibre"}],"navigatorTitle":[{"kind":"identifier","text":"progress"}],"title":"progress"},"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinepack\/progress"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgress":{"type":"topic","title":"MLNOfflinePackProgress","role":"symbol","url":"\/documentation\/maplibre\/mlnofflinepackprogress","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","abstract":[{"text":"A structure containing information about an offline pack’s current download","type":"text"},{"text":" ","type":"text"},{"text":"progress.","type":"text"}],"kind":"symbol","fragments":[{"text":"MLNOfflinePackProgress","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"type":"topic","title":"MLNOfflineStorage","kind":"symbol","abstract":[{"type":"text","text":"MLNOfflineStorage implements a singleton (shared object) that manages offline"},{"type":"text","text":" "},{"type":"text","text":"packs and ambient caching. All of this class’s instance methods are asynchronous,"},{"type":"text","text":" "},{"type":"text","text":"reflecting the fact that offline resources are stored in a database. The shared"},{"type":"text","text":" "},{"type":"text","text":"object maintains a canonical collection of offline packs in its "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property."}],"url":"\/documentation\/maplibre\/mlnofflinestorage","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","fragments":[{"k