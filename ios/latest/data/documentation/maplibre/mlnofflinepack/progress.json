{"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinepack\/progress"]}],"metadata":{"symbolKind":"property","title":"progress","role":"symbol","externalID":"c:objc(cs)MLNOfflinePack(py)progress","navigatorTitle":[{"kind":"identifier","text":"progress"}],"modules":[{"name":"MapLibre"}],"roleHeading":"Instance Property","fragments":[{"text":"progress","kind":"identifier"}]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress","interfaceLanguage":"occ"},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"readonly","kind":"keyword"},{"text":") ","kind":"text"},{"text":"MLNOfflinePackProgress","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","kind":"typeIdentifier","preciseIdentifier":"c:@S@MLNOfflinePackProgress"},{"text":" ","kind":"text"},{"text":"progress","kind":"identifier"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The progress of an inactive or completed pack is computed lazily, and all its"},{"type":"text","text":" "},{"type":"text","text":"fields are set to 0 by default. To request the pack’s progress, use the"},{"type":"text","text":" "},{"type":"codeVoice","code":"-requestProgress"},{"type":"text","text":" method. To get notified when the progress becomes"},{"type":"text","text":" "},{"type":"text","text":"known and when it changes, observe KVO change notifications on this pack’s"},{"type":"text","text":" "},{"type":"codeVoice","code":"state"},{"type":"text","text":" key path. Alternatively, you can add an observer for"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","type":"reference","isActive":true},{"type":"text","text":"s about this pack that come from the"},{"type":"text","text":" "},{"type":"text","text":"default notification center."}]}]}],"abstract":[{"type":"text","text":"The pack’s current progress."}],"sections":[],"kind":"symbol","references":{"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","title":"MapLibre","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol","url":"\/documentation\/maplibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/progress":{"abstract":[{"text":"The pack’s current progress.","type":"text"}],"role":"symbol","url":"\/documentation\/maplibre\/mlnofflinepack\/progress","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress","kind":"symbol","title":"progress","fragments":[{"text":"progress","kind":"identifier"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"fragments":[{"kind":"identifier","text":"MLNOfflinePack"}],"title":"MLNOfflinePack","kind":"symbol","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","type":"reference","isActive":true},{"type":"text","text":" represents a collection of resources necessary for viewing"},{"type":"text","text":" "},{"type":"text","text":"a region offline to a local database."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","url":"\/documentation\/maplibre\/mlnofflinepack","role":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgress":{"role":"symbol","kind":"symbol","title":"MLNOfflinePackProgress","fragments":[{"text":"MLNOfflinePackProgress","kind":"identifier"}],"type":"topic","url":"\/documentation\/maplibre\/mlnofflinepackprogress","abstract":[{"type":"text","text":"A structure containing information about an offline pack’s current download"},{"type":"text","text":" "},{"type":"text","text":"progress."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"type":"topic","fragments":[{"kind":"identifier","text":"MLNOfflineStorage"}],"role":"symbol","title":"MLNOfflineStorage","abstract":[{"text":"MLNOfflineStorage implements a singleton (shared object) that manages offline","type":"text"},{"text":" ","type":"text"},{"text":"packs and ambient caching. All of this class’s instance methods are asynchronous,","type":"text"},{"text":" ","type":"text"},{"text":"reflecting the fact that offline resources are stored in a database. The shared","type":"text"},{"text":" ","type":"text"},{"text":"object maintains a canonical collection of offline packs in its ","type":"text"},{"type":"codeVoice","code":"packs"},{"text":" property.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","url":"\/documentation\/maplibre\/mlnofflinestorage"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgressChangedNotification":{"fragments":[{"kind":"identifier","text":"MLNOfflinePackProgressChangedNotification"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification","role":"symbol","title":"MLNOfflinePackProgressChangedNotification","abstract":[{"type":"text","text":"Posted by the shared "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","type":"reference","isActive":true},{"type":"text","text":" object when an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"object’s progress changes. The progress may change due to a resource being"},{"type":"text","text":" "},{"type":"text","text":"downloaded or because the pack discovers during the download that more"},{"type":"text","text":" "},{"type":"text","text":"resources are required for offline viewing. This notification is posted"},{"type":"text","text":" "},{"type":"text","text":"whenever any field in the "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" property changes."}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification"}}}