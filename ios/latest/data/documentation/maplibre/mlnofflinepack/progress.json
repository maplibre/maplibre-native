","text":"known and when it changes, observe KVO change notifications on this pack’s"},{"type":"text","text":" "},{"type":"codeVoice","code":"state"},{"type":"text","text":" key path. Alternatively, you can add an observer for"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification"},{"type":"text","text":"s about this pack that come from the"},{"type":"text","text":" "},{"type":"text","text":"default notification center."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"type":"topic","url":"\/documentation\/maplibre\/mlnofflinestorage","role":"symbol","abstract":[{"type":"text","text":"MLNOfflineStorage implements a singleton (shared object) that manages offline"},{"type":"text","text":" "},{"type":"text","text":"packs and ambient caching. All of this class’s instance methods are asynchronous,"},{"type":"text","text":" "},{"type":"text","text":"reflecting the fact that offline resources are stored in a database. The shared"},{"type":"text","text":" "},{"type":"text","text":"object maintains a canonical collection of offline packs in its "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property."}],"kind":"symbol","title":"MLNOfflineStorage","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","fragments":[{"kind":"identifier","text":"MLNOfflineStorage"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgressChangedNotification":{"fragments":[{"text":"MLNOfflinePackProgressChangedNotification","kind":"identifier"}],"kind":"symbol","abstract":[{"text":"Posted by the shared ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"},{"text":" object when an ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"},{"text":" ","type":"text"},{"text":"object’s progress changes. The progress may change due to a resource being","type":"text"},{"text":" ","type":"text"},{"text":"downloaded or because the pack discovers during the download that more","type":"text"},{"text":" ","type":"text"},{"text":"resources are required for offline viewing. This notification is posted","type":"text"},{"text":" ","type":"text"},{"text":"whenever any field in the ","type":"text"},{"code":"progress","type":"codeVoice"},{"text":" property changes.","type":"text"}],"url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","title":"MLNOfflinePackProgressChangedNotification","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"fragments":[{"text":"MLNOfflinePack","kind":"identifier"}],"kind":"symbol","abstract":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true,"type":"reference"},{"text":" represents a collection of resources necessary for viewing","type":"text"},{"text":" ","type":"text"},{"text":"a region offline to a local database.","type":"text"}],"url":"\/documentation\/maplibre\/mlnofflinepack","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","title":"MLNOfflinePack","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgress":{"fragments":[{"text":"MLNOfflinePackProgress","kind":"identifier"}],"kind":"symbol","abstract":[{"text":"A structure containing information about an offline pack’s current download","type":"text"},{"text":" ","type":"text"},{"text":"progress.","type":"text"}],"url":"\/documentation\/maplibre\/mlnofflinepackprogress","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/doc