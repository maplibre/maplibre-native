{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress"},"sections":[],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinepack\/progress"]}],"metadata":{"modules":[{"name":"MapLibre"}],"navigatorTitle":[{"text":"progress","kind":"identifier"}],"title":"progress","fragments":[{"text":"progress","kind":"identifier"}],"roleHeading":"Instance Property","role":"symbol","symbolKind":"property","externalID":"c:objc(cs)MLNOfflinePack(py)progress"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"declarations":[{"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"readonly","kind":"keyword"},{"text":") ","kind":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","text":"MLNOfflinePackProgress","kind":"typeIdentifier","preciseIdentifier":"c:@S@MLNOfflinePackProgress"},{"text":" ","kind":"text"},{"text":"progress","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"text":"The progress of an inactive or completed pack is computed lazily, and all its","type":"text"},{"text":" ","type":"text"},{"text":"fields are set to 0 by default. To request the pack’s progress, use the","type":"text"},{"text":" ","type":"text"},{"code":"-requestProgress","type":"codeVoice"},{"text":" method. To get notified when the progress becomes","type":"text"},{"text":" ","type":"text"},{"text":"known and when it changes, observe KVO change notifications on this pack’s","type":"text"},{"text":" ","type":"text"},{"code":"state","type":"codeVoice"},{"text":" key path. Alternatively, you can add an observer for","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","type":"reference","isActive":true},{"text":"s about this pack that come from the","type":"text"},{"text":" ","type":"text"},{"text":"default notification center.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"type":"text","text":"The pack’s current progress."}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgressChangedNotification":{"kind":"symbol","title":"MLNOfflinePackProgressChangedNotification","url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification","fragments":[{"text":"MLNOfflinePackProgressChangedNotification","kind":"identifier"}],"abstract":[{"type":"text","text":"Posted by the shared "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"},{"type":"text","text":" object when an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"},{"type":"text","text":" "},{"type":"text","text":"object’s progress changes. The progress may change due to a resource being"},{"type":"text","text":" "},{"type":"text","text":"downloaded or because the pack discovers during the download that more"},{"type":"text","text":" "},{"type":"text","text":"resources are required for offline viewing. This notification is posted"},{"type":"text","text":" "},{"type":"text","text":"whenever any field in the "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" property changes."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","type":"topic","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgress":{"kind":"symbol","abstract":[{"text":"A structure containing information about an offline pack’s current download","type":"text"},{"text":" ","type":"text"},{"text":"progress.","type":"text"}],"fragments":[{"text":"MLNOfflinePackProgress","kind":"identifier"}],"role":"symbol","url":"\/documentation\/maplibre\/mlnofflinepackprogress","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","type":"topic","title":"MLNOfflinePackProgress"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/progress":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress","fragments":[{"kind":"identifier","text":"progress"}],"url":"\/documentation\/maplibre\/mlnofflinepack\/progress","abstract":[{"type":"text","text":"The pack’s current progress."}],"title":"progress","type":"topic","kind":"symbol","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","role":"symbol","title":"MLNOfflineStorage","abstract":[{"text":"MLNOfflineStorage implements a singleton (shared object) that manages offline","type":"text"},{"text":" ","type":"text"},{"text":"packs and ambient caching. All of this class’s instance methods are asynchronous,","type":"text"},{"text":" ","type":"text"},{"text":"reflecting the fact that offline resources are stored in a database. The shared","type":"text"},{"text":" ","type":"text"},{"text":"object maintains a canonical collection of offline packs in its ","type":"text"},{"type":"codeVoice","code":"packs"},{"text":" property.","type":"text"}],"url":"\/documentation\/maplibre\/mlnofflinestorage","kind":"symbol","fragments":[{"kind":"identifier","text":"MLNOfflineStorage"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"type":"topic","url":"\/documentation\/maplibre\/mlnofflinepack","fragments":[{"text":"MLNOfflinePack","kind":"identifier"}],"title":"MLNOfflinePack","role":"symbol","abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true},{"type":"text","text":" represents a collection of resources necessary for viewing"},{"type":"text","text":" "},{"type":"text","text":"a region offline to a local database."}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","role":"collection","title":"MapLibre","kind":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}]}}}