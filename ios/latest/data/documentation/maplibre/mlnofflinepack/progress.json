 come from the","type":"text"},{"text":" ","type":"text"},{"text":"default notification center.","type":"text"}]}]}],"kind":"symbol","metadata":{"fragments":[{"kind":"identifier","text":"progress"}],"roleHeading":"Instance Property","title":"progress","navigatorTitle":[{"kind":"identifier","text":"progress"}],"role":"symbol","externalID":"c:objc(cs)MLNOfflinePack(py)progress","symbolKind":"property","modules":[{"name":"MapLibre"}]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress","interfaceLanguage":"occ"},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"kind":"symbol","title":"MapLibre","role":"collection","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/progress":{"title":"progress","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress","abstract":[{"text":"The pack’s current progress.","type":"text"}],"kind":"symbol","role":"symbol","fragments":[{"kind":"identifier","text":"progress"}],"url":"\/documentation\/maplibre\/mlnofflinepack\/progress","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgressChangedNotification":{"role":"symbol","fragments":[{"kind":"identifier","text":"MLNOfflinePackProgressChangedNotification"}],"type":"topic","abstract":[{"type":"text","text":"Posted by the shared "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","isActive":true},{"type":"text","text":" object when an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true},{"type":"text","text":" "},{"type":"text","text":"object’s progress changes. The progress may change due to a resource being"},{"type":"text","text":" "},{"type":"text","text":"downloaded or because the pack discovers during the download that more"},{"type":"text","text":" "},{"type":"text","text":"resources are required for offline viewing. This notification is posted"},{"type":"text","text":" "},{"type":"text","text":"whenever any field in the "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" property changes."}],"url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification","title":"MLNOfflinePackProgressChangedNotification","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"type":"topic","role":"symbol","fragments":[{"text":"MLNOfflinePack","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnofflinepack","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","kind":"symbol","title":"MLNOfflinePack","abstract":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","type":"reference","isActive":true},{"text":" represents a collection of resources necessary for viewing","type":"text"},{"text":" ","type":"text"},{"text":"a region offline to a local database.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgress":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","kind":"symbol","role":"symbol","title":"MLNOfflinePackProgress","url":"\/documentation\/maplibre\/mlnofflinepackprogress","type":"topic","fragments":[{"text":"MLNOfflinePackProgress","kind":"identifier"}],"abstract":[{"text":"A structure containing information about an offline pack’s current download","type":"text"},{"text":" ","type":"text"},{"text":"progress.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"