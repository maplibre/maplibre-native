ice","code":"progress"},{"text":" property changes.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","type":"topic","role":"symbol","url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"title":"MLNOfflinePack","url":"\/documentation\/maplibre\/mlnofflinepack","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","fragments":[{"text":"MLNOfflinePack","kind":"identifier"}],"role":"symbol","type":"topic","kind":"symbol","abstract":[{"text":"An ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true},{"text":" represents a collection of resources necessary for viewing","type":"text"},{"text":" ","type":"text"},{"text":"a region offline to a local database.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgress":{"role":"symbol","fragments":[{"kind":"identifier","text":"MLNOfflinePackProgress"}],"title":"MLNOfflinePackProgress","type":"topic","abstract":[{"type":"text","text":"A structure containing information about an offline pack’s current download"},{"type":"text","text":" "},{"type":"text","text":"progress."}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinepackprogress","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/progress":{"kind":"symbol","role":"symbol","title":"progress","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress","abstract":[{"type":"text","text":"The pack’s current progress."}],"fragments":[{"kind":"identifier","text":"progress"}],"url":"\/documentation\/maplibre\/mlnofflinepack\/progress"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"