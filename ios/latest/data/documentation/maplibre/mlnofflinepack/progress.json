":"codeVoice"},{"type":"text","text":" key path. Alternatively, you can add an observer for"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification"},{"type":"text","text":"s about this pack that come from the"},{"type":"text","text":" "},{"type":"text","text":"default notification center."}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress","interfaceLanguage":"occ"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/progress":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress","title":"progress","type":"topic","fragments":[{"kind":"identifier","text":"progress"}],"abstract":[{"type":"text","text":"The pack’s current progress."}],"url":"\/documentation\/maplibre\/mlnofflinepack\/progress","kind":"symbol","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgress":{"kind":"symbol","abstract":[{"text":"A structure containing information about an offline pack’s current download","type":"text"},{"text":" ","type":"text"},{"text":"progress.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","type":"topic","url":"\/documentation\/maplibre\/mlnofflinepackprogress","title":"MLNOfflinePackProgress","role":"symbol","fragments":[{"text":"MLNOfflinePackProgress","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgressChangedNotification":{"url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification","type":"topic","fragments":[{"kind":"identifier","text":"MLNOfflinePackProgressChangedNotification"}],"abstract":[{"text":"Posted by the shared ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","isActive":true,"type":"reference"},{"text":" object when an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"object’s progress changes. The progress may change due to a resource being","type":"text"},{"text":" ","type":"text"},{"text":"downloaded or because the pack discovers during the download that more","type":"text"},{"text":" ","type":"text"},{"text":"resources are required for offline viewing. This notification is posted","type":"text"},{"text":" ","type":"text"},{"text":"whenever any field in the ","type":"text"},{"code":"progress","type":"codeVoice"},{"text":" property changes.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","role":"symbol","kind":"symbol","title":"MLNOfflinePackProgressChangedNotification"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","abstract":[{"type":"text","text":"MLNOfflineStorage implements a singleton (shared object) that manages offline"},{"type":"text","text":" "},{"type":"text","text":"packs and ambient caching. All of this class’s instance methods are asynchronous,"},{"type":"text","text":" "},{"type":"text","text":"reflecting the fact that offline resources are stored in a database. The shared"},{"type":"text","text":" "},{"type":"text","text":"object maintains a canonical collection of offline packs in its "},{"code":"packs","type":"codeVoice"},{"type":"text","text":" property."}],"fragments":[{"kind":"identifier","text":"MLNOfflineStorage"}],"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinestorage","title":"MLNOfflineStorage"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"title":"MLNOfflinePack","kind":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnofflinepack","fragment