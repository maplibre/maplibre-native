":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","type":"topic","url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification","kind":"symbol","title":"MLNOfflinePackProgressChangedNotification","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgress":{"fragments":[{"kind":"identifier","text":"MLNOfflinePackProgress"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","url":"\/documentation\/maplibre\/mlnofflinepackprogress","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"A structure containing information about an offline pack’s current download"},{"type":"text","text":" "},{"type":"text","text":"progress."}],"title":"MLNOfflinePackProgress","role":"symbol"}}}