/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinepack\/progress"]}],"metadata":{"title":"progress","roleHeading":"Instance Property","externalID":"c:objc(cs)MLNOfflinePack(py)progress","navigatorTitle":[{"text":"progress","kind":"identifier"}],"fragments":[{"text":"progress","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"symbolKind":"property","role":"symbol"},"abstract":[{"type":"text","text":"The pack’s current progress."}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/progress":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress","title":"progress","kind":"symbol","role":"symbol","fragments":[{"text":"progress","kind":"identifier"}],"type":"topic","url":"\/documentation\/maplibre\/mlnofflinepack\/progress","abstract":[{"type":"text","text":"The pack’s current progress."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"abstract":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true,"type":"reference"},{"text":" represents a collection of resources necessary for viewing","type":"text"},{"text":" ","type":"text"},{"text":"a region offline to a local database.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","kind":"symbol","fragments":[{"text":"MLNOfflinePack","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnofflinepack","type":"topic","role":"symbol","title":"MLNOfflinePack"},"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"kind":"symbol","title":"MapLibre","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgress":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","title":"MLNOfflinePackProgress","kind":"symbol","role":"symbol","fragments":[{"text":"MLNOfflinePackProgress","kind":"identifier"}],"type":"topic","url":"\/documentation\/maplibre\/mlnofflinepackprogress","abstract":[{"text":"A structure containing information about an offline pack’s current download","type":"text"},{"text":" ","type":"text"},{"text":"progress.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"title":"MLNOfflineStorage","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","kind":"symbol","role":"symbol","fragments":[{"kind":"identifier","text":"MLNOfflineStorage"}],"type":"topic","url":"\/documentation\/maplibre\/mlnofflinestorage","abstract":[{"text":"MLNOfflineStorage implements a singleton (shared object) that manages offline","type":"text"},{"text":" ","type":"text"},{"text":"packs and ambient caching. All of this class’s instance methods are asynchronous,","type":"text"},{"text":" ","type":"text"},{"text":"reflecting the fact that offline resources are stored in a database. The shared","type":"text"},{"text":" ","type":"text"},{"text":"object maintains a canonical collection of offline packs in its ","type":"text"},{"code":"packs","type":"codeVoice"},{"text":" property.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgressChangedNotification":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","title":"MLNOfflinePackProgressChangedNotification","kind":"symbol","role":"symbol","fragments":[{"kind":"identifier","text":"MLNOfflinePackProgressChangedNotification"}],"type":"topic","url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification","abstract":