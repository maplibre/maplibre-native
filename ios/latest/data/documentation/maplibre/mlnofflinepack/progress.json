/MLNOfflinePack\/progress","title":"progress","role":"symbol","fragments":[{"kind":"identifier","text":"progress"}],"type":"topic","url":"\/documentation\/maplibre\/mlnofflinepack\/progress","abstract":[{"type":"text","text":"The pack’s current progress."}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgress":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinepackprogress","role":"symbol","title":"MLNOfflinePackProgress","type":"topic","abstract":[{"text":"A structure containing information about an offline pack’s current download","type":"text"},{"text":" ","type":"text"},{"text":"progress.","type":"text"}],"fragments":[{"text":"MLNOfflinePackProgress","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgressChangedNotification":{"type":"topic","kind":"symbol","title":"MLNOfflinePackProgressChangedNotification","role":"symbol","abstract":[{"text":"Posted by the shared ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","type":"reference"},{"type":"text","text":" object when an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"},{"type":"text","text":" "},{"type":"text","text":"object’s progress changes. The progress may change due to a resource being"},{"type":"text","text":" "},{"type":"text","text":"downloaded or because the pack discovers during the download that more"},{"type":"text","text":" "},{"type":"text","text":"resources are required for offline viewing. This notification is posted"},{"type":"text","text":" "},{"type":"text","text":"whenever any field in the "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" property changes."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNo