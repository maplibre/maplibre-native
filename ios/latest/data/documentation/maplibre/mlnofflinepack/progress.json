{"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress","interfaceLanguage":"occ"},"sections":[],"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"role":"symbol","symbolKind":"property","modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNOfflinePack(py)progress","roleHeading":"Instance Property","title":"progress","fragments":[{"kind":"identifier","text":"progress"}],"navigatorTitle":[{"kind":"identifier","text":"progress"}]},"abstract":[{"type":"text","text":"The pack’s current progress."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinepack\/progress"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"readonly"},{"kind":"text","text":") "},{"kind":"typeIdentifier","preciseIdentifier":"c:@S@MLNOfflinePackProgress","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","text":"MLNOfflinePackProgress"},{"kind":"text","text":" "},{"kind":"identifier","text":"progress"},{"kind":"text","text":";"}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"The progress of an inactive or completed pack is computed lazily, and all its","type":"text"},{"text":" ","type":"text"},{"text":"fields are set to 0 by default. To request the pack’s progress, use the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"-requestProgress"},{"text":" method. To get notified when the progress becomes","type":"text"},{"text":" ","type":"text"},{"text":"known and when it changes, observe KVO change notifications on this pack’s","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"state"},{"text":" key path. Alternatively, you can add an observer for","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","isActive":true,"type":"reference"},{"text":"s about this pack that come from the","type":"text"},{"text":" ","type":"text"},{"text":"default notification center.","type":"text"}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","title":"MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"url":"\/documentation\/maplibre","role":"collection","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"type":"topic","url":"\/documentation\/maplibre\/mlnofflinepack","role":"symbol","kind":"symbol","fragments":[{"text":"MLNOfflinePack","kind":"identifier"}],"abstract":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true,"type":"reference"},{"text":" represents a collection of resources necessary for viewing","type":"text"},{"text":" ","type":"text"},{"text":"a region offline to a local database.","type":"text"}],"title":"MLNOfflinePack","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgress":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","role":"symbol","url":"\/documentation\/maplibre\/mlnofflinepackprogress","type":"topic","kind":"symbol","title":"MLNOfflinePackProgress","fragments":[{"text":"MLNOfflinePackProgress","kind":"identifier"}],"abstract":[{"type":"text","text":"A structure containing information about an offline pack’s current download"},{"type":"text","text":" "},{"type":"text","text":"progress."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgressChangedNotification":{"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","role":"symbol","abstract":[{"type":"text","text":"Posted by the shared "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","type":"reference","isActive":true},{"type":"text","text":" object when an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"object’s progress changes. The progress may change due to a resource being"},{"type":"text","text":" "},{"type":"text","text":"downloaded or because the pack discovers during the download that more"},{"type":"text","text":" "},{"type":"text","text":"resources are required for offline viewing. This notification is posted"},{"type":"text","text":" "},{"type":"text","text":"whenever any field in the "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" property changes."}],"type":"topic","url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification","fragments":[{"text":"MLNOfflinePackProgressChangedNotification","kind":"identifier"}],"title":"MLNOfflinePackProgressChangedNotification"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/progress":{"fragments":[{"text":"progress","kind":"identifier"}],"type":"topic","url":"\/documentation\/maplibre\/mlnofflinepack\/progress","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress","abstract":[{"text":"The pack’s current progress.","type":"text"}],"title":"progress","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"abstract":[{"text":"MLNOfflineStorage implements a singleton (shared object) that manages offline","type":"text"},{"text":" ","type":"text"},{"text":"packs and ambient caching. All of this class’s instance methods are asynchronous,","type":"text"},{"text":" ","type":"text"},{"text":"reflecting the fact that offline resources are stored in a database. The shared","type":"text"},{"text":" ","type":"text"},{"text":"object maintains a canonical collection of offline packs in its ","type":"text"},{"type":"codeVoice","code":"packs"},{"text":" property.","type":"text"}],"kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"MLNOfflineStorage","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnofflinestorage","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","title":"MLNOfflineStorage"}}}