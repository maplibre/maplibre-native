u can add an observer for","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","isActive":true,"type":"reference"},{"text":"s about this pack that come from the","type":"text"},{"text":" ","type":"text"},{"text":"default notification center.","type":"text"}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress","interfaceLanguage":"occ"},"sections":[],"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol","title":"MapLibre","type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/progress":{"fragments":[{"kind":"identifier","text":"progress"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress","role":"symbol","kind":"symbol","title":"progress","abstract":[{"type":"text","text":"The pack’s current progress."}],"type":"topic","url":"\/documentation\/maplibre\/mlnofflinepack\/progress"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"title":"MLNOfflinePack","role":"symbol","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true,"type":"reference"},{"text":" represents a collection of resources necessary for viewing","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"a region offline to a local database."}],"url":"\/documentation\/maplibre\/mlnofflinepack","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","type":"topic","fragments":[{"kind":"iden