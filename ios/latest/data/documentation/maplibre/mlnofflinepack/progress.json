:"text"}]}]}],"sections":[],"abstract":[{"text":"The pack’s current progress.","type":"text"}],"metadata":{"externalID":"c:objc(cs)MLNOfflinePack(py)progress","symbolKind":"property","roleHeading":"Instance Property","role":"symbol","fragments":[{"text":"progress","kind":"identifier"}],"title":"progress","navigatorTitle":[{"text":"progress","kind":"identifier"}],"modules":[{"name":"MapLibre"}]},"schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinepack\/progress"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","url":"\/documentation\/maplibre","kind":"symbol","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/progress":{"role":"symbol","title":"progress","url":"\/documentation\/maplibre\/mlnofflinepack\/progress","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress","type":"topic","abstract":[{"text":"The pack’s current progress.","type":"text"}],"kind":"symbol","fragments":[{"kind":"identifier","text":"progress"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgress":{"abstract":[{"type":"text","text":"A structure containing information about an offline pack’s current download"},{"type":"text","text":" "},{"type":"text","text":"progress."}],"title":"MLNOfflinePackProgress","type":"topic","url":"\/documentation\/maplibre\/mlnofflinepackprogress","kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","fragments":[{"text":"MLNOfflinePackProgress","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"fragments":[{"text":"MLN