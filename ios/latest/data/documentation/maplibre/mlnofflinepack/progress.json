{"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"readonly"},{"kind":"text","text":") "},{"kind":"typeIdentifier","text":"MLNOfflinePackProgress","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","preciseIdentifier":"c:@S@MLNOfflinePackProgress"},{"kind":"text","text":" "},{"kind":"identifier","text":"progress"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"The progress of an inactive or completed pack is computed lazily, and all its"},{"type":"text","text":" "},{"type":"text","text":"fields are set to 0 by default. To request the pack’s progress, use the"},{"type":"text","text":" "},{"code":"-requestProgress","type":"codeVoice"},{"type":"text","text":" method. To get notified when the progress becomes"},{"type":"text","text":" "},{"type":"text","text":"known and when it changes, observe KVO change notifications on this pack’s"},{"type":"text","text":" "},{"code":"state","type":"codeVoice"},{"type":"text","text":" key path. Alternatively, you can add an observer for"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","type":"reference","isActive":true},{"type":"text","text":"s about this pack that come from the"},{"type":"text","text":" "},{"type":"text","text":"default notification center."}],"type":"paragraph"}],"kind":"content"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress"},"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"abstract":[{"type":"text","text":"The pack’s current progress."}],"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinepack\/progress"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"symbol","metadata":{"title":"progress","fragments":[{"kind":"identifier","text":"progress"}],"role":"symbol","symbolKind":"property","externalID":"c:objc(cs)MLNOfflinePack(py)progress","navigatorTitle":[{"kind":"identifier","text":"progress"}],"modules":[{"name":"MapLibre"}],"roleHeading":"Instance Property"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgress":{"kind":"symbol","abstract":[{"type":"text","text":"A structure containing information about an offline pack’s current download"},{"type":"text","text":" "},{"type":"text","text":"progress."}],"title":"MLNOfflinePackProgress","fragments":[{"kind":"identifier","text":"MLNOfflinePackProgress"}],"type":"topic","url":"\/documentation\/maplibre\/mlnofflinepackprogress","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgressChangedNotification":{"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","type":"topic","fragments":[{"kind":"identifier","text":"MLNOfflinePackProgressChangedNotification"}],"abstract":[{"type":"text","text":"Posted by the shared "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","type":"reference","isActive":true},{"text":" object when an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"object’s progress changes. The progress may change due to a resource being","type":"text"},{"text":" ","type":"text"},{"text":"downloaded or because the pack discovers