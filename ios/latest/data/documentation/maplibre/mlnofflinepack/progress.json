{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress"},"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"metadata":{"externalID":"c:objc(cs)MLNOfflinePack(py)progress","title":"progress","roleHeading":"Instance Property","role":"symbol","symbolKind":"property","modules":[{"name":"MapLibre"}],"fragments":[{"text":"progress","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"progress"}]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinepack\/progress"]}],"primaryContentSections":[{"declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"readonly"},{"kind":"text","text":") "},{"kind":"typeIdentifier","text":"MLNOfflinePackProgress","preciseIdentifier":"c:@S@MLNOfflinePackProgress","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress"},{"kind":"text","text":" "},{"kind":"identifier","text":"progress"},{"kind":"text","text":";"}],"languages":["occ"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The progress of an inactive or completed pack is computed lazily, and all its","type":"text"},{"text":" ","type":"text"},{"text":"fields are set to 0 by default. To request the pack’s progress, use the","type":"text"},{"text":" ","type":"text"},{"code":"-requestProgress","type":"codeVoice"},{"text":" method. To get notified when the progress becomes","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"known and when it changes, observe KVO change notifications on this pack’s"},{"type":"text","text":" "},{"code":"state","type":"codeVoice"},{"type":"text","text":" key path. Alternatively, you can add an observer for"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","isActive":true},{"type":"text","text":"s about this pack that come from the"},{"type":"text","text":" "},{"type":"text","text":"default notification center."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"abstract":[{"text":"The pack’s current progress.","type":"text"}],"kind":"symbol","references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/progress":{"title":"progress","kind":"symbol","type":"topic","fragments":[{"text":"progress","kind":"identifier"}],"abstract":[{"text":"The pack’s current progress.","type":"text"}],"url":"\/documentation\/maplibre\/mlnofflinepack\/progress","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","abstract":[{"text":"MLNOfflineStorage implements a singleton (shared object) that manages offline","type":"text"},{"text":" ","type":"text"},{"text":"packs and ambient caching. All of this class’s instance methods are asynchronous,","type":"text"},{"text":" ","type":"text"},{"text":"reflecting the fact that offline resources are stored in a database. The shared","type":"text"},{"text":" ","type":"text"},{"text":"object maintains a canonical collection of offline packs in its ","type":"text"},{"code":"packs","type":"codeVoice"},{"text":" property.","type":"text"}],"url":"\/documentation\/maplibre\/mlnofflinestorage","role":"symbol","title":"MLNOfflineStorage","fragments":[{"text":"MLNOfflineStorage","kind":"identifier"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOffline