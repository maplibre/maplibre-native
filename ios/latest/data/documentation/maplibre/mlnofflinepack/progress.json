bre","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol","url":"\/documentation\/maplibre","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgressChangedNotification":{"abstract":[{"type":"text","text":"Posted by the shared "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","type":"reference"},{"type":"text","text":" object when an "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","type":"reference"},{"type":"text","text":" "},{"type":"text","text":"object’s progress changes. The progress may change due to a resource being"},{"type":"text","text":" "},{"type":"text","text":"downloaded or because the pack discovers during the download that more"},{"type":"text","text":" "},{"type":"text","text":"resources are required for offline viewing. This notification is posted"},{"type":"text","text":" "},{"type":"text","text":"whenever any field in the "},{"code":"progress","type":"codeVoice"},{"type":"text","text":" property changes."}],"type":"topic","fragments":[{"kind":"identifier","text":"MLNOfflinePackProgressChangedNotification"}],"title":"MLNOfflinePackProgressChangedNotification","role":"symbol","url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/progress":{"role":"symbol","fragments":[{"kind":"identifier","text":"progress"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress","abstract":[{"type":"text","text":"The pack’s current progress."}],"url":"\/documentation\/maplibre\/mlnofflinepack\/progress","type":"topic","title":"progress"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"