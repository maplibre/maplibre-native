{"sections":[],"kind":"symbol","abstract":[{"type":"text","text":"The pack’s current progress."}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"readonly"},{"kind":"text","text":") "},{"kind":"typeIdentifier","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","preciseIdentifier":"c:@S@MLNOfflinePackProgress","text":"MLNOfflinePackProgress"},{"kind":"text","text":" "},{"kind":"identifier","text":"progress"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The progress of an inactive or completed pack is computed lazily, and all its"},{"type":"text","text":" "},{"type":"text","text":"fields are set to 0 by default. To request the pack’s progress, use the"},{"type":"text","text":" "},{"code":"-requestProgress","type":"codeVoice"},{"type":"text","text":" method. To get notified when the progress becomes"},{"type":"text","text":" "},{"type":"text","text":"known and when it changes, observe KVO change notifications on this pack’s"},{"type":"text","text":" "},{"code":"state","type":"codeVoice"},{"type":"text","text":" key path. Alternatively, you can add an observer for"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","isActive":true,"type":"reference"},{"type":"text","text":"s about this pack that come from the"},{"type":"text","text":" "},{"type":"text","text":"default notification center."}]}]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress","interfaceLanguage":"occ"},"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata