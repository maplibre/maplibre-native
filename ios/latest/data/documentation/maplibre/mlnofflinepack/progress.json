{"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"fragments":[{"text":"progress","kind":"identifier"}],"role":"symbol","title":"progress","externalID":"c:objc(cs)MLNOfflinePack(py)progress","navigatorTitle":[{"text":"progress","kind":"identifier"}],"symbolKind":"property","roleHeading":"Instance Property","modules":[{"name":"MapLibre"}]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress","interfaceLanguage":"occ"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinepack\/progress"]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"abstract":[{"type":"text","text":"The pack’s current progress."}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"readonly"},{"kind":"text","text":") "},{"kind":"typeIdentifier","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","preciseIdentifier":"c:@S@MLNOfflinePackProgress","text":"MLNOfflinePackProgress"},{"text":" ","kind":"text"},{"text":"progress","kind":"identifier"},{"text":";","kind":"text"}]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The progress of an inactive or completed pack is computed lazily, and all its"},{"type":"text","text":" "},{"type":"text","text":"fields are set to 0 by default. To request the pack’s progress, use the"},{"type":"text","text":" "},{"type":"codeVoice","code":"-requestProgress"},{"type":"text","text":" method. To get notified when the progress becomes"},{"type":"text","text":" "},{"type":"text","text