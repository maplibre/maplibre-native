 from the","type":"text"},{"text":" ","type":"text"},{"text":"default notification center.","type":"text"}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinepack\/progress"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"title":"progress","externalID":"c:objc(cs)MLNOfflinePack(py)progress","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"kind":"identifier","text":"progress"}],"roleHeading":"Instance Property","symbolKind":"property","fragments":[{"kind":"identifier","text":"progress"}],"role":"symbol"},"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgress":{"url":"\/documentation\/maplibre\/mlnofflinepackprogress","type":"topic","kind":"symbol","abstract":[{"text":"A structure containing information about an offline pack’s current download","type":"text"},{"text":" ","type":"text"},{"text":"progress.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","role":"symbol","fragments":[{"kind":"identifier","text":"MLNOfflinePackProgress"}],"title":"MLNOfflinePackProgress"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"abstract":[{"type":"text","text":"MLNOfflineStorage implements a singleton (shared object) that manages offline"},{"type":"text","text":" "},{"type":"text","text":"packs and ambient caching. All of this class’s instance methods are asynchronous,"},{"type":"text","text":" "},{"type":"text","text":"reflecting the fact that offline resources are stored in a database. The shared"},{"type":"text","text":" "},{"type":"text","text":"object maintains a canonical collection of offline packs in its "},{"code":"packs","type":"codeVoice"},{"type":"text","text":" property."}],"title":"MLNOfflineStorage","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlnofflinestorage","fragments":[{"k