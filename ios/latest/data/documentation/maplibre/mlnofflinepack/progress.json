{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress"},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","abstract":[{"type":"text","text":"The pack’s current progress."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"readonly","kind":"keyword"},{"text":") ","kind":"text"},{"text":"MLNOfflinePackProgress","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","kind":"typeIdentifier","preciseIdentifier":"c:@S@MLNOfflinePackProgress"},{"text":" ","kind":"text"},{"text":"progress","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"The progress of an inactive or completed pack is computed lazily, and all its","type":"text"},{"text":" ","type":"text"},{"text":"fields are set to 0 by default. To request the pack’s progress, use the","type":"text"},{"text":" ","type":"text"},{"code":"-requestProgress","type":"codeVoice"},{"text":" method. To get notified when the progress becomes","type":"text"},{"text":" ","type":"text"},{"text":"known and when it changes, observe KVO change notifications on this pack’s","type":"text"},{"text":" ","type":"text"},{"code":"state","type":"codeVoice"},{"text":" key path. Alternatively, you can add an observer for","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","isActive":true},{"text":"s about this pack that come from the","type":"text"},{"text":" ","type":"text"},{"text":"default notification center.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinepack\/progress"]}],"metadata":{"modules":[{"name":"MapLibre"}],"title":"progress","role":"symbol","fragments":[{"text":"progress","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"progress"}],"roleHeading":"Instance Property","externalID":"c:objc(cs)MLNOfflinePack(py)progress","symbolKind":"property"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/progress":{"fragments":[{"kind":"identifier","text":"progress"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress","type":"topic","kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"The pack’s current progress."}],"title":"progress","url":"\/documentation\/maplibre\/mlnofflinepack\/progress"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgress":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","type":"topic","abstract":[{"type":"text","text":"A structure containing information about an offline pack’s current download"},{"type":"text","text":" "},{"type":"text","text":"progress."}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinepackprogress","fragments":[{"kind":"identifier","text":"MLNOfflinePackProgress"}],"title":"MLNOfflinePackProgress","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","title":"MLNOfflinePack","fragments":[{"kind":"identifier","text":"MLNOfflinePack"}],"role":"symbol","url":"\/documentation\/maplibre\/mlnofflinepack","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","type":"reference","isActive":true},{"type":"text","text":" represents a collection of resources necessary for viewing"},{"type":"text","text":" "},{"type":"text","text":"a region offline to a local database."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"fragments":[{"text":"MLNOfflineStorage","kind":"identifier"}],"role":"symbol","title":"MLNOfflineStorage","kind":"symbol","type":"topic","abstract":[{"text":"MLNOfflineStorage implements a singleton (shared object) that manages offline","type":"text"},{"text":" ","type":"text"},{"text":"packs and ambient caching. All of this class’s instance methods are asynchronous,","type":"text"},{"text":" ","type":"text"},{"text":"reflecting the fact that offline resources are stored in a database. The shared","type":"text"},{"text":" ","type":"text"},{"text":"object maintains a canonical collection of offline packs in its ","type":"text"},{"code":"packs","type":"codeVoice"},{"text":" property.","type":"text"}],"url":"\/documentation\/maplibre\/mlnofflinestorage","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgressChangedNotification":{"title":"MLNOfflinePackProgressChangedNotification","type":"topic","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","role":"symbol","url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification","abstract":[{"text":"Posted by the shared ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","isActive":true,"type":"reference"},{"text":" object when an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"object’s progress changes. The progress may change due to a resource being","type":"text"},{"text":" ","type":"text"},{"text":"downloaded or because the pack discovers during the download that more","type":"text"},{"text":" ","type":"text"},{"text":"resources are required for offline viewing. This notification is posted","type":"text"},{"text":" ","type":"text"},{"text":"whenever any field in the ","type":"text"},{"code":"progress","type":"codeVoice"},{"text":" property changes.","type":"text"}],"fragments":[{"text":"MLNOfflinePackProgressChangedNotification","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"title":"MapLibre","kind":"symbol","type":"topic","role":"collection"}}}