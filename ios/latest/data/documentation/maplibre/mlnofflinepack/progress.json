{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress"},"sections":[],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"abstract":[{"type":"text","text":"The pack’s current progress."}],"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinepack\/progress"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"fragments":[{"text":"progress","kind":"identifier"}],"symbolKind":"property","modules":[{"name":"MapLibre"}],"role":"symbol","roleHeading":"Instance Property","title":"progress","navigatorTitle":[{"text":"progress","kind":"identifier"}],"externalID":"c:objc(cs)MLNOfflinePack(py)progress"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"readonly","kind":"keyword"},{"text":") ","kind":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","text":"MLNOfflinePackProgress","preciseIdentifier":"c:@S@MLNOfflinePackProgress","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"progress","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"text":"The progress of an inactive or completed pack is computed lazily, and all its","type":"text"},{"text":" ","type":"text"},{"text":"fields are set to 0 by default. To request the pack’s progress, use the","type":"text"},{"text":" ","type":"text"},{"code":"-requestProgress","type":"codeVoice"},{"text":" method. To get notified when the progress becomes","type":"text"},{"text":" ","type":"text"},{"text":"known and when it changes, observe KVO change notifications on this pack’s","type":"text"},{"text":" ","type":"text"},{"code":"state","type":"codeVoice"},{"text":" key path. Alternatively, you can add an observer for","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","isActive":true},{"text":"s about this pack that come from the","type":"text"},{"text":" ","type":"text"},{"text":"default notification center.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgressChangedNotification":{"type":"topic","url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification","kind":"symbol","fragments":[{"text":"MLNOfflinePackProgressChangedNotification","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","title":"MLNOfflinePackProgressChangedNotification","role":"symbol","abstract":[{"text":"Posted by the shared ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","type":"reference"},{"text":" object when an ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","type":"reference"},{"text":" ","type":"text"},{"text":"object’s progress changes. The progress may change due to a resource being","type":"text"},{"text":" ","type":"text"},{"text":"downloaded or because the pack discovers during the download that more","type":"text"},{"text":" ","type":"text"},{"text":"resources are required for offline viewing. This notification is posted","type":"text"},{"text":" ","type":"text"},{"text":"whenever any field in the ","type":"text"},{"code":"progress","type":"codeVoice"},{"text":" property changes.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/progr