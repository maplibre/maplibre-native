ared "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"},{"type":"text","text":" object when an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"},{"type":"text","text":" "},{"type":"text","text":"object’s progress changes. The progress may change due to a resource being"},{"type":"text","text":" "},{"type":"text","text":"downloaded or because the pack discovers during the download that more"},{"type":"text","text":" "},{"type":"text","text":"resources are required for offline viewing. This notification is posted"},{"type":"text","text":" "},{"type":"text","text":"whenever any field in the "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" property changes."}],"role":"symbol"}}}