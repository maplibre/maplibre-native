ion"},{"type":"text","text":"s about this pack that come from the"},{"type":"text","text":" "},{"type":"text","text":"default notification center."}],"type":"paragraph"}]}],"sections":[],"kind":"symbol","identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress","interfaceLanguage":"occ"},"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"The pack’s current progress."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinepack\/progress"]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgress":{"url":"\/documentation\/maplibre\/mlnofflinepackprogress","type":"topic","abstract":[{"type":"text","text":"A structure containing information about an offline pack’s current download"},{"type":"text","text":" "},{"type":"text","text":"progress."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","title":"MLNOfflinePackProgress","kind":"symbol","role":"symbol","fragments":[{"text":"MLNOfflinePackProgress","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/progress":{"title":"progress","abstract":[{"type":"text","text":"The pack’s current progress."}],"role":"symbol","fragments":[{"text":"progress","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress","type":"topic","url":"\/documentation\/maplibre\/mlnofflinepack\/progress"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"abstract":[{"text":"An ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true},{"text":" represents a collection of resources necessary for viewing","type":"text"},{"text":" ","type":"text"},{"text":"a region offline to a local database.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","kind":"symbol","role":"symbol","title":"MLNOfflinePack","fragments":[{"text":"MLNOfflinePack","kind":"identifier"}],"type":"topic","url":"\/documentation\/maplibre\/mlnofflinepack"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinestorage","abstract":[{"text":"MLNOfflineStorage implements a singleton (shared object) that manages offline","type":"text"},{"text":" ","type":"text"},{"text":"packs and ambient caching. All of this class’s instance methods are asynchronous,","type":"text"},{"text":" ","type":"text"},{"text":"reflecting the fact that offline resources are stored in a database. The shared","type":"text"},{"text":" ","type":"text"},{"text":"object maintains a canonical collection of offline packs in its ","type":"text"},{"code":"packs","type":"codeVoice"},{"text":" property.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","role":"symbol","type":"topic","title":"MLNOfflineStorage","fragments":[{"text":"MLNOfflineStorage","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgressChangedNotification":{"type":"topic","kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"Posted by the shared "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","isActive":true},{"type":"text","text":" object when an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true},{"type":"text","text":" "},{"type":"text","text":"object’s progress changes. The progress may change due to a resource being"},{"type":"text","text":" "},{"type":"text","text":"downloaded or because the pack discovers during the download that more"},{"type":"text","text":" "},{"type":"text","text":"resources are required for offline viewing. This notification is posted"},{