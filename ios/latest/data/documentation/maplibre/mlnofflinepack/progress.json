{"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/progress","interfaceLanguage":"occ"},"abstract":[{"type":"text","text":"The pack’s current progress."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"readonly","kind":"keyword"},{"text":") ","kind":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgress","text":"MLNOfflinePackProgress","preciseIdentifier":"c:@S@MLNOfflinePackProgress","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"progress","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"The progress of an inactive or completed pack is computed lazily, and all its"},{"type":"text","text":" "},{"type":"text","text":"fields are set to 0 by default. To request the pack’s progress, use the"},{"type":"text","text":" "},{"type":"codeVoice","code":"-requestProgress"},{"type":"text","text":" method. To get notified when the progress becomes"},{"type":"text","text":" "},{"type":"text","text":"known and when it changes, observe KVO change notifications on this pack’s"},{"type":"text","text":" "},{"type":"codeVoice","code":"state"},{"type":"text","text":" key path. Alternatively, you can add an observer for"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","type":"reference","isActive":true},{"type":"text","text":"s about this pack that come from the"},{"type":"text","text":" "},{"type":"text","text":"default notification center."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swi