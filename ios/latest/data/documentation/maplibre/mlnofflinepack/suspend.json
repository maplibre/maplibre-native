{"metadata":{"role":"symbol","title":"suspend","fragments":[{"text":"- ","kind":"text"},{"text":"suspend","kind":"identifier"}],"roleHeading":"Instance Method","modules":[{"name":"MapLibre"}],"symbolKind":"method","externalID":"c:objc(cs)MLNOfflinePack(im)suspend","navigatorTitle":[{"text":"- ","kind":"text"},{"text":"suspend","kind":"identifier"}]},"primaryContentSections":[{"declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"],"tokens":[{"text":"- (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"suspend","kind":"identifier"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A pack suspends asynchronously, so some network requests may be sent after this"},{"type":"text","text":" "},{"type":"text","text":"method is called. Regardless, the "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" property will not be updated until"},{"type":"text","text":" "},{"type":"codeVoice","code":"-resume"},{"type":"text","text":" is called."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the pack previously reached a higher level of progress before being"},{"type":"text","text":" "},{"type":"text","text":"suspended, it may wait to suspend until it returns to that level."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To resume downloading, call the "},{"type":"codeVoice","code":"-resume"},{"type":"text","text":" method."}]}],"kind":"content"}],"sections":[],"abstract":[{"type":"text","text":"Temporarily stops downloading if the pack is active."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinepack\/suspend"]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"kind":"symbol","identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/suspend","interfaceLanguage":"occ"},"schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack/suspend":{"kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinepack\/suspend","abstract":[{"type":"text","text":"Temporarily stops downloading if the pack is active."}],"title":"suspend","fragments":[{"text":"- ","kind":"text"},{"text":"suspend","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/suspend","role":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true},{"type":"text","text":" represents a collection of resources necessary for viewing"},{"type":"text","text":" "},{"type":"text","text":"a region offline to a local database."}],"url":"\/documentation\/maplibre\/mlnofflinepack","kind":"symbol","title":"MLNOfflinePack","fragments":[{"kind":"identifier","text":"MLNOfflinePack"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","role":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","title":"MapLibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol","url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre"}}}