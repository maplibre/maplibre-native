{"sections":[],"abstract":[{"type":"text","text":"Resumes downloading if the pack is inactive."}],"primaryContentSections":[{"declarations":[{"languages":["occ"],"tokens":[{"text":"- (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"resume","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS","iPadOS","Mac Catalyst"]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When a pack resumes after being suspended, it may begin by iterating over the"},{"type":"text","text":" "},{"type":"text","text":"already downloaded resources. As a result, the "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" structure’s"},{"type":"text","text":" "},{"type":"codeVoice","code":"countOfResourcesCompleted"},{"type":"text","text":" field may revert to 0 before rapidly returning to"},{"type":"text","text":" "},{"type":"text","text":"the level of progress at the time the pack was suspended."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To temporarily suspend downloading, call the "},{"type":"codeVoice","code":"-suspend"},{"type":"text","text":" method."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinepack\/resume"]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/resume","interfaceLanguage":"occ"},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"fragments":[{"text":"- ","kind":"text"},{"text":"resume","kind":"identifier"}],"roleHeading":"Instance Method","title":"resume","externalID":"c:objc(cs)MLNOfflinePack(im)resume","modules":[{"name":"MapLibre"}],"symbolKind":"method","role":"s