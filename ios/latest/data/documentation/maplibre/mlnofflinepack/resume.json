{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"- (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"resume","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"When a pack resumes after being suspended, it may begin by iterating over the"},{"type":"text","text":" "},{"type":"text","text":"already downloaded resources. As a result, the "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" structure’s"},{"type":"text","text":" "},{"type":"codeVoice","code":"countOfResourcesCompleted"},{"type":"text","text":" field may revert to 0 before rapidly returning to"},{"type":"text","text":" "},{"type":"text","text":"the level of progress at the time the pack was suspended."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To temporarily suspend downloading, call the "},{"type":"codeVoice","code":"-suspend"},{"type":"text","text":" method."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinepack\/resume"]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"]]},"abstract":[{"type":"text","text":"Resumes downloading if the pack is inactive."}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/resume"},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"metadata":{"externalID":"c:objc(cs)MLNOfflinePack(im)resume","roleHeading":"Instance Method","symbolKind":"method","modules":[{"name":"MapLibre"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"resume"}],"fragments":[{"kind":"text","text":"- "},{"kind":"identif