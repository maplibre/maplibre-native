{"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Resumes downloading if the pack is inactive."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinepack\/resume"]}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"- (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"resume","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When a pack resumes after being suspended, it may begin by iterating over the"},{"type":"text","text":" "},{"type":"text","text":"already downloaded resources. As a result, the "},{"code":"progress","type":"codeVoice"},{"type":"text","text":" structure’s"},{"type":"text","text":" "},{"code":"countOfResourcesCompleted","type":"codeVoice"},{"type":"text","text":" field may revert to 0 before rapidly returning to"},{"type":"text","text":" "},{"type":"text","text":"the level of progress at the time the pack was suspended."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To temporarily suspend downloading, call the "},{"type":"codeVoice","code":"-suspend"},{"type":"text","text":" method."}]}],"kind":"content"}],"sections":[],"metadata":{"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"resume"}],"navigatorTitle":[{"text":"resume","kind":"identifier"}],"externalID":"c:objc(cs)MLNOfflinePack(im)resume","symbolKind":"method","role":"symbol","title":"resume","modules":[{"name":"MapLibre"}],"roleHeading":"Instance Method"},"kind":"symbol","identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack\/resume","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swif