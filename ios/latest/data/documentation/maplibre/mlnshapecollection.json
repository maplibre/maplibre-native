"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true},{"type":"text","text":". Configure the appearance of an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true,"type":"reference"},{"type":"text","text":"’s or"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","isActive":true,"type":"reference"},{"type":"text","text":"’s shape collection collectively using an"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer","isActive":true,"type":"reference"},{"type":"text","text":" object, or use multiple instances of"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCircleStyleLayer","isActive":true,"type":"reference"},{"type":"text","text":", "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCircleStyleLayer","isActive":true,"type":"reference"},{"type":"text","text":", and "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCircleStyleLayer","isActive":true,"type":"reference"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"configure the appearance of each kind of shape inside the collection."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You cannot add an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollection","isActive":true,"type":"reference"},{"type":"text","text":" object directly to a map view as an"},{"type":"text","text":" "},{"type":"text","text":"annotation. However, you can create individual "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation","isActive":true,"type":"reference"},{"type":"text","text":","},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolyline","isActive":true,"type":"reference"},{"type":"text","text":", and "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolyline","isActive":true,"type":"reference"},{"type":"text","text":" objects from the "},{"code":"shapes","type":"codeVoice"},{"type":"text","text":" array and add those"},{"type":"text","text":" "},{"type":"text","text":"annotation objects to the map view using the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/addAnnotations:","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"method."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To represent a collection of point, polyline, or polygon shapes, it may be more"},{"type":"text","text":" "},{"type":"text","text":"convenient to use an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection","isActive":true,"type":"reference"},{"type":"text","text":", "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection","isActive":true,"type":"reference"},{"type":"text","text":", or"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon","isActive":true,"type":"reference"},{"type":"text","text":" object, respectively. To access a shape collection’s"},{"type":"text","text":" "},{"type":"text","text":"attributes, use the corresponding "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature","isActive":true,"type":"reference"},{"type":"text","text":" object."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A shape collection is known as a"},{"type":"text","text":" "},{"type":"text","text":"GeometryCollection"},{"type":"text","text":" "},{"type":"text","text":"geometry in GeoJSON."}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollection","int