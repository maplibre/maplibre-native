nce","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource"},{"text":" object. Each concrete","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"subclass of "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"text":" in turn has a subclass that conforms to this protocol. A","type":"text"},{"text":" ","type":"text"},{"text":"feature object associates a shape with an optional identifier and attributes.","type":"text"}],"url":"\/documentation\/maplibre\/mlnfeature","fragments":[{"kind":"identifier","text":"MLNFeature"}],"kind":"symbol","title":"MLNFeature","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/GeoJSON":{"url":"\/documentation\/maplibre-native-for-ios\/geojson","kind":"article","type":"topic","abstract":[],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","role":"article","title":"Working with GeoJSON Data"},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotationImage":{"role":"symbol","title":"MLNAnnotationImage","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage","abstract":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage"},{"text":" class is responsible for presenting point-based","type":"text"},{"text":" ","type":"text"},{"text":"annotations visually on a map view. Annotation image objects wrap ","type":"text"},{"type":"codeVoice","code":"UIImage"},{"text":" ","type":"text"},{"text":"objects and may be recycled later and put into a reuse queue that is maintained","type":"text"},{"text":" ","type":"text"},{"text":"by the map view.","type":"text"}],"url":"\/documentation\/maplibre\/mlnannotationimag