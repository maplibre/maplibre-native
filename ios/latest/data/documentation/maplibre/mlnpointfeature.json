o not provide"},{"text":" ","type":"text"},{"text":"the visual representation of the annotation but typically coordinate (in","type":"text"},{"type":"text","text":" "},{"text":"conjunction with the map view’s delegate) the creation of an appropriate","type":"text"},{"type":"text","text":" "},{"text":"objects to handle the display.","type":"text"}],"url":"\/documentation\/maplibre\/mlnannotation","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","type":"topic","role":"symbol","fragments":[{"text":"MLNAnnotation","kind":"identifier"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/GeoJSON":{"kind":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","role":"article","abstract":[],"type":"topic","url":"\/documentation\/maplibre-native-for-ios\/geojson","title":"Working with GeoJSON Data"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/WebAPIDataExample":{"role":"article","type":"topic","abstract":[{"type":"text","text":"Showing data from an API with custom styling and interaction"}],"url":"\/documentation\/maplibre-native-for-ios\/webapidataexample","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/WebAPIDataExample","kind":"article","title":"Showing data from an API"},"doc://org.swift.MyProject/documentation/MapLibre/MLNPointFeatureCluster":{"url":"\/documentation\/maplibre\/mlnpointfeaturecluster","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointFeatureCluster","abstract":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointFeatureCluster","isActive":true,"type":"reference"},{"text":" object associates a point shape (with an optional","type":"text"},{"text":" ","type":"text"},{"text":"identifier and attributes) and represents a point cluster.","type":"text"}],"fragments":[{"text":"MLNPointFeatureCluster","kind":"identifier