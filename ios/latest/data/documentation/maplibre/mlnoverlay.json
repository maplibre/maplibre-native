MyProject\/documentation\/MapLibre\/MLNAnnotation","kind":"typeIdentifier"},{"text":">","kind":"text"}]}]},{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"inlineContent":[{"type":"text","text":"You use overlays to layer more sophisticated content on top of a map view. For"},{"type":"text","text":" "},{"type":"text","text":"example, you could use an overlay to show the boundaries of a national park or"},{"type":"text","text":" "},{"type":"text","text":"trace a bus route along city streets. This SDK defines several concrete classes"},{"type":"text","text":" "},{"type":"text","text":"that conform to this protocol and define standard shapes."}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay"},{"type":"text","text":" protocol defines a specific type of annotation that represents"},{"type":"text","text":" "},{"type":"text","text":"both a point and an area on a map. Overlay objects are essentially data objects"},{"type":"text","text":" "},{"type":"text","text":"that contain the geographic data needed to represent the map area. Overlays can"},{"type":"text","text":" "},{"type":"text","text":"take the form of a polyline or polygon."}],"variants":[{"paths":["\/documentation\/maplibre\/mlnoverlay"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOverlay/intersectsOverlayBounds:":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay\/intersectsOverlayBounds:","kind":"symbol","url":"\/documentation\/maplibre\/mlnoverlay\/intersectsoverlaybounds:","role":"symbol","abstract":[{"text":"Returns a Boolean indicating whether the specified rectangle intersects the","type":"text"},{"text":" ","type":"text"},{"text":"receiver’s shape.","type":"text"}],"title":"intersectsOverlayBounds:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"intersectsOverlayBounds:"}],"navigatorTitle":[{"kind":"identifier","text":"intersectsOverlayBounds:"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNPolygon":{"abstract":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon","isActive":true,"type":"reference"},{"text":" object represents a closed shape consisting of four or more","type":"text"},{"text":" ","type":"text"},{"text":"vertices, specified as ","type":"text"},{"code":"CLLocationCoordinate2D","type":"codeVoice"},{"text":" instances, and the edges that","type":"text"},{"text":" ","type":"text"},{"text":"connect them. For example, you could use a polygon shape to represent a","type":"text"},{"text":" ","type":"text"},{"text":"building, a lake, or an area you want to highlight.","type":"text"}],"title":"MLNPolygon","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon","kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"MLNPolygon","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnpolygon"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPolygon":{"kind":"symbol","url":"\/documentation\/maplibre\/mlnmultipolygon","abstract":[{"type":"text","text":"An "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon","type":"reference"},{"type":"text","text":" object represents a shape consisting of one or more"},{"type":"text","text":" "},{"type":"text","text":"polygons that do not overlap. For example, you could use a multipolygon shape"},{"type":"text","text":" "},{"type":"text","text":"to represent the body of land that consists of an island surrounded by an"},{"type":"text","text":" "},{"type":"text","text":"atoll: the inner island would be one "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon","type":"reference"},{"type":"text","text":" object, while 