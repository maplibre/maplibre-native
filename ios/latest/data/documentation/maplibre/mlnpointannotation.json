:" ","type":"text"},{"text":"can update a shape source by setting its ","type":"text"},{"type":"codeVoice","code":"shape"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"URL"},{"text":" property.","type":"text"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","title":"MLNShapeSource","url":"\/documentation\/maplibre\/mlnshapesource","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/GeoJSON":{"url":"\/documentation\/maplibre-native-for-ios\/geojson","title":"Working with GeoJSON Data","type":"topic","kind":"article","role":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","abstract":[]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPolygonFeature":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygonFeature","abstract":[{"text":"An ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygonFeature","isActive":true},{"text":" object associates a multipolygon shape with an","type":"text"},{"text":" ","type":"text"},{"text":"optional identifier and attributes.","type":"text"}],"kind":"symbol","fragments":[{"text":"MLNMultiPolygonFeature","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnmultipolygonfeature","type":"topic","role":"symbol","title":"MLNMultiPolygonFeature"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","abstract":[{"text":"The proxy object for the current map style.","type":"text"}],"kind":"symbol","fragments":[{"text":"MLNStyle","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnstyle","type":"topic","role":"symbol","title":"MLNStyle"},"doc://org.swift.MyProject/documentation/MapLibre/MLNPointAnnotation":{"title":"MLNPointAnnotation","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation","kind":"symbol","role":"symbol","fragments":[{"kind":"identifier","text":"MLNPointAnnotation"}],"type":"topic","url":"\/documentation\/maplibre\/mlnpointannotation","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation","isActive":true,"type":"reference"},{"type":"text","text":" object represents a one-dimensional shape located at a"},{"type":"text","text":" "},{"type":"text","text":"single geographical coordinate. Depending on how it is used, an"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation","type":"reference"},{"text":" object is known as a point annotation or point shape. For","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"example, you could use a point shape to represent a city at low zoom levels, an"},{"type":"text","text":" "},{"type":"text","text":"address at high zoom levels, or the location of a long press gesture."}]}}}