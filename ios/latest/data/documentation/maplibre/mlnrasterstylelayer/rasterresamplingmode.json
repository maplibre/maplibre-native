{"abstract":[{"type":"text","text":"The resampling\/interpolation method to use for overscaling, also known as"},{"type":"text","text":" "},{"type":"text","text":"texture magnification filter"}],"metadata":{"fragments":[{"text":"rasterResamplingMode","kind":"identifier"}],"role":"symbol","externalID":"c:objc(cs)MLNRasterStyleLayer(py)rasterResamplingMode","symbolKind":"property","modules":[{"name":"MapLibre"}],"title":"rasterResamplingMode","roleHeading":"Instance Property","navigatorTitle":[{"kind":"identifier","text":"rasterResamplingMode"}]},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer\/rasterResamplingMode","interfaceLanguage":"occ"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"text":"NSExpression","preciseIdentifier":"c:objc(cs)NSExpression","kind":"typeIdentifier"},{"text":" * ","kind":"text"},{"text":"rasterResamplingMode","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default value of this property is an expression that evaluates to "},{"type":"codeVoice","code":"linear"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Set this property to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to reset it to the default value."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This attribute corresponds to the "},{"type":"text","text":"raster-resampling"},{"type":"text","text":" "},{"type":"text","text":"layout property in the MapLibre Style Spec."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can set this property to an expression containing any of the following:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Constant "},{"type":"codeVoice","code":"MLNRasterResamplingMode"},{"type":"text","text":" values"},{"type":"text","text":" "},{"type":"text","text":"Any of the following constant string values:"},{"type":"text","text":" "},{"type":"codeVoice","code":"linear"},{"type":"text","text":": (Bi)linear filtering interpolates pixel values using the weighted"},{"type":"text","text":" "},{"type":"text","text":"average of the four closest original source pixels creating a smooth but blurry"},{"type":"text","text":" "},{"type":"text","text":"look when overscaled"},{"type":"text","text":" "},{"type":"codeVoice","code":"nearest"},{"type":"text","text":": Nearest neighbor filtering interpolates pixel values using the"},{"type":"text","text":" "},{"type":"text","text":"nearest original source pixel creating a sharp but pixelated look when"},{"type":"text","text":" "},{"type":"text","text":"overscaled"},{"type":"text","text":" "},{"type":"text","text":"Predefined functions, including mathematical and string operators"},{"type":"text","text":" "},{"type":"text","text":"Conditional expressions"},{"type":"text","text":" "},{"type":"text","text":"Variable assignments and references to assigned variables"},{"type":"text","text":" "},{"type":"text","text":"Step functions applied to the "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable"}]},{"type":"paragraph","inlineContent":[{"text":"This property does not support applying interpolation functions to the","type":"text"},{"text":" ","type":"text"},{"code":"$zoomLevel","type":"codeVoice"},{"text":" variable or applying interpolation or step functions to feature","type":"text"},{"text":" ","type":"text"},{"text":"attributes.","type":"text"}]}],"kind":"content"}],"sections":[],"variants":[{"paths":["\/documentation\/maplibre\/mlnrasterstylelayer\/rasterresamplingmode"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"symbol","references":{"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"title":"MapLibre","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterStyleLayer":{"url":"\/documentation\/maplibre\/mlnrasterstylelayer","abstract":[{"text":"An ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer"},{"text":" is a style layer that renders georeferenced raster","type":"text"},{"text":" ","type":"text"},{"text":"imagery on the map, especially raster tiles.","type":"text"}],"type":"topic","fragments":[{"text":"MLNRasterStyleLayer","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","kind":"symbol","role":"symbol","title":"MLNRasterStyleLayer"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterStyleLayer/rasterResamplingMode":{"abstract":[{"text":"The resampling\/interpolation method to use for overscaling, also known as","type":"text"},{"text":" ","type":"text"},{"text":"texture magnification filter","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer\/rasterResamplingMode","url":"\/documentation\/maplibre\/mlnrasterstylelayer\/rasterresamplingmode","fragments":[{"text":"rasterResamplingMode","kind":"identifier"}],"role":"symbol","title":"rasterResamplingMode","kind":"symbol","type":"topic"}}}