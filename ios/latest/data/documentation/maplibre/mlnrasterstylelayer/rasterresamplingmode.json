lurry"},{"type":"text","text":" "},{"type":"text","text":"look when overscaled"},{"type":"text","text":" "},{"type":"codeVoice","code":"nearest"},{"type":"text","text":": Nearest neighbor filtering interpolates pixel values using the"},{"type":"text","text":" "},{"type":"text","text":"nearest original source pixel creating a sharp but pixelated look when"},{"type":"text","text":" "},{"type":"text","text":"overscaled"},{"type":"text","text":" "},{"type":"text","text":"Predefined functions, including mathematical and string operators"},{"type":"text","text":" "},{"type":"text","text":"Conditional expressions"},{"type":"text","text":" "},{"type":"text","text":"Variable assignments and references to assigned variables"},{"type":"text","text":" "},{"type":"text","text":"Step functions applied to the "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property does not support applying interpolation functions to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable or applying interpolation or step functions to feature"},{"type":"text","text":" "},{"type":"text","text":"attributes."}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer\/rasterResamplingMode","interfaceLanguage":"occ"},"kind":"symbol","sections":[],"variants":[{"paths":["\/documentation\/maplibre\/mlnrasterstylelayer\/rasterresamplingmode"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"symbolKind":"property","externalID":"c:objc(cs)MLNRasterStyleLayer(py)rasterResamplingMode","roleHeading":"Instance Property","fragments":[{"kind":"identifier","text":"rasterResamplingMode"}],"navigatorTitle":[{"kind":"identifier","text":"rasterResamplingMode"}],"title":"rasterResamplingMode","modules":[{"name":"MapLibre"}],"role":"symbol"},"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"t