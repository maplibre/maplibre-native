{"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer\/rasterResamplingMode","interfaceLanguage":"occ"},"metadata":{"navigatorTitle":[{"text":"rasterResamplingMode","kind":"identifier"}],"externalID":"c:objc(cs)MLNRasterStyleLayer(py)rasterResamplingMode","title":"rasterResamplingMode","symbolKind":"property","modules":[{"name":"MapLibre"}],"role":"symbol","roleHeading":"Instance Property","fragments":[{"text":"rasterResamplingMode","kind":"identifier"}]},"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"kind":"typeIdentifier","text":"NSExpression","preciseIdentifier":"c:objc(cs)NSExpression"},{"kind":"text","text":" * "},{"kind":"identifier","text":"rasterResamplingMode"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"The default value of this property is an expression that evaluates to "},{"type":"codeVoice","code":"linear"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Set this property to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to reset it to the default value."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This attribute corresponds to the "},{"type":"text","text":"raster-resampling"},{"type":"text","text":" "},{"type":"text","text":"layout property in the MapLibre Style Spec."}],"type":"paragraph"},{"inlineContent":[{"text":"You can set this property to an expression containing any of the following:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Constant "},{"type":"codeVoice","code":"MLNRasterResamplingMode"},{"type":"text","text":" values"},{"type":"tex