{"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnrasterstylelayer\/rasterresamplingmode"]}],"sections":[],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer\/rasterResamplingMode","interfaceLanguage":"occ"},"kind":"symbol","abstract":[{"text":"The resampling\/interpolation method to use for overscaling, also known as","type":"text"},{"text":" ","type":"text"},{"text":"texture magnification filter","type":"text"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSExpression","text":"NSExpression","kind":"typeIdentifier"},{"text":" * ","kind":"text"},{"text":"rasterResamplingMode","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"The default value of this property is an expression that evaluates to "},{"type":"codeVoice","code":"linear"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Set this property to "},{"code":"nil","type":"codeVoice"},{"text":" to reset it to the default value.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This attribute corresponds to the "},{"text":"raster-resampling","type":"text"},{"text":" ","type":"text"},{"text":"layout property in the MapLibre Style Spec.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"You can set this property to an expression containing any of the following:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Constant ","type":"text"},{"code":"MLNRasterResamplingMode","type":"codeVoice"},{"text":" values","type":"text"},{"text":" ","type":"text"},{"text":"Any of the following constant string values:","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"linear"},{"text":": (Bi)linear filtering interpolates pixel values using the weighted","type":"text"},{"text":" ","type":"text"},{"text":"average of the four closest original source pixels creating a smooth but blurry","type":"text"},{"text":" ","type":"text"},{"text":"look when overscaled","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"nearest"},{"type":"text","text":": Nearest neighbor filtering interpolates pixel values using the"},{"type":"text","text":" "},{"type":"text","text":"nearest original source pixel creating a sharp but pixelated look when"},{"type":"text","text":" "},{"type":"text","text":"overscaled"},{"type":"text","text":" "},{"type":"text","text":"Predefined functions, including mathematical and string operators"},{"type":"text","text":" "},{"type":"text","text":"Conditional expressions"},{"type":"text","text":" "},{"type":"text","text":"Variable assignments and references to assigned variables"},{"type":"text","text":" "},{"type":"text","text":"Step functions applied to the "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property does not support applying interpolation functions to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable or applying interpolation or step functions to feature"},{"type":"text","text":" "},{"type":"text","text":"attributes."}]}],"kind":"content"}],"metadata":{"symbolKind":"property","fragments":[{"kind":"identifier","text":"rasterResamplingMode"}],"externalID":"c:objc(cs)MLNRasterStyleLayer(py)rasterResamplingMode","navigatorTit