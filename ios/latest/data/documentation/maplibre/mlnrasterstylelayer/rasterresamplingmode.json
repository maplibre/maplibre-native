{"abstract":[{"type":"text","text":"The resampling\/interpolation method to use for overscaling, also known as"},{"type":"text","text":" "},{"type":"text","text":"texture magnification filter"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer"]]},"kind":"symbol","identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer\/rasterResamplingMode","interfaceLanguage":"occ"},"metadata":{"role":"symbol","symbolKind":"property","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"kind":"identifier","text":"rasterResamplingMode"}],"externalID":"c:objc(cs)MLNRasterStyleLayer(py)rasterResamplingMode","title":"rasterResamplingMode","roleHeading":"Instance Property","fragments":[{"kind":"identifier","text":"rasterResamplingMode"}]},"variants":[{"paths":["\/documentation\/maplibre\/mlnrasterstylelayer\/rasterresamplingmode"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"preciseIdentifier":"c:objc(cs)NSExpression","kind":"typeIdentifier","text":"NSExpression"},{"kind":"text","text":" * "},{"kind":"identifier","text":"rasterResamplingMode"},{"kind":"text","text":";"}],"languages":["occ"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The default value of this property is an expression that evaluates to "},{"type":"codeVoice","code":"linear"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Set this property to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to reset it to the default value."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This attribute corresponds to the "},{"type":"text","text":"raster-resampling"},{"type":"text","text":" "},{"type":"text","text":"layout property in the MapLibre Style Spec."}],"type":"paragraph"},{"inlineContent":[{"text":"You can set this property to an expression containing any of the following:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Constant "},{"code":"MLNRasterResamplingMode","type":"codeVoice"},{"type":"text","text":" values"},{"type":"text","text":" "},{"type":"text","text":"Any of the following constant string values:"},{"type":"text","text":" "},{"code":"linear","type":"codeVoice"},{"type":"text","text":": (Bi)linear filtering interpolates pixel values using the weighted"},{"type":"text","text":" "},{"type":"text","text":"average of the four closest original source pixels creating a smooth but blurry"},{"type":"text","text":" "},{"type":"text","text":"look when overscaled"},{"type":"text","text":" "},{"code":"nearest","type":"codeVoice"},{"type":"text","text":": Nearest neighbor filtering interpolates pixel values using the"},{"type":"text","text":" "},{"type":"text","text":"nearest original source pixel creating a sharp but pixelated look when"},{"type":"text","text":" "},{"type":"text","text":"overscaled"},{"type":"text","text":" "},{"type":"text","text":"Predefined functions, including mathematical and string operators"},{"type":"text","text":" "},{"type":"text","text":"Conditional expressions"},{"type":"text","text":" "},{"type":"text","text":"Variable assignments and references to assigned variables"},{"type":"text","text":" "},{"type":"text","text":"Step functions applied to the "},{"code":"$zoomLevel","type":"codeVoice"},{"type":"text","text":" variable"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This property does not support applying interpolation functions to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable or applying interpolation or step functions to feature"},{"type":"text","text":" "},{"type":"text","text":"attributes."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterStyleLayer/rasterResamplingMode":{"abstract":[{"type":"text","text":"The resampling\/interpolation method to use for overscaling, also known as"},{"type":"text","text":" "},{"type":"text","text":"texture magnification filter"}],"title":"rasterResamplingMode","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer\/rasterResamplingMode","fragments":[{"text":"rasterResamplingMode","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnrasterstylelayer\/rasterresamplingmode","kind":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterStyleLayer":{"kind":"symbol","title":"MLNRasterStyleLayer","abstract":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer"},{"type":"text","text":" is a style layer that renders georeferenced raster"},{"type":"text","text":" "},{"type":"text","text":"imagery on the map, especially raster tiles."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","fragments":[{"kind":"identifier","text":"MLNRasterStyleLayer"}],"url":"\/documentation\/maplibre\/mlnrasterstylelayer","type":"topic","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","kind":"symbol","title":"MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","type":"topic"}}}