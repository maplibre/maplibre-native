":"text","text":" "},{"type":"text","text":"one tile at a time, to be shown on the map on demand. You implement a class"},{"type":"text","text":" "},{"type":"text","text":"conforming to the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource"},{"type":"text","text":" protocol that returns"},{"type":"text","text":" "},{"type":"text","text":"instances of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":" or "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":", then add a computed shape source to an"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object along with an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the computed shape"},{"type":"text","text":" "},{"type":"text","text":"source."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMaximumZoomLevel":{"role":"symbol","fragments":[{"text":"MLNShapeSourceOptionMaximumZoomLevel","kind":"identifier"}],"kind":"symbol","abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing an integer; specifies the maximum zoom level at","type":"text"},{"text":" ","type":"text"},{"text":"which to create vector tiles. A greater value produces greater detail at high","type":"text"},{"text":" ","type":"text"},{"text":"zoom levels. The default value is 18.","type":"text"}],"type":"topic","title":"MLNShapeSourceOptionMaximumZoomLevel","url":"\/documentation\/m