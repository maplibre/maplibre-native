ocumentation\/MapLibre\/MLNSymbolStyleLayer\/symbolSortKey"},{"type":"text","text":"."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolZOrder","type":"topic","kind":"symbol","title":"MLNSymbolZOrder","url":"\/documentation\/maplibre\/mlnsymbolzorder","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer/symbolSortKey":{"title":"symbolSortKey","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/symbolSortKey","type":"topic","fragments":[{"kind":"identifier","text":"symbolSortKey"}],"abstract":[{"type":"text","text":"Sorts features in ascending order based on this value. Features with lower sort"},{"type":"text","text":" "},{"type":"text","text":"keys are drawn and placed first.  When "},{"code":"iconAllowsOverlap","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"code":"textAllowsOverlap","type":"codeVoice"},{"type":"text","text":" is "},{"code":"false","type":"codeVoice"},{"type":"text","text":", features with a lower sort key will have"},{"type":"text","text":" "},{"type":"text","text":"priority during placement. When "},{"code":"iconAllowsOverlap","type":"codeVoice"},{"type":"text","text":" or "},{"code":"textAllowsOverlap","type":"codeVoice"},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"set to "},{"code":"YES","type":"codeVoice"},{"type":"text","text":", features with a higher sort key will overlap over features with a"},{"type":"text","text":" "},{"type":"text","text":"lower sort key."}],"url":"\/documentation\/maplibre\/mlnsymbolstylelayer\/symbolsortkey","role":"symbol","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolZOrder/MLNSymbolZOrderViewportY":{"type":"topic","url":"\/documentation\/maplibre\/mlnsymbolzorder\/mlnsymbolzorderviewporty","kind":"symbol","title":"MLNSymbolZOrderViewportY","abstract":[],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/M