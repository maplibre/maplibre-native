LNComputedShapeSourceDataSource":{"abstract":[{"type":"text","text":"Data source for "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource"},{"type":"text","text":". This protocol defines two optional methods for fetching"},{"type":"text","text":" "},{"type":"text","text":"data, one based on tile coordinates, and one based on a bounding box. Classes that implement this"},{"type":"text","text":" "},{"type":"text","text":"protocol must implement one, and only one of the methods. Methods on this protocol will not be"},{"type":"text","text":" "},{"type":"text","text":"called on main thread, they will be called on the caller’s "},{"type":"codeVoice","code":"requestQueue"},{"type":"text","text":"."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource","title":"MLNComputedShapeSourceDataSource","url":"\/documentation\/maplibre\/mlncomputedshapesourcedatasource","type":"topic","fragments":[{"text":"MLNComputedShapeSourceDataSource","kind":"identifier"}],"role":"symbol","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSource":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource"},{"type":"text","text":" is a map content source that supplies vector shapes,"},{"type":"text","text":" "},{"type":"text","text":"one tile at a time, to be shown on the map on demand. You implement a class"},{"type":"text","text":" "},{"type":"text","text":"conforming to the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource"},{"type":"text","text":" protocol that returns"},{"type":"text","text":" "},{"type":"text","text":"instances of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":" or "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":", then add a computed shape source to an"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object along with an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the computed shape"},{"type":"text","text":" "},{"type":"text","text":"source."}],"url":"\/documentation\/maplibre\/mlncomputedshapesource","fragments":[{"text":"MLNComputedShapeSource","kind":"identifier"}],"title":"MLNComputedShapeSource","type":"topic","kind":"symbol","role":"symbol"}}}