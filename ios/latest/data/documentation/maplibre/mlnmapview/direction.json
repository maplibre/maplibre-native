{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"kind":"symbol","abstract":[{"type":"text","text":"The heading of the map, measured in degrees clockwise from true north."}],"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"preciseIdentifier":"c:@T@CLLocationDirection","kind":"typeIdentifier","text":"CLLocationDirection"},{"kind":"text","text":" "},{"kind":"identifier","text":"direction"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The value "},{"code":"0","type":"codeVoice"},{"type":"text","text":" means that the top edge of the map view corresponds to true"},{"type":"text","text":" "},{"type":"text","text":"north. The value "},{"code":"90","type":"codeVoice"},{"type":"text","text":" means the top of the map is pointing due east. The"},{"type":"text","text":" "},{"type":"text","text":"value "},{"code":"180","type":"codeVoice"},{"type":"text","text":" means the top of the map points due south, and so on."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Changing the value of this property updates the map view immediately. If you"},{"type":"text","text":" "},{"type":"text","text":"want to animate the change, use the "},{"type":"codeVoice","code":"-setDirection:animated:"},{"type":"text","text":" method instead."}]}]}],"metadata":{"symbolKind":"property","role":"symbol","externalID":"c:objc(cs)MLNMapView(py)direction","modules":[{"name":"MapLibre"}],"roleHeading":"Instance Property","title":"direction","navigatorTitle":[{"text":"direction","kind":"identifier"}],"fragme