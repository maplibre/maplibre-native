 method instead."}]}]}],"metadata":{"remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L1081"},"symbolKind":"property","fragments":[{"text":"direction","kind":"identifier"}],"externalID":"c:objc(cs)MLNMapView(py)direction","navigatorTitle":[{"text":"direction","kind":"identifier"}],"roleHeading":"Instance Property","modules":[{"name":"MapLibre"}],"role":"symbol","title":"direction"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/direction":{"url":"\/documentation\/maplibre\/mlnmapview\/direction","abstract":[{"text":"The heading of the map, measured in degrees clockwise from true north.","type":"text"}],"fragments":[{"text":"direction","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/direction","title":"direction","kind":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"type":"topic","role":"collection","title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"role":"symbol","fragments":[{"kind":"identifier","text":"MLNMapView"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","kind":"symbol","title":"MLNMapView","type":"topic","url":"\/documentation\/maplibre\/mlnmapview","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}]}}}