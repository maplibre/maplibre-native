{"sections":[],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/direction"},"abstract":[{"text":"The heading of the map, measured in degrees clockwise from true north.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:@T@CLLocationDirection","text":"CLLocationDirection","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"direction","kind":"identifier"},{"text":";","kind":"text"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"The value ","type":"text"},{"code":"0","type":"codeVoice"},{"text":" means that the top edge of the map view corresponds to true","type":"text"},{"text":" ","type":"text"},{"text":"north. The value ","type":"text"},{"code":"90","type":"codeVoice"},{"text":" means the top of the map is pointing due east. The","type":"text"},{"text":" ","type":"text"},{"text":"value ","type":"text"},{"code":"180","type":"codeVoice"},{"text":" means the top of the map points due south, and so on.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Changing the value of this property updates the map view immediately. If you"},{"type":"text","text":" "},{"type":"text","text":"want to animate the change, use the "},{"code":"-setDirection:animated:","type":"codeVoice"},{"type":"text","text":" method instead."}]}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"metadata":{"symbolKind":"property","roleHeading":"Instance Property","role":"symbol","externalID":"c:objc(cs)MLNMapView(py)direction","modules":[{"name":"MapLibre"}],"remoteSourc