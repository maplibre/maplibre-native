{"sections":[],"abstract":[{"type":"text","text":"The heading of the map, measured in degrees clockwise from true north."}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"text":") ","kind":"text"},{"text":"CLLocationDirection","kind":"typeIdentifier","preciseIdentifier":"c:@T@CLLocationDirection"},{"kind":"text","text":" "},{"text":"direction","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The value "},{"type":"codeVoice","code":"0"},{"type":"text","text":" means that the top edge of the map view corresponds to true"},{"type":"text","text":" "},{"type":"text","text":"north. The value "},{"type":"codeVoice","code":"90"},{"type":"text","text":" means the top of the map is pointing due east. The"},{"type":"text","text":" "},{"type":"text","text":"value "},{"type":"codeVoice","code":"180"},{"type":"text","text":" means the top of the map points due south, and so on."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Changing the value of this property updates the map view immediately. If you"},{"type":"text","text":" "},{"type":"text","text":"want to animate the change, use the "},{"type":"codeVoice","code":"-setDirection:animated:"},{"type":"text","text":" method instead."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"roleHeading":"Instance Property","symbolKind":"property","externalID":"c:objc(cs)MLNMapView(py)direction","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"text":"direction","kind":"identifier"}],"role":"symbol","fragments":[{"kind":"identifier","text":"direction"}],"remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L1081","fileName":"MLNMapView