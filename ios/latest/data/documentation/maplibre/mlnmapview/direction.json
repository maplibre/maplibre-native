{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"abstract":[{"type":"text","text":"The heading of the map, measured in degrees clockwise from true north."}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"kind":"typeIdentifier","text":"CLLocationDirection","preciseIdentifier":"c:@T@CLLocationDirection"},{"kind":"text","text":" "},{"kind":"identifier","text":"direction"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"The value ","type":"text"},{"code":"0","type":"codeVoice"},{"text":" means that the top edge of the map view corresponds to true","type":"text"},{"text":" ","type":"text"},{"text":"north. The value ","type":"text"},{"code":"90","type":"codeVoice"},{"text":" means the top of the map is pointing due east. The","type":"text"},{"text":" ","type":"text"},{"text":"value ","type":"text"},{"code":"180","type":"codeVoice"},{"text":" means the top of the map points due south, and so on.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Changing the value of this property updates the map view immediately. If you"},{"type":"text","text":" "},{"type":"text","text":"want to animate the change, use the "},{"code":"-setDirection:animated:","type":"codeVoice"},{"type":"text","text":" method instead."}],"type":"paragraph"}]}],"kind":"symbol","metadata":{"fragments":[{"kind":"identifier","text":"direction"}],"externalID":"c:objc(cs)MLNMapView(py)direction","symbolKind":"property","roleHeading":"Instance Property","navigatorTitle":[{"kind":"identifier","text":"direction"}],"role":"symbol","title":"direction","remoteSource":{"f