aph","inlineContent":[{"text":"Changing the value of this property updates the map view immediately. If you","type":"text"},{"text":" ","type":"text"},{"text":"want to animate the change, use the ","type":"text"},{"type":"codeVoice","code":"-setDirection:animated:"},{"text":" method instead.","type":"text"}]}],"kind":"content"}],"abstract":[{"type":"text","text":"The heading of the map, measured in degrees clockwise from true north."}],"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol","type":"topic","url":"\/documentation\/maplibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/direction":{"fragments":[{"kind":"identifier","text":"direction"}],"title":"direction","url":"\/documentation\/maplibre\/mlnmapview\/direction","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/direction","kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"The heading of the map, measured in degrees clockwise from true north."}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","title":"MLNMapView","abstract":[{"text":"An interactive, customizable map view with an interface similar to the one","type":"text"},{"text":" ","type":"text"},{"text":"provided by Apple’s MapKit.","type":"text"}],"type":"topic","kind":"symbol","url":"\/documentation\/maplibre\/mlnmapview","role":"symbol","fragments":[{"kind":"identifier","text":"MLNMapView"}]}}}