{"abstract":[{"text":"The heading of the map, measured in degrees clockwise from true north.","type":"text"}],"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"text":"CLLocationDirection","preciseIdentifier":"c:@T@CLLocationDirection","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"direction","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"The value ","type":"text"},{"type":"codeVoice","code":"0"},{"text":" means that the top edge of the map view corresponds to true","type":"text"},{"text":" ","type":"text"},{"text":"north. The value ","type":"text"},{"type":"codeVoice","code":"90"},{"text":" means the top of the map is pointing due east. The","type":"text"},{"text":" ","type":"text"},{"text":"value ","type":"text"},{"type":"codeVoice","code":"180"},{"text":" means the top of the map points due south, and so on.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Changing the value of this property updates the map view immediately. If you","type":"text"},{"text":" ","type":"text"},{"text":"want to animate the change, use the ","type":"text"},{"type":"codeVoice","code":"-setDirection:animated:"},{"text":" method instead.","type":"text"}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/direction"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"role":"symbol","externalID":"c:objc(cs)MLNMapView(py)direction","modules":[{"name":"MapLibre"}],"roleHeading":"Instance Property","navigatorTitle":[{"text":"direction","kind":"identifier"}],"symbolKind":"property","fragments":[{"text":"direction","kind":"identifier"}],"remoteSource":{"url":"https:\/\/github.com\/maplibre\/