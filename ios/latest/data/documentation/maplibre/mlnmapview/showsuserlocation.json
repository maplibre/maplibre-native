xt","text":"The default value of this property is "},{"code":"NO","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"Your app must specify a value for ","type":"text"},{"code":"NSLocationWhenInUseUsageDescription","type":"codeVoice"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"code":"NSLocationAlwaysUsageDescription","type":"codeVoice"},{"text":" in its ","type":"text"},{"code":"Info.plist","type":"codeVoice"},{"text":" to satisfy the","type":"text"},{"text":" ","type":"text"},{"text":"requirements of the underlying Core Location framework when enabling this","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"property."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you implement a custom location manager, set the "},{"type":"codeVoice","code":"locationManager"},{"type":"text","text":" before"},{"type":"text","text":" "},{"type":"text","text":"calling "},{"type":"codeVoice","code":"showsUserLocation"},{"type":"text","text":"."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/showsuserlocation"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"fragments":[{"kind":"identifier","text":"showsUserLocation"}],"roleHeading":"Instance Property","remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L590","fileName":"MLNMapView.h"},"role":"symbol","externalID":"c:objc(cs)MLNMapView(py)showsUserLocation","symbolKind":"property","modules":[{"name":"MapLibre"}],"title":"showsUserLocation","navigatorTitle":[{"text":"showsUserLocation","kind":"identifier"}]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/showsUserLocation":{"abstract":[{"text":"A Boolean value indicating whether the map may display the user location.","type":"text"}],"role":"symbol","title":"showsUserLocation","fragments":[{"kind":"identifier","t