"type":"text"},{"code":"Info.plist","type":"codeVoice"},{"text":" to satisfy the","type":"text"},{"text":" ","type":"text"},{"text":"requirements of the underlying Core Location framework when enabling this","type":"text"},{"text":" ","type":"text"},{"text":"property.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If you implement a custom location manager, set the ","type":"text"},{"code":"locationManager","type":"codeVoice"},{"text":" before","type":"text"},{"text":" ","type":"text"},{"text":"calling ","type":"text"},{"code":"showsUserLocation","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"metadata":{"navigatorTitle":[{"kind":"identifier","text":"showsUserLocation"}],"fragments":[{"text":"showsUserLocation","kind":"identifier"}],"title":"showsUserLocation","symbolKind":"property","remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L590","fileName":"MLNMapView.h"},"role":"symbol","modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNMapView(py)showsUserLocation","roleHeading":"Instance Property"},"kind":"symbol","sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"A Boolean value indicating whether the map may display the user location.","type":"text"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/showsUserLocation"},"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/showsuserlocation"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol","title":"MapLibre","identifier":"doc:\/\/org.sw