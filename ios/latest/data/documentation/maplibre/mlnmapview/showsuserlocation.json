{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/showsUserLocation"},"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"A Boolean value indicating whether the map may display the user location."}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"assign","kind":"keyword"},{"text":") ","kind":"text"},{"text":"BOOL","preciseIdentifier":"c:@T@BOOL","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"showsUserLocation","kind":"identifier"},{"text":";","kind":"text"}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Setting this property to "},{"type":"codeVoice","code":"YES"},{"type":"text","text":" causes the map view to use the Core Location"},{"type":"text","text":" "},{"type":"text","text":"framework to find the current location. As long as this property is "},{"type":"codeVoice","code":"YES"},{"type":"text","text":", the"},{"type":"text","text":" "},{"type":"text","text":"map view continues to track the user’s location and update it periodically."}],"type":"paragraph"},{"inlineContent":[{"text":"This property does not indicate whether the user’s position is actually visible","type":"text"},{"text":" ","type":"text"},{"text":"on the map, only whether the map view is allowed to display it. To determine","type":"text"},{"text":" ","type":"text"},{"text":"whether the user’s position is visible, use the ","type":"text"},{"code":"userLocationVisible","type":"codeVoice"},{"text":" property.","type":"text"},{"text":" ","type":"text"},{"text":"The default value of this property is ","type":"text"},{"code":"NO","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Your app must specify a value for ","type":"text"},{"code":"NSLocationWhenInUseUsageDescription","type":"codeVoice"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"code":"NSLocationAlwaysUsageDescription","type":"codeVoice"},{"text":" in its ","type":"text"},{"code":"Info.plist","type":"codeVoice"},{"text":" to satisfy the","type":"text"},{"text":" ","type":"text"},{"text":"requirements of the underlying Core Location framework when enabling this","type":"text"},{"text":" ","type":"text"},{"text":"property.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If you implement a custom location manager, set the ","type":"text"},{"type":"codeVoice","code":"locationManager"},{"text":" before","type":"text"},{"text":" ","type":"text"},{"text":"calling ","type":"text"},{"type":"codeVoice","code":"showsUserLocation"},{"text":".","type":"text"}],"type":"paragraph"}]}],"sections":[],"kind":"symbol","variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/showsuserlocation"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"symbolKind":"property","role":"symbol","navigatorTitle":[{"text":"showsUserLocation","kind":"identifier"}],"externalID":"c:objc(cs)MLNMapView(py)showsUserLocation","fragments":[{"text":"showsUserLocation","kind":"identifier"}],"roleHeading":"Instance Property","remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L590","fileName":"MLNMapView.h"},"modules":[{"name":"MapLibre"}],"title":"showsUserLocation"},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"url":"\/documentation\/maplibre","kind":"symbol","type":"topic","title":"MapLibre","id