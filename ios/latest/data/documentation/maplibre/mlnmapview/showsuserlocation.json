{"kind":"symbol","metadata":{"role":"symbol","symbolKind":"property","roleHeading":"Instance Property","modules":[{"name":"MapLibre"}],"remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L590","fileName":"MLNMapView.h"},"title":"showsUserLocation","navigatorTitle":[{"kind":"identifier","text":"showsUserLocation"}],"externalID":"c:objc(cs)MLNMapView(py)showsUserLocation","fragments":[{"kind":"identifier","text":"showsUserLocation"}]},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/showsUserLocation"},"abstract":[{"type":"text","text":"A Boolean value indicating whether the map may display the user location."}],"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"assign"},{"kind":"text","text":") "},{"preciseIdentifier":"c:@T@BOOL","kind":"typeIdentifier","text":"BOOL"},{"kind":"text","text":" "},{"kind":"identifier","text":"showsUserLocation"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"text":"Setting this property to ","type":"text"},{"code":"YES","type":"codeVoice"},{"text":" causes the map view to use the Core Location","type":"text"},{"text":" ","type":"text"},{"text":"framework to find the current location. As long as this property is ","type":"text"},{"code":"YES","type":"codeVoice"},{"text":", the","type":"text"},{"text":" ","type":"text"},{"text":"map view continues to track the user’s location and update it periodically.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This property does not indicate whether the user’s position is actually visible"},{"type":"text","text":" "},{"type":"text","text":"on the map, only whether the map view is allowed to display it. To determine"},{"type":"text","text":" "},{"type":"text","text":"whether the user’s position is visible, use the "},{"type":"codeVoice","code":"userLocationVisible"},{"type":"text","text":" property."},{"type":"text","text":" "},{"type":"text","text":"The default value of this property is "},{"type":"codeVoice","code":"NO"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Your app must specify a value for "},{"code":"NSLocationWhenInUseUsageDescription","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"code":"NSLocationAlwaysUsageDescription","type":"codeVoice"},{"type":"text","text":" in its "},{"code":"Info.plist","type":"codeVoice"},{"type":"text","text":" to satisfy the"},{"type":"text","text":" "},{"type":"text","text":"requirements of the underlying Core Location framework when enabling this"},{"type":"text","text":" "},{"text":"property.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you implement a custom location manager, set the "},{"type":"codeVoice","code":"locationManager"},{"type":"text","text":" before"},{"type":"text","text":" "},{"type":"text","text":"calling "},{"type":"codeVoice","code":"showsUserLocation"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/showsuserlocation"]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/showsUserLocation":{"fragments":[{"kind":"identifier","text":"showsUserLocation"}],"abstract":[{"type":"text","text":"A Boolean value indicating whether the map may display the user location."}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/showsUserLocation","kind":"symbol","type":"topic","title":"showsUserLocation","url":"\/documentation\/maplibre\/mlnmapview\/showsuserlocation"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"fragments":[{"kind":"identifier","text":"MLNMapView"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","kind":"symbol","url":"\/documentation\/maplibre\/mlnmapview","title":"MLNMapView","role":"symbol","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}]},"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection","type":"topic","url":"\/documentation\/maplibre","title":"MapLibre","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre"}}}