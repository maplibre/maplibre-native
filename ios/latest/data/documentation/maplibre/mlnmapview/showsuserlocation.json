{"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/showsUserLocation","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"assign","kind":"keyword"},{"text":") ","kind":"text"},{"text":"BOOL","kind":"typeIdentifier","preciseIdentifier":"c:@T@BOOL"},{"text":" ","kind":"text"},{"text":"showsUserLocation","kind":"identifier"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Setting this property to "},{"type":"codeVoice","code":"YES"},{"type":"text","text":" causes the map view to use the Core Location"},{"type":"text","text":" "},{"type":"text","text":"framework to find the current location. As long as this property is "},{"type":"codeVoice","code":"YES"},{"type":"text","text":", the"},{"type":"text","text":" "},{"type":"text","text":"map view continues to track the user’s location and update it periodically."}],"type":"paragraph"},{"inlineContent":[{"text":"This property does not indicate whether the user’s position is actually visible","type":"text"},{"text":" ","type":"text"},{"text":"on the map, only whether the map view is allowed to display it. To determine","type":"text"},{"text":" ","type":"text"},{"text":"whether the user’s position is visible, use the ","type":"text"},{"code":"userLocationVisible","type":"codeVoice"},{"text":" property.","type":"text"},{"text":" ","type":"text"},{"text":"The default value of this property is ","type":"text"},{"code":"NO","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Your app must specify a value for "},{"code":"NSLocationWhenInUseUsageDescription","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"code":"NSLocationAlwaysUsageDescription","type":"codeVoice"},{"type":"text","text":" in its "},{"code":"Info.plist","type":"codeVoice"},{"type":"text","text":" to satisfy the"},{"type":"text","text":" "},{"type":"text","text":"requirements of the underlying Core Location framework when enabling this"},{"type":"text","text":" "},{"type":"text","text":"property."}],"type":"paragraph"},{"inlineContent":[{"text":"If you implement a custom location manager, set the ","type":"text"},{"code":"locationManager","type":"codeVoice"},{"text":" before","type":"text"},{"text":" ","type":"text"},{"text":"calling ","type":"text"},{"code":"showsUserLocation","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/showsuserlocation"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"externalID":"c:objc(cs)MLNMapView(py)showsUserLocation","modules":[{"name":"MapLibre"}],"roleHeading":"Instance Property","fragments":[{"text":"showsUserLocation","kind":"identifier"}],"symbolKind":"property","remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L590"},"title":"showsUserLocation","role":"symbol","navigatorTitle":[{"text":"showsUserLocation","kind":"identifier"}]},"kind":"symbol","sections":[],"abstract":[{"text":"A Boolean value indicating whether the map may display the user location.","type":"text"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"fragments":[{"text":"MLNMapView","kind":"identifier"}],"title":"MLNMapView","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","type":"topic","url":"\/documentation\/maplibre\/mlnmapview","abstract":[{"text":"An interactive, customizable map view with an interface similar to the one","type":"text"},{"text":" ","type":"text"},{"text":"provided by Apple’s MapKit.","type":"text"}],"kind":"symbol","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic","url":"\/documentation\/maplibre","title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/showsUserLocation":{"title":"showsUserLocation","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/showsUserLocation","abstract":[{"type":"text","text":"A Boolean value indicating whether the map may display the user location."}],"fragments":[{"kind":"identifier","text":"showsUserLocation"}],"url":"\/documentation\/maplibre\/mlnmapview\/showsuserlocation","type":"topic","role":"symbol","kind":"symbol"}}}