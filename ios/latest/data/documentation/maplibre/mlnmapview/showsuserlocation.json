nUseUsageDescription"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"NSLocationAlwaysUsageDescription"},{"text":" in its ","type":"text"},{"type":"codeVoice","code":"Info.plist"},{"text":" to satisfy the","type":"text"},{"text":" ","type":"text"},{"text":"requirements of the underlying Core Location framework when enabling this","type":"text"},{"text":" ","type":"text"},{"text":"property.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If you implement a custom location manager, set the ","type":"text"},{"type":"codeVoice","code":"locationManager"},{"text":" before","type":"text"},{"text":" ","type":"text"},{"text":"calling ","type":"text"},{"type":"codeVoice","code":"showsUserLocation"},{"text":".","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/showsuserlocation"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"A Boolean value indicating whether the map may display the user location.","type":"text"}],"sections":[],"metadata":{"role":"symbol","externalID":"c:objc(cs)MLNMapView(py)showsUserLocation","navigatorTitle":[{"kind":"identifier","text":"showsUserLocation"}],"title":"showsUserLocation","roleHeading":"Instance Property","remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L590"},"modules":[{"name":"MapLibre"}],"symbolKind":"property","fragments":[{"kind":"identifier","text":"showsUserLocation"}]},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","title":"MapLibre","url":"\/documentation\/maplibre","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"text":"Powerful, free and open-source mapping tool