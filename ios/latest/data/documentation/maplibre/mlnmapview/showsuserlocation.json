{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/showsUserLocation"},"metadata":{"remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L590"},"fragments":[{"kind":"identifier","text":"showsUserLocation"}],"navigatorTitle":[{"text":"showsUserLocation","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"symbolKind":"property","role":"symbol","title":"showsUserLocation","externalID":"c:objc(cs)MLNMapView(py)showsUserLocation","roleHeading":"Instance Property"},"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"abstract":[{"type":"text","text":"A Boolean value indicating whether the map may display the user location."}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"assign","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:@T@BOOL","text":"BOOL","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"showsUserLocation","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Setting this property to "},{"type":"codeVoice","code":"YES"},{"type":"text","text":" causes the map view to use the Core Location"},{"type":"text","text":" "},{"type":"text","text":"framework to find the current location. As long as this property is "},{"type":"codeVoice","code":"YES"},{"type":"text","text":", the"},{"type":"text","text":" "},{"type":"text","text":"map view continues to track the user’s location and update it periodically."}]},{"type":"paragraph","inlineContent":[{"text":"This property does not indicate whether the user’s position is actually visible","type":"text"},{"text":" ","type":"text"},{"text":"on the map, only whether the map view is allowed to display it. To determine","type":"text"},{"text":" ","type":"text"},{"text":"whether the user’s position is visible, use the ","type":"text"},{"code":"userLocationVisible","type":"codeVoice"},{"text":" property.","type":"text"},{"text":" ","type":"text"},{"text":"The default value of this property is ","type":"text"},{"code":"NO","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Your app must specify a value for ","type":"text"},{"type":"codeVoice","code":"NSLocationWhenInUseUsageDescription"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"NSLocationAlwaysUsageDescription"},{"text":" in its ","type":"text"},{"type":"codeVoice","code":"Info.plist"},{"text":" to satisfy the","type":"text"},{"text":" ","type":"text"},{"text":"requirements of the underlying Core Location framework when enabling this","type":"text"},{"text":" ","type":"text"},{"text":"property.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If you implement a custom location manager, set the ","type":"text"},{"code":"locationManager","type":"codeVoice"},{"text":" before","type":"text"},{"text":" ","type":"text"},{"text":"calling ","type":"text"},{"code":"showsUserLocation","type":"codeVoice"},{"text":".","type":"text"}]}],"kind":"content"}],"sections":[],"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/showsuserlocation"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"type":"topic","kind":"symbol","title":"MapLibre","url":"\/document