{"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/showsuserlocation"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"roleHeading":"Instance Property","remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L590","fileName":"MLNMapView.h"},"symbolKind":"property","fragments":[{"text":"showsUserLocation","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNMapView(py)showsUserLocation","title":"showsUserLocation","navigatorTitle":[{"text":"showsUserLocation","kind":"identifier"}],"role":"symbol"},"abstract":[{"type":"text","text":"A Boolean value indicating whether the map may display the user location."}],"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"assign","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:@T@BOOL","text":"BOOL","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"showsUserLocation","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"Setting this property to ","type":"text"},{"code":"YES","type":"codeVoice"},{"text":" causes the map view to use the Core Location","type":"text"},{"text":" ","type":"text"},{"text":"framework to find the current location. As long as this property is ","type":"text"},{"code":"YES","type":"codeVoice"},{"text":", the","type":"text"},{"text":" ","type":"text"},{"text":"map view continues to track the user’s location and update it periodically.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This property does not indicate whether the user’s position is actually visible","type":"text"},{"text":" ","type":"text"},{"text":"on the map, only whether the map view is allowed to display it. To determine","type":"text"},{"text":" ","type":"text"},{"text":"whether the user’s position is visible, use the ","type":"text"},{"code":"userLocationVisible","type":"codeVoice"},{"text":" property.","type":"text"},{"text":" ","type":"text"},{"text":"The default value of this property is ","type":"text"},{"code":"NO","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Your app must specify a value for "},{"code":"NSLocationWhenInUseUsageDescription","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"code":"NSLocationAlwaysUsageDescription","type":"codeVoice"},{"type":"text","text":" in its "},{"code":"Info.plist","type":"codeVoice"},{"type":"text","text":" to satisfy the"},{"type":"text","text":" "},{"type":"text","text":"requirements of the underlying Core Location framework when enabling this"},{"type":"text","text":" "},{"type":"text","text":"property."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you implement a custom location manager, set the "},{"code":"locationManager","type":"codeVoice"},{"type":"text","text":" before"},{"type":"text","text":" "},{"type":"text","text":"calling "},{"code":"showsUserLocation","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/showsUserLocation","interfaceLanguage":"occ"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/showsUserLocation":{"title":"showsUserLocation","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/showsUserLocation","role":"symbol","kind":"symbol","fragments":[{"kind":"identifier"