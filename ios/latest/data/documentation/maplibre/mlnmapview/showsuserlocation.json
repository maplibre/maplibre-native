{"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/showsUserLocation","interfaceLanguage":"occ"},"abstract":[{"text":"A Boolean value indicating whether the map may display the user location.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"assign"},{"kind":"text","text":") "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@BOOL","text":"BOOL"},{"kind":"text","text":" "},{"kind":"identifier","text":"showsUserLocation"},{"kind":"text","text":";"}],"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Setting this property to "},{"type":"codeVoice","code":"YES"},{"text":" causes the map view to use the Core Location","type":"text"},{"text":" ","type":"text"},{"text":"framework to find the current location. As long as this property is ","type":"text"},{"type":"codeVoice","code":"YES"},{"text":", the","type":"text"},{"text":" ","type":"text"},{"text":"map view continues to track the user’s location and update it periodically.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property does not indicate whether the user’s position is actually visible"},{"type":"text","text":" "},{"type":"text","text":"on the map, only whether the map view is allowed to display it. To determine"},{"type":"text","text":" "},{"type":"text","text":"whether the user’s position is visible, use the "},{"type":"codeVoice","code":"userLocationVisible"},{"type":"text","text":" property."},{"type":"text","text":" "},{"type":"text","text":"The default value of this property is "},{"type":"codeVoice","code":"NO"},{"type":"text","text":"."}]},{"type":"paragraph",