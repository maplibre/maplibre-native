{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"metadata":{"remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L590"},"navigatorTitle":[{"kind":"identifier","text":"showsUserLocation"}],"roleHeading":"Instance Property","role":"symbol","fragments":[{"text":"showsUserLocation","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"title":"showsUserLocation","externalID":"c:objc(cs)MLNMapView(py)showsUserLocation","symbolKind":"property"},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/showsUserLocation"},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"assign","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:@T@BOOL","text":"BOOL","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"showsUserLocation","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Setting this property to "},{"type":"codeVoice","code":"YES"},{"type":"text","text":" causes the map view to use the Core Location"},{"type":"text","text":" "},{"type":"text","text":"framework to find the current location. As long as this property is "},{"type":"codeVoice","code":"YES"},{"type":"text","text":", the"},{"type":"text","text":" "},{"type":"text","text":"map view continues to track the user’s location and update it periodically."}]},{"type":"paragraph","inlineContent":[{"text":"This property does not indicate whether the user’s position is actually visible","type":"text"},{"text":" ","type":"text"},{"text":"on the map, only whether the map view is allowed to display it. To determine","type":"text"},{"text":" ","type":"text"},{"text":"whether the user’s position is visible, use the ","type":"text"},{"type":"codeVoice","code":"userLocationVisible"},{"text":" property.","type":"text"},{"text":" ","type":"text"},{"text":"The default value of this property is ","type":"text"},{"type":"codeVoice","code":"NO"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Your app must specify a value for "},{"type":"codeVoice","code":"NSLocationWhenInUseUsageDescription"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSLocationAlwaysUsageDescription"},{"type":"text","text":" in its "},{"type":"codeVoice","code":"Info.plist"},{"type":"text","text":" to satisfy the"},{"type":"text","text":" "},{"type":"text","text":"requirements of the underlying Core Location framework when enabling this"},{"type":"text","text":" "},{"type":"text","text":"property."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you implement a custom location manager, set the "},{"type":"codeVoice","code":"locationManager"},{"type":"text","text":" before"},{"type":"text","text":" "},{"type":"text","text":"calling "},{"type":"codeVoice","code":"showsUserLocation"},{"type":"text","text":"."}]}]}],"sections":[],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"A Boolean value indicating whether the map may display the user location."}],"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/showsuserlocation"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"kind":"symbol","ty