{"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"A Boolean value indicating whether the map may display the user location."}],"sections":[],"metadata":{"navigatorTitle":[{"kind":"identifier","text":"showsUserLocation"}],"title":"showsUserLocation","role":"symbol","symbolKind":"property","fragments":[{"kind":"identifier","text":"showsUserLocation"}],"remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L590"},"externalID":"c:objc(cs)MLNMapView(py)showsUserLocation","roleHeading":"Instance Property","modules":[{"name":"MapLibre"}]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/showsuserlocation"]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/showsUserLocation"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"assign"},{"kind":"text","text":") "},{"preciseIdentifier":"c:@T@BOOL","kind":"typeIdentifier","text":"BOOL"},{"kind":"text","text":" "},{"kind":"identifier","text":"showsUserLocation"},{"kind":"text","text":";"}],"platforms":["iOS","iPadOS","Mac Catalyst"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Setting this property to ","type":"text"},{"type":"codeVoice","code":"YES"},{"text":" causes the map view to use the Core Location","type":"text"},{"text":" ","type":"text"},{"text":"framework to find the current location. As long as this property is ","type":"text"},{"type":"codeVoice","code":"YES"},{"text":", the","type":"text"},{"text":" ","type":"text"},{"text":"map view continues to track the user’s location and update it periodically.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property does not indicate whether the user’s position is actually visible"},{"type":"text","text":" "},{"type":"text","text":"on the map, only whether the map view is allowed to display it. To determine"},{"type":"text","text":" "},{"type":"text","text":"whether the user’s position is visible, use the "},{"type":"codeVoice","code":"userLocationVisible"},{"type":"text","text":" property."},{"type":"text","text":" "},{"type":"text","text":"The default value of this property is "},{"type":"codeVoice","code":"NO"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Your app must specify a value for "},{"type":"codeVoice","code":"NSLocationWhenInUseUsageDescription"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSLocationAlwaysUsageDescription"},{"type":"text","text":" in its "},{"type":"codeVoice","code":"Info.plist"},{"type":"text","text":" to satisfy the"},{"type":"text","text":" "},{"type":"text","text":"requirements of the underlying Core Location framework when enabling this"},{"type":"text","text":" "},{"type":"text","text":"property."}]},{"type":"paragraph","inlineContent":[{"text":"If you implement a custom location manager, set the ","type":"text"},{"code":"locationManager","type":"codeVoice"},{"type":"text","text":" before"},{"type":"text","text":" "},{"type":"text","text":"calling "},{"code":"showsUserLocation","type":"codeVoice"},{"type":"text","text":"."}]}]}],"kind":"symbol","references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/showsUserLocation":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/showsUserLocation","kind":"symbol","type":"topic","title":"showsUserLocation","abstract"