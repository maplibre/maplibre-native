{"metadata":{"title":"showsUserLocation","role":"symbol","roleHeading":"Instance Property","fragments":[{"kind":"identifier","text":"showsUserLocation"}],"remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L590","fileName":"MLNMapView.h"},"modules":[{"name":"MapLibre"}],"symbolKind":"property","externalID":"c:objc(cs)MLNMapView(py)showsUserLocation","navigatorTitle":[{"kind":"identifier","text":"showsUserLocation"}]},"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/showsuserlocation"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"abstract":[{"type":"text","text":"A Boolean value indicating whether the map may display the user location."}],"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"assign"},{"kind":"text","text":") "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@BOOL","text":"BOOL"},{"kind":"text","text":" "},{"kind":"identifier","text":"showsUserLocation"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Setting this property to "},{"type":"codeVoice","code":"YES"},{"type":"text","text":" causes the map view to use the Core Location"},{"type":"text","text":" "},{"type":"text","text":"framework to find the current location. As long as this property is "},{"type":"codeVoice","code":"YES"},{"type":"text","text":", the"},{"type":"text","text":" "},{"type":"text","text":"map view continues to track the user’s location and update it periodically."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This property does not indicate whether the user’s position is actually visible"},{"type":"text","text":" "},{"type":"text","text":"on the map, only whether the map view is allowed to display it. To determine"},{"type":"text","text":" "},{"type":"text","text":"whether the user’s position is visible, use the "},{"code":"userLocationVisible","type":"codeVoice"},{"type":"text","text":" property."},{"type":"text","text":" "},{"type":"text","text":"The default value of this property is "},{"code":"NO","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Your app must specify a value for "},{"type":"codeVoice","code":"NSLocationWhenInUseUsageDescription"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSLocationAlwaysUsageDescription"},{"type":"text","text":" in its "},{"type":"codeVoice","code":"Info.plist"},{"type":"text","text":" to satisfy the"},{"type":"text","text":" "},{"type":"text","text":"requirements of the underlying Core Location framework when enabling this"},{"type":"text","text":" "},{"type":"text","text":"property."}],"type":"paragraph"},{"inlineContent":[{"text":"If you implement a custom location manager, set the ","type":"text"},{"type":"codeVoice","code":"locationManager"},{"text":" before","type":"text"},{"text":" ","type":"text"},{"text":"calling ","type":"text"},{"type":"codeVoice","code":"showsUserLocation"},{"text":".","type":"text"}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/showsUserLocation"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/showsUserLocation":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/showsUserLocation","role":"symbol","kind":"symbol","fragments":[{"kind":"identifier","text":"showsUserLocation"}