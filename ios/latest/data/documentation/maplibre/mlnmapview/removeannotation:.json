ntation/MapLibre/MLNMapView/removeAnnotation:":{"navigatorTitle":[{"text":"removeAnnotation:","kind":"identifier"}],"abstract":[{"type":"text","text":"Removes an annotation from the map view, deselecting it if it is selected."}],"type":"topic","title":"removeAnnotation:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/removeAnnotation:","url":"\/documentation\/maplibre\/mlnmapview\/removeannotation:","kind":"symbol","role":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"removeAnnotation:","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"kind":"symbol","title":"MLNMapView","url":"\/documentation\/maplibre\/mlnmapview","role":"symbol","type":"topic","fragments":[{"text":"MLNMapView","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"title":"MapLibre","role":"collection"}}}