 view, otherwise nil."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/viewForAnnotation:","role":"symbol","title":"viewForAnnotation:","url":"\/documentation\/maplibre\/mlnmapview\/viewforannotation:","navigatorTitle":[{"kind":"identifier","text":"viewForAnnotation:"}],"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"viewForAnnotation:"}],"type":"topic","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"url":"\/documentation\/maplibre\/mlnmapview","role":"symbol","title":"MLNMapView","type":"topic","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","fragments":[{"text":"MLNMapView","kind":"identifier"}],"abstract":[{"text":"An interactive, customizable map view with an interface similar to the one","type":"text"},{"text":" ","type":"text"},{"text":"provided by Apple’s MapKit.","type":"text"}]}}}