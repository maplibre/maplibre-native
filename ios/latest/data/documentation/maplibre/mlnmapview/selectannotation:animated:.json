ameters":[{"name":"annotation","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The annotation object to select."}]}]},{"name":"animated","content":[{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"YES"},{"text":", the annotation and callout view are animated on-screen.","type":"text"}]}]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"The ","type":"text"},{"code":"animated","type":"codeVoice"},{"text":" parameter determines whether the selection is animated including whether the map is","type":"text"},{"text":" ","type":"text"},{"text":"panned to bring the annotation into view, specifically:","type":"text"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"code":"animated","type":"codeVoice"},{"text":" parameter","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Effect"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NO"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"The annotation is selected, and the callout is presented. However the map is"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"not panned to bring the annotation or callout into view. The presentation of the callout is NOT","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"animated."}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"annotation is not visible (or is partially visible) ","type":"text"},{"inlineContent":[{"type":"text","text":"and"}],"type":"emphasis"},{"text":" is of type ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation","isActive":true},{"text":", the","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"map is panned so that the annotation and its callout are brought into view. The annotation is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"not"}]}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"centered within the viewport.","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]]],"header":"row","type":"table"},{"inlineContent":[{"type":"text","text":"Note that a selection initiated by a single tap gesture is always animated."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To specify a completion handler to execute after the animation finishes, use"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"-selectAnnotation:animated:completionHandler:"},{"type":"text","text":" method."}],"type":"paragraph"},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"In versions prior to ","type":"text"},{"code":"4.0.0","type":"codeVoice"},{"text":" selecting an offscreen annotation did not","type":"text"},{"text":" ","type":"text"},{"text":"change the camera.","type":"text"}]}],"style":"note","type":"aside"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNPointAnnotation":{"role":"symbol","kind":"symbol","fragments":[{"kind":"identifier","text":"MLNPointAnnotation"}],"type":"topic","title":"MLNPointAnnotation","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation","url":"\/documentation\/maplibre\/mlnpointannotation","abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation","isActive":true},{"type":"text","text":" object represents a one-dimensional shape located at a"},{"type":"text","text":" "},{"type":"text","text":"single geographical coordinate. Depending on how it is used, an"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentati