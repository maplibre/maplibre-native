Project/documentation/MapLibre/MLNUserTrackingMode/MLNUserTrackingModeFollowWithCourse":{"role":"symbol","fragments":[{"text":"MLNUserTrackingModeFollowWithCourse","kind":"identifier"}],"title":"MLNUserTrackingModeFollowWithCourse","url":"\/documentation\/maplibre\/mlnusertrackingmode\/mlnusertrackingmodefollowwithcourse","abstract":[{"type":"text","text":"The map follows the user location and rotates when the course changes."},{"type":"text","text":" "},{"type":"text","text":"Course represents the direction in which the device is traveling."},{"type":"text","text":" "},{"type":"text","text":"The default user location annotation shows a puck-shaped indicator"},{"type":"text","text":" "},{"type":"text","text":"that rotates as the course changes."}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol","title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","type":"topic","role":"collection"}}}