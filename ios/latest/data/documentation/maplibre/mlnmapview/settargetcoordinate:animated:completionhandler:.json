{"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"text","text":"- ("},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"setTargetCoordinate:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:@S@CLLocationCoordinate2D","kind":"typeIdentifier","text":"CLLocationCoordinate2D"},{"kind":"text","text":") "},{"kind":"internalParam","text":"targetCoordinate"},{"kind":"text","text":" "},{"kind":"identifier","text":"animated:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:@T@BOOL","text":"BOOL","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"animated","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"completionHandler:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":" (^)()) ","kind":"text"},{"text":"completion","kind":"internalParam"},{"text":";","kind":"text"}],"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"]}],"kind":"declarations"},{"parameters":[{"name":"targetCoordinate","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The target coordinate to fit within the viewport."}]}]},{"name":"animated","content":[{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"YES","type":"codeVoice"},{"text":", the map animates to fit the target within the map","type":"text"},{"text":" ","type":"text"},{"text":"view. If ","type":"text"},{"code":"NO","type":"codeVoice"},{"text":", the map fits the target instantaneously.","type":"text"}]}]},{"name":"completion","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The block executed after the animation finishes."}]}]}],"kind":"parameters"},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"By default, the target coordinate is set to an invalid coordinate, indicating","type":"text"},{"text":" ","type":"text"},{"text":"that there is no target. In course tracking mode, the target forms one of two","type":"text"},{"text":" ","type":"text"},{"text":"foci in the viewport, the other being the user location annotation. Typically,","type":"text"},{"text":" ","type":"text"},{"text":"the target is set to a destination or waypoint in a real-time navigation scene.","type":"text"},{"text":" ","type":"text"},{"text":"As the user annotation moves toward the target, the map automatically zooms in","type":"text"},{"text":" ","type":"text"},{"text":"to fit both foci optimally within the viewport.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method has no effect if the "},{"type":"codeVoice","code":"userTrackingMode"},{"type":"text","text":" property is set to a value"},{"type":"text","text":" "},{"type":"text","text":"other than "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse"},{"type":"text","text":"."}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setTargetCoordinate:animated:completionHandler:"},"metadata":{"navigatorTitle":[{"text":"- ","kind":"text"},{"text":"setTargetCoordinate:animated:completionHandler:","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"fragments":[{"text":"- ","kind":"text"},{"text":"setTargetCoordinate:animated:completionHandler:","kind":"identifier"}],"remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L799"},"title":"setTargetCoordinate:animated:completionHandler:","role":"symbol","externalID":"c:objc(cs)MLNMapView(im)setTargetCoordinate:animated:completionHandler:","symbolKind":"method","roleHeading":"Instance Method"},"abstract":[{"text":"Sets the geographic coordinate that is the subject of observation as the user","type":"text"},{"text":" ","type":"text"},{"text":"location is being tracked, with an optional transition animation and completion","type":"text"},{"text":" ","type":"text"},{"text":"handler.","type":"text"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"kind":"symbol","variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/settargetcoordinate:animated:completionhandler:"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol","title":"MapLibre","type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/setTargetCoordinate:animated:completionHandler:":{"url":"\/documentation\/maplibre\/mlnmapview\/settargetcoordinate:animated:completionhandler:","abstract":[{"text":"Sets the geographic coordinate that is the subject of observation as the user","type":"text"},{"text":" ","type":"text"},{"text":"location is being tracked, with an optional transition animation and completion","type":"text"},{"text":" ","type":"text"},{"text":"handler.","type":"text"}],"type":"topic","kind":"symbol","title":"setTargetCoordinate:animated:completionHandler:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setTargetCoordinate:animated:completionHandler:","role":"symbol","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"setTargetCoordinate:animated:completionHandler:"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"type":"topic","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"text":" ","type":"text"},{"text":"provided by Apple’s MapKit.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","url":"\/documentation\/maplibre\/mlnmapview","fragments":[{"text":"MLNMapView","kind":"identifier"}],"kind":"symbol","title":"MLNMapView","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserTrackingMode/MLNUserTrackingModeFollowWithCourse":{"title":"MLNUserTrackingModeFollowWithCourse","abstract":[{"text":"The map follows the user location and rotates when the course changes.","type":"text"},{"text":" ","type":"text"},{"text":"Course represents the direction in which the device is traveling.","type":"text"},{"text":" ","type":"text"},{"text":"The default user location annotation shows a puck-shaped indicator","type":"text"},{"text":" ","type":"text"},{"text":"that rotates as the course changes.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse","role":"symbol","fragments":[{"kind":"identifier","text":"MLNUserTrackingModeFollowWithCourse"}],"url":"\/documentation\/maplibre\/mlnusertrackingmode\/mlnusertrackingmodefollowwithcourse","type":"topic","kind":"symbol"}}}