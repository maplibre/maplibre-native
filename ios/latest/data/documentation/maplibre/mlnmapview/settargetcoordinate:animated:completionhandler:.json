{"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"- (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"setTargetCoordinate:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:@S@CLLocationCoordinate2D","text":"CLLocationCoordinate2D","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"targetCoordinate","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"animated:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@BOOL","text":"BOOL"},{"kind":"text","text":") "},{"kind":"internalParam","text":"animated"},{"kind":"text","text":" "},{"kind":"identifier","text":"completionHandler:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":" (^)()) "},{"kind":"internalParam","text":"completion"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"name":"targetCoordinate","content":[{"type":"paragraph","inlineContent":[{"text":"The target coordinate to fit within the viewport.","type":"text"}]}]},{"name":"animated","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"YES"},{"type":"text","text":", the map animates to fit the target within the map"},{"type":"text","text":" "},{"type":"text","text":"view. If "},{"type":"codeVoice","code":"NO"},{"type":"text","text":", the map fits the target instantaneously."}]}]},{"name":"completion","content":[{"inlineContent":[{"type":"text","text":"The block executed after the animation finishes."}],"type":"paragraph"}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, the target coordinate is set to an invalid coordinate, indicating"},{"type":"text","text":" "},{"type":"text","text":"that there is no target. In course tracking mode, the target forms one of two"},{"type":"text","text":" "},{"type":"text","text":"foci in the viewport, the other being the user location annotation. Typically,"},{"type":"text","text":" "},{"type":"text","text":"the target is set to a destination or waypoint in a real-time navigation scene."},{"type":"text","text":" "},{"type":"text","text":"As the user annotation moves toward the target, the map automatically zooms in"},{"type":"text","text":" "},{"type":"text","text":"to fit both foci optimally within the viewport."}]},{"type":"paragraph","inlineContent":[{"text":"This method has no effect if the ","type":"text"},{"code":"userTrackingMode","type":"codeVoice"},{"text":" property is set to a value","type":"text"},{"text":" ","type":"text"},{"text":"other than ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse","isActive":true,"type":"reference"},{"text":".","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/settargetcoordinate:animated:completionhandler:"]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setTargetCoordinate:animated:completionHandler:"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"kind":"symbol","sections":[],"abstract":[{"type":"text","text":"Sets the geographic coordinate that is the subject of observation as the user"},{"type":"text","text":" "},{"type":"text","text":"location is being tracked, with an optional transition animation and completion"},{"type":"text","text":" "},{"type":"text","text":"handler."}],"metadata":{"externalID":"c:objc(cs)MLNMapView(im)setTargetCoordinate:animated:completionHan