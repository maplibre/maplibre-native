e ","type":"text"},{"code":"-setZoomLevel:animated:","type":"codeVoice"},{"text":" method instead.","type":"text"}],"type":"paragraph"}]}],"sections":[],"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/zoomlevel"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"type":"text","text":"The zoom level of the receiver."}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"kind":"symbol","references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"fragments":[{"kind":"identifier","text":"MLNMapView"}],"kind":"symbol","role":"symbol","title":"MLNMapView","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","url":"\/documentation\/maplibre\/mlnmapview"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/zoomLevel":{"type":"topic","title":"zoomLevel","url":"\/documentation\/maplibre\/mlnmapview\/zoomlevel","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/zoomLevel","abstract":[{"text":"The zoom level of the receiver.","type":"text"}],"kind":"symbol","role":"symbol","fragments":[{"kind":"identifier","text":"zoomLevel"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","url":"\/documentation\/maplibre","type":"topic","kind":"symbol","title":"MapLibre"}}}