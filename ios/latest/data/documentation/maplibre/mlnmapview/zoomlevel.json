{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"abstract":[{"text":"The zoom level of the receiver.","type":"text"}],"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"preciseIdentifier":"c:d","kind":"typeIdentifier","text":"double"},{"kind":"text","text":" "},{"kind":"identifier","text":"zoomLevel"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"In addition to affecting the visual size and detail of features on the map,","type":"text"},{"text":" ","type":"text"},{"text":"the zoom level affects the size of the vector tiles that are loaded. At zoom","type":"text"},{"text":" ","type":"text"},{"text":"level 0, each tile covers the entire world map; at zoom level 1, it covers ¼","type":"text"},{"text":" ","type":"text"},{"text":"of the world; at zoom level 2, ","type":"text"},{"text":"1","type":"text"},{"text":"⁄","type":"text"},{"text":"16","type":"text"},{"text":" of the world, and","type":"text"},{"text":" ","type":"text"},{"text":"so on.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Changing the value of this property updates the map view immediately. If you"},{"type":"text","text":" "},{"type":"text","text":"want to animate the change, use the "},{"type":"codeVoice","code":"-setZoomLevel:animated:"},{"type":"text","text":" method instead."}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/zoomlevel"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/zoomLevel"},"schemaVersion":{"major":0,"mi