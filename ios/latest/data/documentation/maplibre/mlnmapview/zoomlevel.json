{"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","abstract":[{"type":"text","text":"The zoom level of the receiver."}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/zoomLevel"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/zoomlevel"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L1026"},"modules":[{"name":"MapLibre"}],"navigatorTitle":[{"kind":"identifier","text":"zoomLevel"}],"symbolKind":"property","title":"zoomLevel","role":"symbol","roleHeading":"Instance Property","fragments":[{"text":"zoomLevel","kind":"identifier"}],"externalID":"c:objc(cs)MLNMapView(py)zoomLevel"},"primaryContentSections":[{"declarations":[{"languages":["occ"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"kind":"typeIdentifier","preciseIdentifier":"c:d","text":"double"},{"kind":"text","text":" "},{"kind":"identifier","text":"zoomLevel"},{"kind":"text","text":";"}],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"text":"In addition to affecting the visual size and detail of features on the map,","type":"text"},{"text":" ","type":"text"},{"text":"the zoom level affects the size of the vector tiles that are loaded. At zoom","type":"text"},{"text":" ","type":"text"},{"text":"level 0, each tile covers the entire world map; at zoom level 1, it covers ¼","type":"text"},{"text":" ","type":"text"},{"text":"of the world; at zoom level 2, ","type":"text"},{"text":"1","type":"text"},{"text":"⁄","type":"text"},{"text":"16","type":"text"},{"text":" of the world, and","type":"text"},{"text":" ","type":"text"},{"text":"so on.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Changing the value of this property updates the map view immediately. If you","type":"text"},{"text":" ","type":"text"},{"text":"want to animate the change, use the ","type":"text"},{"code":"-setZoomLevel:animated:","type":"codeVoice"},{"text":" method instead.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"url":"\/documentation\/maplibre\/mlnmapview","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","title":"MLNMapView","fragments":[{"text":"MLNMapView","kind":"identifier"}],"type":"topic","kind":"symbol","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"type":"topic","url":"\/documentation\/maplibre","title":"MapLibre","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/zoomLevel":{"role":"symbol","kind":"symbol","title":"zoomLevel","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/zoomLevel","url":"\/documentation\/maplibre\/mlnmapview\/zoomlevel","fragments":[{"kind":"identifier","text":"zoomLevel"}],"abstract":[{"text":"The zoom level of the receiver.","type":"text"}]}}}