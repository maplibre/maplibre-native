{"abstract":[{"type":"text","text":"The zoom level of the receiver."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"text":"double","kind":"typeIdentifier","preciseIdentifier":"c:d"},{"text":" ","kind":"text"},{"text":"zoomLevel","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"In addition to affecting the visual size and detail of features on the map,"},{"type":"text","text":" "},{"type":"text","text":"the zoom level affects the size of the vector tiles that are loaded. At zoom"},{"type":"text","text":" "},{"type":"text","text":"level 0, each tile covers the entire world map; at zoom level 1, it covers ¼"},{"type":"text","text":" "},{"type":"text","text":"of the world; at zoom level 2, "},{"type":"text","text":"1"},{"type":"text","text":"⁄"},{"type":"text","text":"16"},{"type":"text","text":" of the world, and"},{"type":"text","text":" "},{"type":"text","text":"so on."}],"type":"paragraph"},{"inlineContent":[{"text":"Changing the value of this property updates the map view immediately. If you","type":"text"},{"text":" ","type":"text"},{"text":"want to animate the change, use the ","type":"text"},{"code":"-setZoomLevel:animated:","type":"codeVoice"},{"text":" method instead.","type":"text"}],"type":"paragraph"}]}],"metadata":{"role":"symbol","title":"zoomLevel","externalID":"c:objc(cs)MLNMapView(py)zoomLevel","remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L1026"},"modules":[{"name":"MapLibre"}],"fragments":[{"text":"zoomLevel","kind":"identifier"}],"symbolKind":"property","roleHeading":"Instance Property","navigatorTitle":[{"text"