text","text":"1"},{"type":"text","text":"⁄"},{"type":"text","text":"16"},{"type":"text","text":" of the world, and"},{"type":"text","text":" "},{"type":"text","text":"so on."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Changing the value of this property updates the map view immediately. If you"},{"type":"text","text":" "},{"type":"text","text":"want to animate the change, use the "},{"type":"codeVoice","code":"-setZoomLevel:animated:"},{"type":"text","text":" method instead."}],"type":"paragraph"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"url":"\/documentation\/maplibre\/mlnmapview","title":"MLNMapView","role":"symbol","fragments":[{"text":"MLNMapView","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","type":"topic","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}]},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","title":"MapLibre","role":"collection","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/zoomLevel":{"fragments":[{"text":"zoomLevel","kind":"identifier"}],"type":"topic","url":"\/documentation\/maplibre\/mlnmapview\/zoomlevel","title":"zoomLevel","role":"symbol","abstract":[{"type":"text","text":"The zoom level of the receiver."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/zoomLevel","kind":"symbol"}}}