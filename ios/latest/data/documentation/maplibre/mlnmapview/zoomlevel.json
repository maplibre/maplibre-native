{"sections":[],"abstract":[{"type":"text","text":"The zoom level of the receiver."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:d","text":"double","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"zoomLevel","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"In addition to affecting the visual size and detail of features on the map,"},{"type":"text","text":" "},{"type":"text","text":"the zoom level affects the size of the vector tiles that are loaded. At zoom"},{"type":"text","text":" "},{"type":"text","text":"level 0, each tile covers the entire world map; at zoom level 1, it covers ¼"},{"type":"text","text":" "},{"type":"text","text":"of the world; at zoom level 2, "},{"type":"text","text":"1"},{"type":"text","text":"⁄"},{"type":"text","text":"16"},{"type":"text","text":" of the world, and"},{"type":"text","text":" "},{"type":"text","text":"so on."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Changing the value of this property updates the map view immediately. If you"},{"type":"text","text":" "},{"type":"text","text":"want to animate the change, use the "},{"code":"-setZoomLevel:animated:","type":"codeVoice"},{"type":"text","text":" method instead."}]}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/zoomLevel"},"metadata":{"remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L1026"},"symbolKind":"property","title":"zoomLevel","externalID":"c:objc(cs)MLNMapView(py)zoomLevel","roleHeading":"Instance Property","role":"symbol","fragments":[{"kind":"identifier","text":"zoomLevel"}],"navigatorTitle":[{"text":"zoomLevel","kind":"identifier"}],"modules":[{"name":"MapLibre"}]},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/zoomlevel"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/zoomLevel":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/zoomLevel","fragments":[{"text":"zoomLevel","kind":"identifier"}],"type":"topic","kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlnmapview\/zoomlevel","abstract":[{"text":"The zoom level of the receiver.","type":"text"}],"title":"zoomLevel"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"title":"MLNMapView","url":"\/documentation\/maplibre\/mlnmapview","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"role":"symbol","type":"topic","kind":"symbol","fragments":[{"kind":"identifier","text":"MLNMapView"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","url":"\/documentation\/maplibre","role":"collection"}}}