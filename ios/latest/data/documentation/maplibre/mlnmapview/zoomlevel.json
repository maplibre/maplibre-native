{"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/zoomlevel"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"The zoom level of the receiver."}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"preciseIdentifier":"c:d","kind":"typeIdentifier","text":"double"},{"kind":"text","text":" "},{"kind":"identifier","text":"zoomLevel"},{"kind":"text","text":";"}],"platforms":["iOS","iPadOS","Mac Catalyst"]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"In addition to affecting the visual size and detail of features on the map,"},{"type":"text","text":" "},{"type":"text","text":"the zoom level affects the size of the vector tiles that are loaded. At zoom"},{"type":"text","text":" "},{"type":"text","text":"level 0, each tile covers the entire world map; at zoom level 1, it covers ¼"},{"type":"text","text":" "},{"type":"text","text":"of the world; at zoom level 2, "},{"type":"text","text":"1"},{"type":"text","text":"⁄"},{"type":"text","text":"16"},{"type":"text","text":" of the world, and"},{"type":"text","text":" "},{"type":"text","text":"so on."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Changing the value of this property updates the map view immediately. If you"},{"type":"text","text":" "},{"type":"text","text":"want to animate the change, use the "},{"code":"-setZoomLevel:animated:","type":"codeVoice"},{"type":"text","text":" method instead."}],"type":"paragraph"}]}],"metadata":{"title":"zoomLevel","role":"symbol","roleHeading":"Instance Property","remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L1026"},"fragments":[{"kind":"identifier","text":"zoomLevel"}],"modules":[{"name":"MapLibre"}],"navigatorTitle":[{"kind":"identifier","text":"zoomLevel"}],"symbolKind":"property","externalID":"c:objc(cs)MLNMapView(py)zoomLevel"},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/zoomLevel"},"kind":"symbol","references":{"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","url":"\/documentation\/maplibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/zoomLevel":{"title":"zoomLevel","url":"\/documentation\/maplibre\/mlnmapview\/zoomlevel","abstract":[{"type":"text","text":"The zoom level of the receiver."}],"role":"symbol","fragments":[{"text":"zoomLevel","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/zoomLevel","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"url":"\/documentation\/maplibre\/mlnmapview","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","title":"MLNMapView","role":"symbol","type":"topic","abstract":[{"text":"An interactive, customizable map view with an interface similar to the one","type":"text"},{"text":" ","type":"text"},{"text":"provided by Apple’s MapKit.","type":"text"}],"kind":"symbol","fragments":[{"kind":"identifier","text":"MLNMapView"}]}}}