xt","text":"want to animate the change, use the "},{"type":"codeVoice","code":"-setZoomLevel:animated:"},{"type":"text","text":" method instead."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/zoomlevel"]}],"abstract":[{"type":"text","text":"The zoom level of the receiver."}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/zoomLevel":{"url":"\/documentation\/maplibre\/mlnmapview\/zoomlevel","abstract":[{"text":"The zoom level of the receiver.","type":"text"}],"title":"zoomLevel","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/zoomLevel","role":"symbol","type":"topic","fragments":[{"kind":"identifier","text":"zoomLevel"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","url":"\/documentation\/maplibre\/mlnmapview","title":"MLNMapView","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"kind":"symbol","fragments":[{"kind":"identifier","text":"MLNMapView"}],"role":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection","kind":"symbol","title":"MapLibre","url":"\/documentation\/maplibre","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre"}}}