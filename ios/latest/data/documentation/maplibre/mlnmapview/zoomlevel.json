iew immediately. If you","type":"text"},{"text":" ","type":"text"},{"text":"want to animate the change, use the ","type":"text"},{"type":"codeVoice","code":"-setZoomLevel:animated:"},{"text":" method instead.","type":"text"}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/zoomlevel"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"kind":"symbol","title":"MapLibre","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"kind":"symbol","fragments":[{"text":"MLNMapView","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnmapview","type":"topic","role":"symbol","title":"MLNMapView"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/zoomLevel":{"role":"symbol","fragments":[{"kind":"identifier","text":"zoomLevel"}],"url":"\/documentation\/maplibre\/mlnmapview\/zoomlevel","kind":"symbol","title":"zoomLevel","abstract":[{"type":"text","text":"The zoom level of the receiver."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/zoomLevel","type":"topic"}}}