{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"The zoom level of the receiver."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"kind":"typeIdentifier","text":"double","preciseIdentifier":"c:d"},{"kind":"text","text":" "},{"kind":"identifier","text":"zoomLevel"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}]},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"In addition to affecting the visual size and detail of features on the map,","type":"text"},{"text":" ","type":"text"},{"text":"the zoom level affects the size of the vector tiles that are loaded. At zoom","type":"text"},{"text":" ","type":"text"},{"text":"level 0, each tile covers the entire world map; at zoom level 1, it covers ¼","type":"text"},{"text":" ","type":"text"},{"text":"of the world; at zoom level 2, ","type":"text"},{"text":"1","type":"text"},{"text":"⁄","type":"text"},{"text":"16","type":"text"},{"text":" of the world, and","type":"text"},{"text":" ","type":"text"},{"text":"so on.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Changing the value of this property updates the map view immediately. If you"},{"type":"text","text":" "},{"type":"text","text":"want to animate the change, use the "},{"type":"codeVoice","code":"-setZoomLevel:animated:"},{"type":"text","text":" method instead."}]}],"kind":"content"}],"metadata":{"role":"symbol","symbolKind":"property","fragments":[{"text":"zoomLevel","kind":"identifier"}],"roleHeading":"Instance Property","externalID":"c:objc(cs)MLNMapView(py)zoomLevel","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"kind":"identifier","text":"zoomLevel"}],"remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L1026","fileName":"MLNMapView.h"},"title":"zoomLevel"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/zoomlevel"]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/zoomLevel"},"kind":"symbol","references":{"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic","title":"MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol","url":"\/documentation\/maplibre","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/zoomLevel":{"abstract":[{"text":"The zoom level of the receiver.","type":"text"}],"fragments":[{"text":"zoomLevel","kind":"identifier"}],"type":"topic","kind":"symbol","url":"\/documentation\/maplibre\/mlnmapview\/zoomlevel","role":"symbol","title":"zoomLevel","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/zoomLevel"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"type":"topic","fragments":[{"kind":"identifier","text":"MLNMapView"}],"title":"MLNMapView","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","url":"\/documentation\/maplibre\/mlnmapview"}}}