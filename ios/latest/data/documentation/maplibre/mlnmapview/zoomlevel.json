{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/zoomLevel"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"text":"double","kind":"typeIdentifier","preciseIdentifier":"c:d"},{"text":" ","kind":"text"},{"text":"zoomLevel","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"In addition to affecting the visual size and detail of features on the map,","type":"text"},{"text":" ","type":"text"},{"text":"the zoom level affects the size of the vector tiles that are loaded. At zoom","type":"text"},{"text":" ","type":"text"},{"text":"level 0, each tile covers the entire world map; at zoom level 1, it covers ¼","type":"text"},{"text":" ","type":"text"},{"text":"of the world; at zoom level 2, ","type":"text"},{"text":"1","type":"text"},{"text":"⁄","type":"text"},{"text":"16","type":"text"},{"text":" of the world, and","type":"text"},{"text":" ","type":"text"},{"text":"so on.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Changing the value of this property updates the map view immediately. If you"},{"type":"text","text":" "},{"type":"text","text":"want to animate the change, use the "},{"code":"-setZoomLevel:animated:","type":"codeVoice"},{"type":"text","text":" method instead."}]}]}],"abstract":[{"text":"The zoom level of the receiver.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/zoomlevel"]}],"sections":[],"metadata":{"navigatorTitle":[{"text":"zoomLevel","kind":"identifier"}],"symbolKind":"property","modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNMapView(py)zoomLevel","remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L1026"},"role":"symbol","title":"zoomLevel","roleHeading":"Instance Property","fragments":[{"text":"zoomLevel","kind":"identifier"}]},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","kind":"symbol","url":"\/documentation\/maplibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"type":"topic","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","url":"\/documentation\/maplibre\/mlnmapview","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"title":"MLNMapView","fragments":[{"text":"MLNMapView","kind":"identifier"}],"kind":"symbol","type":"topic","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/zoomLevel":{"abstract":[{"type":"text","text":"The zoom level of the receiver."}],"type":"topic","kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlnmapview\/zoomlevel","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/zoomLevel","title":"zoomLevel","fragments":[{"kind":"identifier","text":"zoomLevel"}]}}}