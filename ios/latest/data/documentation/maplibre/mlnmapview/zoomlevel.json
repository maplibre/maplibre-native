{"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/zoomLevel","interfaceLanguage":"occ"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"text":"double","kind":"typeIdentifier","preciseIdentifier":"c:d"},{"text":" ","kind":"text"},{"text":"zoomLevel","kind":"identifier"},{"text":";","kind":"text"}]}]},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"In addition to affecting the visual size and detail of features on the map,"},{"type":"text","text":" "},{"type":"text","text":"the zoom level affects the size of the vector tiles that are loaded. At zoom"},{"type":"text","text":" "},{"type":"text","text":"level 0, each tile covers the entire world map; at zoom level 1, it covers ¼"},{"type":"text","text":" "},{"type":"text","text":"of the world; at zoom level 2, "},{"type":"text","text":"1"},{"type":"text","text":"⁄"},{"type":"text","text":"16"},{"type":"text","text":" of the world, and"},{"type":"text","text":" "},{"type":"text","text":"so on."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Changing the value of this property updates the map view immediately. If you"},{"type":"text","text":" "},{"type":"text","text":"want to animate the change, use the "},{"code":"-setZoomLevel:animated:","type":"codeVoice"},{"type":"text","text":" method instead."}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"text":"The zoom level of the receiver.","type":"text"}],"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/zoomlevel"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"metadata":{"symbolKind":"property","navigatorTitle":[{"kind":"identifier","text":"zoomLevel"}],"role":"symbol","roleHeading":"Instance Property","title":"zoomLevel","externalID":"c:objc(cs)MLNMapView(py)zoomLevel","modules":[{"name":"MapLibre"}],"fragments":[{"kind":"identifier","text":"zoomLevel"}],"remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L1026","fileName":"MLNMapView.h"}},"kind":"symbol","references":{"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","kind":"symbol","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","title":"MapLibre","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"url":"\/documentation\/maplibre\/mlnmapview","role":"symbol","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","title":"MLNMapView","fragments":[{"kind":"identifier","text":"MLNMapView"}],"type":"topic","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/zoomLevel":{"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/zoomLevel","url":"\/documentation\/maplibre\/mlnmapview\/zoomlevel","abstract":[{"text":"The zoom level of the receiver.","type":"text"}],"type":"topic","fragments":[{"text":"zoomLevel","kind":"identifier"}],"title":"zoomLevel","kind":"symbol"}}}