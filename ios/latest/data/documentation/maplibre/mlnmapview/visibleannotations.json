r represent annotation data. Each object then serves as the source of"},{"type":"text","text":" "},{"type":"text","text":"information about a single map annotation and provides critical information,"},{"type":"text","text":" "},{"type":"text","text":"such as the annotation’s location on the map. Annotation objects do not provide"},{"type":"text","text":" "},{"type":"text","text":"the visual representation of the annotation but typically coordinate (in"},{"type":"text","text":" "},{"type":"text","text":"conjunction with the map view’s delegate) the creation of an appropriate"},{"type":"text","text":" "},{"type":"text","text":"objects to handle the display."}],"role":"symbol","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/visibleAnnotations":{"url":"\/documentation\/maplibre\/mlnmapview\/visibleannotations","abstract":[{"type":"text","text":"The complete list of annotations associated with the receiver that are"},{"type":"text","text":" "},{"type":"text","text":"currently visible."}],"role":"symbol","fragments":[{"text":"visibleAnnotations","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/visibleAnnotations","title":"visibleAnnotations","kind":"symbol"}}}