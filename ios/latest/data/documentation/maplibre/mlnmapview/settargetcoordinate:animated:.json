{"abstract":[{"type":"text","text":"Deprecated. Sets the geographic coordinate that is the subject of observation as"},{"type":"text","text":" "},{"type":"text","text":"the user location is being tracked, with an optional transition animation."}],"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/settargetcoordinate:animated:"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setTargetCoordinate:animated:","interfaceLanguage":"occ"},"metadata":{"roleHeading":"Instance Method","modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNMapView(im)setTargetCoordinate:animated:","platforms":[{"unavailable":false,"deprecated":true,"beta":false}],"fragments":[{"text":"- ","kind":"text"},{"text":"setTargetCoordinate:animated:","kind":"identifier"}],"role":"symbol","remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L775","fileName":"MLNMapView.h"},"navigatorTitle":[{"text":"setTargetCoordinate:animated:","kind":"identifier"}],"title":"setTargetCoordinate:animated:","symbolKind":"method"},"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"text","text":"- ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"setTargetCoordinate:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:@S@CLLocationCoordinate2D","text":"CLLocationCoordinate2D"},{"kind":"text","text":") "},{"kind":"internalParam","text":"targetCoordinate"},{"kind":"text","text":" "},{"kind":"identifier","text":"animated:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@BOOL","text":"BOOL"},{"kind":"text","text":") "},{"kind":"internalParam","text":"animated"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The target coordinate to fit within the viewport."}]}],"name":"targetCoordinate"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"YES"},{"type":"text","text":", the map animates to fit the target within the map"},{"type":"text","text":" "},{"type":"text","text":"view. If "},{"type":"codeVoice","code":"NO"},{"type":"text","text":", the map fits the target instantaneously."}]}],"name":"animated"}]},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"text":"By default, the target coordinate is set to an invalid coordinate, indicating","type":"text"},{"text":" ","type":"text"},{"text":"that there is no target. In course tracking mode, the target forms one of two","type":"text"},{"text":" ","type":"text"},{"text":"foci in the viewport, the other being the user location annotation. Typically,","type":"text"},{"text":" ","type":"text"},{"text":"the target is set to a destination or waypoint in a real-time navigation scene.","type":"text"},{"text":" ","type":"text"},{"text":"As the user annotation moves toward the target, the map automatically zooms in","type":"text"},{"text":" ","type":"text"},{"text":"to fit both foci optimally within the viewport.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This method has no effect if the ","type":"text"},{"code":"userTrackingMode","type":"codeVoice"},{"text":" property is set to a value","type":"text"},{"text":" ","type":"text"},{"text":"other than ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse","type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To specify a completion handler to execute after the animation finishes, use","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"type":"codeVoice","code":"-setTargetCoordinate:animated:completionHandler:"},{"text":" method.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"url":"\/documentation\/maplibre\/mlnmapview","role":"symbol","title":"MLNMapView","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","fragments":[{"kind":"identifier","text":"MLNMapView"}],"type":"topic","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserTrackingMode/MLNUserTrackingModeFollowWithCourse":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse","abstract":[],"url":"\/documentation\/maplibre\/mlnusertrackingmode\/mlnusertrackingmodefollowwithcourse","role":"symbol","title":"MLNUserTrackingModeFollowWithCourse","fragments":[{"text":"MLNUserTrackingModeFollowWithCourse","kind":"identifier"}],"type":"topic","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","role":"collection","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"title":"MapLibre","url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/setTargetCoordinate:animated:":{"title":"setTargetCoordinate:animated:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setTargetCoordinate:animated:","role":"symbo