{"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setTargetCoordinate:animated:","interfaceLanguage":"occ"},"metadata":{"roleHeading":"Instance Method","remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L775","fileName":"MLNMapView.h"},"platforms":[],"externalID":"c:objc(cs)MLNMapView(im)setTargetCoordinate:animated:","symbolKind":"method","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"setTargetCoordinate:animated:"}],"title":"setTargetCoordinate:animated:","role":"symbol","navigatorTitle":[{"kind":"text","text":"- "},{"kind":"identifier","text":"setTargetCoordinate:animated:"}],"modules":[{"name":"MapLibre"}]},"abstract":[{"text":"Deprecated. Sets the geographic coordinate that is the subject of observation as","type":"text"},{"text":" ","type":"text"},{"text":"the user location is being tracked, with an optional transition animation.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"],"tokens":[{"text":"- (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"setTargetCoordinate:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"CLLocationCoordinate2D","preciseIdentifier":"c:@S@CLLocationCoordinate2D","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"targetCoordinate","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"animated:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"BOOL","preciseIdentifier":"c:@T@BOOL","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"animated","kind":"internalParam"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"targetCoordinate","content":[{"type":"paragraph","inlineContent":[{"text":"The target coordinate to fit within the viewport.","type":"text"}]}]},{"name":"animated","content":[{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"YES","type":"codeVoice"},{"text":", the map animates to fit the target within the map","type":"text"},{"text":" ","type":"text"},{"text":"view. If ","type":"text"},{"code":"NO","type":"codeVoice"},{"text":", the map fits the target instantaneously.","type":"text"}]}]}]},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"text":"By default, the target coordinate is set to an invalid coordinate, indicating","type":"text"},{"text":" ","type":"text"},{"text":"that there is no target. In course tracking mode, the target forms one of two","type":"text"},{"text":" ","type":"text"},{"text":"foci in the viewport, the other being the user location annotation. Typically,","type":"text"},{"text":" ","type":"text"},{"text":"the target is set to a destination or waypoint in a real-time navigation scene.","type":"text"},{"text":" ","type":"text"},{"text":"As the user annotation moves toward the target, the map automatically zooms in","type":"text"},{"text":" ","type":"text"},{"text":"to fit both foci optimally within the viewport.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This method has no effect if the ","type":"text"},{"code":"userTrackingMode","type":"codeVoice"},{"text":" property is set to a value","type":"text"},{"text":" ","type":"text"},{"text":"other than ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To specify a completion handler to execute after the animation finishes, use","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"code":"-setTargetCoordinate:animated:completionHandler:","type":"codeVoice"},{"text":" method.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/settargetcoordinate:animated:"]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"kind":"symbol","sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/setTargetCoordinate:animated:":{"type":"topic","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"setTargetCoordinate:animated:"}],"title":"setTargetCoordinate:animated:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setTargetCoordinate:animated:","url":"\/documentation\/maplibre\/mlnmapview\/settargetcoordinate:animated:","kind":"symbol","role":"symbol","abstract":[{"text":"Deprecated. Sets the geographic coordinate that is the subject of observation as","type":"text"},{"text":" ","type":"text"},{"text":"the user location is being tracked, with an optional transition animation.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","kind":"symbol","role":"collection","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserTrackingMode/MLNUserTrackingModeFollowWithCourse":{"type":"topic","fragments":[{"text":"MLNUserTrackingModeFollowWithCourse","kind":"identifier"}],"title":"MLNUserTrackingModeFollowWithCourse","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse","url":"\/documentation\/maplibre\/mlnusertrackingmode\/mlnusertrackingmodefollowwithcourse","kind":"symbol","role":"symbol","abstract":[{"text":"The map follows the user location and rotates when the course changes.","type":"text"},{"text":" ","type":"text"},{"text":"Course represents the direction in which the device is traveling.","type":"text"},{"text":" ","type":"text"},{"text":"The default user location annotation shows a puck-shaped indicator","type":"text"},{"text":" ","type":"text"},{"text":"that rotates as the course changes.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"type":"topic","fragments":[{"text":"MLNMapView","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","title":"MLNMapView","url":"\/documentation\/maplibre\/mlnmapview","kind":"symbol","role":"symbol","abstract":[{"text":"An interactive, customizable map view with an interface similar to the one","type":"text"},{"text":" ","type":"text"},{"text":"provided by Apple’s MapKit.","type":"text"}]}}}