{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"- (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"setTargetCoordinate:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"CLLocationCoordinate2D","preciseIdentifier":"c:@S@CLLocationCoordinate2D","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"targetCoordinate","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"animated:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"BOOL","preciseIdentifier":"c:@T@BOOL","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"animated","kind":"internalParam"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"parameters":[{"name":"targetCoordinate","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The target coordinate to fit within the viewport."}]}]},{"name":"animated","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"YES","type":"codeVoice"},{"type":"text","text":", the map animates to fit the target within the map"},{"type":"text","text":" "},{"type":"text","text":"view. If "},{"code":"NO","type":"codeVoice"},{"type":"text","text":", the map fits the target instantaneously."}]}]}],"kind":"parameters"},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"By default, the target coordinate is set to an invalid coordinate, indicating"},{"type":"text","text":" "},{"type":"text","text":"that there is no target. In course tracking mode, the target forms one of two"},{"type":"text","text":" "},{"type":"text","text":"foci in the viewport, the other being the user location annotation. Typically,"},{"type":"text","text":" "},{"type":"text","text