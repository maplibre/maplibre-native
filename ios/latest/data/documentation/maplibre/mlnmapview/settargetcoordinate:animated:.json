{"sections":[],"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"text","text":"- ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"setTargetCoordinate:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:@S@CLLocationCoordinate2D","text":"CLLocationCoordinate2D"},{"kind":"text","text":") "},{"kind":"internalParam","text":"targetCoordinate"},{"kind":"text","text":" "},{"kind":"identifier","text":"animated:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@BOOL","text":"BOOL"},{"kind":"text","text":") "},{"kind":"internalParam","text":"animated"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"name":"targetCoordinate","content":[{"inlineContent":[{"type":"text","text":"The target coordinate to fit within the viewport."}],"type":"paragraph"}]},{"name":"animated","content":[{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"YES","type":"codeVoice"},{"text":", the map animates to fit the target within the map","type":"text"},{"text":" ","type":"text"},{"text":"view. If ","type":"text"},{"code":"NO","type":"codeVoice"},{"text":", the map fits the target instantaneously.","type":"text"}]}]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"By default, the target coordinate is set to an invalid coordinate, indicating","type":"text"},{"text":" ","type":"text"},{"text":"that there is no target. In course tracking mode, the target forms one of two","type":"text"},{"text":" ","type":"text"},{"text":"foci in the viewport, the other being the user location annotation. Typically,","type":"text"},{"text":" ","type":"text"},{"text":"the target is set to a destination or waypoint in a real-time navigation scene.","type":"text"},{"text":" ","type":"text"},{"text":"As the user annotation moves toward the target, the map automatically zooms in","type":"text"},{"text":" ","type":"text"},{"text":"to fit both foci optimally within the viewport.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method has no effect if the "},{"type":"codeVoice","code":"userTrackingMode"},{"type":"text","text":" property is set to a value"},{"type":"text","text":" "},{"type":"text","text":"other than "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To specify a completion handler to execute after the animation finishes, use"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"-setTargetCoordinate:animated:completionHandler:"},{"type":"text","text":" method."}]}]}],"abstract":[{"text":"Deprecated. Sets the geographic coordinate that is the subject of observation as","type":"text"},{"text":" ","type":"text"},{"text":"the user location is being tracked, with an optional transition animation.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"metadata":{"roleHeading":"Instance Method","platforms":[{"beta":false,"unavailable":false,"deprecated":true}],"role":"symbol","modules":[{"name":"MapLibre"}],"fragments":[{"text":"- ","kind":"text"},{"text":"setTargetCoordinate:animated:","kind":"identifier"}],"externalID":"c:objc(cs)MLNMapView(im)setTargetCoordinate:animated:","title":"setTargetCoordinate:animated:","symbolKind":"method","remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L775"},"navigatorTit