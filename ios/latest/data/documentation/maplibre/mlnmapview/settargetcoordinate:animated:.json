:"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, the target coordinate is set to an invalid coordinate, indicating"},{"type":"text","text":" "},{"type":"text","text":"that there is no target. In course tracking mode, the target forms one of two"},{"type":"text","text":" "},{"type":"text","text":"foci in the viewport, the other being the user location annotation. Typically,"},{"type":"text","text":" "},{"type":"text","text":"the target is set to a destination or waypoint in a real-time navigation scene."},{"type":"text","text":" "},{"type":"text","text":"As the user annotation moves toward the target, the map automatically zooms in"},{"type":"text","text":" "},{"type":"text","text":"to fit both foci optimally within the viewport."}]},{"type":"paragraph","inlineContent":[{"text":"This method has no effect if the ","type":"text"},{"code":"userTrackingMode","type":"codeVoice"},{"text":" property is set to a value","type":"text"},{"text":" ","type":"text"},{"text":"other than ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse","type":"reference","isActive":true},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To specify a completion handler to execute after the animation finishes, use"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"-setTargetCoordinate:animated:completionHandler:"},{"type":"text","text":" method."}]}]}],"abstract":[{"text":"Deprecated. Sets the geographic coordinate that is the subject of observation as","type":"text"},{"text":" ","type":"text"},{"text":"the user location is being tracked, with an optional transition animation.","type":"text"}],"sections":[],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setTargetCoordinate:animated:"}