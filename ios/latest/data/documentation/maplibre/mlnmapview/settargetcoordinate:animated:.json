{"abstract":[{"type":"text","text":"Deprecated. Sets the geographic coordinate that is the subject of observation as"},{"type":"text","text":" "},{"type":"text","text":"the user location is being tracked, with an optional transition animation."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"sections":[],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setTargetCoordinate:animated:"},"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/settargetcoordinate:animated:"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"role":"symbol","modules":[{"name":"MapLibre"}],"title":"setTargetCoordinate:animated:","platforms":[{"unavailable":false,"deprecated":true,"beta":false}],"externalID":"c:objc(cs)MLNMapView(im)setTargetCoordinate:animated:","roleHeading":"Instance Method","symbolKind":"method","remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L775"},"fragments":[{"text":"- ","kind":"text"},{"text":"setTargetCoordinate:animated:","kind":"identifier"}],"navigatorTitle":[{"text":"setTargetCoordinate:animated:","kind":"identifier"}]},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"text","text":"- ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"setTargetCoordinate:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:@S@CLLocationCoordinate2D","text":"CLLocationCoordinate2D"},{"kind":"text","text":") "},{"kind":"internalParam","text":"targetCoordinate"},{"kind":"text","text":" "},{"kind":"identifier","text":"animated:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@BOOL","text":"BOOL"},{"kind":"text","text":") "},{"kind":"internalParam","text":"animated"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"parameters":[{"name":"targetCoordinate","content":[{"inlineContent":[{"type":"text","text":"The target coordinate to fit within the viewport."}],"type":"paragraph"}]},{"name":"animated","content":[{"inlineContent":[{"type":"text","text":"If "},{"code":"YES","type":"codeVoice"},{"type":"text","text":", the map animates to fit the target within the map"},{"type":"text","text":" "},{"type":"text","text":"view. If "},{"code":"NO","type":"codeVoice"},{"type":"text","text":", the map fits the target instantaneously."}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"By default, the target coordinate is set to an invalid coordinate, indicating"},{"type":"text","text":" "},{"type":"text","text":"that there is no target. In course tracking mode, the target forms one of two"},{"type":"text","text":" "},{"type":"text","text":"foci in the viewport, the other being the user location annotation. Typically,"},{"type":"text","text":" "},{"type":"text","text":"the target is set to a destination or waypoint in a real-time navigation scene."},{"type":"text","text":" "},{"type":"text","text":"As the user annotation moves toward the target, the map automatically zooms in"},{"type":"text","text":" "},{"type":"text","text":"to fit both foci optimally within the viewport."}],"type":"paragraph"},{"inlineContent":[{"text":"This method has no effect if the ","type":"text"},{"code":"userTrackingMode","type":"codeVoice"},{"text":" property is set to a value","type":"text"},{"text":" ","type":"text"},{"text":"other than ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To specify a completion handler to execute after the animation finishes, use"},{"type":"text","text":" "},{"type":"text","text":"the "},{"code":"-setTargetCoordinate:animated:completionHandler:","type":"codeVoice"},{"type":"text","text":" method."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/setTargetCoordinate:animated:":{"kind":"symbol","abstract":[{"type":"text","text":"Deprecated. Sets the geographic coordinate that is the subject of observation as"},{"type":"text","text":" "},{"type":"text","text":"the user location is being tracked, with an optional transition animation."}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"setTargetCoordinate:animated:"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setTargetCoordinate:animated:","title":"setTargetCoordinate:animated:","role":"symbol","url":"\/documentation\/maplibre\/mlnmapview\/settargetcoordinate:animated:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"setTargetCoordinate:animated:"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"url":"\/documentation\/maplibre","kind":"symbol","type":"topic","title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"fragments":[{"text":"MLNMapView","kind":"identifier"}],"kind":"symbol","title":"MLNMapView","role":"symbol","url":"\/documentation\/maplibre\/mlnmapview","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentatio