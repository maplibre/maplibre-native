type":"text"},{"code":"-setTargetCoordinate:animated:completionHandler:","type":"codeVoice"},{"text":" method.","type":"text"}],"type":"paragraph"}]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/settargetcoordinate:animated:"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/setTargetCoordinate:animated:":{"abstract":[{"type":"text","text":"Deprecated. Sets the geographic coordinate that is the subject of observation as"},{"type":"text","text":" "},{"type":"text","text":"the user location is being tracked, with an optional transition animation."}],"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"setTargetCoordinate:animated:"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setTargetCoordinate:animated:","kind":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnmapview\/settargetcoordinate:animated:","role":"symbol","title":"setTargetCoordinate:animated:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"type":"topic","url":"\/documentation\/maplibre\/mlnmapview","role":"symbol","title":"MLNMapView","fragments":[{"kind":"identifier","text":"MLNMapView"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","kind":"symbol","abstract":[{"text":"An interactive, customizable map view with an interface similar to the one","type":"text"},{"text":" ","type":"text"},{"text":"provided by Apple’s MapKit.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserTrackingMode/MLNUserTrackingModeFollowWithCourse":{"abstract":[{"type":"text","text":"The map follows the user location and rotates when the course changes."},{"type":"text","text":" "},{"type":"text","text":"Course represents the direction in which the device is traveling."},{"type":"text","text":" "},{"type":"text","text":"The default user location ann