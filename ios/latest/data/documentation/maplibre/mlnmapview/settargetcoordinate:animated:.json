{"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","sections":[],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setTargetCoordinate:animated:","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/settargetcoordinate:animated:"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"declarations":[{"languages":["occ"],"tokens":[{"kind":"text","text":"- ("},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"setTargetCoordinate:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:@S@CLLocationCoordinate2D","kind":"typeIdentifier","text":"CLLocationCoordinate2D"},{"kind":"text","text":") "},{"kind":"internalParam","text":"targetCoordinate"},{"kind":"text","text":" "},{"kind":"identifier","text":"animated:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:@T@BOOL","kind":"typeIdentifier","text":"BOOL"},{"kind":"text","text":") "},{"kind":"internalParam","text":"animated"},{"kind":"text","text":";"}],"platforms":["iOS"]}],"kind":"declarations"},{"parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The target coordinate to fit within the viewport."}],"type":"paragraph"}],"name":"targetCoordinate"},{"content":[{"inlineContent":[{"text":"If ","type":"text"},{"code":"YES","type":"codeVoice"},{"text":", the map animates to fit the target within the map","type":"text"},{"text":" ","type":"text"},{"text":"view. If ","type":"text"},{"code":"NO","type":"codeVoice"},{"text":", the map fits the target instantaneously.","type":"text"}],"type":"paragraph"}],"name":"animated"}],"kind":"parameters"},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, the target coordinate is set to an invalid coordinate, indicating"},{"type":"text","text":" "},{"type":"text","text":"that there is no target. In course tracking mode, the target forms one of two"},{"type":"text","text":" "},{"type":"text","text":"foci in the viewport, the other being the user location annotation. Typically,"},{"type":"text","text":" "},{"type":"text","text":"the target is set to a destination or waypoint in a real-time navigation scene."},{"type":"text","text":" "},{"type":"text","text":"As the user annotation moves toward the target, the map automatically zooms in"},{"type":"text","text":" "},{"type":"text","text":"to fit both foci optimally within the viewport."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method has no effect if the "},{"type":"codeVoice","code":"userTrackingMode"},{"type":"text","text":" property is set to a value"},{"type":"text","text":" "},{"type":"text","text":"other than "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To specify a completion handler to execute after the animation finishes, use"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"-setTargetCoordinate:animated:completionHandler:"},{"type":"text","text":" method."}]}],"kind":"content"}],"metadata":{"symbolKind":"method","navigatorTitle":[{"text":"setTargetCoordinate:animated:","kind":"identifier"}],"role":"symbol","remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L775","fileName":"MLNMapView.h"},"externalID":"c:objc(cs)MLNMapView(im)setTargetCoordinate:animated:","title":"setTargetCoordinate:animated:","modules":[{"name":"MapLibre"}],"platforms":[{"unavailable":false,"beta":false,"deprecated":true}],"fragments":[{"text":"- ","kind":"