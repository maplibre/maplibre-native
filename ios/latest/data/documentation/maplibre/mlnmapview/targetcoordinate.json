{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/targetCoordinate"},"abstract":[{"type":"text","text":"The geographic coordinate that is the subject of observation as the user"},{"type":"text","text":" "},{"type":"text","text":"location is being tracked."}],"primaryContentSections":[{"declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"assign","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:@S@CLLocationCoordinate2D","text":"CLLocationCoordinate2D","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"targetCoordinate","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, this property is set to an invalid coordinate, indicating that"},{"type":"text","text":" "},{"type":"text","text":"there is no target. In course tracking mode, the target forms one of two foci"},{"type":"text","text":" "},{"type":"text","text":"in the viewport, the other being the user location annotation. Typically, this"},{"type":"text","text":" "},{"type":"text","text":"property is set to a destination or waypoint in a real-time navigation scene."},{"type":"text","text":" "},{"type":"text","text":"As the user annotation moves toward the target, the map automatically zooms in"},{"type":"text","text":" "},{"type":"text","text":"to fit both foci optimally within the viewport."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property has no effect if the "},{"type":"codeVoice","code":"userTrackingMode"},{"type":"text","text":" property is set to a"},{"type":"text","text":" "},{"type":"text","text":"value other than "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse","type":"reference","isActive":true},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Changing the value of this property updates the map view with an animated"},{"type":"text","text":" "},{"type":"text","text":"transition. If you don’t want to animate the change, use the"},{"type":"text","text":" "},{"type":"codeVoice","code":"-setTargetCoordinate:animated:"},{"type":"text","text":" method instead."}]}],"kind":"content"}],"metadata":{"role":"symbol","title":"targetCoordinate","externalID":"c:objc(cs)MLNMapView(py)targetCoordinate","navigatorTitle":[{"kind":"identifier","text":"targetCoordinate"}],"roleHeading":"Instance Property","remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L752"},"symbolKind":"property","modules":[{"name":"MapLibre"}],"fragments":[{"text":"targetCoordinate","kind":"identifier"}]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/targetcoordinate"]}],"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNUserTrackingMode/MLNUserTrackingModeFollowWithCourse":{"kind":"symbol","url":"\/documentation\/maplibre\/mlnusertrackingmode\/mlnusertrackingmodefollowwithcourse","fragments":[{"text":"MLNUserTrackingModeFollowWithCourse","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse","type":"topic","abstract":[{"type":"text","text":"The map follows the user location and rotates when the course changes."},{"type":"text","text":" "},{"type":"text","text":"Course represents the direction in which the device is traveling."},{"type":"text","text":" "},{"type":"text","text":"The default user location annotation shows a puck-shaped indicator"},{"type":"text","text":" "},{"type":"text","text":"that rotates as the course changes."}],"title":"MLNUserTrackingModeFollowWithCourse","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"fragments":[{"kind":"identifier","text":"MLNMapView"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","kind":"symbol","title":"MLNMapView","url":"\/documentation\/maplibre\/mlnmapview","role":"symbol","abstract":[{"text":"An interactive, customizable map view with an interface similar to the one","type":"text"},{"text":" ","type":"text"},{"text":"provided by Apple’s MapKit.","type":"text"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/targetCoordinate":{"role":"symbol","title":"targetCoordinate","kind":"symbol","abstract":[{"type":"text","text":"The geographic coordinate that is the subject of observation as the user"},{"type":"text","text":" "},{"type":"text","text":"location is being tracked."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/targetCoordinate","type":"topic","fragments":[{"text":"targetCoordinate","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnmapview\/targetcoordinate"}}}