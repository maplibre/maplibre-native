{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"The geographic coordinate that is the subject of observation as the user"},{"type":"text","text":" "},{"type":"text","text":"location is being tracked."}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/targetCoordinate","interfaceLanguage":"occ"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"assign","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:@S@CLLocationCoordinate2D","text":"CLLocationCoordinate2D","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"targetCoordinate","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"text":"By default, this property is set to an invalid coordinate, indicating that","type":"text"},{"text":" ","type":"text"},{"text":"there is no target. In course tracking mode, the target forms one of two foci","type":"text"},{"text":" ","type":"text"},{"text":"in the viewport, the other being the user location annotation. Typically, this","type":"text"},{"text":" ","type":"text"},{"text":"property is set to a destination or waypoint in a real-time navigation scene.","type":"text"},{"text":" ","type":"text"},{"text":"As the user annotation moves toward the target, the map automatically zooms in","type":"text"},{"text":" ","type":"text"},{"text":"to fit both foci optimally within the viewport.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This property has no effect if the ","type":"text"},{"code":"userTrackingMode","type":"codeVoice"},{"text":" property is set to a","type":"text"},{"text":" ","type":"text"},{"text":"value other than ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Changing the value of this property updates the map view with an animated","type":"text"},{"text":" ","type":"text"},{"text":"transition. If you don’t want to animate the change, use the","type":"text"},{"text":" ","type":"text"},{"code":"-setTargetCoordinate:animated:","type":"codeVoice"},{"text":" method instead.","type":"text"}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/targetcoordinate"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"fragments":[{"text":"targetCoordinate","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"targetCoordinate"}],"externalID":"c:objc(cs)MLNMapView(py)targetCoordinate","role":"symbol","modules":[{"name":"MapLibre"}],"title":"targetCoordinate","remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L752","fileName":"MLNMapView.h"},"symbolKind":"property","roleHeading":"Instance Property"},"kind":"symbol","references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"type":"topic","kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlnmapview","title":"MLNMapView","fragments":[{"kind":"identifier","text":"MLNMapView"}],"abstract":[{"text":"An interactive, customizable map view with an interface similar to the one","type":"text"},{"text":" ","type":"text"},{"text":"provided by Apple’s MapKit.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/targetCoordinate":{"abstract":[{"type":"text","text":"The geographic coordinate that is the subject of observation as the user"},{"type":"text","text":" "},{"type":"text","text":"location is being tracked."}],"url":"\/documentation\/maplibre\/mlnmapview\/targetcoordinate","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/targetCoordinate","kind":"symbol","title":"targetCoordinate","role":"symbol","fragments":[{"text":"targetCoordinate","kind":"identifier"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","type":"topic","kind":"symbol","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserTrackingMode/MLNUserTrackingModeFollowWithCourse":{"type":"topic","fragments":[{"text":"MLNUserTrackingModeFollowWithCourse","kind":"identifier"}],"abstract":[{"type":"text","text":"The map follows the user location and rotates when the course changes."},{"type":"text","text":" "},{"type":"text","text":"Course represents the direction in which the device is traveling."},{"type":"text","text":" "},{"type":"text","text":"The default user location annotation shows a puck-shaped indicator"},{"type":"text","text":" "},{"type":"text","text":"that rotates as the course changes."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse","title":"MLNUserTrackingModeFollowWithCourse","role":"symbol","url":"\/documentation\/maplibre\/mlnusertrackingmode\/mlnusertrackingmodefollowwithcourse","kind":"symbol"}}}