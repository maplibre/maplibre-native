ackingMode","type":"codeVoice"},{"text":" property is set to a","type":"text"},{"text":" ","type":"text"},{"text":"value other than ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse","type":"reference","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Changing the value of this property updates the map view with an animated","type":"text"},{"text":" ","type":"text"},{"text":"transition. If you don’t want to animate the change, use the","type":"text"},{"text":" ","type":"text"},{"code":"-setTargetCoordinate:animated:","type":"codeVoice"},{"text":" method instead.","type":"text"}],"type":"paragraph"}]}],"abstract":[{"text":"The geographic coordinate that is the subject of observation as the user","type":"text"},{"type":"text","text":" "},{"type":"text","text":"location is being tracked."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/targetcoordinate"]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/targetCoordinate","interfaceLanguage":"occ"},"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/targetCoordinate":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/targetCoordinate","abstract":[{"type":"text","text":"The geographic coordinate that is the subject of observation as the user"},{"type":"text","text":" "},{"type":"text","text":"location is being tracked."}],"fragments":[{"text":"targetCoordinate","kind":"identifier"}],"title":"targetCoordinate","kind":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnmapview\/targetcoordinate","role":"symbol"},"doc://org.swift.