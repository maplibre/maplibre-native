{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/targetCoordinate","interfaceLanguage":"occ"},"metadata":{"externalID":"c:objc(cs)MLNMapView(py)targetCoordinate","navigatorTitle":[{"text":"targetCoordinate","kind":"identifier"}],"symbolKind":"property","fragments":[{"text":"targetCoordinate","kind":"identifier"}],"remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L752","fileName":"MLNMapView.h"},"role":"symbol","title":"targetCoordinate","modules":[{"name":"MapLibre"}],"roleHeading":"Instance Property"},"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"assign","kind":"keyword"},{"text":") ","kind":"text"},{"text":"CLLocationCoordinate2D","kind":"typeIdentifier","preciseIdentifier":"c:@S@CLLocationCoordinate2D"},{"text":" ","kind":"text"},{"text":"targetCoordinate","kind":"identifier"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"text":"By default, this property is set to an invalid coordinate, indicating that","type":"text"},{"text":" ","type":"text"},{"text":"there is no target. In course tracking mode, the target forms one of two foci","type":"text"},{"text":" ","type":"text"},{"text":"in the viewport, the other being the user location annotation. Typically, this","type":"text"},{"text":" ","type":"text"},{"text":"property is set to a destination or waypoint in a real-time navigation scene.","type":"text"},{"text":" ","type":"text"},{"text":"As the user annotation moves toward the target, the map automatically zooms in","type":"text"},{"text":" ","type":"text"},{"text":"to fit both foci optimally within the viewport.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This property has no effect if the "},{"type":"codeVoice","code":"userTrackingMode"},{"type":"text","text":" property is set to a"},{"type":"text","text":" "},{"type":"text","text":"value other than "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"Changing the value of this property updates the map view with an animated","type":"text"},{"text":" ","type":"text"},{"text":"transition. If you don’t want to animate the change, use the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"-setTargetCoordinate:animated:"},{"text":" method instead.","type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/targetcoordinate"]}],"sections":[],"abstract":[{"type":"text","text":"The geographic coordinate that is the subject of observation as the user"},{"type":"text","text":" "},{"type":"text","text":"location is being tracked."}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/targetCoordinate":{"role":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/targetCoordinate","url":"\/documentation\/maplibre\/mlnmapview\/targetcoordinate","title":"targetCoordinate","kind":"symbol","fragments":[{"kind":"identifier","text":"targetCoordinate"}],"abstract":[{"type":"text","text":"The geographic coordinate that is the subject of observation as the user"},{"type":"text","text":" "},{"type":"text","text":"location is being tracked."}]},"doc://org.swift.MyProject/documentation/