{"metadata":{"roleHeading":"Instance Property","externalID":"c:objc(cs)MLNMapView(py)targetCoordinate","title":"targetCoordinate","remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L752","fileName":"MLNMapView.h"},"fragments":[{"text":"targetCoordinate","kind":"identifier"}],"symbolKind":"property","navigatorTitle":[{"text":"targetCoordinate","kind":"identifier"}],"role":"symbol","modules":[{"name":"MapLibre"}]},"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"assign","kind":"keyword"},{"text":") ","kind":"text"},{"text":"CLLocationCoordinate2D","kind":"typeIdentifier","preciseIdentifier":"c:@S@CLLocationCoordinate2D"},{"text":" ","kind":"text"},{"text":"targetCoordinate","kind":"identifier"},{"text":";","kind":"text"}]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, this property is set to an invalid coordinate, indicating that"},{"type":"text","text":" "},{"type":"text","text":"there is no target. In course tracking mode, the target forms one of two foci"},{"type":"text","text":" "},{"type":"text","text":"in the viewport, the other being the user location annotation. Typically, this"},{"type":"text","text":" "},{"type":"text","text":"property is set to a destination or waypoint in a real-time navigation scene."},{"type":"text","text":" "},{"type":"text","text":"As the user annotation moves toward the target, the map automatically zooms in"},{"type":"text","text":" "},{"type":"text","text":"to fit both foci optimally within the viewport."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property has no effect if the "},{"type":"codeVoice","code":"userTrackingMode"},{"type":"text","text":" property is set to a"},{"type":"text","text":" "},{"type":"text","text":"value other than "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse","isActive":true},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Changing the value of this property updates the map view with an animated"},{"type":"text","text":" "},{"type":"text","text":"transition. If you don’t want to animate the change, use the"},{"type":"text","text":" "},{"type":"codeVoice","code":"-setTargetCoordinate:animated:"},{"type":"text","text":" method instead."}]}]}],"kind":"symbol","abstract":[{"type":"text","text":"The geographic coordinate that is the subject of observation as the user"},{"type":"text","text":" "},{"type":"text","text":"location is being tracked."}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/targetCoordinate","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/targetcoordinate"]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"text":"provided by Apple’s MapKit.","type":"text"}],"title":"MLNMapView","url":"\/documentation\/maplibre\/mlnmapview","fragments":[{"text":"MLNMapView","kind":"identifier"}],"kind":"symbol","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","url":"\/documentation\/maplibre","kind":"symbol","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserTrackingMode/MLNUserTrackingModeFollowWithCourse":{"fragments":[{"text":"MLNUserTrackingModeFollowWithCourse","kind":"identifier"}],"title":"MLNUserTrackingModeFollowWithCourse","type":"topic","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse","role":"symbol","abstract":[{"type":"text","text":"The map follows the user location and rotates when the course changes."},{"type":"text","text":" "},{"type":"text","text":"Course represents the direction in which the device is traveling."},{"type":"text","text":" "},{"type":"text","text":"The default user location annotation shows a puck-shaped indicator"},{"type":"text","text":" "},{"type":"text","text":"that rotates as the course changes."}],"url":"\/documentation\/maplibre\/mlnusertrackingmode\/mlnusertrackingmodefollowwithcourse"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/targetCoordinate":{"fragments":[{"text":"targetCoordinate","kind":"identifier"}],"role":"symbol","type":"topic","kind":"symbol","abstract":[{"text":"The geographic coordinate that is the subject of observation as the user","type":"text"},{"text":" ","type":"text"},{"text":"location is being tracked.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/targetCoordinate","title":"targetCoordinate","url":"\/documentation\/maplibre\/mlnmapview\/targetcoordinate"}}}