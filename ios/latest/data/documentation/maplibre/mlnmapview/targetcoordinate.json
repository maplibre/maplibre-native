{"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/targetcoordinate"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"type":"text","text":"The geographic coordinate that is the subject of observation as the user"},{"type":"text","text":" "},{"type":"text","text":"location is being tracked."}],"metadata":{"externalID":"c:objc(cs)MLNMapView(py)targetCoordinate","modules":[{"name":"MapLibre"}],"role":"symbol","roleHeading":"Instance Property","fragments":[{"text":"targetCoordinate","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"targetCoordinate"}],"symbolKind":"property","remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L752"},"title":"targetCoordinate"},"kind":"symbol","identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/targetCoordinate","interfaceLanguage":"occ"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"assign","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:@S@CLLocationCoordinate2D","text":"CLLocationCoordinate2D","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"targetCoordinate","kind":"identifier"},{"text":";","kind":"text"}]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"By default, this property is set to an invalid coordinate, indicating that","type":"text"},{"text":" ","type":"text"},{"text":"there is no target. In course tracking mode, the target forms one of two foci","type":"text"},{"text":" ","type":"text"},{"text":"in the viewport, the other being the user location annotation. Typically, this","type":"text"},{"text":" ","type":"text"},{"text":"property is set to a destination or waypoint in a real-time navigation scene.","type":"text"},{"text":" ","type":"text"},{"text":"As the user annotation moves toward the target, the map automatically zooms in","type":"text"},{"text":" ","type":"text"},{"text":"to fit both foci optimally within the viewport.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This property has no effect if the ","type":"text"},{"code":"userTrackingMode","type":"codeVoice"},{"text":" property is set to a","type":"text"},{"text":" ","type":"text"},{"text":"value other than ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse","type":"reference","isActive":true},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Changing the value of this property updates the map view with an animated","type":"text"},{"text":" ","type":"text"},{"text":"transition. If you don’t want to animate the change, use the","type":"text"},{"text":" ","type":"text"},{"code":"-setTargetCoordinate:animated:","type":"codeVoice"},{"text":" method instead.","type":"text"}]}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","type":"topic","abstract":[{"text":"An interactive, customizable map view with an interface similar to the one","type":"text"},{"text":" ","type":"text"},{"text":"provided by Apple’s MapKit.","type":"text"}],"title":"MLNMapView","url":"\/documentation\/maplibre\/mlnmapview","fragments":[{"kind":"identifier","text":"MLNMapView"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/targetCoordinate":{"kind":"symbol","role":