{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"assign","kind":"keyword"},{"text":") ","kind":"text"},{"text":"CLLocationCoordinate2D","preciseIdentifier":"c:@S@CLLocationCoordinate2D","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"targetCoordinate","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"By default, this property is set to an invalid coordinate, indicating that","type":"text"},{"text":" ","type":"text"},{"text":"there is no target. In course tracking mode, the target forms one of two foci","type":"text"},{"text":" ","type":"text"},{"text":"in the viewport, the other being the user location annotation. Typically, this","type":"text"},{"text":" ","type":"text"},{"text":"property is set to a destination or waypoint in a real-time navigation scene.","type":"text"},{"text":" ","type":"text"},{"text":"As the user annotation moves toward the target, the map automatically zooms in","type":"text"},{"text":" ","type":"text"},{"text":"to fit both foci optimally within the viewport.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property has no effect if the "},{"code":"userTrackingMode","type":"codeVoice"},{"type":"text","text":" property is set to a"},{"type":"text","text":" "},{"type":"text","text":"value other than "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse","isActive":true},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Changing the value of this property updates the map view with an animated"},{"type":"text","text":" "},{"type":"text","text":"transition. If you don’t want to animate the change, use the"},{"type":"text","text":" "},{"type":"codeVoice","code":"-setTargetCoordinate:animated:"},{"type":"text","text":" method instead."}]}]}],"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/targetcoordinate"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/targetCoordinate","interfaceLanguage":"occ"},"abstract":[{"type":"text","text":"The geographic coordinate that is the subject of observation as the user"},{"type":"text","text":" "},{"type":"text","text":"location is being tracked."}],"kind":"symbol","metadata":{"modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNMapView(py)targetCoordinate","symbolKind":"property","fragments":[{"text":"targetCoordinate","kind":"identifier"}],"remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L752"},"role":"symbol","title":"targetCoordinate","navigatorTitle":[{"text":"targetCoordinate","kind":"identifier"}],"roleHeading":"Instance Property"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/targetCoordinate":{"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/targetCoordinate","kind":"symbol","abstract":[{"type":"text","text":"The geographic coordinate that is the subject of observation as the user"},{"type":"text","text":" "},{"type":"text","text":"location is being tracked."}],"title":"targetCoordinate","type":"topic","fragments":[{"text":"targetCoordinate","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnmapview\/targetcoordinate"},"doc://org.swift.MyProject/documentation/