ibre\/mlnusertrackingmode\/mlnusertrackingmodefollowwithcourse","fragments":[{"kind":"identifier","text":"MLNUserTrackingModeFollowWithCourse"}],"kind":"symbol","title":"MLNUserTrackingModeFollowWithCourse","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithCourse","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","url":"\/documentation\/maplibre\/mlnmapview","type":"topic","fragments":[{"text":"MLNMapView","kind":"identifier"}],"role":"symbol","kind":"symbol","title":"MLNMapView"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/targetCoordinate":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/targetCoordinate","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"The geographic coordinate that is the subject of observation as the user"},{"type":"text","text":" "},{"type":"text","text":"location is being tracked."}],"title":"targetCoordinate","url":"\/documentation\/maplibre\/mlnmapview\/targetcoordinate","role":"symbol","fragments":[{"kind":"identifier","text":"targetCoordinate"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","type":"topic","role":"collection","kind":"symbol","title":"MapLibre"}}}