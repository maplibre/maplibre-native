{"sections":[],"abstract":[{"type":"text","text":"The distance from the edges of the map view’s frame to the edges of the map"},{"type":"text","text":" "},{"type":"text","text":"view’s logical viewport."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"assign"},{"kind":"text","text":") "},{"kind":"typeIdentifier","preciseIdentifier":"c:@S@UIEdgeInsets","text":"UIEdgeInsets"},{"kind":"text","text":" "},{"kind":"identifier","text":"contentInset"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"When the value of this property is equal to ","type":"text"},{"code":"UIEdgeInsetsZero","type":"codeVoice"},{"text":", viewport","type":"text"},{"text":" ","type":"text"},{"text":"properties such as ","type":"text"},{"code":"centerCoordinate","type":"codeVoice"},{"text":" assume a viewport that matches the map","type":"text"},{"text":" ","type":"text"},{"text":"view’s frame. Otherwise, those properties are inset, excluding part of the","type":"text"},{"text":" ","type":"text"},{"text":"frame from the viewport. For instance, if the only the top edge is inset, the","type":"text"},{"text":" ","type":"text"},{"text":"map center is effectively shifted downward.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When the map view’s superview is an instance of "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":" whose"},{"type":"text","text":" "},{"type":"codeVoice","code":"automaticallyAdjustsScrollViewInsets"},{"type":"text","text":" property is "},{"type":"codeVoice","code":"YES"},{"type":"text","text":", the value of this"},{"type":"text","text":" "},{"type":"text","text":"property may be overridden at any time."}],"type":"paragraph"},{"inlineContent":[{"text":"The usage of ","type":"text"},{"type":"codeVoice","code":"automaticallyAdjustsScrollViewInsets"},{"text":" has been deprecated","type":"text"},{"text":" ","type":"text"},{"text":"use the map view’s property ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/automaticallyAdjustsContentInset","isActive":true,"type":"reference"},{"text":"instead.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Changing the value of this property updates the map view immediately. If you","type":"text"},{"text":" ","type":"text"},{"text":"want to animate the change, use the ","type":"text"},{"code":"-setContentInset:animated:completionHandler:","type":"codeVoice"},{"text":" ","type":"text"},{"text":"method instead.","type":"text"}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/contentInset","interfaceLanguage":"occ"},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"symbolKind":"property","title":"contentInset","remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L1610"},"navigatorTitle":[{"kind":"identifier","text":"contentInset"}],"role":"symbol","modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNMapView(py)contentInset","roleHeading":"Instance Property","fragments":[{"kind":"identifier","text":"contentInset"}]},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/contentinset"]}],"kind":"symbol","references":{"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"sym