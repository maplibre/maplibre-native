{"sections":[],"metadata":{"symbolKind":"property","fragments":[{"text":"contentInset","kind":"identifier"}],"role":"symbol","title":"contentInset","navigatorTitle":[{"text":"contentInset","kind":"identifier"}],"externalID":"c:objc(cs)MLNMapView(py)contentInset","roleHeading":"Instance Property","remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L1610"},"modules":[{"name":"MapLibre"}]},"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/contentinset"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"assign","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:@S@UIEdgeInsets","text":"UIEdgeInsets","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"contentInset","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"When the value of this property is equal to ","type":"text"},{"code":"UIEdgeInsetsZero","type":"codeVoice"},{"text":", viewport","type":"text"},{"text":" ","type":"text"},{"text":"properties such as ","type":"text"},{"code":"centerCoordinate","type":"codeVoice"},{"text":" assume a viewport that matches the map","type":"text"},{"text":" ","type":"text"},{"text":"view’s frame. Otherwise, those properties are inset, excluding part of the","type":"text"},{"text":" ","type":"text"},{"text":"frame from the viewport. For instance, if the only the top edge is inset, the","type":"text"},{"text":" ","type":"text"},{"text":"map center is effectively shifted downward.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"When the map view’s superview is an instance