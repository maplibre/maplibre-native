{"sections":[],"kind":"symbol","variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/contentinset"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/contentInset"},"metadata":{"roleHeading":"Instance Property","fragments":[{"text":"contentInset","kind":"identifier"}],"externalID":"c:objc(cs)MLNMapView(py)contentInset","title":"contentInset","modules":[{"name":"MapLibre"}],"role":"symbol","symbolKind":"property","remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L1610"},"navigatorTitle":[{"text":"contentInset","kind":"identifier"}]},"abstract":[{"text":"The distance from the edges of the map view’s frame to the edges of the map","type":"text"},{"text":" ","type":"text"},{"text":"view’s logical viewport.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"assign","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:@S@UIEdgeInsets","text":"UIEdgeInsets","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"contentInset","kind":"identifier"},{"text":";","kind":"text"}]}]},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"When the value of this property is equal to "},{"code":"UIEdgeInsetsZero","type":"codeVoice"},{"type":"text","text":", viewport"},{"type":"text","text":" "},{"type":"text","text":"properties such as "},{"code":"centerCoordinate","type":"codeVoice"},{"type":"text","text":" assume a viewport that matches the map"},{"type":"text","text":" "},{"type":"text","text":"view’s frame. Otherwise, those properties are inset, excluding part of the"},{"type":"text","text":" "},{"type":"text","text":"frame from the viewport. For instance, if the only the top edge is inset, the"},{"type":"text","text":" "},{"type":"text","text":"map center is effectively shifted downward."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When the map view’s superview is an instance of "},{"code":"UIViewController","type":"codeVoice"},{"type":"text","text":" whose"},{"type":"text","text":" "},{"code":"automaticallyAdjustsScrollViewInsets","type":"codeVoice"},{"type":"text","text":" property is "},{"code":"YES","type":"codeVoice"},{"type":"text","text":", the value of this"},{"type":"text","text":" "},{"type":"text","text":"property may be overridden at any time."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The usage of "},{"type":"codeVoice","code":"automaticallyAdjustsScrollViewInsets"},{"type":"text","text":" has been deprecated"},{"type":"text","text":" "},{"type":"text","text":"use the map view’s property "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/automaticallyAdjustsContentInset"},{"type":"text","text":"instead."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Changing the value of this property updates the map view immediately. If you"},{"type":"text","text":" "},{"type":"text","text":"want to animate the change, use the "},{"type":"codeVoice","code":"-setContentInset:animated:completionHandler:"},{"type":"text","text":" "},{"type":"text","text":"method instead."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/automaticallyAdjustsContentInset":{"type":"topic","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/automaticallyAdjustsContentInset","url":"\/documentation\/maplibre\/mlnmapview\/automaticallyadjustscontentinset","title":"automaticallyAdjustsContentInset","fragments":[{"text":"automaticallyAdjustsContentInset","kind":"identifier"}],"abstract":[{"type":"text","text":"A boolean value that indicates if whether the map view should automatically"},{"type":"text","text":" "},{"type":"text","text":"adjust its content insets."}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"fragments":[{"kind":"identifier","text":"MLNMapView"}],"url":"\/documentation\/maplibre\/mlnmapview","type":"topic","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","title":"MLNMapView"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/contentInset":{"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/contentInset","url":"\/documentation\/maplibre\/mlnmapview\/contentinset","abstract":[{"type":"text","text":"The distance from the edges of the map view’s frame to the edges of the map"},{"type":"text","text":" "},{"type":"text","text":"view’s logical viewport."}],"title":"contentInset","type":"topic","fragments":[{"text":"contentInset","kind":"identifier"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","kind":"symbol","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","title":"MapLibre"}}}