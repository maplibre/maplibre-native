{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"sections":[],"abstract":[{"type":"text","text":"The distance from the edges of the map view’s frame to the edges of the map"},{"type":"text","text":" "},{"type":"text","text":"view’s logical viewport."}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"assign"},{"kind":"text","text":") "},{"kind":"typeIdentifier","text":"UIEdgeInsets","preciseIdentifier":"c:@S@UIEdgeInsets"},{"kind":"text","text":" "},{"kind":"identifier","text":"contentInset"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"When the value of this property is equal to "},{"code":"UIEdgeInsetsZero","type":"codeVoice"},{"type":"text","text":", viewport"},{"type":"text","text":" "},{"type":"text","text":"properties such as "},{"code":"centerCoordinate","type":"codeVoice"},{"type":"text","text":" assume a viewport that matches the map"},{"type":"text","text":" "},{"type":"text","text":"view’s frame. Otherwise, those properties are inset, excluding part of the"},{"type":"text","text":" "},{"type":"text","text":"frame from the viewport. For instance, if the only the top edge is inset, the"},{"type":"text","text":" "},{"type":"text","text":"map center is effectively shifted downward."}],"type":"paragraph"},{"inlineContent":[{"text":"When the map view’s superview is an instance of ","type":"text"},{"type":"codeVoice","code":"UIViewController"},{"text":" whose","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"automaticallyAdjustsScrollViewInsets"},{"type":"text","text":" property is "},{"type":"codeVoice","code":"YES"},{"type":"text","text":", the value of this"},{"type":"text","text":" "},{"type":"text","text":"property may be overridden at any time."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The usage of ","type":"text"},{"type":"codeVoice","code":"automaticallyAdjustsScrollViewInsets"},{"text":" has been deprecated","type":"text"},{"text":" ","type":"text"},{"text":"use the map view’s property ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/automaticallyAdjustsContentInset","type":"reference","isActive":true},{"text":"instead.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Changing the value of this property updates the map view immediately. If you","type":"text"},{"text":" ","type":"text"},{"text":"want to animate the change, use the ","type":"text"},{"type":"codeVoice","code":"-setContentInset:animated:completionHandler:"},{"text":" ","type":"text"},{"text":"method instead.","type":"text"}]}],"kind":"content"}],"metadata":{"fragments":[{"text":"contentInset","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"navigatorTitle":[{"text":"contentInset","kind":"identifier"}],"roleHeading":"Instance Property","role":"symbol","externalID":"c:objc(cs)MLNMapView(py)contentInset","symbolKind":"property","title":"contentInset","remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L1610"}},"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/contentInset"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/contentinset"]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/contentInset":{"abstract":[{"text":"The distance from the edges of the map view’s frame to the edges of the map","type":"text"},{"text":