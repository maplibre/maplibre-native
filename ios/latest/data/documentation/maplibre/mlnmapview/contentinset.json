ext","text":" assume a viewport that matches the map"},{"type":"text","text":" "},{"type":"text","text":"view’s frame. Otherwise, those properties are inset, excluding part of the"},{"type":"text","text":" "},{"type":"text","text":"frame from the viewport. For instance, if the only the top edge is inset, the"},{"type":"text","text":" "},{"type":"text","text":"map center is effectively shifted downward."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When the map view’s superview is an instance of "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":" whose"},{"type":"text","text":" "},{"type":"codeVoice","code":"automaticallyAdjustsScrollViewInsets"},{"type":"text","text":" property is "},{"type":"codeVoice","code":"YES"},{"type":"text","text":", the value of this"},{"type":"text","text":" "},{"type":"text","text":"property may be overridden at any time."}],"type":"paragraph"},{"inlineContent":[{"text":"The usage of ","type":"text"},{"type":"codeVoice","code":"automaticallyAdjustsScrollViewInsets"},{"text":" has been deprecated","type":"text"},{"text":" ","type":"text"},{"text":"use the map view’s property ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/automaticallyAdjustsContentInset"},{"text":"instead.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Changing the value of this property updates the map view immediately. If you"},{"type":"text","text":" "},{"type":"text","text":"want to animate the change, use the "},{"code":"-setContentInset:animated:completionHandler:","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"method instead."}],"type":"paragraph"}],"kind":"content"}],"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling