{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"assign"},{"kind":"text","text":") "},{"kind":"typeIdentifier","text":"UIEdgeInsets","preciseIdentifier":"c:@S@UIEdgeInsets"},{"text":" ","kind":"text"},{"text":"contentInset","kind":"identifier"},{"text":";","kind":"text"}]}]},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"When the value of this property is equal to "},{"code":"UIEdgeInsetsZero","type":"codeVoice"},{"type":"text","text":", viewport"},{"type":"text","text":" "},{"type":"text","text":"properties such as "},{"code":"centerCoordinate","type":"codeVoice"},{"type":"text","text":" assume a viewport that matches the map"},{"type":"text","text":" "},{"type":"text","text":"view’s frame. Otherwise, those properties are inset, excluding part of the"},{"type":"text","text":" "},{"type":"text","text":"frame from the viewport. For instance, if the only the top edge is inset, the"},{"type":"text","text":" "},{"text":"map center is effectively shifted downward.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"When the map view’s superview is an instance of ","type":"text"},{"type":"codeVoice","code":"UIViewController"},{"text":" whose","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"automaticallyAdjustsScrollViewInsets"},{"text":" property is ","type":"text"},{"type":"codeVoice","code":"YES"},{"text":", the value of this","type":"text"},{"text":" ","type":"text"},{"text":"property may be overridden at any time.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The usage of ","type":"text"},{"code":"automaticallyAdjustsScrollViewInsets","type":"codeVoice"},{"text":" has been deprecated","type":"text"},{"text":" ","type":"text"},{"text":"use the map view’s property ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/automaticallyAdjustsContentInset","type":"reference"},{"text":"instead.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Changing the value of this property updates the map view immediately. If you"},{"type":"text","text":" "},{"type":"text","text":"want to animate the change, use the "},{"code":"-setContentInset:animated:completionHandler:","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"method instead."}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/contentInset"},"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"abstract":[{"type":"text","text":"The distance from the edges of the map view’s frame to the edges of the map"},{"type":"text","text":" "},{"type":"text","text":"view’s logical viewport."}],"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/contentinset"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"symbolKind":"property","roleHeading":"Instance Property","fragments":[{"kind":"identifier","text":"contentInset"}],"role":"symbol","remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L1610","fileName":"MLNMapView.h"},"navigatorTitle":[{"kind":"identifier","text":"contentInset"}],"title":"contentInset","modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNMapView(py)contentInset"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/automaticallyAdjustsContentInset":{"role":"symbol","url":"\/documentation\/maplibre\/mlnmapview\/automaticallyad