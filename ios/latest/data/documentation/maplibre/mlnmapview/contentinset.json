{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/contentInset"},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"assign"},{"kind":"text","text":") "},{"kind":"typeIdentifier","text":"UIEdgeInsets","preciseIdentifier":"c:@S@UIEdgeInsets"},{"kind":"text","text":" "},{"kind":"identifier","text":"contentInset"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"text":"When the value of this property is equal to ","type":"text"},{"type":"codeVoice","code":"UIEdgeInsetsZero"},{"text":", viewport","type":"text"},{"text":" ","type":"text"},{"text":"properties such as ","type":"text"},{"type":"codeVoice","code":"centerCoordinate"},{"text":" assume a viewport that matches the map","type":"text"},{"text":" ","type":"text"},{"text":"view’s frame. Otherwise, those properties are inset, excluding part of the","type":"text"},{"text":" ","type":"text"},{"text":"frame from the viewport. For instance, if the only the top edge is inset, the","type":"text"},{"text":" ","type":"text"},{"text":"map center is effectively shifted downward.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When the map view’s superview is an instance of "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":" whose"},{"type":"text","text":" "},{"type":"codeVoice","code":"automaticallyAdjustsScrollViewInsets"},{"type":"text","text":" property is "},{"type":"codeVoice","code":"YES"},{"type":"text","text":", the value of this"},{"type":"text","text":" "},{"type":"text","text":"property may be overridden at any time."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The usage of "},{"typ