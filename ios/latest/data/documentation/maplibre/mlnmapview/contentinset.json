{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/contentInset"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"assign"},{"kind":"text","text":") "},{"kind":"typeIdentifier","preciseIdentifier":"c:@S@UIEdgeInsets","text":"UIEdgeInsets"},{"kind":"text","text":" "},{"kind":"identifier","text":"contentInset"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"When the value of this property is equal to "},{"code":"UIEdgeInsetsZero","type":"codeVoice"},{"type":"text","text":", viewport"},{"type":"text","text":" "},{"type":"text","text":"properties such as "},{"code":"centerCoordinate","type":"codeVoice"},{"type":"text","text":" assume a viewport that matches the map"},{"type":"text","text":" "},{"type":"text","text":"view’s frame. Otherwise, those properties are inset, excluding part of the"},{"type":"text","text":" "},{"type":"text","text":"frame from the viewport. For instance, if the only the top edge is inset, the"},{"type":"text","text":" "},{"type":"text","text":"map center is effectively shifted downward."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When the map view’s superview is an instance of "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":" whose"},{"type":"text","text":" "},{"type":"codeVoice","code":"automaticallyAdjustsScrollViewInsets"},{"type":"text","text":" property is "},{"type":"codeVoice","code":"YES"},{"type":"text","text":", the value of this"},{"type":"text","text":" "},{"type":"text","text":"property may be overridden at any time."}],"type":"paragraph"},{"inlineContent":[{"text":"The usage of ","type":"text"},{"code":"automaticallyAdjustsScrollViewInsets","type":"codeVoice"},{"text":" has been deprecated","type":"text"},{"text":" ","type":"text"},{"text":"use the map view’s property ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/automaticallyAdjustsContentInset","type":"reference"},{"text":"instead.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Changing the value of this property updates the map view immediately. If you"},{"type":"text","text":" "},{"type":"text","text":"want to animate the change, use the "},{"type":"codeVoice","code":"-setContentInset:animated:completionHandler:"},{"type":"text","text":" "},{"type":"text","text":"method instead."}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"type":"text","text":"The distance from the edges of the map view’s frame to the edges of the map"},{"type":"text","text":" "},{"type":"text","text":"view’s logical viewport."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/contentinset"]}],"metadata":{"title":"contentInset","symbolKind":"property","role":"symbol","externalID":"c:objc(cs)MLNMapView(py)contentInset","remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L1610","fileName":"MLNMapView.h"},"modules":[{"name":"MapLibre"}],"navigatorTitle":[{"kind":"identifier","text":"contentInset"}],"fragments":[{"text":"contentInset","kind":"identifier"}],"roleHeading":"Instance Property"},"kind":"symbol","sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/contentInset":{"url":"\/documentation\/maplibre\/mlnmapview\/contentinset","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/contentInset","type":"topic","abstract":[{"text":"The distance from the edges of the map view’s frame to the edges of the map","type":"text"},{"text":" ","type":"text"},{"text":"view’s logical viewport.","type":"text"}],"role":"symbol","kind":"symbol","title":"contentInset","fragments":[{"text":"contentInset","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"type":"topic","url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"url":"\/documentation\/maplibre\/mlnmapview","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","fragments":[{"kind":"identifier","text":"MLNMapView"}],"role":"symbol","title":"MLNMapView","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/automaticallyAdjustsContentInset":{"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/automaticallyAdjustsContentInset","title":"automaticallyAdjustsContentInset","role":"symbol","fragments":[{"kind":"identifier","text":"automaticallyAdjustsContentInset"}],"url":"\/documentation\/maplibre\/mlnmapview\/automaticallyadjustscontentinset","abstract":[{"type":"text","text":"A boolean value that indicates if whether the map view should automatically"},{"type":"text","text":" "},{"type":"text","text":"adjust its content insets."}],"type":"topic"}}}