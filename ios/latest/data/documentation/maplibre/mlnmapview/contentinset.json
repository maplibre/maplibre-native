{"kind":"symbol","sections":[],"abstract":[{"text":"The distance from the edges of the map view’s frame to the edges of the map","type":"text"},{"text":" ","type":"text"},{"text":"view’s logical viewport.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/contentinset"]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/contentInset","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"metadata":{"externalID":"c:objc(cs)MLNMapView(py)contentInset","roleHeading":"Instance Property","role":"symbol","navigatorTitle":[{"text":"contentInset","kind":"identifier"}],"fragments":[{"text":"contentInset","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"symbolKind":"property","remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L1610","fileName":"MLNMapView.h"},"title":"contentInset"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"assign"},{"kind":"text","text":") "},{"kind":"typeIdentifier","preciseIdentifier":"c:@S@UIEdgeInsets","text":"UIEdgeInsets"},{"kind":"text","text":" "},{"kind":"identifier","text":"contentInset"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"text":"When the value of this property is equal to ","type":"text"},{"code":"UIEdgeInsetsZero","type":"codeVoice"},{"text":", viewport","type":"text"},{"text":" ","type":"text"},{"text":"properties such as ","type":"text"},{"code":"centerCoordinate","type":"codeVoice"},{"text":" assume a viewport that matches the map","type":"text"},{"text":" ","type":"text"},{"text":"view’s frame. Otherwise, those properties are inset, excluding part of the","type":"text"},{"text":" ","type":"text"},{"text":"frame from the viewport. For instance, if the only the top edge is inset, the","type":"text"},{"text":" ","type":"text"},{"text":"map center is effectively shifted downward.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"When the map view’s superview is an instance of ","type":"text"},{"code":"UIViewController","type":"codeVoice"},{"text":" whose","type":"text"},{"text":" ","type":"text"},{"code":"automaticallyAdjustsScrollViewInsets","type":"codeVoice"},{"text":" property is ","type":"text"},{"code":"YES","type":"codeVoice"},{"text":", the value of this","type":"text"},{"text":" ","type":"text"},{"text":"property may be overridden at any time.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The usage of ","type":"text"},{"type":"codeVoice","code":"automaticallyAdjustsScrollViewInsets"},{"text":" has been deprecated","type":"text"},{"text":" ","type":"text"},{"text":"use the map view’s property ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/automaticallyAdjustsContentInset"},{"text":"instead.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Changing the value of this property updates the map view immediately. If you"},{"type":"text","text":" "},{"type":"text","text":"want to animate the change, use the "},{"type":"codeVoice","code":"-setContentInset:animated:completionHandler:"},{"type":"text","text":" "},{"type":"text","text":"method instead."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/automaticallyAdjustsContentInset":{"abstract":[{"type":"text","text":"A boolean value that indicates if whether the map view should auto