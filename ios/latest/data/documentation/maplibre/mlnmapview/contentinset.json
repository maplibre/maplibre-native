xt","text":"property may be overridden at any time."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The usage of "},{"type":"codeVoice","code":"automaticallyAdjustsScrollViewInsets"},{"type":"text","text":" has been deprecated"},{"type":"text","text":" "},{"type":"text","text":"use the map view’s property "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/automaticallyAdjustsContentInset","isActive":true},{"type":"text","text":"instead."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Changing the value of this property updates the map view immediately. If you"},{"type":"text","text":" "},{"type":"text","text":"want to animate the change, use the "},{"type":"codeVoice","code":"-setContentInset:animated:completionHandler:"},{"type":"text","text":" "},{"type":"text","text":"method instead."}]}]}],"kind":"symbol","variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/contentinset"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"externalID":"c:objc(cs)MLNMapView(py)contentInset","roleHeading":"Instance Property","symbolKind":"property","role":"symbol","fragments":[{"text":"contentInset","kind":"identifier"}],"remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L1610"},"title":"contentInset","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"text":"contentInset","kind":"identifier"}]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/contentInset"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/automaticallyAdjustsContentInset":{"fragments":[{"text":"automaticallyAdjustsContentInset","kind":"identifier"}]