{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"assign"},{"kind":"text","text":") "},{"kind":"typeIdentifier","preciseIdentifier":"c:@S@UIEdgeInsets","text":"UIEdgeInsets"},{"kind":"text","text":" "},{"kind":"identifier","text":"contentInset"},{"kind":"text","text":";"}]}]},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the value of this property is equal to "},{"type":"codeVoice","code":"UIEdgeInsetsZero"},{"type":"text","text":", viewport"},{"type":"text","text":" "},{"type":"text","text":"properties such as "},{"type":"codeVoice","code":"centerCoordinate"},{"type":"text","text":" assume a viewport that matches the map"},{"type":"text","text":" "},{"type":"text","text":"view’s frame. Otherwise, those properties are inset, excluding part of the"},{"type":"text","text":" "},{"type":"text","text":"frame from the viewport. For instance, if the only the top edge is inset, the"},{"type":"text","text":" "},{"type":"text","text":"map center is effectively shifted downward."}]},{"inlineContent":[{"type":"text","text":"When the map view’s superview is an instance of "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":" whose"},{"type":"text","text":" "},{"type":"codeVoice","code":"automaticallyAdjustsScrollViewInsets"},{"type":"text","text":" property is "},{"type":"codeVoice","code":"YES"},{"type":"text","text":", the value of this"},{"type":"text","text":" "},{"type":"text","text":"property may be overridden at any time."}],"type":"paragraph"},{"inlineContent":[{"text":"The usage of ","type":"text"},{"code":"automaticallyAdjustsScrollViewInsets","type":"codeVoice"},{"text":" has been deprecated","type":"text"},{"text":" ","type":"text"},{"text":"use the map view’s property ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/automaticallyAdjustsContentInset","isActive":true},{"text":"instead.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Changing the value of this property updates the map view immediately. If you","type":"text"},{"text":" ","type":"text"},{"text":"want to animate the change, use the ","type":"text"},{"code":"-setContentInset:animated:completionHandler:","type":"codeVoice"},{"text":" ","type":"text"},{"text":"method instead.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/contentinset"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"metadata":{"modules":[{"name":"MapLibre"}],"roleHeading":"Instance Property","fragments":[{"text":"contentInset","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"contentInset"}],"title":"contentInset","remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L1610","fileName":"MLNMapView.h"},"symbolKind":"property","role":"symbol","externalID":"c:objc(cs)MLNMapView(py)contentInset"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/contentInset","interfaceLanguage":"occ"},"abstract":[{"type":"text","text":"The distance from the edges of the map view’s frame to the edges of the map"},{"type":"text","text":" "},{"type":"text","text":"view’s logical viewport."}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/contentInset":{"kind":"symbol","title":"contentInset","type":"topic","role":"symbol","url":"\/documentation\/maplibre\/mlnmapview\/conte