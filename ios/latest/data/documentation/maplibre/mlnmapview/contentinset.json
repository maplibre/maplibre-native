{"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"The distance from the edges of the map view’s frame to the edges of the map"},{"type":"text","text":" "},{"type":"text","text":"view’s logical viewport."}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/contentInset","interfaceLanguage":"occ"},"metadata":{"roleHeading":"Instance Property","remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L1610","fileName":"MLNMapView.h"},"modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNMapView(py)contentInset","symbolKind":"property","title":"contentInset","navigatorTitle":[{"kind":"identifier","text":"contentInset"}],"fragments":[{"kind":"identifier","text":"contentInset"}],"role":"symbol"},"sections":[],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/contentinset"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"assign"},{"kind":"text","text":") "},{"kind":"typeIdentifier","preciseIdentifier":"c:@S@UIEdgeInsets","text":"UIEdgeInsets"},{"kind":"text","text":" "},{"kind":"identifier","text":"contentInset"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"When the value of this property is equal to ","type":"text"},{"code":"UIEdgeInsetsZero","type":"codeVoice"},{"text":", viewport","type":"text"},{"text":" ","type":"text"},{"text":"properties such as ","type":"text"},{"code":"centerCoordinate","type":"codeVoice"},{"text":" assume a viewport that matches the map","type":"text"},{"text":" ","type":"text"},{"text":"view’s frame. Otherwise, those properties are inset, excluding part of the","type":"text"},{"text":" ","type":"text"},{"text":"frame from the viewport. For instance, if the only the top edge is inset, the","type":"text"},{"text":" ","type":"text"},{"text":"map center is effectively shifted downward.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"When the map view’s superview is an instance of ","type":"text"},{"type":"codeVoice","code":"UIViewController"},{"text":" whose","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"automaticallyAdjustsScrollViewInsets"},{"text":" property is ","type":"text"},{"type":"codeVoice","code":"YES"},{"text":", the value of this","type":"text"},{"text":" ","type":"text"},{"text":"property may be overridden at any time.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The usage of "},{"type":"codeVoice","code":"automaticallyAdjustsScrollViewInsets"},{"type":"text","text":" has been deprecated"},{"type":"text","text":" "},{"type":"text","text":"use the map view’s property "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/automaticallyAdjustsContentInset"},{"type":"text","text":"instead."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Changing the value of this property updates the map view immediately. If you"},{"type":"text","text":" "},{"type":"text","text":"want to animate the change, use the "},{"code":"-setContentInset:animated:completionHandler:","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"method instead."}]}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/contentInset":{"title":"contentInset","fragments":[{"text":"contentInset","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnmap