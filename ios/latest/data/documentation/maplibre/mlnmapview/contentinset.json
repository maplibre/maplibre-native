{"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"abstract":[{"type":"text","text":"The distance from the edges of the map view’s frame to the edges of the map"},{"type":"text","text":" "},{"type":"text","text":"view’s logical viewport."}],"metadata":{"symbolKind":"property","modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNMapView(py)contentInset","fragments":[{"kind":"identifier","text":"contentInset"}],"remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L1610"},"title":"contentInset","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"contentInset"}],"roleHeading":"Instance Property"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"assign"},{"kind":"text","text":") "},{"kind":"typeIdentifier","text":"UIEdgeInsets","preciseIdentifier":"c:@S@UIEdgeInsets"},{"kind":"text","text":" "},{"kind":"identifier","text":"contentInset"},{"kind":"text","text":";"}]}]},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"When the value of this property is equal to ","type":"text"},{"type":"codeVoice","code":"UIEdgeInsetsZero"},{"text":", viewport","type":"text"},{"text":" ","type":"text"},{"text":"properties such as ","type":"text"},{"type":"codeVoice","code":"centerCoordinate"},{"text":" assume a viewport that matches the map","type":"text"},{"text":" ","type":"text"},{"text":"view’s frame. Otherwise, those properties are inset, excluding part of the","type":"text"},{"text":" ","type":"text"},{"text":"frame from the viewport. For instance, if the only the top edge is inset, the","type":"text"},{"text":" ","type":"text"},{"text":"map center is effectively shifted downward.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"When the map view’s superview is an instance of ","type":"text"},{"code":"UIViewController","type":"codeVoice"},{"text":" whose","type":"text"},{"text":" ","type":"text"},{"code":"automaticallyAdjustsScrollViewInsets","type":"codeVoice"},{"text":" property is ","type":"text"},{"code":"YES","type":"codeVoice"},{"text":", the value of this","type":"text"},{"text":" ","type":"text"},{"text":"property may be overridden at any time.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The usage of "},{"code":"automaticallyAdjustsScrollViewInsets","type":"codeVoice"},{"type":"text","text":" has been deprecated"},{"type":"text","text":" "},{"type":"text","text":"use the map view’s property "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/automaticallyAdjustsContentInset","type":"reference","isActive":true},{"type":"text","text":"instead."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Changing the value of this property updates the map view immediately. If you"},{"type":"text","text":" "},{"type":"text","text":"want to animate the change, use the "},{"type":"codeVoice","code":"-setContentInset:animated:completionHandler:"},{"type":"text","text":" "},{"type":"text","text":"method instead."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/contentinset"]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/contentInset"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"type":"topic","title":"MLNMapView","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"kind":"symbol","role":"symbol","fragments":[{"kind":"identifier","text":"MLNMapView"}],"url":"\/documentation\/maplibre\/mlnmapview","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"},"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/maplibre","title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/contentInset":{"abstract":[{"text":"The distance from the edges of the map view’s frame to the edges of the map","type":"text"},{"text":" ","type":"text"},{"text":"view’s logical viewport.","type":"text"}],"title":"contentInset","type":"topic","kind":"symbol","url":"\/documentation\/maplibre\/mlnmapview\/contentinset","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/contentInset","fragments":[{"kind":"identifier","text":"contentInset"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/automaticallyAdjustsContentInset":{"title":"automaticallyAdjustsContentInset","type":"topic","abstract":[{"type":"text","text":"A boolean value that indicates if whether the map view should automatically"},{"type":"text","text":" "},{"type":"text","text":"adjust its content insets."}],"url":"\/documentation\/maplibre\/mlnmapview\/automaticallyadjustscontentinset","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/automaticallyAdjustsContentInset","role":"symbol","fragments":[{"text":"automaticallyAdjustsContentInset","kind":"identifier"}],"kind":"symbol"}}}