{"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"role":"symbol","fragments":[{"text":"contentInset","kind":"identifier"}],"symbolKind":"property","remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L1610","fileName":"MLNMapView.h"},"title":"contentInset","roleHeading":"Instance Property","externalID":"c:objc(cs)MLNMapView(py)contentInset","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"kind":"identifier","text":"contentInset"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"assign"},{"kind":"text","text":") "},{"preciseIdentifier":"c:@S@UIEdgeInsets","kind":"typeIdentifier","text":"UIEdgeInsets"},{"kind":"text","text":" "},{"kind":"identifier","text":"contentInset"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"When the value of this property is equal to ","type":"text"},{"type":"codeVoice","code":"UIEdgeInsetsZero"},{"text":", viewport","type":"text"},{"text":" ","type":"text"},{"text":"properties such as ","type":"text"},{"type":"codeVoice","code":"centerCoordinate"},{"text":" assume a viewport that matches the map","type":"text"},{"text":" ","type":"text"},{"text":"view’s frame. Otherwise, those properties are inset, excluding part of the","type":"text"},{"text":" ","type":"text"},{"text":"frame from the viewport. For instance, if the only the top edge is inset, the","type":"text"},{"text":" ","type":"text"},{"text":"map center is effectively shifted downward.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When the map view’s superview is an instance of "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","