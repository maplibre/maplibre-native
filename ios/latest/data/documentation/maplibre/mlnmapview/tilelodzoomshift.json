"},{"type":"text","text":" "},{"type":"text","text":"average It is recommended to first configure the pixelRatio before adjusting TileLodZoomShift."}],"type":"paragraph"}]}],"metadata":{"navigatorTitle":[{"kind":"identifier","text":"tileLodZoomShift"}],"modules":[{"name":"MapLibre"}],"title":"tileLodZoomShift","roleHeading":"Instance Property","externalID":"c:objc(cs)MLNMapView(py)tileLodZoomShift","role":"symbol","fragments":[{"kind":"identifier","text":"tileLodZoomShift"}],"symbolKind":"property","remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L533","fileName":"MLNMapView.h"}},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/tileLodZoomShift":{"abstract":[{"text":"Camera based tile level of detail controls","type":"text"}],"url":"\/documentation\/maplibre\/mlnmapview\/tilelodzoomshift","title":"tileLodZoomShift","role":"symbol","kind":"symbol","fragments":[{"kind":"identifier","text":"tileLodZoomShift"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/tileLodZoomShift"},"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"title":"MapLibre","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"fragments":[{"text":"MLNMapView","kind":"identifier"}],"abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"kind":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","url":"\/documentation\/maplibre\/mlnmapview","title":"MLNMapView","role":"symbol"}}}