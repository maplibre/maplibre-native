{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/tileLodZoomShift"},"metadata":{"symbolKind":"property","modules":[{"name":"MapLibre"}],"remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L533","fileName":"MLNMapView.h"},"roleHeading":"Instance Property","externalID":"c:objc(cs)MLNMapView(py)tileLodZoomShift","navigatorTitle":[{"text":"tileLodZoomShift","kind":"identifier"}],"role":"symbol","title":"tileLodZoomShift","fragments":[{"text":"tileLodZoomShift","kind":"identifier"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","abstract":[{"text":"Camera based tile level of detail controls","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/tilelodzoomshift"]}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"assign","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:d","text":"double","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"tileLodZoomShift","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Shift applied to the Zoom level during LOD calculation"},{"type":"text","text":" "},{"type":"text","text":"A negative value shifts the Zoom level to a coarser level reducing quality but improving"},{"type":"text","text":" "},{"type":"text","text":"performance A positive value shifts the Zoom level to a finer level increasing details but"},{"type":"text","text":" "},{"type":"text","text":"negatively affecting performance A value of zero (default) does not apply any shift to the Zoom"},{"type":"text","text":" "},{"type":"text","text":"level It is not recommended to change the default value unless performance is critical and the loss"},{"type":"text","text":" "},{"type":"text","text":"of quality is acceptable. A value of -1 reduces the number of displayed tiles by a factor of 4 on"},{"type":"text","text":" "},{"type":"text","text":"average It is recommended to first configure the pixelRatio before adjusting TileLodZoomShift."}]}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","type":"topic","title":"MapLibre","url":"\/documentation\/maplibre","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"kind":"symbol","type":"topic","role":"symbol","url":"\/documentation\/maplibre\/mlnmapview","title":"MLNMapView","fragments":[{"text":"MLNMapView","kind":"identifier"}],"abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/tileLodZoomShift":{"fragments":[{"kind":"identifier","text":"tileLodZoomShift"}],"role":"symbol","abstract":[{"type":"text","text":"Camera based tile level of detail controls"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/tileLodZoomShift","title":"tileLodZoomShift","type":"topic","url":"\/documentation\/maplibre\/mlnmapview\/tilelodzoomshift","kind":"symbol"}}}