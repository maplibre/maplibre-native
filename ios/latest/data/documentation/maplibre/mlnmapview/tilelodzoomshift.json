{"abstract":[{"type":"text","text":"Camera based tile level of detail controls"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"assign","kind":"keyword"},{"text":") ","kind":"text"},{"text":"double","kind":"typeIdentifier","preciseIdentifier":"c:d"},{"text":" ","kind":"text"},{"text":"tileLodZoomShift","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"Shift applied to the Zoom level during LOD calculation","type":"text"},{"text":" ","type":"text"},{"text":"A negative value shifts the Zoom level to a coarser level reducing quality but improving","type":"text"},{"text":" ","type":"text"},{"text":"performance A positive value shifts the Zoom level to a finer level increasing details but","type":"text"},{"text":" ","type":"text"},{"text":"negatively affecting performance A value of zero (default) does not apply any shift to the Zoom","type":"text"},{"text":" ","type":"text"},{"text":"level It is not recommended to change the default value unless performance is critical and the loss","type":"text"},{"text":" ","type":"text"},{"text":"of quality is acceptable. A value of -1 reduces the number of displayed tiles by a factor of 4 on","type":"text"},{"text":" ","type":"text"},{"text":"average It is recommended to first configure the pixelRatio before adjusting TileLodZoomShift.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"kind":"symbol","metadata":{"symbolKind":"property","fragments":[{"kind":"identifier","text":"tileLodZoomShift"}],"role":"symbol","navigatorTitle":[{"text":"tileLodZoomShift","kind":