{"abstract":[{"type":"text","text":"Camera based tile level of detail controls"}],"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/tilelodzoomshift"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/tileLodZoomShift","interfaceLanguage":"occ"},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"metadata":{"navigatorTitle":[{"text":"tileLodZoomShift","kind":"identifier"}],"externalID":"c:objc(cs)MLNMapView(py)tileLodZoomShift","symbolKind":"property","fragments":[{"text":"tileLodZoomShift","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"title":"tileLodZoomShift","roleHeading":"Instance Property","remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L533","fileName":"MLNMapView.h"},"role":"symbol"},"sections":[],"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"assign","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:d","text":"double","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"tileLodZoomShift","kind":"identifier"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Shift applied to the Zoom level during LOD calculation"},{"type":"text","text":" "},{"type":"text","text":"A negative value shifts the Zoom level to a coarser level reducing quality but improving"},{"type":"text","text":" "},{"type":"text","text":"performance A positive value shifts the Zoom level to a finer level increasing details but"},{"type":"text","text":" "},{"type":"text","text":"negatively affecting performance A value of zero (default) does not apply any shift to the Zoom"},{"type":"text","text":" "},{"type":"text","text":"level It is not recommended to change the default value unless performance is critical and the loss"},{"type":"text","text":" "},{"type":"text","text":"of quality is acceptable. A value of -1 reduces the number of displayed tiles by a factor of 4 on"},{"type":"text","text":" "},{"type":"text","text":"average It is recommended to first configure the pixelRatio before adjusting TileLodZoomShift."}]}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","url":"\/documentation\/maplibre","kind":"symbol","title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","abstract":[{"text":"An interactive, customizable map view with an interface similar to the one","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"provided by Apple’s MapKit."}],"url":"\/documentation\/maplibre\/mlnmapview","fragments":[{"kind":"identifier","text":"MLNMapView"}],"role":"symbol","title":"MLNMapView","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/tileLodZoomShift":{"title":"tileLodZoomShift","fragments":[{"kind":"identifier","text":"tileLodZoomShift"}],"url":"\/documentation\/maplibre\/mlnmapview\/tilelodzoomshift","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/tileLodZoomShift","kind":"symbol","abstract":[{"text":"Camera based tile level of detail controls","type":"text"}],"role":"symbol","type":"topic"}}}