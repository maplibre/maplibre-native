{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/tileLodZoomShift","interfaceLanguage":"occ"},"abstract":[{"type":"text","text":"Camera based tile level of detail controls"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"assign","kind":"keyword"},{"text":") ","kind":"text"},{"text":"double","kind":"typeIdentifier","preciseIdentifier":"c:d"},{"text":" ","kind":"text"},{"text":"tileLodZoomShift","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Shift applied to the Zoom level during LOD calculation","type":"text"},{"text":" ","type":"text"},{"text":"A negative value shifts the Zoom level to a coarser level reducing quality but improving","type":"text"},{"text":" ","type":"text"},{"text":"performance A positive value shifts the Zoom level to a finer level increasing details but","type":"text"},{"text":" ","type":"text"},{"text":"negatively affecting performance A value of zero (default) does not apply any shift to the Zoom","type":"text"},{"text":" ","type":"text"},{"text":"level It is not recommended to change the default value unless performance is critical and the loss","type":"text"},{"text":" ","type":"text"},{"text":"of quality is acceptable. A value of -1 reduces the number of displayed tiles by a factor of 4 on","type":"text"},{"text":" ","type":"text"},{"text":"average It is recommended to first configure the pixelRatio before adjusting TileLodZoomShift.","type":"text"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/tilelodzoomshift"]}],"sections":[],"metadata":{"navigatorTitle":[{"text":"tileLodZoomShift","kind":"identifier"}],"title":"tileLodZoomShift","fragments":[{"text":"tileLodZoomShift","kind":"identifier"}],"symbolKind":"property","role":"symbol","remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L533","fileName":"MLNMapView.h"},"roleHeading":"Instance Property","externalID":"c:objc(cs)MLNMapView(py)tileLodZoomShift","modules":[{"name":"MapLibre"}]},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","title":"MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"type":"topic","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/tileLodZoomShift":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/tileLodZoomShift","role":"symbol","title":"tileLodZoomShift","abstract":[{"text":"Camera based tile level of detail controls","type":"text"}],"kind":"symbol","fragments":[{"kind":"identifier","text":"tileLodZoomShift"}],"url":"\/documentation\/maplibre\/mlnmapview\/tilelodzoomshift","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"url":"\/documentation\/maplibre\/mlnmapview","title":"MLNMapView","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"type":"text","text":"provided by Apple’s MapKit."}],"type":"topic","fragments":[{"kind":"identifier","text":"MLNMapView"}],"role":"symbol"}}}