 "},{"type":"text","text":"of quality is acceptable. A value of -1 reduces the number of displayed tiles by a factor of 4 on"},{"type":"text","text":" "},{"type":"text","text":"average It is recommended to first configure the pixelRatio before adjusting TileLodZoomShift."}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/tileLodZoomShift"},"abstract":[{"text":"Camera based tile level of detail controls","type":"text"}],"variants":[{"paths":["\/documentation\/maplibre\/mlnmapview\/tilelodzoomshift"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","url":"\/documentation\/maplibre\/mlnmapview","type":"topic","abstract":[{"text":"An interactive, customizable map view with an interface similar to the one","type":"text"},{"text":" ","type":"text"},{"text":"provided by Apple’s MapKit.","type":"text"}],"role":"symbol","kind":"symbol","fragments":[{"text":"MLNMapView","kind":"identifier"}],"title":"MLNMapView"},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","url":"\/documentation\/maplibre","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/tileLodZoomShift":{"abstract":[{"type":"text","text":"Camera based tile level of detail controls"}],"title":"tileLodZoomShift","role":"symbol","fragments":[{"kind":"identifier","text":"tileLodZoomShift"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/tileLodZoomShift","kind":"symbol","url":"\/documentation\/maplibre\/mlnmapview\/tilelodzoomshift","type":"topic"}}}