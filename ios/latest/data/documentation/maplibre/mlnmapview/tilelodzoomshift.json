{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/tileLodZoomShift"},"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/tilelodzoomshift"]}],"metadata":{"fragments":[{"text":"tileLodZoomShift","kind":"identifier"}],"navigatorTitle":[{"text":"tileLodZoomShift","kind":"identifier"}],"title":"tileLodZoomShift","symbolKind":"property","role":"symbol","remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L533"},"modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNMapView(py)tileLodZoomShift","roleHeading":"Instance Property"},"abstract":[{"type":"text","text":"Camera based tile level of detail controls"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"assign","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:d","text":"double","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"tileLodZoomShift","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Shift applied to the Zoom level during LOD calculation"},{"type":"text","text":" "},{"type":"text","text":"A negative value shifts the Zoom level to a coarser level reducing quality but improving"},{"type":"text","text":" "},{"type":"text","text":"performance A positive value shifts the Zoom level to a finer level increasing details but"},{"type":"text","text":" "},{"type":"text","text":"negatively affecting performance A value of zero (default) does not apply any shift to the Zoom"},{"type":"text","text":" "},{"type":"text","text":"level It is not recommended to change the default value unless performance is critical and the loss"},{"type":"text","text":" "},{"type":"text","text":"of quality is acceptable. A value of -1 reduces the number of displayed tiles by a factor of 4 on"},{"type":"text","text":" "},{"type":"text","text":"average It is recommended to first configure the pixelRatio before adjusting TileLodZoomShift."}]}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","title":"MapLibre","kind":"symbol","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/tileLodZoomShift":{"type":"topic","abstract":[{"text":"Camera based tile level of detail controls","type":"text"}],"url":"\/documentation\/maplibre\/mlnmapview\/tilelodzoomshift","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/tileLodZoomShift","title":"tileLodZoomShift","role":"symbol","fragments":[{"text":"tileLodZoomShift","kind":"identifier"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"type":"topic","fragments":[{"text":"MLNMapView","kind":"identifier"}],"role":"symbol","url":"\/documentation\/maplibre\/mlnmapview","kind":"symbol","abstract":[{"text":"An interactive, customizable map view with an interface similar to the one","type":"text"},{"text":" ","type":"text"},{"text":"provided by Apple’s MapKit.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","title":"MLNMapView"}}}