{"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"assign"},{"kind":"text","text":") "},{"kind":"typeIdentifier","text":"double","preciseIdentifier":"c:d"},{"kind":"text","text":" "},{"kind":"identifier","text":"tileLodZoomShift"},{"kind":"text","text":";"}],"platforms":["iOS"]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Shift applied to the Zoom level during LOD calculation"},{"type":"text","text":" "},{"type":"text","text":"A negative value shifts the Zoom level to a coarser level reducing quality but improving"},{"type":"text","text":" "},{"type":"text","text":"performance A positive value shifts the Zoom level to a finer level increasing details but"},{"type":"text","text":" "},{"type":"text","text":"negatively affecting performance A value of zero (default) does not apply any shift to the Zoom"},{"type":"text","text":" "},{"type":"text","text":"level It is not recommended to change the default value unless performance is critical and the loss"},{"type":"text","text":" "},{"type":"text","text":"of quality is acceptable. A value of -1 reduces the number of displayed tiles by a factor of 4 on"},{"type":"text","text":" "},{"type":"text","text":"average It is recommended to first configure the pixelRatio before adjusting TileLodZoomShift."}]}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/tileLodZoomShift"},"kind":"symbol","abstract":[{"type":"text","text":"Camera based tile level of detail controls"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapview\/tilelodzoomshift"]}