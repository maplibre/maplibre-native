{"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"assign","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:d","text":"double","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"tileLodZoomShift","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Shift applied to the Zoom level during LOD calculation","type":"text"},{"text":" ","type":"text"},{"text":"A negative value shifts the Zoom level to a coarser level reducing quality but improving","type":"text"},{"text":" ","type":"text"},{"text":"performance A positive value shifts the Zoom level to a finer level increasing details but","type":"text"},{"text":" ","type":"text"},{"text":"negatively affecting performance A value of zero (default) does not apply any shift to the Zoom","type":"text"},{"text":" ","type":"text"},{"text":"level It is not recommended to change the default value unless performance is critical and the loss","type":"text"},{"text":" ","type":"text"},{"text":"of quality is acceptable. A value of -1 reduces the number of displayed tiles by a factor of 4 on","type":"text"},{"text":" ","type":"text"},{"text":"average It is recommended to first configure the pixelRatio before adjusting TileLodZoomShift.","type":"text"}]}],"kind":"content"}],"abstract":[{"type":"text","text":"Camera based tile level of detail controls"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/tileLodZoomShift","interfaceLangu