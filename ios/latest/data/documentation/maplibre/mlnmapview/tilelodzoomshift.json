{"sections":[],"abstract":[{"text":"Camera based tile level of detail controls","type":"text"}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"assign","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:d","text":"double","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"tileLodZoomShift","kind":"identifier"},{"text":";","kind":"text"}]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Shift applied to the Zoom level during LOD calculation","type":"text"},{"text":" ","type":"text"},{"text":"A negative value shifts the Zoom level to a coarser level reducing quality but improving","type":"text"},{"text":" ","type":"text"},{"text":"performance A positive value shifts the Zoom level to a finer level increasing details but","type":"text"},{"text":" ","type":"text"},{"text":"negatively affecting performance A value of zero (default) does not apply any shift to the Zoom","type":"text"},{"text":" ","type":"text"},{"text":"level It is not recommended to change the default value unless performance is critical and the loss","type":"text"},{"text":" ","type":"text"},{"text":"of quality is acceptable. A value of -1 reduces the number of displayed tiles by a factor of 4 on","type":"text"},{"text":" ","type":"text"},{"text":"average It is recommended to first configure the pixelRatio before adjusting TileLodZoomShift.","type":"text"}]}]}],"metadata":{"externalID":"c:objc(cs)MLNMapView(py)tileLodZoomShift","title":"tileLodZoomShift","role":"symbol","symbolKind":"property","modules":[{"name":"MapLibre"}],"fragments":[{"kind":"identifier","text":"tileLodZoomShift"}],"roleHeading":"Instance Property","navigatorTitle":[{"text":"tileLodZoo