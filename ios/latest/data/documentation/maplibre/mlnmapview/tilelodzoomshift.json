","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"negatively affecting performance A value of zero (default) does not apply any shift to the Zoom"},{"text":" ","type":"text"},{"text":"level It is not recommended to change the default value unless performance is critical and the loss","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of quality is acceptable. A value of -1 reduces the number of displayed tiles by a factor of 4 on"},{"type":"text","text":" "},{"type":"text","text":"average It is recommended to first configure the pixelRatio before adjusting TileLodZoomShift."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","abstract":[{"type":"text","text":"An interactive, customizable map view with an interface similar to the one"},{"type":"text","text":" "},{"text":"provided by Apple’s MapKit.","type":"text"}],"kind":"symbol","type":"topic","role":"symbol","title":"MLNMapView","fragments":[{"kind":"identifier","text":"MLNMapView"}],"url":"\/documentation\/maplibre\/mlnmapview"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/tileLodZoomShift":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/tileLodZoomShift","role":"symbol","url":"\/documentation\/maplibre\/mlnmapview\/tilelodzoomshift","title":"tileLodZoomShift","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Camera based tile level of detail controls"}],"fragments":[{"kind":"identifier","text":"tileLodZoomShift"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"type":"topic","kind":"symbol","role":"collection","title":"MapLibre","url":"\/documentation\/maplibre"}}}