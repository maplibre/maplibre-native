om","type":"text"},{"type":"text","text":" "},{"text":"level It is not recommended to change the default value unless performance is critical and the loss","type":"text"},{"type":"text","text":" "},{"text":"of quality is acceptable. A value of -1 reduces the number of displayed tiles by a factor of 4 on","type":"text"},{"type":"text","text":" "},{"text":"average It is recommended to first configure the pixelRatio before adjusting TileLodZoomShift.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"sections":[],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/tileLodZoomShift"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/tileLodZoomShift":{"abstract":[{"type":"text","text":"Camera based tile level of detail controls"}],"url":"\/documentation\/maplibre\/mlnmapview\/tilelodzoomshift","fragments":[{"kind":"identifier","text":"tileLodZoomShift"}],"kind":"symbol","title":"tileLodZoomShift","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/tileLodZoomShift","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView":{"role":"symbol","title":"MLNMapView","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","abstract":[{"text":"An interactive, customizable map view with an interface similar to the one","type":"text"},{"text":" ","type":"text"},{"text":"provided by Apple’s MapKit.","type":"text"}],"url":"\/documentation\/maplibre\/mlnmapview","fragments":[{"text":"MLNMapView","kind":"identifier"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","title":"MapLibre","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"url":"\/documentation\/maplibre","type":"topic"}}}