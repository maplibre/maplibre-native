{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/setContentInset:animated:"},"abstract":[{"text":"Deprecated. Sets the distance from the edges of the map view’s frame to the edges","type":"text"},{"text":" ","type":"text"},{"text":"of the map view’s logical viewport with an optional transition animation.","type":"text"}],"metadata":{"modules":[{"name":"MapLibre"}],"remoteSource":{"fileName":"MLNMapView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNMapView.h#L1650"},"externalID":"c:objc(cs)MLNMapView(im)setContentInset:animated:","navigatorTitle":[{"text":"- ","kind":"text"},{"text":"setContentInset:animated:","kind":"identifier"}],"fragments":[{"text":"- ","kind":"text"},{"text":"setContentInset:animated:","kind":"identifier"}],"roleHeading":"Instance Method","title":"setContentInset:animated:","symbolKind":"method","role":"symbol","platforms":[]},"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"]]},"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"],"tokens":[{"kind":"text","text":"- ("},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"setContentInset:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:@S@UIEdgeInsets","kind":"typeIdentifier","text":"UIEdgeInsets"},{"kind":"text","text":") "},{"kind":"internalParam","text":"contentInset"},{"kind":"text","text":" "},{"kind":"identifier","text":"animated:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:@T@BOOL","kind":"typeIdentifier","text":"BOOL"},{"kind":"text","text":") "},{"kind":"internalParam","text":"animated"},{"kind":"text","text":";"}]}]},{"kind":"parameters","parameter