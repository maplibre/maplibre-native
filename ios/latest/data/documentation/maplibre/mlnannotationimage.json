otation view is created","type":"text"},{"text":" ","type":"text"},{"text":"with a reuse identifier, the map view may recycle the view when it goes","type":"text"},{"text":" ","type":"text"},{"text":"offscreen.","type":"text"}],"title":"MLNAnnotationView"},"doc://org.swift.MyProject/documentation/MapLibre/MLNPointFeature":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointFeature","role":"symbol","fragments":[{"kind":"identifier","text":"MLNPointFeature"}],"abstract":[{"text":"An ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointFeature"},{"text":" object associates a point shape with an optional","type":"text"},{"text":" ","type":"text"},{"text":"identifier and attributes.","type":"text"}],"kind":"symbol","type":"topic","title":"MLNPointFeature","url":"\/documentation\/maplibre\/mlnpointfeature"},"doc://org.swift.MyProject/objc(pl)NSSecureCoding":{"title":"NSSecureCoding","type":"unresolvable","identifier":"doc:\/\/org.swift.MyProject\/objc(pl)NSSecureCoding"},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotationImage/image":{"title":"image","abstract":[{"text":"The image to be displayed for the annotation.","type":"text"}],"kind":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnannotationimage\/image","fragments":[{"text":"image","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage\/image"}}}