nd":"text","text":"- "},{"kind":"identifier","text":"mapView:strokeColorForShapeAnnotation:"}],"type":"topic","abstract":[{"type":"text","text":"Returns the color to use when rendering the outline of a shape annotation."}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnmapviewdelegate\/mapview:strokecolorforshapeannotation:","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol","url":"\/documentation\/maplibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeCollection":{"type":"topic","kind":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeCollection"}],"url":"\/documentation\/maplibre\/mlnshapecollection","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollection","title":"MLNShapeCollection","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollection","type":"reference","isActive":true},{"type":"text","text":" object represents a shape consisting of zero or more"},{"type":"text","text":" "},{"type":"text","text":"distinct but related shapes that are instances of "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":". The constituent"},{"type":"text","text":" "},{"type":"text","text":"shapes can be a mixture of different kinds of shapes."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"fragments":[{"kind":"identifier","text":"MLNShapeSource"}],"kind":"symbol","type":"topic","role":"symbol","title":"MLNShapeSource","url":"\/documentation\/maplibre\/mlnshapesource","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/org.s