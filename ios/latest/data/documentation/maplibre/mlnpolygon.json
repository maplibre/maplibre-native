{"seeAlsoSections":[{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNEmptyFeature","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygonFeature","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolyline","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolylineFeature","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolylineFeature","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollectionFeature","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolyline","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolylineFeature","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollection","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollectionFeature"],"anchor":"Shapes","generated":true,"title":"Shapes"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","variants":[{"paths":["\/documentation\/maplibre\/mlnpolygon"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"tokens":[{"text":"@interface","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MLNPolygon","kind":"identifier"},{"text":" : ","kind":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint","preciseIdentifier":"c:objc(cs)MLNMultiPoint","text":"MLNMultiPoint","kind":"typeIdentifier"}],"languages":["occ"]}],"kind":"declarations"},{"mentions":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/GeoJSON","doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/Predicates_and_Expressions"],"kind":"mentions"},{"content":[{"type":"heading","anchor":"overview","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can add polygon shapes to the map by adding them to an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"object. Configure the appearance of an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true,"type":"reference"},{"type":"text","text":"’s or"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","isActive":true,"type":"reference"},{"type":"text","text":"’s polygons collectively using an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","isActive":true,"type":"reference"},{"type":"text","text":" or"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer","isActive":true,"type":"reference"},{"type":"text","text":" object. To access a polygon’s attributes, use an"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygonFeature","isActive":true,"type":"reference"},{"type":"text","text":" object."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Alternatively, you can add a polygon overlay directly to a map view using the"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/addAnnotation:","isActive":true,"type":"reference"},{"type":"text","text":" or "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/addOverlay:","isActive":true,"type":"reference"},{"type":"text","text":" method. Configure"},{"type":"text","text":" "},{"type":"text","text":"a polygon overlay’s appearance using"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:strokeColorForShapeAnnotation:","isActive":true,"type":"reference"},{"type":"text","text":" and"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:fillColorForPolygonAnnotation:","isActive":true,"type":"reference"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The vertices are automatically connected in the order in which you provide"},{"type":"text","text":" "},{"type":"text","text":"them. You should close the polygon by specifying the same"},{"type":"text","text":" "},{"type":"codeVoice","code":"CLLocationCoordinate2D"},{"type":"text","text":" as the first and last vertices; otherwise, the"},{"type":"text","text":" "},{"type":"text","text":"polygon’s fill may not cover the area you expect it to. To avoid filling the"},{"text":" ","type":"text"},{"type":"text","text":"space within the shape, give the polygon a transparent fill or use an"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolyline","isActive":true,"type":"reference"},{"type":"text","text":" object."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A polygon may have one or more interior polygons, or holes, that you specify as"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon","isActive":true,"type":"reference"},{"type":"text","text":" objects with the "},{"type":"codeVoice","code":"+polygonWithCoordinates:count:interiorPolygons:"},{"type":"text","text":" "},{"type":"text","text":"method. For example, if a polygon represents a lake, it could exclude an island"},{"type":"text","text":" "},{"type":"text","text":"within the lake using an interior polygon. Interior polygons may not themselves"},{"type":"text","text":" "},{"type":"text","text":"have interior polygons. To represent a shape that includes a polygon within a"},{"type":"text","text":" "},{"type":"text","text":"hole or, more generally, to group multiple polygons together in one shape, use"},{"type":"text","text":" "},{"type":"text","text":"an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon","isActive":true,"type":"reference"},{"type":"text","text":" or "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon","isActive":true,"type":"reference"},{"type":"text","text":" object."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To make the polygon straddle the antimeridian, specify some longitudes less"},{"type":"text","text":" "},{"type":"text","text":"than −180 degrees or greater than 180 degrees."}]},{"type":"heading","level":4,"text":"Related examples","anchor":"Related-examples"},{"type":"paragraph","inlineContent":[{"type":"text","text":"TODO: Add a polygon annotation, learn how to initialize an"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon"},{"type":"text","text":" object from an array of coordinates."}]}],"kind":"content"}],"topicSections":[{"generated":true,"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon\/interiorPolygons"]},{"generated":true,"title":"Type Methods","anchor":"Type-Methods","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon\/polygonWithCoordinates:count:","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon\/polygonWithCoordinates:count:interiorPolygons:"]}],"relationshipsSections":[{"title":"Inherits From","type":"inheritsFrom","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint"],"kind":"relationships"},{"title":"Inherited By","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygonFeature"],"type":"inheritedBy","kind":"relationships"},{"title":"Conforms To","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay"],"type":"conformsTo","kind":"relationships"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"sections":[],"metadata":{"navigatorTitle":[{"text":"MLNPolygon","kind":"identifier"}],"roleHeading":"Class","externalID":"c:objc(cs)MLNPolygon","symbolKind":"class","role":"symbol","modules":[{"name":"MapLibre"}],"title":"MLNPolygon","fragments":[{"text":"MLNPolygon","kind":"identifier"}]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon"},"abstract":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon"},{"text":" object represents a closed shape consisting of four or more","type":"text"},{"type":"text","text":" "},{"type":"text","text":"vertices, specified as "},{"type":"codeVoice","code":"CLLocationCoordinate2D"},{"text":" instances, and the edges that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"connect them. For example, you could use a polygon shape to represent a"},{"type":"text","text":" "},{"type":"text","text":"building, a lake, or an area you want to highlight."}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate/mapView:fillColorForPolygonAnnotation:":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:fillColorForPolygonAnnotation:","kind":"symbol","title":"mapView:fillColorForPolygonAnnotation:","url":"\/documentation\/maplibre\/mlnmapviewdelegate\/mapview:fillcolorforpolygonannotation:","fragments":[{"text":"- ","kind":"text"},{"text":"mapView:fillColorForPolygonAnnotation:","kind":"identifier"}],"type":"topic","abstract":[{"type":"text","text":"Returns the color to use when rendering the fill of a pol