ectionFeature","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolyline","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolylineFeature","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollection","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollectionFeature"],"anchor":"Shapes","generated":true}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"@interface"},{"kind":"text","text":" "},{"kind":"identifier","text":"MLNPolygon"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)MLNMultiPoint","text":"MLNMultiPoint","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint"}],"languages":["occ"]}]},{"kind":"content","content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"inlineContent":[{"text":"You can add polygon shapes to the map by adding them to an ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true},{"text":" ","type":"text"},{"text":"object. Configure the appearance of an ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true},{"text":"’s or","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","isActive":true},{"text":"’s polygons collectively using an ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","isActive":true},{"text":" or","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer","isActive":true},{"text":" object. To access a polygon’s attributes, use an","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygonFeature","isActive":true},{"text":" object.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Alternatively, you can add a polygon overlay directly to a map view using the"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/addAnnotation:","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/addOverlay:","isActive":true},{"type":"text","text":" method. Configure"},{"type":"text","text":" "},{"type":"text","text":"a polygon overlay’s appearance using"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:strokeColorForShapeAnnotation:","isActive":true},{"type":"text","text":" and"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:fillColorForPolygonAnnotation:","type":"reference","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The vertices are automatically connected in the order in which you provide"},{"type":"text","text":" "},{"type":"text","text":"them. You should close the polygon by specifying the same"},{"type":"text","text":" "},{"code":"CLLocationCoordinate2D","type":"codeVoice"},{"type":"text","text":" as the first and last vertices; otherwise, the"},{"type":"text","text":" "},{"type":"text","text":"polygon’s fill may not cover the area you expect it to. To avoid filling the"},{"type":"text","text":" "},{"type":"text","text":"space within the shape, give the polygon a transparent fill or use an"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolyline","isActive":true},{"type":"text","text":" object."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A polygon may have one or more interior polygons, or holes, that you specify as"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon","isActive":true,"type":"reference"},{"type":"text","text":" objects with the "},{"type":"codeVoice","code":"+polygonWithCoordinates:count:interiorPolygons:"},{"type":"text","text":" "},{"type":"text","text":"method. For example, if a polygon represents a lake, it could exclude an island"},{"type":"text","text":" "},{"type":"text","text":"within the lake using an interior polygon. Interior polygons may not themselves"},{"type":"text","text":" "},{"type":"text","text":"have interior polygons. To represent a shape that includes a polygon within a"},{"type":"text","text":" "},{"type":"text","text":"hole or, more generally, to group multiple polygons together in one shape, use"},{"type":"text","text":" "},{"type":"text","text":"an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon","isActive":true,"type":"reference"},{"type":"text","text":" or "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon","isActive":true,"type":"reference"},{"type":"text","text":" object."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To make the polygon straddle the antimeridian, specify some longitudes less"},{"type":"text","text":" "},{"type":"text","text":"than −180 degrees or greater than 180 degrees."}],"type":"paragraph"},{"level":4,"anchor":"Related-examples","type":"heading","text":"Related examples"},{"inlineContent":[{"type":"text","text":"TODO: Add a polygon annotation, learn how to initialize an"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon"},{"type":"text","text":" object from an array of coordinates."}],"type":"paragraph"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"metadata":{"role":"symbol","title":"MLNPolygon","symbolKind":"class","externalID":"c:objc(cs)MLNPolygon","roleHeading":"Class","modules":[{"name":"MapLibre"}],"fragments":[{"kind":"identifier","text":"MLNPolygon"}],"navigatorTitle":[{"kind":"identifier","text":"MLNPolygon"}]},"sections":[],"abstract":[{"text":"An ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon"},{"text":" object represents a closed shape consisting of four or more","type":"text"},{"text":" ","type":"text"},{"text":"vertices, specified as ","type":"text"},{"code":"CLLocationCoordinate2D","type":"codeVoice"},{"text":" instances, and the edges that","type":"text"},{"text":" ","type":"text"},{"text":"connect them. For example, you could use a polygon shape to represent a","type":"text"},{"text":" ","type":"text"},{"text":"building, a lake, or an area you want to highlight.","type":"text"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNPolygonFeature":{"kind":"symbol","url":"\/documentation\/maplibre\/mlnpolygonfeature","role":"symbol","fragments":[{"kind":"identifier","text":"MLNPolygonFeature"}],"abstract":[{"text":"An ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygonFeature","type":"reference"},{"text":" object associates a polygon shape with an optional","type":"text"},{"text":" ","type":"text"},{"text":"identifier and attributes.","type":"text"}],"title":"MLNPolygonFeature","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygonFeature"},"doc://org.swift.MyProject/documentation/MapLibre/MLNPolygon":{"kind":"symbol","url":"\/documentation\/maplibre\/mlnpolygon","abstract":[{"type":"text","text":"An "},{"type":"refe