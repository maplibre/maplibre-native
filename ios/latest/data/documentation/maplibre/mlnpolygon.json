{"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon\/interiorPolygons"],"title":"Instance Properties","generated":true,"anchor":"Instance-Properties"},{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon\/polygonWithCoordinates:count:","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon\/polygonWithCoordinates:count:interiorPolygons:"],"title":"Type Methods","generated":true,"anchor":"Type-Methods"}],"seeAlsoSections":[{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNEmptyFeature","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygonFeature","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolyline","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolylineFeature","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolylineFeature","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollectionFeature","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolyline","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolylineFeature","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollection","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollectionFeature"],"title":"Shapes","generated":true,"anchor":"Shapes"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"@interface"},{"kind":"text","text":" "},{"kind":"identifier","text":"MLNPolygon"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)MLNMultiPoint","text":"MLNMul