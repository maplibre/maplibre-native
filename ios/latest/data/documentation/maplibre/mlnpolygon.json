e\/mlnpointcollectionfeature","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollectionFeature","fragments":[{"kind":"identifier","text":"MLNPointCollectionFeature"}],"kind":"symbol","title":"MLNPointCollectionFeature","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPolylineFeature":{"url":"\/documentation\/maplibre\/mlnmultipolylinefeature","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolylineFeature","type":"reference","isActive":true},{"type":"text","text":" object associates a multipolyline shape with an"},{"type":"text","text":" "},{"type":"text","text":"optional identifier and attributes."}],"type":"topic","fragments":[{"kind":"identifier","text":"MLNMultiPolylineFeature"}],"kind":"symbol","title":"MLNMultiPolylineFeature","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolylineFeature"},"doc://org.swift.MyProject/documentation/MapLibre/MLNEmptyFeature":{"url":"\/documentation\/maplibre\/mlnemptyfeature","role":"symbol","title":"MLNEmptyFeature","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNEmptyFeature","type":"reference","isActive":true},{"type":"text","text":" object associates an empty shape with an optional"},{"type":"text","text":" "},{"type":"text","text":"identifier and attributes."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNEmptyFeature","type":"topic","fragments":[{"kind":"identifier","text":"MLNEmptyFeature"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorTileSource":{"title":"MLNVectorTileSource","url":"\/documentation\/maplibre\/mlnvectortilesource","role":"symbol","kind":"symbol","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","type":"reference","isActive":true},{"type":"text","text":" is a map content source that supplies tiled vector data"},{"type":"text","text":" "},{"type":"text","text":"in "},{"type":"text","text":"Mapbox Vector Tile"},{"type":"text","text":" format"},{"type":"text","text":" "},{"type":"text","text":"to be shown on the map. The location of and metadata about the tiles are"},{"type":"text","text":" "},{"type":"text","text":"defined either by an option dictionary or by an external file that conforms to"},{"type":"text","text":" "},{"type":"text","text":"the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A vector tile source is added to an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","type":"reference","isActive":true},{"type":"text","text":" objects. A vector style layer defines the appearance of"},{"type":"text","text":" "},{"type":"text","text":"any content supplied by the vector tile source."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","type":"topic","fragments":[{"kind":"identifier","text":"MLNVectorTileSource"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNPointAnnotation":{"fragments":[{"kind":"identifier","text":"MLNPointAnnotation"}],"title":"MLNPointAnnotation","role":"symbol","url":"\/documentation\/maplibre\/mlnpointannotation","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation","type":"reference","isActive":true},{"type":"text","text":" object represents a one-dimensional shape located at a"},{"type":"text","text":" "},{"type":"text","text":"single geographical coordinate. Depending on how it is used, an"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation","type":"reference","isActive":true},{"type":"text","text":" object is known as a point annotation or point shape. For"},{"type":"text","text":" "},{"type":"text","text":"example, you could use a point shape to represent a city at low zoom levels, an"},{"type":"text","text":" "},{"type":"text","text":"address at high zoom levels, or the location of a long press gesture."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation","kind":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","url":"\/documentation\/maplibre\/mlnshape","role":"symbol","title":"MLNShape","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":" is an abstract class that represents a shape or annotation. Shapes"},{"type":"text","text":" "},{"type":"text","text":"constitute the content of a map — not only the overlays atop the map, but also"},{"type":"text","text":" "},{"type":"text","text":"the content that forms the base map."}],"kind":"symbol","fragments":[{"kind":"identifier","text":"MLNShape"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPolygonFeature":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygonFeature","kind":"symbol","fragments":[{"kind":"identifier","text":"MLNMultiPolygonFeature"}],"url":"\/documentation\/maplibre\/mlnmultipolygonfeature","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygonFeature","type":"reference","isActive":true},{"type":"text","text":" object associates a multipolygon shape with an"},{"type":"text","text":" "},{"type":"text","text":"optional identifier and attributes."}],"type":"topic","title":"MLNMultiPolygonFeature","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNPolygon/polygonWithCoordinates:count:interiorPolygons:":{"abstract":[{"type":"text","text":"Creates and returns an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon","type":"reference","isActive":true},{"type":"text","text":" object from the specified set of"},{"type":"text","text":" "},{"type":"text","text":"coordinates and interior polygons."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon\/polygonWithCoordinates:count:interiorPolygons:","navigatorTitle":[{"text":"polygonWithCoordinates:count:interiorPolygons:","kind":"identifier"}],"role":"symbol","kind":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"polygonWithCoordinates:count:interiorPolygons:","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnpolygon\/polygonwithcoordinates:count:interiorpolygons:","type":"topic","title":"polygonWithCoordinates:count:interiorPolygons:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeCollection":{"kind":"symbol","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollection","type":"reference","isActive":true},{"type":"text","text":" object represents a shape consisting of zero or more"},{"type":"text","text":" "},{"type":"text","text":"distinct but related shapes that are instances of "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":". The constituent"},{"type":"text","text":" "},{"type":"text","text":"shapes can be a mixture of different kinds of shapes."}],"title":"MLNShapeCollection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollection","role":"symbol","url":"\/documentation\/maplibre\/mlnshapecollection","fragments":[{"kind":"identifier","text":"MLNShapeCollection"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPoint":{"fragments":[{"kind":"identifier","text":"MLNMultiPoint"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint","title":"MLNMultiPoint","type":"topic","url":"\/documentation\/maplibre\/mlnmultipoint","abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint","type":"reference","isActive":true},{"type":"text","text":" class is an abstract superclass used to define shapes"},{"type":"text","text":" "},{"type":"text","text":"composed of multiple vertices."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeCollectionFeature":{"role":"symbol","url":"\/documentation\/maplibre\/mlnshapecollectionfeature","abstract":[{"type":"text","text":"An "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollectionFeature","type":"reference"},{"type":"text","text":" object associates a shape collection with an"},{"type":"text","text":" "},{"type":"text","text":"optional identifier and attributes."}],"title":"MLNShapeCollectionFeature","type":"topic","kind":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeCollectionFeature"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollectionFeature"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPolygon":{"type":"topic","role":"symbol","fragments":[{"kind":"identifier","text":"MLNMultiPolygon"}],"title":"MLNMultiPolygon","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon","type":"reference","isActive":true},{"type":"text","text":" object represents a shape consisting of one or more"},{"type":"text","text":" "},{"type":"text","text":"polygons that do not overlap. For example, you could use a multipolygon shape"},{"type":"text","text":" "},{"type":"text","text":"to represent the body of land that consists of an island surrounded by an"},{"type":"text","text":" "},{"type":"text","text":"atoll: the inner island would be one "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon","type":"reference","isActive":true},{"type":"text","text":" object, while the surrounding"},{"type":"text","text":" "},{"type":"text","text":"atoll would be another. You could also use a multipolygon shape to represent a"},{"type":"text","text":" "},{"type":"text","text":"group of disconnected but related buildings."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon","kind":"symbol","url":"\/documentation\/maplibre\/mlnmultipolygon"},"doc://org.swift.MyProject/documentation/MapLibre/MLNPolygon/interiorPolygons":{"abstract":[{"text":"The array of polygons nested inside the receiver.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon\/interiorPolygons","role":"symbol","kind":"symbol","url":"\/documentation\/maplibre\/mlnpolygon\/interiorpolygons","title":"interiorPolygons","fragments":[{"kind":"identifier","text":"interiorPolygons"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate/mapView:fillColorForPolygonAnnotation:":{"url":"\/documentation\/maplibre\/mlnmapviewdelegate\/mapview:fillcolorforpolygonannotation:","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"mapView:fillColorForPolygonAnnotation:"}],"abstract":[{"text":"Returns the color to use when rendering the fill of a polygon annotation.","type":"text"}],"title":"mapView:fillColorForPolygonAnnotation:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:fillColorForPolygonAnnotation:","kind":"symbol","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"mapView:fillColorForPolygonAnnotation:"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","url":"\/documentation\/maplibre\/mlnshapesource","role":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeSource"}],"abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"type":"text","text":" is a map content source that supplies vector shapes to be"},{"type":"text","text":" "},{"type":"text","text":"shown on the map. The shapes may be instances of "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":" or "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or they may be defined by local or external"},{"type":"text","text":" "},{"type":"text","text":"GeoJSON"},{"type":"text","text":" code. A shape source is added to an"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object along with an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the shape source. You"},{"type":"text","text":" "},{"type":"text","text":"can update a shape source by setting its "},{"type":"codeVoice","code":"shape"},{"text":" or ","type":"text"},{"code":"URL","type":"codeVoice"},{"text":" property.","type":"text"}],"kind":"symbol","title":"MLNShapeSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorStyleLayer":{"kind":"symbol","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","type":"reference","isActive":true},{"type":"text","text":" is an abstract superclass for style layers whose content"},{"type":"text","text":" "},{"type":"text","text":"is defined by an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"type":"text","text":" or "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"type":"text","text":" object."}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","url":"\/documentation\/maplibre\/mlnvectorstylelayer","role":"symbol","title":"MLNVectorStyleLayer","fragments":[{"kind":"identifier","text":"MLNVectorStyleLayer"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPolyline":{"type":"topic","fragments":[{"kind":"identifier","text":"MLNMultiPolyline"}],"abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolyline","type":"reference","isActive":true},{"type":"text","text":" object represents a shape consisting of one or more"},{"type":"text","text":" "},{"type":"text","text":"polylines. For example, you could use a multipolyline shape to represent both"},{"type":"text","text":" "},{"type":"text","text":"sides of a divided highway (dual carriageway), excluding the median (central"},{"type":"text","text":" "},{"type":"text","text":"reservation): each carriageway would be a distinct "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolyline","type":"reference","isActive":true},{"type":"text","text":" object."}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolyline","url":"\/documentation\/maplibre\/mlnmultipolyline","role":"symbol","title":"MLNMultiPolyline"},"doc://org.swift.MyProject/documentation/MapLibre/MLNPolygon/polygonWithCoordinates:count:":{"fragments":[{"text":"+ ","kind":"text"},{"text":"polygonWithCoordinates:count:","kind":"identifier"}],"abstract":[{"text":"Creates and returns an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon","type":"reference","isActive":true},{"text":" object from the specified set of","type":"text"},{"text":" ","type":"text"},{"text":"coordinates.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon\/polygonWithCoordinates:count:","kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlnpolygon\/polygonwithcoordinates:count:","navigatorTitle":[{"text":"polygonWithCoordinates:count:","kind":"identifier"}],"title":"polygonWithCoordinates:count:","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNPolyline":{"title":"MLNPolyline","url":"\/documentation\/maplibre\/mlnpolyline","role":"symbol","kind":"symbol","type":"topic","fragments":[{"kind":"identifier","text":"MLNPolyline"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolyline","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolyline","type":"reference","isActive":true},{"type":"text","text":" object represents a shape consisting of two or more vertices,"},{"type":"text","text":" "},{"type":"text","text":"specified as "},{"code":"CLLocationCoordinate2D","type":"codeVoice"},{"type":"text","text":" instances, and the line segments that"},{"type":"text","text":" "},{"type":"text","text":"connect them. For example, you could use an polyline to represent a road or the"},{"type":"text","text":" "},{"type":"text","text":"path along which something moves."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNPointCollection":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection","title":"MLNPointCollection","url":"\/documentation\/maplibre\/mlnpointcollection","fragments":[{"kind":"identifier","text":"MLNPointCollection"}],"abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection","type":"reference","isActive":true},{"type":"text","text":" object represents a shape consisting of one or more"},{"type":"text","text":" "},{"type":"text","text":"disconnected vertices, specified as "},{"code":"CLLocationCoordinate2D","type":"codeVoice"},{"type":"text","text":" instances. The"},{"type":"text","text":" "},{"type":"text","text":"points in the collection may be related but are not connected spatially. For"},{"type":"text","text":" "},{"type":"text","text":"example, you could use a point collection to represent all the trees in an"},{"type":"text","text":" "},{"type":"text","text":"orchard."}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/addOverlay:":{"fragments":[{"text":"- ","kind":"text"},{"text":"addOverlay:","kind":"identifier"}],"type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Adds a single overlay object to the map."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/addOverlay:","role":"symbol","navigatorTitle":[{"text":"addOverlay:","kind":"identifier"}],"title":"addOverlay:","url":"\/documentation\/maplibre\/mlnmapview\/addoverlay:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNPolygonFeature":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygonFeature","fragments":[{"kind":"identifier","text":"MLNPolygonFeature"}],"abstract":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygonFeature","isActive":true,"type":"reference"},{"text":" object associates a polygon shape with an optional","type":"text"},{"text":" ","type":"text"},{"text":"identifier and attributes.","type":"text"}],"title":"MLNPolygonFeature","kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlnpolygonfeature","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/addAnnotatio