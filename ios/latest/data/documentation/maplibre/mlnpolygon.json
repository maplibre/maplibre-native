e,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"text":"’s or","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource"},{"text":"’s polygons collectively using an ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer"},{"text":" object. To access a polygon’s attributes, use an","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygonFeature"},{"text":" object.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Alternatively, you can add a polygon overlay directly to a map view using the"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/addAnnotation:","type":"reference"},{"type":"text","text":" or "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/addOverlay:","type":"reference"},{"type":"text","text":" method. Configure"},{"type":"text","text":" "},{"type":"text","text":"a polygon overlay’s appearance using"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:strokeColorForShapeAnnotation:","type":"reference"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:fillColorForPolygonAnnotation:"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The vertices are automatically connected in the order in which you provide"},{"type":"text","text":" "},{"type":"text","text":"them. You should close the polygon by specifying the same"},{"type":"text","text":" "},{"code":"CLLocationCoordinate2D","type":"codeVoice"},{"type":"text","text":" as the first and last vertices; otherwise, the"},{"type":"text","text":" "},{"type":"text","text":"polygon’s fill may not cover the area you expect it to. To avoid filling the"},{"type":"text","text":" "},{"type":"text","text":"space within the shape, give the polygon a transparent fill or use an"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolyline","type":"reference"},{"type":"text","text":" object."}]},{"type":"paragraph","inlineContent":[{"text":"A polygon may have one or more interior polygons, or holes, that you specify as","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon","isActive":true,"type":"reference"},{"text":" objects with the ","type":"text"},{"type":"codeVoice","code":"+polygonWithCoordinates:count:interiorPolygons:"},{"text":" ","type":"text"},{"text":"method. For example, if a polygon represents a lake, it could exclude an island","type":"text"},{"text":" ","type":"text"},{"text":"within the lake using an interior polygon. Interior polygons may not themselves","type":"text"},{"text":" ","type":"text"},{"text":"have interior polygons. To represent a shape that includes a polygon within a","type":"text"},{"text":" ","type":"text"},{"text":"hole or, more generally, to group multiple polygons together in one shape, use","type":"text"},{"text":" ","type":"text"},{"text":"an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon","isActive":true,"type":"reference"},{"text":" or ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon","isActive":true,"type":"reference"},{"text":" object.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To make the polygon straddle the antimeridian, specify some longitudes less"},{"type":"text","text":" "},{"type":"text","text":"than −180 degrees or greater than 180 degrees."}]},{"level":4,"anchor":"Related-examples","type":"heading","text":"Related examples"},{"type":"paragraph","inlineContent":[{"text":"TODO: Add a polygon annotation, learn how to initialize an","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon","isActive":true,"type":"reference"},{"text":" object from an array of coordinates.","type":"text"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnpolygon"]}],"metadata":{"title":"MLNPolygon","role":"symbol","modules":[{"name":"MapLibre"}],"symbolKind":"class","fragments":[{"text":"MLNPolygon","kind":"identifier"}],"roleHeading":"Class","externalID":"c:objc(cs)MLNPolygon","navigatorTitle":[{"text":"MLNPolygon","kind":"identifier"}]},"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapViewDelegate/mapView:strokeColorForShapeAnnotation:":{"title":"mapView:strokeColorForShapeAnnotation:","url":"\/documentation\/maplibre\/mlnmapviewdelegate\/mapview:strokecolorforshapeannotation:","abstract":[{"text":"Returns the color to use when rendering the outline of a shape annotation.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:strokeColorForShapeAnnotation:","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"mapView:strokeColorForShapeAnnotation:","kind":"identifier"}],"fragments":[{"text":"- ","kind":"text"},{"text":"mapView:strokeColorForShapeAnnotation:","kind":"identifier"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNPointAnnotation":{"title":"MLNPointAnnotation","kind":