{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"seeAlsoSections":[{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNEmptyFeature","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygonFeature","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolyline","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolylineFeature","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolylineFeature","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollectionFeature","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolyline","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolylineFeature","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollection","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollectionFeature"],"anchor":"Shapes","generated":true,"title":"Shapes"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnpolygon"]}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"@interface"},{"kind":"text","text":" "},{"kind":"identifier","text":"MLNPolygon"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint","preciseIdentifier":"c:objc(cs)MLNMultiPoint","kind":"typeIdentifier","text":"MLNMultiPoint"}],"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"]}]},{"mentions":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iO