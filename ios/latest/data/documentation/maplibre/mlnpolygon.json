text","text":"a polygon overlay’s appearance using"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:strokeColorForShapeAnnotation:","type":"reference","isActive":true},{"type":"text","text":" and"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:fillColorForPolygonAnnotation:","type":"reference","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The vertices are automatically connected in the order in which you provide"},{"type":"text","text":" "},{"type":"text","text":"them. You should close the polygon by specifying the same"},{"type":"text","text":" "},{"type":"codeVoice","code":"CLLocationCoordinate2D"},{"type":"text","text":" as the first and last vertices; otherwise, the"},{"type":"text","text":" "},{"type":"text","text":"polygon’s fill may not cover the area you expect it to. To avoid filling the"},{"type":"text","text":" "},{"type":"text","text":"space within the shape, give the polygon a transparent fill or use an"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolyline","isActive":true,"type":"reference"},{"type":"text","text":" object."}]},{"type":"paragraph","inlineContent":[{"text":"A polygon may have one or more interior polygons, or holes, that you specify as","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon"},{"text":" objects with the ","type":"text"},{"code":"+polygonWithCoordinates:count:interiorPolygons:","type":"codeVoice"},{"text":" ","type":"text"},{"text":"method. For example, if a polygon represents a lake, it could exclude an island","type":"text"},{"text":" ","type":"text"},{"text":"within the lake using an interior polygon. Interior polygons may not themselves","type":"text"},{"text":" ","type":"text"},{"text":"have interior polygons. To represent a shape that includes a polygon within a","type":"text"},{"text":" ","type":"text"},{"text":"hole or, more generally, to group multiple polygons together in one shape, use","type":"text"},{"text":" ","type":"text"},{"text":"an ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon"},{"text":" or ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon"},{"text":" object.","type":"text"}]},{"inlineContent":[{"type":"text","text":"To make the polygon straddle the antimeridian, specify some longitudes less"},{"type":"text","text":" "},{"type":"text","text":"than −180 degrees or greater than 180 degrees."}],"type":"paragraph"},{"text":"Related examples","anchor":"Related-examples","level":4,"type":"heading"},{"inlineContent":[{"text":"TODO: Add a polygon annotation, learn how to initialize an","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon"},{"text":" object from an array of coordinates.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon"},"kind":"symbol","abstract":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon","isActive":true,"type":"reference"},{"text":" object represents a closed shape consisting of four or more","type":"text"},{"text":" ","type":"text"},{"text":"vertices, specified as ","type":"text"},{"code":"CLLocationCoordinate2D","type":"codeVoice"},{"text":" instances, and the edges that","type":"text"},{"text":" ","type":"text"},{"text":"connect them. For example, you could use a polygon shape to represent a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"building, a lake, or an area you want to highlight."}],"relationshipsSections":[{"kind":"relationships","title":"Inherits From","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint"],"type":"inheritsFrom"},{"kind":"relationships","title":"Inherited By","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygonFeature"],"type":"inheritedBy"},{"kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay"],"type":"conformsTo"}],"metadata":{"modules":[{"name":"MapLibre"}],"role":"symbol","symbolKind":"class","navigatorTitle":[{"text":"MLNPolygon","kind":"identifier"}],"fragments":[{"text":"MLNPolygon","kind":"identifier"}],"roleHeading":"Class","title":"MLNPolygon","externalID":"c:objc(cs)MLNPolygon"},"topicSections":[{"generated":true,"title":"Instance Properties","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon\/interiorPolygons"],"anchor":"Instance-Properties"},{"generated":true,"title":"Type Methods","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon\/polygonWithCoordinates:count:","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon\/polygonWithCoordinates:count:interiorPolygons:"],"anchor":"Type-Methods"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"topic","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"text":" is a map content source that supplies vector shapes to be","type":"text"},{"text":" ","type":"text"},{"text":"shown on the map. The shapes may be instances of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"text":" or ","