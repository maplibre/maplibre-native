ifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":" is an abstract class that represents a shape or annotation. Shapes"},{"type":"text","text":" "},{"type":"text","text":"constitute the content of a map — not only the overlays atop the map, but also"},{"type":"text","text":" "},{"type":"text","text":"the content that forms the base map."}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","url":"\/documentation\/maplibre\/mlnshape","title":"MLNShape","type":"topic","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"fragments":[{"text":"MLNStyle","kind":"identifier"}],"role":"symbol","kind":"symbol","title":"MLNStyle","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","url":"\/documentation\/maplibre\/mlnstyle","abstract":[{"type":"text","text":"The proxy object for the current map style."}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSourceDataSource":{"url":"\/documentation\/maplibre\/mlncomputedshapesourcedatasource","title":"MLNComputedShapeSourceDataSource","abstract":[{"text":"Data source for ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","type":"reference"},{"text":". This protocol defines two optional methods for fetching","type":"text"},{"text":" ","type":"text"},{"text":"data, one based on tile coordinates, and one based on a bounding box. Classes that implement this","type":"text"},{"text":" ","type":"text"},{"text":"protocol must implement one, and only one of the methods. Methods on this protocol will not be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"called on main thread, they will be called on the caller’s "},{"type":"codeVoice","code":"requestQueue"},{"type":"text","text":"."}],"fragments":[{"text":"MLNComputedShapeSourceDataSource","kind