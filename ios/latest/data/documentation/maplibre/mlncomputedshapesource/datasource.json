ass that represents a shape or annotation. Shapes"},{"type":"text","text":" "},{"type":"text","text":"constitute the content of a map — not only the overlays atop the map, but also"},{"type":"text","text":" "},{"type":"text","text":"the content that forms the base map."}],"url":"\/documentation\/maplibre\/mlnshape"},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSource/dataSource":{"fragments":[{"text":"dataSource","kind":"identifier"}],"title":"dataSource","type":"topic","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource\/dataSource","role":"symbol","abstract":[{"type":"text","text":"An object that implements the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource","isActive":true},{"type":"text","text":" protocol that will be queried"},{"type":"text","text":" "},{"type":"text","text":"for tile data."}],"url":"\/documentation\/maplibre\/mlncomputedshapesource\/datasource"}}}