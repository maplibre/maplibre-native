rg.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"text":" is an abstract class that represents a shape or annotation. Shapes","type":"text"},{"text":" ","type":"text"},{"text":"constitute the content of a map — not only the overlays atop the map, but also","type":"text"},{"text":" ","type":"text"},{"text":"the content that forms the base map.","type":"text"}],"type":"topic","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","kind":"symbol","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"url":"\/documentation\/maplibre\/mlnstyle","role":"symbol","kind":"symbol","type":"topic","title":"MLNStyle","abstract":[{"text":"The proxy object for the current map style.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","fragments":[{"text":"MLNStyle","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSourceDataSource":{"url":"\/documentation\/maplibre\/mlncomputedshapesourcedatasource","kind":"symbol","type":"topic","role":"symbol","abstract":[{"text":"Data source for ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","isActive":true,"type":"reference"},{"text":". This protocol defines two optional methods for fetching","type":"text"},{"text":" ","type":"text"},{"text":"data, one based on tile coordinates, and one based on a bounding box. Classes that implement this","type":"text"},{"text":" ","type":"text"},{"text":"protocol must implement one, and only one of the methods. Methods on this protocol will not be","type":"text"},{"text":" ","type":"text"},{"text":"called on main thread, they will be ca