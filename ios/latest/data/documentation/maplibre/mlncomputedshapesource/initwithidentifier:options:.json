MyProject/documentation/MapLibre/MLNShapeSourceOptionWrapsCoordinates":{"title":"MLNShapeSourceOptionWrapsCoordinates","type":"topic","role":"symbol","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing a Boolean value; specifies whether the shape of"},{"type":"text","text":" "},{"type":"text","text":"an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","isActive":true},{"type":"text","text":" should be wrapped to accomodate coordinates with"},{"type":"text","text":" "},{"type":"text","text":"longitudes beyond −180 and 180. The default value is "},{"type":"codeVoice","code":"NO"},{"type":"text","text":"."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionWrapsCoordinates","kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionwrapscoordinates","fragments":[{"text":"MLNShapeSourceOptionWrapsCoordinates","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSource/initWithIdentifier:options:":{"fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:options:","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource\/initWithIdentifier:options:","kind":"symbol","type":"topic","title":"initWithIdentifier:options:","url":"\/documentation\/maplibre\/mlncomputedshapesource\/initwithidentifier:options:","role":"symbol","navigatorTitle":[{"text":"initWithIdentifier:options:","kind":"identifier"}],"abstract":[{"text":"Returns a custom shape data source initialized with an identifier, and a","type":"text"},{"text":" ","type":"text"},{"text":"dictionary of options for the source according to the","type":"text"},{"text":" ","type":"text"},{"text":"style","type":"text"},{"text":" ","type":"text"},{"text":"specification","type":"text"},{"text":".","type":"text"}]},"doc://org.swift.MyProject/doc