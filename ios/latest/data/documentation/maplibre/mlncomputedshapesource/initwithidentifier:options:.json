entation\/MapLibre\/MLNShape","isActive":true,"type":"reference"},{"text":", then add a computed shape source to an","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true,"type":"reference"},{"text":" object along with an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true,"type":"reference"},{"text":" object. The vector style","type":"text"},{"text":" ","type":"text"},{"text":"layer defines the appearance of any content supplied by the computed shape","type":"text"},{"text":" ","type":"text"},{"text":"source.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","url":"\/documentation\/maplibre\/mlncomputedshapesource","type":"topic","fragments":[{"text":"MLNComputedShapeSource","kind":"identifier"}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionSimplificationTolerance":{"title":"MLNShapeSourceOptionSimplificationTolerance","url":"\/documentation\/maplibre\/mlnshapesourceoptionsimplificationtolerance","type":"topic","abstract":[{"text":"An ","type":"text"},{"type":"codeVoice","code":"NSNumber"},{"text":" object containing a double; specifies the Douglas-Peucker","type":"text"},{"text":" ","type":"text"},{"text":"simplification tolerance. A greater value produces simpler geometries and","type":"text"},{"text":" ","type":"text"},{"text":"improves performance. The default value is 0.375.","type":"text"}],"fragments":[{"text":"MLNShapeSourceOptionSimplificationTolerance","kind":"identifier"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionSimplificationTolerance"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionWrapsCoordinates":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionWrapsCoord