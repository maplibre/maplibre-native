e\/MLNComputedShapeSource","type":"reference","isActive":true},{"type":"text","text":" should be clipped at the edge of each tile. The"},{"type":"text","text":" "},{"type":"text","text":"default value is "},{"code":"NO","type":"codeVoice"},{"type":"text","text":"."}],"type":"topic","fragments":[{"text":"MLNShapeSourceOptionClipsCoordinates","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMinimumZoomLevel":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMinimumZoomLevel","abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing an integer; specifies the minimum zoom level at","type":"text"},{"text":" ","type":"text"},{"text":"which to create vector tiles. The default value is 0.","type":"text"}],"type":"topic","title":"MLNShapeSourceOptionMinimumZoomLevel","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionMinimumZoomLevel"}],"kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionminimumzoomlevel"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionBuffer":{"abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing an integer; specifies the size of the tile","type":"text"},{"text":" ","type":"text"},{"text":"buffer on each side. A value of 0 produces no buffer. A value of 512 produces a","type":"text"},{"text":" ","type":"text"},{"text":"buffer as wide as the tile itself. Larger values produce fewer rendering","type":"text"},{"text":" ","type":"text"},{"text":"artifacts near tile edges and slower performance. The default value is 128.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionBuffer","type":"topic","title":"MLNShapeSourceOptionBuffer","fragments":[{"text":"MLNShapeSourceOptionBuffer","kind":"identifier"}],"kind":"symbol","role":"symbol","url":"\/documentation\/map