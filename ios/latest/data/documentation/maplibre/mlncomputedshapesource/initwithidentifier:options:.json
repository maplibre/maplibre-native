xt":" "},{"type":"text","text":"source."}],"fragments":[{"kind":"identifier","text":"MLNComputedShapeSource"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionClipsCoordinates":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClipsCoordinates","title":"MLNShapeSourceOptionClipsCoordinates","role":"symbol","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing a Boolean value; specifies whether the shape of"},{"type":"text","text":" "},{"type":"text","text":"an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource"},{"type":"text","text":" should be clipped at the edge of each tile. The"},{"type":"text","text":" "},{"type":"text","text":"default value is "},{"type":"codeVoice","code":"NO"},{"type":"text","text":"."}],"type":"topic","kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionclipscoordinates","fragments":[{"text":"MLNShapeSourceOptionClipsCoordinates","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSource/initWithIdentifier:options:":{"type":"topic","navigatorTitle":[{"text":"initWithIdentifier:options:","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlncomputedshapesource\/initwithidentifier:options:","abstract":[{"type":"text","text":"Returns a custom shape data source initialized with an identifier, and a"},{"type":"text","text":" "},{"text":"dictionary of options for the source according to the","type":"text"},{"text":" ","type":"text"},{"text":"style","type":"text"},{"text":" ","type":"text"},{"text":"specification","type":"text"},{"text":".","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource\/initWithIdentifier:options:","fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:options:","kind":"identif