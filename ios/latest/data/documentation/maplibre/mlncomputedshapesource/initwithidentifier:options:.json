pplies vector shapes,"},{"type":"text","text":" "},{"type":"text","text":"one tile at a time, to be shown on the map on demand. You implement a class"},{"type":"text","text":" "},{"type":"text","text":"conforming to the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource"},{"type":"text","text":" protocol that returns"},{"type":"text","text":" "},{"type":"text","text":"instances of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":" or "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":", then add a computed shape source to an"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object along with an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the computed shape"},{"type":"text","text":" "},{"type":"text","text":"source."}],"kind":"symbol","role":"symbol","title":"MLNComputedShapeSource","url":"\/documentation\/maplibre\/mlncomputedshapesource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSource/initWithIdentifier:options:":{"navigatorTitle":[{"kind":"identifier","text":"initWithIdentifier:options:"}],"abstract":[{"type":"text","text":"Returns a custom shape data source initialized with an identifier, and a"},{"type":"text","text":" "},{"type":"text","text":"dictionary of options for the source according to the"},{"type":"text","text":" "},{"type":"text","text":"style"},{"type":"text","text":" "},{"type":"text","text":"specification"},{"type":"text","text":"."}],"type":"topic","url":"\/documentation\/maplibre\/mlncomputedshapesource\/initwithidentifier:options:","kind":"symbol","role":"symbol","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"initWithIdentifier:options:"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource\/initWithIdentifier:options:","title":"initWithIdentifier:options:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"url":"\/documentation\/maplibre\/mlnstyle","kind":"symbol","role":"symbol","abstract":[{"text":"The proxy object for the current map style.","type":"text"}],"type":"topic","fragments":[{"text":"MLNStyle","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","title":"MLNStyle"},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSourceDataSource":{"role":"symbol","fragments":[{"kind":"identifier","text":"MLNComputedShapeSourceDataSource"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource","title":"MLNComputedShapeSourceDataSource","url":"\/documentation\/maplibre\/mlncomputedshapesourcedatasource","abstract":[{"type":"text","text":"Data source for "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource"},{"type":"text","text":". This protocol defines two optional methods for fetching"},{"type":"text","text":" "},{"type":"text","text":"data, one based on tile coordinates, and one based on a bounding box. Classes that implement this"},{"type":"text","text":" "},{"type":"text","text":"protocol must implement one, and only one of the methods. Methods on this protocol will not be"},{"type":"text","text":" "},{"type":"text","text":"called on main thread, they will be called on the caller’s "},{"type":"codeVoice","code":"requestQueue"},{"type":"text","text":"."}],"type":"topic"}}}