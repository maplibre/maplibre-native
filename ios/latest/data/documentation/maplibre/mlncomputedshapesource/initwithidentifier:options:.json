\/MLNStyle","isActive":true},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the computed shape"},{"type":"text","text":" "},{"type":"text","text":"source."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionClipsCoordinates":{"abstract":[{"text":"An ","type":"text"},{"type":"codeVoice","code":"NSNumber"},{"text":" object containing a Boolean value; specifies whether the shape of","type":"text"},{"text":" ","type":"text"},{"text":"an ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","isActive":true},{"text":" should be clipped at the edge of each tile. The","type":"text"},{"text":" ","type":"text"},{"text":"default value is ","type":"text"},{"type":"codeVoice","code":"NO"},{"text":".","type":"text"}],"fragments":[{"text":"MLNShapeSourceOptionClipsCoordinates","kind":"identifier"}],"kind":"symbol","title":"MLNShapeSourceOptionClipsCoordinates","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClipsCoordinates","url":"\/documentation\/maplibre\/mlnshapesourceoptionclipscoordinates","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionSimplificationTolerance":{"kind":"symbol","title":"MLNShapeSourceOptionSimplificationTolerance","role":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionSimplificationTolerance"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionSimplificationTolerance","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing a double; specifies the Douglas-Peucker"},{"type":"text","text":" "},{"type":"text","text":"simplification tolerance. A greater value produces simpler geometries and"},{"type":"text","text":" "},{"type":"text","text":"i