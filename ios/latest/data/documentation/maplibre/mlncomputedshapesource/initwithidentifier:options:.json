/MLNComputedShapeSourceDataSource":{"title":"MLNComputedShapeSourceDataSource","abstract":[{"type":"text","text":"Data source for "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource"},{"type":"text","text":". This protocol defines two optional methods for fetching"},{"type":"text","text":" "},{"type":"text","text":"data, one based on tile coordinates, and one based on a bounding box. Classes that implement this"},{"type":"text","text":" "},{"type":"text","text":"protocol must implement one, and only one of the methods. Methods on this protocol will not be"},{"type":"text","text":" "},{"type":"text","text":"called on main thread, they will be called on the caller’s "},{"type":"codeVoice","code":"requestQueue"},{"type":"text","text":"."}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource","url":"\/documentation\/maplibre\/mlncomputedshapesourcedatasource","role":"symbol","type":"topic","fragments":[{"text":"MLNComputedShapeSourceDataSource","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","kind":"symbol","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionClipsCoordinates":{"fragments":[{"text":"MLNShapeSourceOptionClipsCoordinates","kind":"identifier"}],"type":"topic","title":"MLNShapeSourceOptionClipsCoordinates","abstract":[{"type":"text","text":"An "},{"code":"NSNumber","type":"codeVoice"},{"type":"text","text":" object containing a Boolean value; specifies whether the shape of"},{"type":"text","text":" "},{"type":"text","text":"an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","type":"reference","isActive":true},{"type":"text","text":" should be clipped at the edge of each tile. The"},{"type":"text","text":" "},{"type":"text","text":"default value is "},{"code":"NO","type":"codeVoice"},{"type":"text","text":"."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClipsCoordinates","role":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionclipscoordinates","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionBuffer":{"fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionBuffer"}],"title":"MLNShapeSourceOptionBuffer","kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionBuffer","abstract":[{"type":"text","text":"An "},{"code":"NSNumber","type":"codeVoice"},{"type":"text","text":" object containing an integer; specifies the size of the tile"},{"type":"text","text":" "},{"type":"text","text":"buffer on each side. A value of 0 produces no buffer. A value of 512 produces a"},{"type":"text","text":" "},{"type":"text","text":"buffer as wide as the tile itself. Larger values produce fewer rendering"},{"type":"text","text":" "},{"type":"text","text":"artifacts near tile edges and slower performance. The default value is 128."}],"url":"\/documentation\/maplibre\/mlnshapesourceoptionbuffer","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionWrapsCoordinates":{"url":"\/documentation\/maplibre\/mlnshapesourceoptionwrapscoordinates","type":"topic","role":"symbol","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing a Boolean value; specifies whether the shape of"},{"type":"text","text":" "},{"type":"text","text":"an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","isActive":true},{"type":"text","text":" should be wrapped to accomodate coordinates with"},{"type":"text","text":" "},{"type":"text","text":"longitudes beyond −180 and 180. The default value is "},{"type":"codeVoice","code":"NO"},{"type":"text","text":"."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionWrapsCoordinates","title":"MLNShapeSourceOptionWrapsCoordinates","kind":"symbol","fragments":[{"text":"MLNShapeSourceOptionWrapsCoordinates","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSource/initWithIdentifier:options:":{"abstract":[{"type":"text","text":"Returns a custom shape data source initialized with an identifier, and a"},{"type":"text","text":" "},{"type":"text","text":"dictionary of options for the source according to the"},{"type":"text","text":" "},{"type":"text","text":"style"},{"type":"text","text":" "},{"type":"text","text":"specification"},{"type":"text","text":"."}],"type":"topic","title":"initWithIdentifier:options:","kind":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:options:","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource\/initWithIdentifier:options:","role":"symbol","url":"\/documentation\/maplibre\/mlncomputedshapesource\/initwithidentifier:options:","navigatorTitle":[{"text":"initWithIdentifier:options:","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMinimumZoomLevel":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMinimumZoomLevel","title":"MLNShapeSourceOptionMinimumZoomLevel","role":"symbol","kind":"symbol","abstract":[{"text":"An ","type":"text"},{"type":"codeVoice","code":"NSNumber"},{"text":" object containing an integer; specifies the minimum zoom level at","type":"text"},{"text":" ","type":"text"},{"text":"which to create vector tiles. The default value is 0.","type":"text"}],"url":"\/documentation\/maplibre\/mlnshapesourceoptionminimumzoomlevel","fragments":[{"text":"MLNShapeSourceOptionMinimumZoomLevel","kind":"identifier"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSource":{"abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","type":"reference","isActive":true},{"type":"text","text":" is a map content source that supplies vector shapes,"},{"type":"text","text":" "},{"type":"text","text":"one tile at a time, to be shown on the map on demand. You implement a class"},{"type":"text","text":" "},{"type":"text","text":"conforming to the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource","type":"reference","isActive":true},{"type":"text","text":" protocol that returns"},{"type":"text","text":" "},{"type":"text","text":"instances of "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":" or "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":", then add a computed shape source to an"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"type":"text","text":" object along with an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the computed shape"},{"type":"text","text":" "},{"type":"text","text":"source."}],"title":"MLNComputedShapeSource","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","url":"\/documentation\/maplibre\/mlncomputedshapesource","fragments":[{"kind":"identifier","text":"MLNComputedShapeSource"}],"role":"symbol","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionSimplificationTolerance":{"title":"MLNShapeSourceOptionSimplificationTolerance","abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing a double; specifies the Douglas-Peucker","type":"text"},{"text":" ","type":"text"},{"text":"simplification tolerance. A greater value produces simpler geometries and","type":"text"},{"text":" ","type":"text"},{"text":"improves performance. The default value is 0.375.","type":"text"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionSimplificationTolerance","fragments":[{"text":"MLNShapeSourceOptionSimplificationTolerance","kind":"identifier"}],"type":"topic","url":"\/documentation\/maplibre\/mlnshapesourceoptionsimplificationtolerance"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"abstract":[{"type":"text","text":"The proxy object for the current map style."}],"type":"topic","url":"\/documentation\/maplibre\/mlnstyle","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","role":"symbol","fragments":[{"text":"MLNStyle","kind":"identifier"}],"kind":"symbol","title":"MLNStyle"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"url":"\/documentation\/maplibre\/mlnshape","kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","title":"MLNShape","fragments":[{"text":"MLNShape","kind":"identifier"}],"type":"topic","abstract":[{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference"},{"text":" is an abstract class that represents a shape or annotation. Shapes","type":"text"},{"text":" ","type":"text"},{"text":"constitute the content of a map — not only the overlays atop the map, but also","type":"text"},{"text":" ","type":"text"},{"text":"the content that forms the base map.","type":"text"}]}}}