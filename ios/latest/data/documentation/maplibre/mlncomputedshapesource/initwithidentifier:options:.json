":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","type":"topic","url":"\/documentation\/maplibre\/mlncomputedshapesource","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","url":"\/documentation\/maplibre\/mlnshape","kind":"symbol","role":"symbol","title":"MLNShape","abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":" is an abstract class that represents a shape or annotation. Shapes"},{"type":"text","text":" "},{"type":"text","text":"constitute the content of a map — not only the overlays atop the map, but also"},{"type":"text","text":" "},{"type":"text","text":"the content that forms the base map."}],"type":"topic","fragments":[{"text":"MLNShape","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"title":"MLNStyle","kind":"symbol","abstract":[{"type":"text","text":"The proxy object for the current map style."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","url":"\/documentation\/maplibre\/mlnstyle","type":"topic","role":"symbol","fragments":[{"kind":"identifier","text":"MLNStyle"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSource/initWithIdentifier:options:":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource\/initWithIdentifier:options:","url":"\/documentation\/maplibre\/mlncomputedshapesource\/initwithidentifier:options:","kind":"symbol","role":"symbol","title":"initWithIdentifier:options:","abstract":[{"type":"text","text":"Returns a custom shape data source initialized with an identifier, and a"},{"type":"text","text":" "},{"type":"text","text":"dictionary of options for the source according to the"},{"type":"text","text":" "},{"type":"text","text":"style"},{"type":"text","text"