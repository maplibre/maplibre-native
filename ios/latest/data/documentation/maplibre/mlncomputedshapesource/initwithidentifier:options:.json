],"url":"\/documentation\/maplibre\/mlncomputedshapesource\/initwithidentifier:options:","abstract":[{"text":"Returns a custom shape data source initialized with an identifier, and a","type":"text"},{"text":" ","type":"text"},{"text":"dictionary of options for the source according to the","type":"text"},{"text":" ","type":"text"},{"text":"style","type":"text"},{"text":" ","type":"text"},{"text":"specification","type":"text"},{"text":".","type":"text"}],"kind":"symbol","navigatorTitle":[{"text":"initWithIdentifier:options:","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMinimumZoomLevel":{"title":"MLNShapeSourceOptionMinimumZoomLevel","role":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionminimumzoomlevel","type":"topic","kind":"symbol","abstract":[{"text":"An ","type":"text"},{"type":"codeVoice","code":"NSNumber"},{"text":" object containing an integer; specifies the minimum zoom level at","type":"text"},{"text":" ","type":"text"},{"text":"which to create vector tiles. The default value is 0.","type":"text"}],"fragments":[{"text":"MLNShapeSourceOptionMinimumZoomLevel","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMinimumZoomLevel"},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSourceDataSource":{"role":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlncomputedshapesourcedatasource","abstract":[{"type":"text","text":"Data source for "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","isActive":true},{"type":"text","text":". This protocol defines two optional methods for fetching"},{"type":"text","text":" "},{"type":"text","text":"data, one based on tile coordinates, and one based on a bounding box. Classes that implement this"},{"type":"text","text":" "},{"type":"text","text":"protocol must implement one, and only one of the methods. Methods on this protocol will not be"},{"type":"text","text":" "},{"type":"text","text":"called on main thread, they will be called on the caller’s "},{"type":"codeVoice","code":"requestQueue"},{"type":"text","text":"."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource","fragments":[{"text":"MLNComputedShapeSourceDataSource","kind":"identifier"}],"kind":"symbol","title":"MLNComputedShapeSourceDataSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionSimplificationTolerance":{"abstract":[{"type":"text","text":"An "},{"code":"NSNumber","type":"codeVoice"},{"type":"text","text":" object containing a double; specifies the Douglas-Peucker"},{"type":"text","text":" "},{"type":"text","text":"simplification tolerance. A greater value produces simpler geometries and"},{"type":"text","text":" "},{"type":"text","text":"improves performance. The default value is 0.375."}],"kind":"symbol","fragments":[{"text":"MLNShapeSourceOptionSimplificationTolerance","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnshapesourceoptionsimplificationtolerance","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionSimplificationTolerance","role":"symbol","title":"MLNShapeSourceOptionSimplificationTolerance","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":" is an abstract class that represents a shape or annotation. Shapes"},{"type":"text","text":" "},{"type":"text","text":"constitute the content of a map — not only the overlays atop the map, but also"},{"type":"text","text":" "},{"type":"text","text":"the content that forms the base map."}],"fragments":[{"kind":"identifier","text":"MLNShape"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnshape","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","title":"MLNShape","type":"topic"}}}