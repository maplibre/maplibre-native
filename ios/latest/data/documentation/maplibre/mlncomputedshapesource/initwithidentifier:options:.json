":"text","text":" or "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":", then add a computed shape source to an"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"type":"text","text":" object along with an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the computed shape"},{"type":"text","text":" "},{"type":"text","text":"source."}],"title":"MLNComputedShapeSource","type":"topic","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection","url":"\/documentation\/maplibre","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionSimplificationTolerance":{"title":"MLNShapeSourceOptionSimplificationTolerance","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionSimplificationTolerance","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionSimplificationTolerance"}],"url":"\/documentation\/maplibre\/mlnshapesourceoptionsimplificationtolerance","type":"topic","abstract":[{"type":"text","text":"An "},{"code":"NSNumber","type":"codeVoice"},{"type":"text","text":" object containing a double; specifies the Douglas-Peucker"},{"type":"text","text":" "},{"type":"text","text":"simplification tolerance. A greater value produces simpler geometries and"},{"type":"text","text":" "},{"type":"text","text":"improves performance. The default value i