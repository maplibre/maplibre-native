"}],"role":"symbol","title":"MLNShapeSourceOptionClipsCoordinates","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionClipsCoordinates"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClipsCoordinates","url":"\/documentation\/maplibre\/mlnshapesourceoptionclipscoordinates","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMinimumZoomLevel":{"abstract":[{"type":"text","text":"An "},{"code":"NSNumber","type":"codeVoice"},{"type":"text","text":" object containing an integer; specifies the minimum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to create vector tiles. The default value is 0."}],"type":"topic","kind":"symbol","fragments":[{"text":"MLNShapeSourceOptionMinimumZoomLevel","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnshapesourceoptionminimumzoomlevel","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMinimumZoomLevel","title":"MLNShapeSourceOptionMinimumZoomLevel"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"kind":"symbol","title":"MLNStyle","url":"\/documentation\/maplibre\/mlnstyle","type":"topic","abstract":[{"text":"The proxy object for the current map style.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","role":"symbol","fragments":[{"kind":"identifier","text":"MLNStyle"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSource/initWithIdentifier:options:":{"title":"initWithIdentifier:options:","abstract":[{"text":"Returns a custom shape data source initialized with an identifier, and a","type":"text"},{"text":" ","type":"text"},{"text":"dictionary of options for the source according to the","type":"text"},{"text":" ","type":"text"},{"text":"style","type":"text"},{"text":" ","type":"text"},{"text":"specification","type":"text"},{"text":".","type":"text"}],"type":"topic","kind":"symbol","navigatorTitle":[{"text":"initWithIdentifier:options:","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlncomputedshapesource\/initwithidentifier:options:","role":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:options:","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource\/initWithIdentifier:options:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSourceDataSource":{"kind":"symbol","url":"\/documentation\/maplibre\/mlncomputedshapesourcedatasource","type":"topic","title":"MLNComputedShapeSourceDataSource","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource","fragments":[{"kind":"identifier","text":"MLNComputedShapeSourceDataSource"}],"abstract":[{"type":"text","text":"Data source for "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","isActive":true},{"type":"text","text":". This protocol defines two optional methods for fetching"},{"type":"text","text":" "},{"type":"text","text":"data, one based on tile coordinates, and one based on a bounding box. Classes that implement this"},{"type":"text","text":" "},{"type":"text","text":"protocol must implement one, and only one of the methods. Methods on this protocol will not be"},{"type":"text","text":" "},{"type":"text","text":"called on main thread, they will be called on the caller’s "},{"code":"requestQueue","type":"codeVoice"},{"type":"text","text":"."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSource":{"type":"topic","kind":"symbol","abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","isActive":true},{"type":"text","text":" is a map content source that supplies vector shapes,"},{"type":"text","text":" "},{"type":"text","text":"one tile at a time, to be shown on the map on demand. You implement a class"},{"type":"text","text":" "},{"type":"text","text":"conforming to the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource","isActive":true},{"type":"text","text":" protocol that returns"},{"type":"text","text":" "},{"type":"text","text":"instances of "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":", then add a computed shape source to an"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object along with an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the computed shape"},{"type":"text","text":" "},{"type":"text","text":"source."}],"title":"MLNComputedShapeSource","url":"\/documentation\/maplibre\/mlncomputedshapesource","role":"symbol","fragments":[{"kind":"identifier","text":"MLNComputedShapeSource"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionSimplificationTolerance":{"fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionSimplificationTolerance"}],"abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing a double; specifies the Douglas-Peucker"},{"type":"text","text":" "},{"type":"text","text":"simplification tolerance. A greater value produces simpler geometries and"},{"type":"text","text":" "},{"type":"text","text":"improves performance. The default value is 0.375."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionSimplificationTolerance","url":"\/documentation\/maplibre\/mlnshapesourceoptionsimplificationtolerance","title":"MLNShapeSourceOptionSimplificationTolerance","type":"topic","role":"symbol","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionBuffer":{"abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the size of the tile"},{"type":"text","text":" "},{"type":"text","text":"buffer on each side. A value of 0 produces no buffer. A value of 512 produces a"},{"type":"text","text":" "},{"type":"text","text":"buffer as wide as the tile itself. Larger values produce fewer rendering"},{"type":"text","text":" "},{"type":"text","text":"artifacts near tile edges and slower performance. The default value is 128."}],"type":"topic","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionBuffer"}],"title":"MLNShapeSourceOptionBuffer","role":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionbuffer","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionBuffer"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","kind":"symbol","type":"topic","abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":" is an abstract class that represents a shape or annotation. Shapes"},{"type":"text","text":" "},{"type":"text","text":"constitute the content of a map — not only the overlays atop the map, but also"},{"type":"text","text":" "},{"type":"text","text":"the content that forms the base map."}],"title":"MLNShape","role":"symbol","url":"\/documentation\/maplibre\/mlnshape","fragments":[{"text":"MLNShape","kind":"identifier"}]}}}