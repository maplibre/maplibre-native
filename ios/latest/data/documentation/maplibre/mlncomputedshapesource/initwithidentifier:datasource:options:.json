ource, and a","type":"text"},{"text":" ","type":"text"},{"text":"dictionary of options for the source according to the","type":"text"},{"text":" ","type":"text"},{"text":"style","type":"text"},{"text":" ","type":"text"},{"text":"specification","type":"text"},{"text":".","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSourceDataSource":{"role":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlncomputedshapesourcedatasource","abstract":[{"type":"text","text":"Data source for "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","isActive":true},{"type":"text","text":". This protocol defines two optional methods for fetching"},{"type":"text","text":" "},{"type":"text","text":"data, one based on tile coordinates, and one based on a bounding box. Classes that implement this"},{"type":"text","text":" "},{"type":"text","text":"protocol must implement one, and only one of the methods. Methods on this protocol will not be"},{"type":"text","text":" "},{"type":"text","text":"called on main thread, they will be called on the caller’s "},{"type":"codeVoice","code":"requestQueue"},{"type":"text","text":"."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource","fragments":[{"text":"MLNComputedShapeSourceDataSource","kind":"identifier"}],"kind":"symbol","title":"MLNComputedShapeSourceDataSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionWrapsCoordinates":{"role":"symbol","type":"topic","title":"MLNShapeSourceOptionWrapsCoordinates","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionWrapsCoordinates","fragments":[{"text":"MLNShapeSourceOptionWrapsCoordinates","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnshapesourceoptionwrapscoordinates","abstract":[{"text":"An ","type":"text"},{"type":"codeVoice","code":"NSNumber"},{"text":" object containing a Boole