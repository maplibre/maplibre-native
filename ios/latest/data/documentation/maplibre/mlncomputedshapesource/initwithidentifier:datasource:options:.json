":"text"}],"fragments":[{"text":"MLNShapeSourceOptionBuffer","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionbuffer","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionSimplificationTolerance":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionSimplificationTolerance","role":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionsimplificationtolerance","kind":"symbol","fragments":[{"text":"MLNShapeSourceOptionSimplificationTolerance","kind":"identifier"}],"title":"MLNShapeSourceOptionSimplificationTolerance","type":"topic","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing a double; specifies the Douglas-Peucker"},{"type":"text","text":" "},{"type":"text","text":"simplification tolerance. A greater value produces simpler geometries and"},{"type":"text","text":" "},{"type":"text","text":"improves performance. The default value is 0.375."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionClipsCoordinates":{"url":"\/documentation\/maplibre\/mlnshapesourceoptionclipscoordinates","title":"MLNShapeSourceOptionClipsCoordinates","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClipsCoordinates","role":"symbol","kind":"symbol","type":"topic","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionClipsCoordinates"}],"abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing a Boolean value; specifies whether the shape of","type":"text"},{"text":" ","type":"text"},{"text":"an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","isActive":true,"type":"reference"},{"text":" should be clipped at the edge of each tile. The","type":"text"},{"text":" ","type":"text"},{"text":"default value is ","type":"text"},{"code":"NO","type":"codeVoice"},{"text":".","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMinimumZoomLevel":{"fragments":[{"text":"MLNShapeSourceOptionMinimumZoomLevel","kind":"identifier"}],"role":"symbol","title":"MLNShapeSourceOptionMinimumZoomLevel","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the minimum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to create vector tiles. The default value is 0."}],"url":"\/documentation\/maplibre\/mlnshapesourceoptionminimumzoomlevel","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMinimumZoomLevel","type":"topic","kind":"symbol"}}}