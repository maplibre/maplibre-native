xt"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","type":"reference","isActive":true},{"text":" should be clipped at the edge of each tile. The","type":"text"},{"text":" ","type":"text"},{"text":"default value is ","type":"text"},{"type":"codeVoice","code":"NO"},{"text":".","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","role":"collection","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol","title":"MapLibre","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"title":"MLNStyle","type":"topic","url":"\/documentation\/maplibre\/mlnstyle","fragments":[{"text":"MLNStyle","kind":"identifier"}],"abstract":[{"text":"The proxy object for the current map style.","type":"text"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSource/initWithIdentifier:dataSource:options:":{"title":"initWithIdentifier:dataSource:options:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource\/initWithIdentifier:dataSource:options:","navigatorTitle":[{"text":"initWithIdentifier:dataSource:options:","kind":"identifier"}],"role":"symbol","type":"topic","abstract":[{"type":"text","text":"Returns a custom shape data source initialized with an identifier, data source, and a"},{"type":"text","text":" "},{"type":"text","text":"dictionary of options for the source according to the"},{"type":"text","text":" "},{"type":"text","text":"style"},{"type":"text","text":" "},{"type":"text","text":"specification"},{"type":"text","text":"."}],"kind":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:dataSource:options:","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlncomputedshapesource\/initwithidentifier:datasource:options:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMinimumZoomLevel":{"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMinimumZoomLevel","title":"MLNShapeSourceOptionMinimumZoomLevel","abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing an integer; specifies the minimum zoom level at","type":"text"},{"text":" ","type":"text"},{"text":"which to create vector tiles. The default value is 0.","type":"text"}],"fragments":[{"text":"MLNShapeSourceOptionMinimumZoomLevel","kind":"identifier"}],"type":"topic","url":"\/documentation\/maplibre\/mlnshapesourceoptionminimumzoomlevel","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSource":{"title":"MLNComputedShapeSource","type":"topic","url":"\/documentation\/maplibre\/mlncomputedshapesource","kind":"symbol","role":"symbol","fragments":[{"kind":"identifier","text":"MLNComputedShapeSource"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource"},{"type":"text","text":" is a map content source that supplies vector shapes,"},{"type":"text","text":" "},{"type":"text","text":"one tile at a time, to be shown on the map on demand. You implement a class"},{"type":"text","text":" "},{"type":"text","text":"conforming to the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource"},{"type":"text","text":" protocol that returns"},{"type":"text","text":" "},{"type":"text","text":"instances of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":" or "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":", then add a computed shape source to an"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object along with an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the computed shape"},{"type":"text","text":" "},{"type":"text","text":"source."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionBuffer":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionBuffer","url":"\/documentation\/maplibre\/mlnshapesourceoptionbuffer","abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing an integer; specifies the size of the tile","type":"text"},{"text":" ","type":"text"},{"text":"buffer on each side. A value of 0 produces no buffer. A value of 512 produces a","type":"text"},{"text":" ","type":"text"},{"text":"buffer as wide as the tile itself. Larger values produce fewer rendering","type":"text"},{"text":" ","type":"text"},{"text":"artifacts near tile edges and slower performance. The default value is 128.","type":"text"}],"type":"topic","role":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionBuffer"}],"title":"MLNShapeSourceOptionBuffer","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSourceDataSource":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource","type":"topic","fragments":[{"text":"MLNComputedShapeSourceDataSource","kind":"identifier"}],"title":"MLNComputedShapeS