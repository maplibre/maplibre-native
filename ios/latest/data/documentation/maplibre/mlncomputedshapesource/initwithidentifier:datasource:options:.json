ext":"MLNShapeSourceOptionBuffer","kind":"identifier"}],"title":"MLNShapeSourceOptionBuffer","abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing an integer; specifies the size of the tile","type":"text"},{"text":" ","type":"text"},{"text":"buffer on each side. A value of 0 produces no buffer. A value of 512 produces a","type":"text"},{"text":" ","type":"text"},{"text":"buffer as wide as the tile itself. Larger values produce fewer rendering","type":"text"},{"text":" ","type":"text"},{"text":"artifacts near tile edges and slower performance. The default value is 128.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSourceDataSource":{"role":"symbol","url":"\/documentation\/maplibre\/mlncomputedshapesourcedatasource","abstract":[{"type":"text","text":"Data source for "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource"},{"type":"text","text":". This protocol defines two optional methods for fetching"},{"type":"text","text":" "},{"type":"text","text":"data, one based on tile coordinates, and one based on a bounding box. Classes that implement this"},{"type":"text","text":" "},{"type":"text","text":"protocol must implement one, and only one of the methods. Methods on this protocol will not be"},{"type":"text","text":" "},{"type":"text","text":"called on main thread, they will be called on the caller’s "},{"type":"codeVoice","code":"requestQueue"},{"type":"text","text":"."}],"title":"MLNComputedShapeSourceDataSource","fragments":[{"text":"MLNComputedShapeSourceDataSource","kind":"identifier"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"role":"symbol","title":"MLNShape","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","url":"\/