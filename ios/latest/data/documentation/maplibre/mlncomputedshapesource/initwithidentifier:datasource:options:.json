t","text":" "},{"type":"text","text":"protocol must implement one, and only one of the methods. Methods on this protocol will not be"},{"type":"text","text":" "},{"type":"text","text":"called on main thread, they will be called on the caller’s "},{"type":"codeVoice","code":"requestQueue"},{"type":"text","text":"."}],"title":"MLNComputedShapeSourceDataSource","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionClipsCoordinates":{"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClipsCoordinates","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing a Boolean value; specifies whether the shape of"},{"type":"text","text":" "},{"type":"text","text":"an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource"},{"type":"text","text":" should be clipped at the edge of each tile. The"},{"type":"text","text":" "},{"type":"text","text":"default value is "},{"type":"codeVoice","code":"NO"},{"type":"text","text":"."}],"type":"topic","url":"\/documentation\/maplibre\/mlnshapesourceoptionclipscoordinates","title":"MLNShapeSourceOptionClipsCoordinates","fragments":[{"text":"MLNShapeSourceOptionClipsCoordinates","kind":"identifier"}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"title":"MLNStyle","kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","url":"\/documentation\/maplibre\/mlnstyle","fragments":[{"kind":"identifier","text":"MLNStyle"}],"abstract":[{"type":"text","text":"The proxy object for the current map style."}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"kind":"symbol","type":"topic","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","fragments":[{"kind":"identifier","text":"MLN