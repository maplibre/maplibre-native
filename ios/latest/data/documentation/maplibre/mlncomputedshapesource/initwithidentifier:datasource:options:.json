://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionWrapsCoordinates":{"fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionWrapsCoordinates"}],"title":"MLNShapeSourceOptionWrapsCoordinates","kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionwrapscoordinates","type":"topic","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionWrapsCoordinates","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing a Boolean value; specifies whether the shape of"},{"type":"text","text":" "},{"type":"text","text":"an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource"},{"type":"text","text":" should be wrapped to accomodate coordinates with"},{"type":"text","text":" "},{"type":"text","text":"longitudes beyond −180 and 180. The default value is "},{"type":"codeVoice","code":"NO"},{"type":"text","text":"."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionMinimumZoomLevel":{"kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"MLNShapeSourceOptionMinimumZoomLevel","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnshapesourceoptionminimumzoomlevel","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing an integer; specifies the minimum zoom level at"},{"type":"text","text":" "},{"type":"text","text":"which to create vector tiles. The default value is 0."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionMinimumZoomLevel","title":"MLNShapeSourceOptionMinimumZoomLevel"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionBuffer":{"url":"\/documentation\/maplibre\/mlnshapesourceoptionbuffer","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","t