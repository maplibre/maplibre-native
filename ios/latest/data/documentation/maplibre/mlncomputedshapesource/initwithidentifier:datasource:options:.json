ype":"text","text":" "},{"type":"text","text":"an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","type":"reference","isActive":true},{"type":"text","text":" should be wrapped to accomodate coordinates with"},{"type":"text","text":" "},{"type":"text","text":"longitudes beyond −180 and 180. The default value is "},{"code":"NO","type":"codeVoice"},{"type":"text","text":"."}],"type":"topic","kind":"symbol","role":"symbol","title":"MLNShapeSourceOptionWrapsCoordinates","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionWrapsCoordinates","url":"\/documentation\/maplibre\/mlnshapesourceoptionwrapscoordinates","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionWrapsCoordinates"}]}}}