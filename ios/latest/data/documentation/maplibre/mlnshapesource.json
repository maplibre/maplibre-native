"},{"text":"layer defines the appearance of any content supplied by the computed shape","type":"text"},{"text":" ","type":"text"},{"text":"source.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterDEMSource":{"url":"\/documentation\/maplibre\/mlnrasterdemsource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterDEMSource","kind":"symbol","role":"symbol","fragments":[{"text":"MLNRasterDEMSource","kind":"identifier"}],"type":"topic","title":"MLNRasterDEMSource","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterDEMSource"},{"type":"text","text":" is a map content source that supplies rasterized"},{"type":"text","text":" "},{"type":"text","text":"digital elevation model"},{"type":"text","text":" "},{"type":"text","text":"(DEM) tiles to be shown on the map. The location of and metadata about the"},{"type":"text","text":" "},{"type":"text","text":"tiles are defined either by an option dictionary or by an external file that"},{"type":"text","text":" "},{"type":"text","text":"conforms to the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A raster DEM source is added to an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"},{"type":"text","text":" or "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNColorReliefStyleLayer"},{"type":"text","text":" objects. Use a hillshade"},{"type":"text","text":" "},{"type":"text","text":