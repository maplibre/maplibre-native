/documentation/MapLibre/MLNStyle/addSource:":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","abstract":[{"type":"text","text":"Adds a new source to the current style."}],"role":"symbol","url":"\/documentation\/maplibre\/mlnstyle\/addsource:","type":"topic","title":"addSource:","kind":"symbol","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"addSource:"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNCluster":{"url":"\/documentation\/maplibre\/mlncluster","role":"symbol","fragments":[{"kind":"identifier","text":"MLNCluster"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCluster","type":"topic","kind":"symbol","title":"MLNCluster","abstract":[{"type":"text","text":"A protocol that feature subclasses (i.e. those already conforming to"},{"type":"text","text":" "},{"type":"text","text":"the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature","isActive":true,"type":"reference"},{"type":"text","text":" protocol) conform to if they represent clusters."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterDEMSource":{"kind":"symbol","fragments":[{"kind":"identifier","text":"MLNRasterDEMSource"}],"title":"MLNRasterDEMSource","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterDEMSource","isActive":true,"type":"reference"},{"type":"text","text":" is a map content source that supplies rasterized"},{"type":"text","text":" "},{"type":"text","text":"digital elevation model"},{"type":"text","text":" "},{"type":"text","text":"(DEM) tiles to be shown on the map. The location of and metadata about the"},{"type":"text","text":" "},{"type":"text","text":"tiles are defined either by an option dictionary or by an external file that"},{"type":"text","text":" "},{"type":"text","text":"conforms to the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A raster DEM source is added to an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true,"type":"reference"},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","isActive":true,"type":"reference"},{"type":"text","text":" or "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNColorReliefStyleLayer","isActive":true,"type":"reference"},{"type":"text","text":" objects. Use a hillshade"},{"type":"text","text":" "},{"type":"text","text":"style layer to control the appearance of content supplied by the raster DEM source,"},{"type":"text","text":" "},{"type":"text","text":"or a color relief style layer to render elevation data with a color ramp."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterDEMSource","type":"topic","role":"symbol","url":"\/documentation\/maplibre\/mlnrasterdemsource"}}}