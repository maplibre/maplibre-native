":[{"text":"MLNRasterStyleLayer","kind":"identifier"}],"type":"topic","url":"\/documentation\/maplibre\/mlnrasterstylelayer","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","isActive":true,"type":"reference"},{"type":"text","text":" is a style layer that renders georeferenced raster"},{"type":"text","text":" "},{"type":"text","text":"imagery on the map, especially raster tiles."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/URL":{"fragments":[{"text":"URL","kind":"identifier"}],"abstract":[{"text":"The URL to the GeoJSON document that specifies the contents of the source.","type":"text"}],"role":"symbol","title":"URL","type":"topic","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/URL","url":"\/documentation\/maplibre\/mlnshapesource\/url"},"doc://org.swift.MyProject/documentation/MapLibre/MLNImageSource":{"fragments":[{"text":"MLNImageSource","kind":"identifier"}],"role":"symbol","url":"\/documentation\/maplibre\/mlnimagesource","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNImageSource","title":"MLNImageSource","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNImageSource","type":"reference","isActive":true},{"type":"text","text":" is a content source that is used for a georeferenced raster"},{"type":"text","text":" "},{"type":"text","text":"image to be shown on the map. The georeferenced image scales and rotates as the"},{"type":"text","text":" "},{"type":"text","text":"user zooms and rotates the map. Images may also be used as icons or patterns"},{"type":"text","text":" "},{"type":"text","text":"in a style layer. To register an image for use as an icon or pattern,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/setImage:forName:","type":"reference","isActive":true},{"type":"text","text":" method. To configure a point"},{"type":"text","text":" "},{"type":"text","text":"annotation’s image, use the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage","type":"reference","isActive":true},{"type":"text","text":" class."}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/initWithIdentifier:URL:options:":{"type":"topic","fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:URL:options:","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/initWithIdentifier:URL:options:","navigatorTitle":[{"text":"initWithIdentifier:URL:options:","kind":"identifier"}],"role":"symbol","title":"initWithIdentifier:URL:options:","url":"\/documentation\/maplibre\/mlnshapesource\/initwithidentifier:url:options:","kind":"symbol","abstract":[{"type":"text","text":"Returns a shape source with an identifier, URL, and dictionary of options for"},{"type":"text","text":" "},{"type":"text","text":"the source."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterDEMSource":{"url":"\/documentation\/maplibre\/mlnrasterdemsource","abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterDEMSource","isActive":true},{"type":"text","text":" is a map content source that supplies rasterized"},{"type":"text","text":" "},{"type":"text","text":"digital elevation model"},{"type":"text","text":" "},{"type":"text","text":"(DEM) tiles to be shown on the map. The location of and metadata about the"},{"type":"text","text":" "},{"type":"text","text":"tiles are defined either by an option dictionary or by an external file that"},{"type":"text","text":" "},{"type":"text","text":"conforms to the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A raster DEM source is added to an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNColorReliefStyleLayer","isActive":true},{"type":"text","text":" objects. Use a hillshade"},{"type":"text","text":" "},{"type":"text","text":"style layer to control the appearance of content supplied by the raster DEM source,"},{"type":"text","text":" "},{"type":"text","text":"or a color relief style layer to render elevation data with a color ramp."}],"role":"symbol","fragments":[{"text":"MLNRasterDEMSource","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterDEMSource","type":"topic","kind":"symbol","title":"MLNRasterDEMSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/addSource:":{"url":"\/documentation\/maplibre\/mlnstyle\/addsource:","title":"addSource:","type":"topic","role":"symbol","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"addSource:"}],"navigatorTitle":[{"kind":"identifier","text":"addSource:"}],"abstract":[{"text":"Adds a new source to the current style.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyleLayer":{"title":"MLNHillshadeStyleLayer","role":"symbol","fragments":[{"text":"MLNHillshadeStyleLayer","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnhillshadestylelayer","type":"topic","kind":"symbol","abstract":[{"text":"An ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyle