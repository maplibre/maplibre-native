entation\/MapLibre\/MLNStyle","isActive":true,"type":"reference"},{"type":"text","text":" object. The"},{"type":"text","text":" "},{"type":"text","text":"foreground style layer defines the appearance of any content supplied by the"},{"type":"text","text":" "},{"type":"text","text":"source."}],"url":"\/documentation\/maplibre\/mlnsource","type":"topic","role":"symbol","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSource","fragments":[{"text":"MLNSource","kind":"identifier"}],"title":"MLNSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/featuresMatchingPredicate:":{"abstract":[{"text":"Returns an array of map features for this source, filtered by the given","type":"text"},{"text":" ","type":"text"},{"text":"predicate.","type":"text"}],"kind":"symbol","role":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"featuresMatchingPredicate:","kind":"identifier"}],"title":"featuresMatchingPredicate:","navigatorTitle":[{"text":"featuresMatchingPredicate:","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/featuresMatchingPredicate:","url":"\/documentation\/maplibre\/mlnshapesource\/featuresmatchingpredicate:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"title":"MLNShape","kind":"symbol","fragments":[{"text":"MLNShape","kind":"identifier"}],"abstract":[{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference"},{"text":" is an abstract class that represents a shape or annotation. Shapes","type":"text"},{"text":" ","type":"text"},{"text":"constitute the content of a map — not only the overlays atop the map, but also","type":"text"},{"text":" ","type":"text"},{"text":"the content that forms the base map.","type":"text"}],"role":"symbol","url":"\/documentation\/maplibre\/mlnshape","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSha