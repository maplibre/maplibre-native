ionary or by an external file that conforms to"},{"type":"text","text":" "},{"type":"text","text":"the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A raster tile source is added to an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer"},{"type":"text","text":" objects. Use a raster style layer to control the"},{"type":"text","text":" "},{"type":"text","text":"appearance of content supplied by the raster tile source."}],"title":"MLNRasterTileSource","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","url":"\/documentation\/maplibre\/mlnrastertilesource","fragments":[{"kind":"identifier","text":"MLNRasterTileSource"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/initWithIdentifier:shapes:options:":{"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/initWithIdentifier:shapes:options:","title":"initWithIdentifier:shapes:options:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"initWithIdentifier:shapes:options:"}],"navigatorTitle":[{"kind":"identifier","text":"initWithIdentifier:shapes:options:"}],"type":"topic","url":"\/documentation\/maplibre\/mlnshapesource\/initwithidentifier:shapes:options:","abstract":[{"type":"text","text":"Returns a shape source with an identifier, an array of shapes, and a dictionary of"},{"type":"text","text":" "},{"type":"text","text":"options for the source."}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNSource":{"role":"symbol","url":"\/documentation\/maplibre\/mlnsource","abstract":[{"identifier