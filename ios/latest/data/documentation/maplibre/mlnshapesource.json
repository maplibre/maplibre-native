e\/MLNRasterStyleLayer"},{"type":"text","text":" is a style layer that renders georeferenced raster"},{"type":"text","text":" "},{"type":"text","text":"imagery on the map, especially raster tiles."}],"fragments":[{"kind":"identifier","text":"MLNRasterStyleLayer"}],"type":"topic","url":"\/documentation\/maplibre\/mlnrasterstylelayer"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/childrenOfCluster:":{"kind":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"childrenOfCluster:","kind":"identifier"}],"type":"topic","url":"\/documentation\/maplibre\/mlnshapesource\/childrenofcluster:","navigatorTitle":[{"text":"childrenOfCluster:","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/childrenOfCluster:","title":"childrenOfCluster:","role":"symbol","abstract":[{"text":"Returns an array of map features that are the immediate children of the specified","type":"text"},{"text":" ","type":"text"},{"text":"cluster ","type":"text"},{"inlineContent":[{"text":"on the next zoom level","type":"text"}],"type":"emphasis"},{"text":". The may include features that also conform to","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCluster","isActive":true,"type":"reference"},{"text":" protocol (currently only objects of type ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCluster","isActive":true,"type":"reference"},{"text":").","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNImageSource":{"fragments":[{"text":"MLNImageSource","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnimagesource","type":"topic","role":"symbol","title":"MLNImageSource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNImageSource","abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNImageSource","isActive":true},{"type":"text","text":" is a content source that is used for a georeferenced raster"},{"type":"text","text":" "},{"type":"text","text":"image to be shown on the map. The georeferenced image scales and rotates as the"},{"type":"text","text":" "},{"type":"text","text":"user zooms and rotates the map. Images may also be used as icons or patterns"},{"type":"text","text":" "},{"type":"text","text":"in a style layer. To register an image for use as an icon or pattern,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/setImage:forName:","isActive":true},{"type":"text","text":" method. To configure a point"},{"type":"text","text":" "},{"type":"text","text":"annotation’s image, use the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage","isActive":true},{"type":"text","text":" class."}],"kind":"symbol"}}}