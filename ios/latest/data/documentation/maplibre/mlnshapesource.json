isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer"},{"text":" objects. Use a style layer to","type":"text"},{"text":" ","type":"text"},{"text":"control the appearance of content supplied by the tile source.","type":"text"}],"fragments":[{"kind":"identifier","text":"MLNTileSource"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNColorReliefStyleLayer":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNColorReliefStyleLayer","fragments":[{"text":"MLNColorReliefStyleLayer","kind":"identifier"}],"title":"MLNColorReliefStyleLayer","abstract":[{"type":"text","text":"Client-side elevation coloring based on DEM data. The implementation supports"},{"type":"text","text":" "},{"type":"text","text":"Mapbox Terrain RGB, Mapzen Terrarium tiles and custom encodings."}],"url":"\/documentation\/maplibre\/mlncolorreliefstylelayer","role":"symbol","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/sourceWithIdentifier:":{"kind":"symbol","url":"\/documentation\/maplibre\/mlnstyle\/sourcewithidentifier:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"sourceWithIdentifier:"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/sourceWithIdentifier:","type":"topic","title":"sourceWithIdentifier:","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"sourceWithIdentifier:"}],"abstract":[{"text":"Returns a source with the given identifier in the current style.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotationImage":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage","url":"\/documentation\/maplibre\/mlnannotationimage","kind":"symbol","role":"symbol","fragments":[{"text":"MLNAnnotationImage","kind":"identifier"}],"title":"MLNAnnotationImage","type":"topic","abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage","isActive":true},{"type":"text","text":" class is responsible for presenting point-based"},{"type":"text","text":" "},{"type":"text","text":"annotations visually on a map view. Annotation image objects wrap "},{"type":"codeVoice","code":"UIImage"},{"type":"text","text":" "},{"type":"text","text":"objects and may be recycled later and put into a reuse queue that is maintained"},{"type":"text","text":" "},{"type":"text","text":"by the map view."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/initWithIdentifier:URL:options:":{"url":"\/documentation\/maplibre\/mlnshapesource\/initwithidentifier:url:options:","fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:URL:options:","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/initWithIdentifier:URL:options:","navigatorTitle":[{"text":"initWithIdentifier:URL:options:","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"text","text":"Returns a shape source with an identifier, URL, and dictionary of options for"},{"type":"text","text":" "},{"type":"text","text":"the source."}],"title":"initWithIdentifier:URL:options:","role":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"title":"MLNShapeSource","type":"topic","kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesource","abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true},{"type":"text","text":" is a map content source that supplies vector shapes to be"},{"type":"text","text":" "},{"type":"text","text":"shown on the map. The shapes may be instances of "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or they may be defined by local or external"},{"type":"text","text":" "},{"type":"text","text":"GeoJSON"},{"type":"text","text":" code. A shape source is added to an"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object along with an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the shape source. You"},{"type":"text","text":" "},{"type":"text","text":"can update a shape source by setting its "},{"code":"shape","type":"codeVoice"},{"type":"text","text":" or "},{"code":"URL","type":"codeVoice"},{"type":"text","text":" property."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","fragments":[{"text":"MLNShapeSource","kind":"identifier"}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"url":"\/documentation\/maplibre\/mlnstyle","fragments":[{"kind":"identifier","text":"MLNStyle"}],"title":"MLNStyle","abstract":[{"text":"The proxy object for the current map style.","type":"text"}],"role":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNImageSource":{"role":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNImageSource","kind":"symbol","url":"\/documentation\/maplibre\/mlnimagesource","fragments":[{"kind":"identifier","text":"MLNImageSource"}],"title":"MLNImageSource","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNImageSource"},{"text":" is a content source that is used for a georeferenced raster","type":"text"},{"text":" ","type":"text"},{"text":"image to be shown on the map. The georeferenced image scales and rotates as the","type":"text"},{"text":" ","type":"text"},{"text":"user zooms and rotates the map. Images may also be used as icons or patterns","type":"text"},{"text":" ","type":"text"},{"text":"in a style layer. To register an image for use as an icon or pattern,","type":"text"},{"text":" ","type":"text"},{"text":"use the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/setImage:forName:"},{"text":" method. To configure a point","type":"text"},{"text":" ","type":"text"},{"text":"annotation’s image, use the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage"},{"text":" class.","type":"text"}]}}}