is a content source that is used for a georeferenced raster"},{"type":"text","text":" "},{"type":"text","text":"image to be shown on the map. The georeferenced image scales and rotates as the"},{"type":"text","text":" "},{"type":"text","text":"user zooms and rotates the map. Images may also be used as icons or patterns"},{"type":"text","text":" "},{"type":"text","text":"in a style layer. To register an image for use as an icon or pattern,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/setImage:forName:","isActive":true},{"type":"text","text":" method. To configure a point"},{"type":"text","text":" "},{"type":"text","text":"annotation’s image, use the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage","isActive":true},{"type":"text","text":" class."}],"role":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnimagesource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNImageSource","fragments":[{"kind":"identifier","text":"MLNImageSource"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"abstract":[{"text":"The proxy object for the current map style.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","kind":"symbol","role":"symbol","type":"topic","title":"MLNStyle","fragments":[{"kind":"identifier","text":"MLNStyle"}],"url":"\/documentation\/maplibre\/mlnstyle"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/setImage:forName:":{"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/setImage:forName:","navigatorTitle":[{"text":"setImage:forName:","kind":"identifier"}],"type":"topic","role":"symbol","url":"\/documentation\/maplibre\/mlnstyle\/setimage:forname:","title":"setImage:forName:","fragments":[{"text":"- ","kind":"text"},{"text":"setImage:forName:","kind":"identifier"}],"abstract":[{"type":"text","text":"Adds or overrides an image used by the style’s layers."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSourceDataSource":{"role":"symbol","abstract":[{"type":"text","text":"Data source for "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","isActive":true},{"type":"text","text":". This protocol defines two optional methods for fetching"},{"type":"text","text":" "},{"type":"text","text":"data, one based on tile coordinates, and one based on a bounding box. Classes that implement this"},{"type":"text","text":" "},{"type":"text","text":"protocol must implement one, and only one of the methods. Methods on this protocol will not be"},{"type":"text","text":" "},{"type":"text","text":"called on main thread, they will be called on the caller’s "},{"code":"requestQueue","type":"codeVoice"},{"type":"text","text":"."}],"title":"MLNComputedShapeSourceDataSource","type":"topic","fragments":[{"text":"MLNComputedShapeSourceDataSource","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlncomputedshapesourcedatasource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/initWithIdentifier:shapes:options:":{"abstract":[{"type":"text","text":"Returns a shape source with an identifier, an array of shapes, and a dictionary of"},{"type":"text","text":" "},{"type":"text","text":"options for the source."}],"kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlnshapesource\/initwithidentifier:shapes:options:","title":"initWithIdentifier:shapes:options:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/initWithIdentifier:shapes:options:","type":"topic","fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:shapes:options:","kind":"identifier"}],"navigatorTitle":[{"text":"initWithIdentifier:shapes:options:","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotationImage":{"fragments":[{"kind":"identifier","text":"MLNAnnotationImage"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage","type":"topic","abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage","isActive":true},{"type":"text","text":" class is responsible for presenting point-based"},{"type":"text","text":" "},{"type":"text","text":"annotations visually on a map view. Annotation image objects wrap "},{"type":"codeVoice","code":"UIImage"},{"type":"text","text":" "},{"type":"text","text":"objects and may be recycled later and put into a reuse queue that is maintained"},{"type":"text","text":" "},{"type":"text","text":"by the map view."}],"role":"symbol","title":"MLNAnnotationImage","kind":"symbol","url":"\/documentation\/maplibre\/mlnannotationimage"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterDEMSource":{"url":"\/documentation\/maplibre\/mlnrasterdemsource","abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterDEMSource","isActive":true},{"type":"text","text":" is a map content source that supplies rasterized"},{"type":"text","text":" "},{"type":"text","text":"digital elevation model"},{"type":"text","text":" "},{"type":"text","text":"(DEM) tiles to be shown on the map. The location of and metadata about the"},{"type":"text","text":" "},{"type":"text","text":"tiles are defined either by an option dictionary or by an external file that"},{"type":"text","text":" "},{"type":"text","text":"conforms to the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A raster DEM source is added to an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNColorReliefStyleLayer","isActive":true},{"type":"text","text":" objects. Use a hillshade"},{"type":"text","text":" "},{"type":"text","text":"style layer to control the appearance of content supplied by the raster DEM source,"},{"type":"text","text":" "},{"type":"text","text":"or a color relief style layer to render elevation data with a color ramp."}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterDEMSource","type":"topic","fragments":[{"kind":"identifier","text":"MLNRasterDEMSource"}],"title":"MLNRasterDEMSource"}}}