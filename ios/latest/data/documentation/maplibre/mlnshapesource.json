s for"},{"type":"text","text":" "},{"type":"text","text":"the source."}]},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection","type":"topic","url":"\/documentation\/maplibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNImageSource":{"url":"\/documentation\/maplibre\/mlnimagesource","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNImageSource","kind":"symbol","title":"MLNImageSource","fragments":[{"text":"MLNImageSource","kind":"identifier"}],"abstract":[{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNImageSource","type":"reference"},{"text":" is a content source that is used for a georeferenced raster","type":"text"},{"text":" ","type":"text"},{"text":"image to be shown on the map. The georeferenced image scales and rotates as the","type":"text"},{"text":" ","type":"text"},{"text":"user zooms and rotates the map. Images may also be used as icons or patterns","type":"text"},{"text":" ","type":"text"},{"text":"in a style layer. To register an image for use as an icon or pattern,","type":"text"},{"text":" ","type":"text"},{"text":"use the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/setImage:forName:","type":"reference"},{"text":" method. To configure a point","type":"text"},{"text":" ","type":"text"},{"text":"annotation’s image, use the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage","type":"reference"},{"text":" class.","type":"text"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSourceDataSource":{"abstract":[{"text":"Data source for ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","isActive":true},{"text":". This protocol defines two optional methods for fetching","type":"text"},{"text":" ","type":"text"},{"text":"data, one based on tile coordinates, and one based on a bounding box. Classes that implement this","type":"text"},{"text":" ","type":"text"},{"text":"protocol must implement one, and only one of the methods. Methods on this protocol will not be","type":"text"},{"text":" ","type":"text"},{"text":"called on main thread, they will be called on the caller’s ","type":"text"},{"type":"codeVoice","code":"requestQueue"},{"text":".","type":"text"}],"kind":"symbol","fragments":[{"text":"MLNComputedShapeSourceDataSource","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlncomputedshapesourcedatasource","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource","role":"symbol","title":"MLNComputedShapeSourceDataSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterDEMSource":{"fragments":[{"text":"MLNRasterDEMSource","kind":"identifier"}],"abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterDEMSource","isActive":true,"type":"reference"},{"text":" is a map content source that supplies rasterized","type":"text"},{"text":" ","type":"text"},{"text":"digital elevation model","type":"text"},{"text":" ","type":"text"},{"text":"(DEM) tiles to be shown on the map. The location of and metadata about the","type":"text"},{"text":" ","type":"text"},{"text":"tiles are defined either by an option dictionary or by an external file that","type":"text"},{"text":" ","type":"text"},{"text":"conforms to the","type":"text"},{"text":" ","type":"text"},{"text":"TileJSON specification","type":"text"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"A raster DEM source is added to an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true,"type":"reference"},{"text":" object along with one or more","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","isActive":true,"type":"reference"},{"text":" or ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNColorReliefStyleLayer","isActive":true,"type":"reference"},{"text":" objects. Use a hillshade","type":"text"},{"text":" ","type":"text"},{"text":"style layer to control the appearance of content supplied by the raster DEM source,","type":"text"},{"text":" ","type":"text"},{"text":"or a color relief style layer to render elevation data with a color ramp.","type":"text"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnrasterdemsource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterDEMSource","role":"symbol","type":"topic","title":"MLNRasterDEMSource"}}}