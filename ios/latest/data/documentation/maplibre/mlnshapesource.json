MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","isActive":true},{"type":"text","text":" objects. Use a raster style layer to control the"},{"type":"text","text":" "},{"type":"text","text":"appearance of content supplied by the raster tile source."}],"title":"MLNRasterTileSource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","fragments":[{"text":"MLNRasterTileSource","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/leavesOfCluster:offset:limit:":{"role":"symbol","type":"topic","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"leavesOfCluster:offset:limit:"}],"abstract":[{"text":"Returns an array of map features that are the leaves of the specified cluster.","type":"text"},{"text":" ","type":"text"},{"text":"(“Leaves” are the original points that belong to the cluster.)","type":"text"}],"title":"leavesOfCluster:offset:limit:","url":"\/documentation\/maplibre\/mlnshapesource\/leavesofcluster:offset:limit:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"leavesOfCluster:offset:limit:"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/leavesOfCluster:offset:limit:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNCluster":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCluster","kind":"symbol","abstract":[{"type":"text","text":"A protocol that feature subclasses (i.e. those already conforming to"},{"type":"text","text":" "},{"type":"text","text":"the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature","type":"reference","isActive":true},{"type":"text","text":" protocol) conform to if they represent clusters."}],"url":"\/documentation\/maplibre\/mlncluster","role":"symbol","fragments":[{"kind":"identifier","text":"MLNCluster"}],"type":"topic","title":"MLNCluster"}}}