n"},{"type":"text","text":" "},{"type":"text","text":"option dictionary or by an external file that conforms to the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A tile source is added to an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer"},{"type":"text","text":" or "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer"},{"type":"text","text":" objects. Use a style layer to"},{"type":"text","text":" "},{"type":"text","text":"control the appearance of content supplied by the tile source."}],"url":"\/documentation\/maplibre\/mlntilesource","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/leavesOfCluster:offset:limit:":{"type":"topic","abstract":[{"type":"text","text":"Returns an array of map features that are the leaves of the specified cluster."},{"type":"text","text":" "},{"type":"text","text":"(“Leaves” are the original points that belong to the cluster.)"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/leavesOfCluster:offset:limit:","role":"symbol","title":"leavesOfCluster:offset:limit:","url":"\/documentation\/maplibre\/mlnshapesource\/leavesofcluster:offset:limit:","kind":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"leavesOfCluster:offset:limit:","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/featuresMatchingPredicate:":{"type":"topic","abstract":[{"type":"text","text":"Returns an array of map features for this source, filtered by the given"},{"type":"text","text":" "},{"type":"text","text