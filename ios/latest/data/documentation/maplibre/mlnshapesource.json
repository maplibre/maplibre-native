,"text":"by the map view."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/shape":{"url":"\/documentation\/maplibre\/mlnshapesource\/shape","type":"topic","kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape","title":"shape","abstract":[{"type":"text","text":"The contents of the source. A shape can represent a GeoJSON geometry, a"},{"type":"text","text":" "},{"type":"text","text":"feature, or a collection of features."}],"fragments":[{"text":"shape","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/zoomLevelForExpandingCluster:":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/zoomLevelForExpandingCluster:","title":"zoomLevelForExpandingCluster:","abstract":[{"text":"Returns the zoom level at which the given cluster expands.","type":"text"}],"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"zoomLevelForExpandingCluster:"}],"role":"symbol","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"zoomLevelForExpandingCluster:"}],"url":"\/documentation\/maplibre\/mlnshapesource\/zoomlevelforexpandingcluster:"},"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol","url":"\/documentation\/maplibre","role":"collection","title":"MapLibre","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTileSource":{"fragments":[{"text":"MLNTileSource","kind":"identifier"}],"type":"topic","title":"MLNTileSource","abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSource","isActive":true},{"type":"text","text":" is a map content source that supplies map tiles to be shown on"},{"type":"text","text":" "},{"type":"text","text":"the map. The location of and metadata about the tiles are defined either by an"},{"type":"text","text":" "},{"type":"text","text":"option dictionary or by an external file that conforms to the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A tile source is added to an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","isActive":true},{"type":"text","text":" objects. Use a style layer to"},{"type":"text","text":" "},{"type":"text","text":"control the appearance of content supplied by the tile source."}],"kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlntilesource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNCluster":{"abstract":[{"text":"A protocol that feature subclasses (i.e. those already conforming to","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature"},{"text":" protocol) conform to if they represent clusters.","type":"text"}],"title":"MLNCluster","url":"\/documentation\/maplibre\/mlncluster","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCluster","fragments":[{"kind":"identifier","text":"MLNCluster"}],"role":"symbol","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"url":"\/documentation\/maplibre\/mlnshapesour