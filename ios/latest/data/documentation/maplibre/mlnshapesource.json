/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","isActive":true},{"type":"text","text":" objects. Use a raster style layer to control the"},{"type":"text","text":" "},{"type":"text","text":"appearance of content supplied by the raster tile source."}],"url":"\/documentation\/maplibre\/mlnrastertilesource","role":"symbol","fragments":[{"text":"MLNRasterTileSource","kind":"identifier"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterDEMSource":{"fragments":[{"kind":"identifier","text":"MLNRasterDEMSource"}],"title":"MLNRasterDEMSource","kind":"symbol","url":"\/documentation\/maplibre\/mlnrasterdemsource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterDEMSource","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterDEMSource","type":"reference","isActive":true},{"type":"text","text":" is a map content source that supplies rasterized"},{"type":"text","text":" "},{"type":"text","text":"digital elevation model"},{"type":"text","text":" "},{"type":"text","text":"(DEM) tiles to be shown on the map. The location of and metadata about the"},{"type":"text","text":" "},{"type":"text","text":"tiles are defined either by an option dictionary or by an external file that"},{"type":"text","text":" "},{"type":"text","text":"conforms to the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A raster DEM source is added to an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","type":"reference","isActive":true},{"type":"text","text":" or "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNColorReliefStyleLayer","type":"reference","isActive":true},{"type":"text","text":" objects. Use a hillshade"},{"type":"text","text":" "},{"type":"text","text":"style layer to control the appearance of content supplied by the raster DEM source,"},{"type":"text","text":" "},{"type":"text","text":"or a color relief style layer to render elevation data with a color ramp."}],"type":"topic","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyleLayer":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","type":"topic","title":"MLNHillshadeStyleLayer","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","isActive":true,"type":"reference"},{"type":"text","text":" is a style layer that renders raster "},{"type":"text","text":"digital elevation"},{"type":"text","text":" "},{"type":"text","text":"model"},{"type":"text","text":" (DEM) tiles on the map."}],"fragments":[{"kind":"identifier","text":"MLNHillshadeStyleLayer"}],"url":"\/documentation\/maplibre\/mlnhillshadestylelayer","role":"symbol","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSourceDataSource":{"kind":"symbol","fragments":[{"kind":"identifier","text":"MLNComputedShapeSourceDataSource"}],"abstract":[{"type":"text","text":"Data source for "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","isActive":true},{"type":"text","text":". This protocol defines two optional methods for fetching"},{"type":"text","text":" "},{"type":"text","text":"data, one based on tile coordinates, and one based on a bounding box. Classes that implement this"},{"type":"text","text":" "},{"type":"text","text":"protocol must implement one, and only one of the methods. Methods on this protocol will not be"},{"type":"text","text":" "},{"type":"text","text":"called on main thread, they will be called on the caller’s "},{"