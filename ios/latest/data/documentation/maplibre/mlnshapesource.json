,"type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNColorReliefStyleLayer","isActive":true,"type":"reference"},{"text":" objects. Use a hillshade","type":"text"},{"text":" ","type":"text"},{"text":"style layer to control the appearance of content supplied by the raster DEM source,","type":"text"},{"text":" ","type":"text"},{"text":"or a color relief style layer to render elevation data with a color ramp.","type":"text"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/leavesOfCluster:offset:limit:":{"type":"topic","abstract":[{"text":"Returns an array of map features that are the leaves of the specified cluster.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(“Leaves” are the original points that belong to the cluster.)"}],"navigatorTitle":[{"kind":"identifier","text":"leavesOfCluster:offset:limit:"}],"url":"\/documentation\/maplibre\/mlnshapesource\/leavesofcluster:offset:limit:","title":"leavesOfCluster:offset:limit:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"leavesOfCluster:offset:limit:"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/leavesOfCluster:offset:limit:","kind":"symbol","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"role":"symbol","abstract":[{"type":"text","text":"The proxy object for the current map style."}],"fragments":[{"kind":"identifier","text":"MLNStyle"}],"url":"\/documentation\/maplibre\/mlnstyle","title":"MLNStyle","kind":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotationImage":{"abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage"},{"type":"text","text":" class is responsible for presenting point-based"},{"type":"text","text":" "},{"type":"text","text":"annotations visually on a map view. Annotation image objects wrap "},{"type":"codeVoice","code":"UIImage"},{"type":"text","text":" "},{"type":"text","text":"objects and may be recycled later and put into a reuse queue that is maintained"},{"type":"text","text":" "},{"type":"text","text":"by the map view."}],"role":"symbol","fragments":[{"text":"MLNAnnotationImage","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnannotationimage","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage","kind":"symbol","title":"MLNAnnotationImage"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"abstract":[{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference"},{"text":" is an abstract class that represents a shape or annotation. Shapes","type":"text"},{"text":" ","type":"text"},{"text":"constitute the content of a map — not only the overlays atop the map, but also","type":"text"},{"text":" ","type":"text"},{"text":"the content that forms the base map.","type":"text"}],"fragments":[{"kind":"identifier","text":"MLNShape"}],"url":"\/documentation\/maplibre\/mlnshape","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","title":"MLNShape","kind":"symbol","type":"topic","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNColorReliefStyleLayer":{"role":"symbol","kind":"symbol","type":"topic","title":"MLNColorReliefStyleLayer","abstract":[{"type":"text","text":"Client-side elevation coloring based on DEM data. The implementation supports"},{"type":"text","text":" "},{"type":"text","text":"Mapbox Terrain RGB, Mapzen Terrarium tiles and custom encodings."}],"fragments":[{"text":"MLNColorReliefStyleLayer","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlncolorreliefstylelayer","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNColorReliefStyleLayer"},"doc://org.swift.MyProjec