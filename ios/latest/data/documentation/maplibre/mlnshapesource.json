ation’s image, use the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage","isActive":true},{"type":"text","text":" class."}],"url":"\/documentation\/maplibre\/mlnimagesource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","role":"symbol","title":"MLNStyle","type":"topic","url":"\/documentation\/maplibre\/mlnstyle","kind":"symbol","abstract":[{"text":"The proxy object for the current map style.","type":"text"}],"fragments":[{"text":"MLNStyle","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/initWithIdentifier:shape:options:":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/initWithIdentifier:shape:options:","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"Returns a shape source with an identifier, a shape, and dictionary of options"},{"type":"text","text":" "},{"type":"text","text":"for the source."}],"url":"\/documentation\/maplibre\/mlnshapesource\/initwithidentifier:shape:options:","type":"topic","fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:shape:options:","kind":"identifier"}],"title":"initWithIdentifier:shape:options:","navigatorTitle":[{"text":"initWithIdentifier:shape:options:","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource":{"fragments":[{"kind":"identifier","text":"MLNRasterTileSource"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","role":"symbol","url":"\/documentation\/maplibre\/mlnrastertilesource","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","type":"reference","isActive":true},{"type":"text","text":" is a map content source that supplies raster image tiles"},{"type":"text","text":" "},{"type":"text","text":"to be shown on the map. The location of and metadata about the tiles are"},{"type":"text","text":" "},{"type":"text","text":"defined either by an option dictionary or by an external file that conforms to"},{"type":"text","text":" "},{"type":"text","text":"the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A raster tile source is added to an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","type":"reference","isActive":true},{"type":"text","text":" objects. Use a raster style layer to control the"},{"type":"text","text":" "},{"type":"text","text":"appearance of content supplied by the raster tile source."}],"title":"MLNRasterTileSource","type":"topic"}}}