e immediate children of the specified","type":"text"},{"text":" ","type":"text"},{"text":"cluster ","type":"text"},{"inlineContent":[{"text":"on the next zoom level","type":"text"}],"type":"emphasis"},{"text":". The may include features that also conform to","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCluster","isActive":true,"type":"reference"},{"text":" protocol (currently only objects of type ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCluster","isActive":true,"type":"reference"},{"text":").","type":"text"}],"type":"topic","title":"childrenOfCluster:","navigatorTitle":[{"kind":"identifier","text":"childrenOfCluster:"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/childrenOfCluster:","role":"symbol","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"childrenOfCluster:"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesource\/childrenofcluster:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/URL":{"url":"\/documentation\/maplibre\/mlnshapesource\/url","type":"topic","kind":"symbol","role":"symbol","fragments":[{"kind":"identifier","text":"URL"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/URL","title":"URL","abstract":[{"type":"text","text":"The URL to the GeoJSON document that specifies the contents of the source."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/addSource:":{"type":"topic","role":"symbol","navigatorTitle":[{"text":"addSource:","kind":"identifier"}],"kind":"symbol","title":"addSource:","abstract":[{"text":"Adds a new source to the current style.","type":"text"}],"fragments":[{"text":"- ","kind":"text"},{"text":"addSource:","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","url":"\/documentation\/maplibre\/mlnstyle\/addsource:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNSource":{"role":"symbol","kind":"symbol","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSource"},{"type":"text","text":" is an abstract base class for map content sources. A map content"},{"type":"text","text":" "},{"type":"text","text":"source supplies content to be shown on the map. A source is added to an"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object along with an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object. The"},{"type":"text","text":" "},{"type":"text","text":"foreground style layer defines the appearance of any content supplied by the"},{"type":"text","text":" "},{"type":"text","text":"source."}],"url":"\/documentation\/maplibre\/mlnsource","title":"MLNSource","fragments":[{"text":"MLNSource","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource":{"abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","isActive":true},{"type":"text","text":" is a map content source that supplies raster image tiles"},{"type":"text","text":" "},{"type":"text","text":"to be shown on the map. The location of and metadata about the tiles are"},{"type":"text","text":" "},{"type":"text","text":"defined either by an option dictionary or by an external file that conforms to"},{"type":"text","text":" "},{"type":"text","text":"the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A raster tile source is added to an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","isActive":true},{"type":"text","text":" objects. Use a raster style layer to control the"},{"type":"text","text":" "},{"type":"text","text":"appearance of content supplied by the raster tile source."}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","type":"topic","fragments":[{"text":"MLNRasterTileSource","kind":"identifier"}],"title":"MLNRasterTileSource","url":"\/documentation\/maplibre\/mlnrastertilesource","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNImageSource":{"role":"symbol","url":"\/documentation\/maplibre\/mlnimagesource","fragments":[{"text":"MLNImageSource","kind":"identifier"}],"abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNImageSource","isActive":true,"type":"reference"},{"text":" is a content source that is used for a georeferenced raster","type":"text"},{"text":" ","type":"text"},{"text":"image to be shown on the map. The georeferenced image scales and rotates as the","type":"text"},{"text":" ","type":"text"},{"text":"user zooms and rotates the map. Images may also be used as icons or patterns","type":"text"},{"text":" ","type":"text"},{"text":"in a style layer. To register an image for use as an icon or pattern,","type":"text"},{"text":" ","type":"text"},{"text":"use the ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/setImage:forName:","isActive":true,"type":"reference"},{"text":" method. To configure a point","type":"text"},{"text":" ","type":"text"},{"text":"annotation’s image, use the ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage","isActive":true,"type":"reference"},{"text":" class.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNImageSource","title":"MLNImageSource","type":"topic","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyleLayer":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","url":"\/documentation\/maplibre\/mlnhillshadestylelayer","role":"symbol","abstract":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","isActive":true,"type":"reference"},{"text":" is a style layer that renders raster ","type":"text"},{"text":"digital elevation","type":"text"},{"text":" ","type":"text"},{"text":"model","type":"text"},{"text":" (DEM) tiles on the map.","type":"text"}],"kind":"symbol","type":"topic","fragments":[{"text":"MLNHillshadeStyleLayer","kind":"identifier"}],"title":"MLNHillshadeStyleLayer"}}}