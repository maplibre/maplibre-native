re\/MLNColorReliefStyleLayer","isActive":true},{"type":"text","text":" objects. Use a hillshade"},{"type":"text","text":" "},{"type":"text","text":"style layer to control the appearance of content supplied by the raster DEM source,"},{"type":"text","text":" "},{"type":"text","text":"or a color relief style layer to render elevation data with a color ramp."}],"title":"MLNRasterDEMSource","role":"symbol","fragments":[{"kind":"identifier","text":"MLNRasterDEMSource"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","url":"\/documentation\/maplibre\/mlnshapesource","abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true},{"type":"text","text":" is a map content source that supplies vector shapes to be"},{"type":"text","text":" "},{"type":"text","text":"shown on the map. The shapes may be instances of "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or they may be defined by local or external"},{"type":"text","text":" "},{"type":"text","text":"GeoJSON"},{"type":"text","text":" code. A shape source is added to an"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object along with an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the shape source. You"},{"type":"text","text":" "},{"type":"text","text":"can update a shape source by setting its "},{"code":"shape","type":"codeVoice"},{"type":"text","text":" or "},{"code":"URL","type":"codeVoice"},{"type":"text","text":" property."}],"title":"MLNShapeSource","role":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeSource"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotationImage":{"type":"topic","kind":"symbol","url":"\/documentation\/maplibre\/mlnannotationimage","title":"MLNAnnotationImage","abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage","type":"reference","isActive":true},{"type":"text","text":" class is responsible for presenting point-based"},{"type":"text","text":" "},{"type":"text","text":"annotations visually on a map view. Annotation image objects wrap "},{"type":"codeVoice","code":"UIImage"},{"type":"text","text":" "},{"type":"text","text":"objects and may be recycled later and put into a reuse queue that is maintained"},{"type":"text","text":" "},{"type":"text","text":"by the map view."}],"role":"symbol","fragments":[{"kind":"identifier","text":"MLNAnnotationImage"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTileSource":{"role":"symbol","kind":"symbol","fragments":[{"kind":"identifier","text":"MLNTileSource"}],"type":"topic","title":"MLNTileSource","url":"\/documentation\/maplibre\/mlntilesource","abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSource","isActive":true},{"text":" is a map content source that supplies map tiles to be shown on","type":"text"},{"text":" ","type":"text"},{"text":"the map. The location of and metadata about the tiles are defined either by an","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"option dictionary or by an external file that conforms to the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A tile source is added to an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","type":"reference","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","isActive":true},{"text":" objects. Use a style layer to","type":"text"},{"text":" ","type":"text"},{"text":"control the appearance of content supplied by the tile source.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/leavesOfCluster:offset:limit:":{"role":"symbol","kind":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"leavesOfCluster:offset:limit:","kind":"identifier"}],"type":"topic","title":"leavesOfCluster:offset:limit:","url":"\/documentation\/maplibre\/mlnshapesource\/leavesofcluster:offset:limit:","abstract":[{"text":"Returns an array of map features that are the leaves of the specified cluster.","type":"text"},{"text":" ","type":"text"},{"text":"(“Leaves” are the original points that belong to the cluster.)","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/leavesOfCluster:offset:limit:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/addSource:":{"role":"symbol","kind":"symbol","fragments":[{"text":"- ","kind":"text"},{"kind":"identifier","text":"addSource:"}],"type":"topic","title":"addSource:","url":"\/documentation\/maplibre\/mlnstyle\/addsource:","abstract":[{"type":"text","text":"Adds a new source to the current style."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/For_Style_Authors":{"role":"article","kind":"article","type":"topic","title":"Information for Style Authors","url":"\/documentation\/maplibre-native-for-ios\/for_style_authors","abstract":[],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/For_Style_Authors"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/zoomLevelForExpandingCluster:":{"kind":"symbol","title":"zoomLevelForExpandingCluster:","role":"symbol","abstract":[{"type":"text","text":"Returns the zoom level at which the given cluster expands."}],"fragments":[{"text":"- ","kind":"text"},{"text":"zoomLevelForExpandingCluster:","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnshapesource\/zoomlevelforexpandingcluster:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/zoomLevelForExpandingCluster:","type":"topic"}}}