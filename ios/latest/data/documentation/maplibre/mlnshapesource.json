drenOfCluster:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"childrenOfCluster:"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSourceDataSource":{"url":"\/documentation\/maplibre\/mlncomputedshapesourcedatasource","kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"Data source for "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","isActive":true},{"type":"text","text":". This protocol defines two optional methods for fetching"},{"type":"text","text":" "},{"type":"text","text":"data, one based on tile coordinates, and one based on a bounding box. Classes that implement this"},{"type":"text","text":" "},{"type":"text","text":"protocol must implement one, and only one of the methods. Methods on this protocol will not be"},{"type":"text","text":" "},{"type":"text","text":"called on main thread, they will be called on the caller’s "},{"type":"codeVoice","code":"requestQueue"},{"type":"text","text":"."}],"title":"MLNComputedShapeSourceDataSource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource","type":"topic","fragments":[{"text":"MLNComputedShapeSourceDataSource","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/zoomLevelForExpandingCluster:":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/zoomLevelForExpandingCluster:","url":"\/documentation\/maplibre\/mlnshapesource\/zoomlevelforexpandingcluster:","navigatorTitle":[{"text":"zoomLevelForExpandingCluster:","kind":"identifier"}],"fragments":[{"text":"- ","kind":"text"},{"text":"zoomLevelForExpandingCluster:","kind":"identifier"}],"abstract":[{"type":"text","text":"Returns the zoom level at which the given cluster expands."}],"type":"topic","role":"symbol","title":"zoomLevelForExpandingCluster:","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/sourceWithIdentifier:":{"abstract":[{"type":"text","text":"Returns a source with the given identifier in the current style."}],"kind":"symbol","role":"symbol","title":"sourceWithIdentifier:","fragments":[{"text":"- ","kind":"text"},{"text":"sourceWithIdentifier:","kind":"identifier"}],"navigatorTitle":[{"text":"sourceWithIdentifier:","kind":"identifier"}],"type":"topic","url":"\/documentation\/maplibre\/mlnstyle\/sourcewithidentifier:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/sourceWithIdentifier:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/leavesOfCluster:offset:limit:":{"kind":"symbol","abstract":[{"text":"Returns an array of map features that are the leaves of the specified cluster.","type":"text"},{"text":" ","type":"text"},{"text":"(“Leaves” are the original points that belong to the cluster.)","type":"text"}],"type":"topic","title":"leavesOfCluster:offset:limit:","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"leavesOfCluster:offset:limit:"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/leavesOfCluster:offset:limit:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"leavesOfCluster:offset:limit:"}],"url":"\/documentation\/maplibre\/mlnshapesource\/leavesofcluster:offset:limit:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/URL":{"fragments":[{"kind":"identifier","text":"URL"}],"title":"URL","url":"\/documentation\/maplibre\/mlnshapesource\/url","type":"topic","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/URL","abstract":[{"text":"The URL to the GeoJSON document that specifies the contents of the source.","type":"text"}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","title":"MLNShapeSource","abstract":[{"isActive":true,"ty