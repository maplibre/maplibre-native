\/MLNCluster","isActive":true},{"type":"text","text":" protocol (currently only objects of type "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCluster","isActive":true},{"type":"text","text":")."}],"title":"childrenOfCluster:","url":"\/documentation\/maplibre\/mlnshapesource\/childrenofcluster:","kind":"symbol","type":"topic","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/childrenOfCluster:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"childrenOfCluster:"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/addSource:":{"title":"addSource:","url":"\/documentation\/maplibre\/mlnstyle\/addsource:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"addSource:"}],"abstract":[{"text":"Adds a new source to the current style.","type":"text"}],"kind":"symbol","type":"topic","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTileSource":{"title":"MLNTileSource","url":"\/documentation\/maplibre\/mlntilesource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSource","fragments":[{"text":"MLNTileSource","kind":"identifier"}],"abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSource","isActive":true,"type":"reference"},{"text":" is a map content source that supplies map tiles to be shown on","type":"text"},{"text":" ","type":"text"},{"text":"the map. The location of and metadata about the tiles are defined either by an","type":"text"},{"text":" ","type":"text"},{"text":"option dictionary or by an external file that conforms to the","type":"text"},{"text":" ","type":"text"},{"text":"TileJSON specification","type":"text"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"A tile source is added to an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true,"type":"reference"},{"text":" object along with one or more","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","isActive":true,"type":"reference"},{"text":" or ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","isActive":true,"type":"reference"},{"text":" objects. Use a style layer to","type":"text"},{"text":" ","type":"text"},{"text":"control the appearance of content supplied by the tile source.","type":"text"}],"kind":"symbol","type":"topic","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"url":"\/documentation\/maplibre\/mlnshape","title":"MLNShape","kind":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","role":"symbol","fragments":[{"text":"MLNShape","kind":"identifier"}],"abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":" is an abstract class that represents a shape or annotation. Shapes"},{"type":"text","text":" "},{"type":"text","text":"constitute the content of a map — not only the overlays atop the map, but also"},{"type":"text","text":" "},{"type":"text","text":"the content that forms the base map."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"url":"\/documentation\/maplibre\/mlnstyle","title":"MLNStyle","kind":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","role":"symbol","fragments":[{"text":"MLNStyle","kind":"identifier"}],"abstract":[{"type":"text","text":"The proxy object for the current map style."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/shape":{"url":"\/documentation\/maplibre\/mlnshapesource\/shape","title":"shape","kind":"symbol","type":"topic","identifier":"doc:\/\/or