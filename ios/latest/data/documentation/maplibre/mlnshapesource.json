ern,","type":"text"},{"text":" ","type":"text"},{"text":"use the ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/setImage:forName:","isActive":true,"type":"reference"},{"text":" method. To configure a point","type":"text"},{"text":" ","type":"text"},{"text":"annotation’s image, use the ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage","isActive":true,"type":"reference"},{"text":" class.","type":"text"}],"fragments":[{"text":"MLNImageSource","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNImageSource","kind":"symbol","url":"\/documentation\/maplibre\/mlnimagesource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterDEMSource":{"fragments":[{"text":"MLNRasterDEMSource","kind":"identifier"}],"type":"topic","kind":"symbol","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterDEMSource","isActive":true,"type":"reference"},{"text":" is a map content source that supplies rasterized","type":"text"},{"text":" ","type":"text"},{"text":"digital elevation model","type":"text"},{"text":" ","type":"text"},{"text":"(DEM) tiles to be shown on the map. The location of and metadata about the","type":"text"},{"text":" ","type":"text"},{"text":"tiles are defined either by an option dictionary or by an external file that","type":"text"},{"text":" ","type":"text"},{"text":"conforms to the","type":"text"},{"text":" ","type":"text"},{"text":"TileJSON specification","type":"text"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"A raster DEM source is added to an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true,"type":"reference"},{"text":" object along with one or more","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","isActive":true,"type":"reference"},{"text":" or ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNColorReliefStyleLayer","isActive":true,"type":"reference"},{"text":" objects. Use a hillshade","type":"text"},{"text":" ","type":"text"},{"text":"style layer to control the appearance of content supplied by the raster DEM source,","type":"text"},{"text":" ","type":"text"},{"text":"or a color relief style layer to render elevation data with a color ramp.","type":"text"}],"url":"\/documentation\/maplibre\/mlnrasterdemsource","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterDEMSource","title":"MLNRasterDEMSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","title":"MLNShapeSource","type":"topic","fragments":[{"kind":"identifier","text":"MLNShapeSource"}],"role":"symbol","kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesource","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"type":"text","text":" is a map content source that supplies vector shapes to be"},{"type":"text","text":" "},{"type":"text","text":"shown on the map. The shapes may be instances of "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":" or "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or they may be defined by local or external"},{"type":"text","text":" "},{"type":"text","text":"GeoJSON"},{"type":"text","text":" code. A shape source is added to an"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"typ