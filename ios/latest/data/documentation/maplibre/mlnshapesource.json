ferenced image scales and rotates as the"},{"type":"text","text":" "},{"type":"text","text":"user zooms and rotates the map. Images may also be used as icons or patterns"},{"type":"text","text":" "},{"type":"text","text":"in a style layer. To register an image for use as an icon or pattern,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/setImage:forName:","isActive":true},{"type":"text","text":" method. To configure a point"},{"type":"text","text":" "},{"type":"text","text":"annotation’s image, use the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage","isActive":true},{"type":"text","text":" class."}],"url":"\/documentation\/maplibre\/mlnimagesource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNImageSource","title":"MLNImageSource","fragments":[{"text":"MLNImageSource","kind":"identifier"}],"kind":"symbol","type":"topic","role":"symbol"}}}