"text":"MLNEmptyFeature","kind":"identifier"}],"title":"MLNEmptyFeature"},"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorStyleLayer":{"url":"\/documentation\/maplibre\/mlnvectorstylelayer","abstract":[{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","type":"reference"},{"text":" is an abstract superclass for style layers whose content","type":"text"},{"text":" ","type":"text"},{"text":"is defined by an ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference"},{"text":" or ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference"},{"text":" object.","type":"text"}],"kind":"symbol","fragments":[{"text":"MLNVectorStyleLayer","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","role":"symbol","type":"topic","title":"MLNVectorStyleLayer"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"topic","kind":"symbol","title":"MLNStyle","url":"\/documentation\/maplibre\/mlnstyle","abstract":[{"type":"text","text":"The proxy object for the current map style."}],"fragments":[{"text":"MLNStyle","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPolygon":{"fragments":[{"text":"MLNMultiPolygon","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon","url":"\/documentation\/maplibre\/mlnmultipolygon","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon"},{"type":"text","text":" object represents a shape consisting of one or more"},{"type":"text","text":" "},{"type":"text","text":"polygons that do not overlap. For example, you could use a multipolygon shape"},{"type":"text","text":" "},{"type":"text","text":"to represent the body of land that consists of an island surrounded by an"},{"type":"text","text":" "},{"type":"text","text":"atoll: the inner island would be one "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon"},{"type":"text","text":" object, while the surrounding"},{"type":"text","text":" "},{"type":"text","text":"atoll would be another. You could also use a multipolygon shape to represent a"},{"type":"text","text":" "},{"type":"text","text":"group of disconnected but related buildings."}],"title":"MLNMultiPolygon"}}}