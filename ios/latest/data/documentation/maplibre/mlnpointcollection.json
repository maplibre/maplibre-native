the collection may be related but are not connected spatially. For","type":"text"},{"text":" ","type":"text"},{"text":"example, you could use a point collection to represent all the trees in an","type":"text"},{"text":" ","type":"text"},{"text":"orchard.","type":"text"}],"kind":"symbol","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNPointCollection/pointCount":{"abstract":[{"type":"text","text":"The number of coordinates associated with the shape."}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnpointcollection\/pointcount","fragments":[{"text":"pointCount","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection\/pointCount","title":"pointCount","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNPointCollection/coordinates":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection\/coordinates","role":"symbol","abstract":[{"text":"The array of coordinates associated with the shape.","type":"text"}],"kind":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnpointcollection\/coordinates","title":"coordinates","fragments":[{"kind":"identifier","text":"coordinates"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPolygon":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon","title":"MLNMultiPolygon","url":"\/documentation\/maplibre\/mlnmultipolygon","type":"topic","abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon","isActive":true},{"type":"text","text":" object represents a shape consisting of one or more"},{"type":"text","text":" "},{"type":"text","text":"polygons that do not overlap. For example, you could use a multipolygon shape"},{"type":"text","text":" "},{"type":"text","text":"to represent the body of land that consists of an island surrounded by an"},{"type":"text","text"