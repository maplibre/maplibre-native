","text":"can update a shape source by setting its "},{"type":"codeVoice","code":"shape"},{"type":"text","text":" or "},{"type":"codeVoice","code":"URL"},{"type":"text","text":" property."}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","role":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeSource"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNEmptyFeature":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNEmptyFeature","kind":"symbol","type":"topic","role":"symbol","fragments":[{"kind":"identifier","text":"MLNEmptyFeature"}],"url":"\/documentation\/maplibre\/mlnemptyfeature","title":"MLNEmptyFeature","abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNEmptyFeature","isActive":true},{"type":"text","text":" object associates an empty shape with an optional"},{"type":"text","text":" "},{"type":"text","text":"identifier and attributes."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNPointCollection/pointCount":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection\/pointCount","kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"The number of coordinates associated with the shape."}],"fragments":[{"text":"pointCount","kind":"identifier"}],"type":"topic","url":"\/documentation\/maplibre\/mlnpointcollection\/pointcount","title":"pointCount"},"doc://org.swift.MyProject/documentation/MapLibre/MLNPointCollection/coordinates":{"url":"\/documentation\/maplibre\/mlnpointcollection\/coordinates","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection\/coordinates","title":"coordinates","kind":"symbol","type":"topic","role":"symbol","abstract":[{"type":"text","text":"The array of coordinates associated with the shape."}],"fragments":[{"kind":"identifier","text":"coordinates"}]},"doc://org.swift.MyProject/documentation/Ma