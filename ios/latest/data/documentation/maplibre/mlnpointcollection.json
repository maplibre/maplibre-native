w"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can add point collections to the map by adding them to an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":" "},{"type":"text","text":"object. Configure the appearance of an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":"’s or"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource"},{"type":"text","text":"’s point collections collectively using an"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCircleStyleLayer"},{"type":"text","text":" or "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCircleStyleLayer"},{"type":"text","text":" object. To access a point"},{"type":"text","text":" "},{"type":"text","text":"collection’s attributes, use an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollectionFeature"},{"type":"text","text":" object."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You cannot add an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection"},{"type":"text","text":" object directly to a map view as an"},{"type":"text","text":" "},{"type":"text","text":"annotation. However, you can create individual "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation"},{"type":"text","text":" objects"},{"type":"text","text":" "},{"type":"text","text":"from the "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" array and add those annotation objects to the map view"},{"type":"text","text":" "},{"type":"text","text":"using the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/addAnnotations:"},{"type":"text","text":" method."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A point collection is known as a"},{"type":"text","text":" "},{"type":"text","text":"MultiPoint"},{"type":"text","text":" "},{"type":"text","text":"geometry in GeoJSON. Do not confuse "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection"},{"type":"text","text":" with "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"the abstract superclass of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolyline"},{"type":"text","text":" and "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolyline"},{"type":"text","text":"."}]}]}],"metadata":{"externalID":"c:objc(cs)MLNPointCollection","roleHeading":"Class","role":"symbol","title":"MLNPointCollection","fragments":[{"kind":"identifier","text":"MLNPointCollection"}],"modules":[{"name":"MapLibre"}],"symbolKind":"class","navigatorTitle":[{"kind":"identifier","text":"MLNPointCollection"}]},"abstract":[{"type":"text","text":"An "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection"},{"type":"text","text":" object represents a shape consisting of one or more"},{"type":"text","text":" "},{"type":"text","text":"disconnected vertices, specified as "},{"type":"codeVoice","code":"CLLocationCoordinate2D"},{"type":"text","text":" instances. The"},{"type":"text","text":" "},{"type":"text","text":"points in the collection may be related but are not connected spatially. For"},{"type":"text","text":" "},{"type":"text","text":"example, you could use a point collection to represent all the trees in an"},{"type":"text","text":" "},{"type":"text","text":"orchard."}],"relationshipsSections":[{"kind":"relationships","title":"Inherits From","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"],"type":"inheritsFrom"},{"kind":"relationships","title":"Inherited By","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollectionFeature"],"type":"inheritedBy"},{"kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay"],"type":"conformsTo"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnpointcollection"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"sections":[],"topicSections":[{"anchor":"Instance-Properties","title":"Instance Properties","generated":true,"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection\/coordinates","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection\/pointCount"]},{"anchor":"Instance-Methods","title":"Instance Methods","generated":true,"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection\/getCoordinates:range:"]},{"anchor":"Type-Methods","title":"Type Methods","generated":true,"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection\/pointCollectionWithCoordinates:count:"]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/addAnnotations:":{"kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlnmapview\/addannotations:","fragments":[{"text":"- ","kind":"text"},{"text":"addAnnotations:","kind":"identifier"}],"title":"addAnnotations:","abstract"