on\/MapLibre\/MLNEmptyFeature"},{"type":"text","text":" object associates an empty shape with an optional"},{"type":"text","text":" "},{"type":"text","text":"identifier and attributes."}],"url":"\/documentation\/maplibre\/mlnemptyfeature","fragments":[{"kind":"identifier","text":"MLNEmptyFeature"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorStyleLayer":{"title":"MLNVectorStyleLayer","type":"topic","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","role":"symbol","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer"},{"type":"text","text":" is an abstract superclass for style layers whose content"},{"type":"text","text":" "},{"type":"text","text":"is defined by an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":" or "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":" object."}],"url":"\/documentation\/maplibre\/mlnvectorstylelayer","fragments":[{"kind":"identifier","text":"MLNVectorStyleLayer"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorTileSource":{"title":"MLNVectorTileSource","type":"topic","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","role":"symbol","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource"},{"type":"text","text":" is a map content source that supplies tiled vector data"},{"type":"text","text":" "},{"type":"text","text":"in "},{"type":"text","text":"Mapbox Vector Tile"},{"type":"text","text":" format"},{"type":"text","text":" "},{"type":"text","text":"to be shown on the map. The location of and metadata about the tiles are"},{"type":"text","text":" "},{"type":"text","text":"defined either by an option dictionary or by an external file that conforms to"},{"type":"text","text":" "},{"type":"text","text":"the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A vector tile source is added to an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer"},{"type":"text","text":" objects. A vector style layer defines the appearance of"},{"type":"text","text":" "},{"type":"text","text":"any content supplied by the vector tile source."}],"url":"\/documentation\/maplibre\/mlnvectortilesource","fragments":[{"kind":"identifier","text":"MLNVectorTileSource"}]}}}