{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"- (","kind":"text"},{"text":"NSArray<id<MLNFeature>>","preciseIdentifier":"c:Q$objc(cs)NSArray","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"featuresInSourceLayersWithIdentifiers:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSSet<NSString *>","preciseIdentifier":"c:Q$objc(cs)NSSet","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"sourceLayerIdentifiers","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"predicate:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSPredicate","text":"NSPredicate","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"predicate","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}]},{"parameters":[{"name":"sourceLayerIdentifiers","content":[{"inlineContent":[{"text":"The source layers to include in the query. Only","type":"text"},{"text":" ","type":"text"},{"text":"the features contained in these source layers are included in the returned","type":"text"},{"text":" ","type":"text"},{"text":"array. This array may not be empty.","type":"text"}],"type":"paragraph"}]},{"name":"predicate","content":[{"inlineContent":[{"text":"A predicate to filter the returned features. Use ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" to","type":"text"},{"text":" ","type":"text"},{"text":"include all loaded features.","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"return-value","text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An array of objects conforming to the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature","isActive":true},{"type":"text","text":" protocol that"},{"type":"text","text":" "},{"type":"text","text":"represent features loaded by the source that match the predicate."}]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"Each object in the returned array represents a feature loaded by the source and","type":"text"},{"text":" ","type":"text"},{"text":"provides access to attributes specified as part of the loaded feature. The","type":"text"},{"text":" ","type":"text"},{"text":"source loads a feature if the source is added to an ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","isActive":true},{"text":"’s style; that","type":"text"},{"text":" ","type":"text"},{"text":"style has a layer that uses the source; and the map view has recently scrolled","type":"text"},{"text":" ","type":"text"},{"text":"to the region containing the feature.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Features come from tiled vector data that is converted to tiles internally, so"},{"type":"text","text":" "},{"type":"text","text":"feature geometries are clipped at tile boundaries and features may appear"},{"type":"text","text":" "},{"type":"text","text":"duplicated across tiles. For example, suppose part of a lengthy polyline"},{"type":"text","text":" "},{"type":"text","text":"representing a road has recently scrolled into view. The resulting array"},{"type":"text","text":" "},{"type":"text","text":"includes those parts of the road that lie within the map tiles that the source"},{"type":"text","text":" "},{"type":"text","text":"has loaded, even if the road extends into other tiles. The portion of the road"},{"type":"text","text":" "},{"type":"text","text":"within each map tile is included individually."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Returned features may not necessarily be visible to the user at the time they"},{"type":"text","text":" "},{"type":"text","text":"are loaded: the style may contain a layer that forces the source’s tiles to"},{"type":"text","text":" "},{"type":"text","text":"load but filters out the features in question, preventing them from being"},{"type":"text","text":" "},{"type":"text","text":"drawn. To obtain only "},{"type":"emphasis","inlineContent":[{"text":"visible","type":"text"}]},{"type":"text","text":" features, use the"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/visibleFeaturesAtPoint:inStyleLayersWithIdentifiers:predicate:","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"or"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/visibleFeaturesInRect:inStyleLayersWithIdentifiers:predicate:"},{"type":"text","text":" "},{"type":"text","text":"method."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnvectortilesource\/featuresinsourcelayerswithidentifiers:predicate:"]}],"abstract":[{"text":"Returns an array of map features loaded by this source, restricted to the given","type":"text"},{"text":" ","type":"text"},{"text":"source layers and filtered by the given predicate.","type":"text"}],"metadata":{"title":"featuresInSourceLayersWithIdentifiers:predicate:","externalID":"c:objc(cs)MLNVectorTileSource(im)featuresInSourceLayersWithIdentifiers:predicate:","role":"symbol","symbolKind":"method","fragments":[{"text":"- ","kind":"text"},{"text":"featuresInSourceLayersWithIdentifiers:predicate:","kind":"identifier"}],"roleHeading":"Instance Method","navigatorTitle":[{"text":"featuresInSourceLayersWithIdentifiers:predicate:","kind":"identifier"}],"modules":[{"name":"MapLibre"}]},"sections":[],"kind":"symbol","identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource\/featuresInSourceLayersWithIdentifiers:predicate:","interfaceLanguage":"occ"},"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorTileSource":{"fragments":[{"text":"MLNVectorTileSource","kind":"identifier"}],"abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","isActive":true,"type":"reference"},{"text":" is a map content source that supplies tiled vector data","type":"text"},{"text":" ","type":"text"},{"text":"in ","type":"text"},{"text":"Mapbox Vector Tile","type":"text"},{"text":" format","type":"text"},{"text":" ","type":"text"},{"text":"to be shown on the map. The location of and metadata about the tiles are","type":"text"},{"text":" ","type":"text"},{"text":"defined either by an option dictionary or by an external file that conforms to","type":"text"},{"text":" ","type":"text"},{"text":"the","type":"text"},{"text":" ","type":"text"},{"text":"TileJSON specification","type":"text"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"A vector tile source is added to an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","isActive":true},{"type":"text","text":" objects. A vector style layer defines the appearance of"},{"type":"text","text":" "},{"type":"text","text":"any content supplied by the vector tile source."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","title":"MLNVectorTileSource","type":"topic","url":"\/documentation\/maplibre\/mlnvectortilesource","role":"symbol","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/visibleFeaturesInRect:inStyleLayers