{"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource"]]},"sections":[],"metadata":{"role":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"featuresInSourceLayersWithIdentifiers:predicate:","kind":"identifier"}],"navigatorTitle":[{"text":"featuresInSourceLayersWithIdentifiers:predicate:","kind":"identifier"}],"title":"featuresInSourceLayersWithIdentifiers:predicate:","modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNVectorTileSource(im)featuresInSourceLayersWithIdentifiers:predicate:","roleHeading":"Instance Method","symbolKind":"method"},"abstract":[{"text":"Returns an array of map features loaded by this source, restricted to the given","type":"text"},{"text":" ","type":"text"},{"text":"source layers and filtered by the given predicate.","type":"text"}],"variants":[{"paths":["\/documentation\/maplibre\/mlnvectortilesource\/featuresinsourcelayerswithidentifiers:predicate:"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource\/featuresInSourceLayersWithIdentifiers:predicate:","interfaceLanguage":"occ"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"text","text":"- ("},{"preciseIdentifier":"c:Q$objc(cs)NSArray","kind":"typeIdentifier","text":"NSArray<id<MLNFeature>>"},{"kind":"text","text":" *) "},{"kind":"identifier","text":"featuresInSourceLayersWithIdentifiers:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:Q$objc(cs)NSSet","kind":"typeIdentifier","text":"NSSet<NSString *>"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"sourceLayerIdentifiers"},{"kind":"text","text":" "},{"kind":"identifier","text":"predicate:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSPredicate","kind":"typeIdentifier","text":"NSPredicate"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"predicate"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"The source layers to include in the query. Only","type":"text"},{"text":" ","type":"text"},{"text":"the features contained in these source layers are included in the returned","type":"text"},{"text":" ","type":"text"},{"text":"array. This array may not be empty.","type":"text"}],"type":"paragraph"}],"name":"sourceLayerIdentifiers"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A predicate to filter the returned features. Use ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" to","type":"text"},{"text":" ","type":"text"},{"text":"include all loaded features.","type":"text"}]}],"name":"predicate"}]},{"kind":"content","content":[{"text":"Return Value","anchor":"return-value","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An array of objects conforming to the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature"},{"type":"text","text":" protocol that"},{"type":"text","text":" "},{"type":"text","text":"represent features loaded by the source that match the predicate."}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each object in the returned array represents a feature loaded by the source and"},{"type":"text","text":" "},{"type":"text","text":"provides access to attributes specified as part of the loaded feature. The"},{"type":"text","text":" "},{"type":"text","text":"source loads a feature if the source is added to an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","type":"reference","isActive":true},{"type":"text","text":"’s style; that"},{"type":"text","text":" "},{"type":"text","text":"style has a layer that uses the source; and the map view has recently scrolled"},{"type":"text","text":" "},{"type":"text","text":"to the region containing the feature."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Features come from tiled vector data that is converted to tiles internally, so"},{"type":"text","text":" "},{"type":"text","text":"feature geometries are clipped at tile boundaries and features may appear"},{"type":"text","text":" "},{"type":"text","text":"duplicated across tiles. For example, suppose part of a lengthy polyline"},{"type":"text","text":" "},{"type":"text","text":"representing a road has recently scrolled into view. The resulting array"},{"type":"text","text":" "},{"type":"text","text":"includes those parts of the road that lie within the map tiles that the source"},{"type":"text","text":" "},{"type":"text","text":"has loaded, even if the road extends into other tiles. The portion of the road"},{"text":" ","type":"text"},{"text":"within each map tile is included individually.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Returned features may not necessarily be visible to the user at the time they","type":"text"},{"text":" ","type":"text"},{"text":"are loaded: the style may contain a layer that forces the source’s tiles to","type":"text"},{"text":" ","type":"text"},{"text":"load but filters out the features in question, preventing them from being","type":"text"},{"text":" ","type":"text"},{"text":"drawn. To obtain only ","type":"text"},{"inlineContent":[{"text":"visible","type":"text"}],"type":"emphasis"},{"text":" features, use the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/visibleFeaturesAtPoint:inStyleLayersWithIdentifiers:predicate:","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"or","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/visibleFeaturesInRect:inStyleLayersWithIdentifiers:predicate:","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"method.","type":"text"}]}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/visibleFeaturesAtPoint:inStyleLayersWithIdentifiers:predicate:":{"title":"visibleFeaturesAtPoint:inStyleLayersWithIdentifiers:predicate:","role":"symbol","type":"topic","abstract":[{"type":"text","text":"Returns an array of rendered map features that intersect with a given point,"},{"type":"text","text":" "},{"type":"text","text":"restricted to the given style layers and filtered by the given predicate."}],"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"visibleFeaturesAtPoint:inStyleLayersWithIdentifiers:predicate:"}],"navigatorTitle":[{"kind":"identifier","text":"visibleFeaturesAtPoint:inStyleLayersWithIdentifiers:predicate:"}],"url":"\/documentation\/maplibre\/mlnmapview\/visiblefeaturesatpoint:instylelayerswithidentifiers:predicate:","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/visibleFeaturesAtPoint:inStyleLayersWithIdentifiers:predicate:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/visibleFeaturesInRect:inStyleLayersWithIdentifiers:predicate:":{"type":"topic","abstract":[{"text":"Returns an array of rendered map features that intersect with the given","type":"text"},{"text":" ","type":"text"},{"text":"rectangle, restricted to the given style layers and filtered by the given","type":"text"},{"text":" ","type":"text"},{"text":"predicate.","type":"text"}],"fragments":[{"text":"- ","kind":"text"},{"text":"visibleFeaturesInRect:inStyleLayersWithIdentifiers:predicate:","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/visibleFeaturesInRect:inStyleLayersWithIdentifiers:predicate:","role":"symbol","kind":"symbol","navigatorTitle":[{"text":"visibleFeaturesInRect:inStyleLayersWithIdentifiers: