 ","type":"text"},{"code":"MLNHillshadeMethodCombined","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"MLNHillshadeMethodIgor","type":"codeVoice"},{"text":", or ","type":"text"},{"code":"MLNHillshadeMethodMultidirectional","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer\/hillshadeMethod","kind":"symbol","type":"topic","role":"symbol","fragments":[{"kind":"identifier","text":"hillshadeMethod"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyleLayer":{"role":"symbol","abstract":[{"type":"text","text":"An "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"},{"type":"text","text":" is a style layer that renders raster "},{"type":"text","text":"digital elevation"},{"type":"text","text":" "},{"type":"text","text":"model"},{"type":"text","text":" (DEM) tiles on the map."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","kind":"symbol","url":"\/documentation\/maplibre\/mlnhillshadestylelayer","type":"topic","fragments":[{"kind":"identifier","text":"MLNHillshadeStyleLayer"}],"title":"MLNHillshadeStyleLayer"}}}