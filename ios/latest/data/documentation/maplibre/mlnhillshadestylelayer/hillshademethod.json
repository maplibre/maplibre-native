he "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This property does not support applying interpolation functions to the"},{"type":"text","text":" "},{"code":"$zoomLevel","type":"codeVoice"},{"type":"text","text":" variable or applying interpolation or step functions to feature"},{"type":"text","text":" "},{"type":"text","text":"attributes."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/maplibre\/mlnhillshadestylelayer\/hillshademethod"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer\/hillshadeMethod"},"metadata":{"modules":[{"name":"MapLibre"}],"roleHeading":"Instance Property","externalID":"c:objc(cs)MLNHillshadeStyleLayer(py)hillshadeMethod","role":"symbol","navigatorTitle":[{"text":"hillshadeMethod","kind":"identifier"}],"fragments":[{"kind":"identifier","text":"hillshadeMethod"}],"title":"hillshadeMethod","symbolKind":"property"},"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyleLayer":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","title":"MLNHillshadeStyleLayer","type":"topic","abstract":[{"text":"An ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"},{"text":" is a style layer that renders raster ","type":"text"},{"text":"digital elevation","type":"text"},{"text":" ","type":"text"},{"text":"model","type":"text"},{"text":" (DEM) tiles on the map.","type":"text"}],"kind":"symbol","fragments":[{"text":"MLNHillshadeStyleLayer","kind":"identifier"}],"role":"symbol","url":"\/documentation\/maplibre\/mlnhillshadestylelayer"},"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collect