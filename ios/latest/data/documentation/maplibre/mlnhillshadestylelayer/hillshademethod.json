h multiple illumination directions. Uses"},{"type":"text","text":" "},{"type":"text","text":"the basic hillshade model with multiple independent light sources."},{"type":"text","text":" "},{"type":"text","text":"Predefined functions, including mathematical and string operators"},{"text":" ","type":"text"},{"text":"Conditional expressions","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Variable assignments and references to assigned variables"},{"text":" ","type":"text"},{"text":"Step functions applied to the ","type":"text"},{"code":"$zoomLevel","type":"codeVoice"},{"type":"text","text":" variable"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This property does not support applying interpolation functions to the"},{"type":"text","text":" "},{"code":"$zoomLevel","type":"codeVoice"},{"text":" variable or applying interpolation or step functions to feature","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"attributes."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyleLayer/hillshadeMethod":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer\/hillshadeMethod","url":"\/documentation\/maplibre\/mlnhillshadestylelayer\/hillshademethod","kind":"symbol","role":"symbol","title":"hillshadeMethod","abstract":[{"type":"text","text":"The hillshade algorithm to use, one of "},{"code":"MLNHillshadeMethodStandard","type":"codeVoice"},{"text":",","type":"text"},{"type":"text","text":" "},{"code":"MLNHillshadeMethodBasic","type":"codeVoice"},{"type":"text","text":", "},{"code":"MLNHillshadeMethodCombined","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"MLNHillshadeMethodIgor"},{"type":"text","text":", or "},{"cod