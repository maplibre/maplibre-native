{"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnhillshadestylelayer\/hillshademethod"]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer\/hillshadeMethod","interfaceLanguage":"occ"},"metadata":{"symbolKind":"property","title":"hillshadeMethod","fragments":[{"text":"hillshadeMethod","kind":"identifier"}],"roleHeading":"Instance Property","externalID":"c:objc(cs)MLNHillshadeStyleLayer(py)hillshadeMethod","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"text":"hillshadeMethod","kind":"identifier"}],"role":"symbol"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"text":"NSExpression","preciseIdentifier":"c:objc(cs)NSExpression","kind":"typeIdentifier"},{"text":" * ","kind":"text"},{"text":"hillshadeMethod","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default value of this property is an expression that evaluates to"},{"type":"text","text":" "},{"code":"standard","type":"codeVoice"},{"type":"text","text":". Set this property to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" to reset it to the default value."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can set this property to an expression containing any of the following:"}]},{"type":"paragraph","inlineContent":[{"text":"Constant ","type":"text"},{"code":"MLNHillshadeMethod","type":"codeVoice"},{"text":" values","type":"text"},{"text":" ","type":"text"},{"text":"Any of the following constant string values:","type":"text"},{"text":" ","type":"text"},{"code":"standard","type":"codeVoice"},{"type":"text","text":": The legacy hillshade method."},{"type":"text","text":" "},{"code":"basic","type":"codeVoice"},{"type":"text","text":": Basic hillshade. Uses a simple physics model where the reflected"},{"type":"text","text":" "},{"type":"text","text":"light intensity is proportional to the cosine of the angle between the incident"},{"type":"text","text":" "},{"type":"text","text":"light and the surface normal. Similar to GDAL’s "},{"code":"gdaldem","type":"codeVoice"},{"type":"text","text":" default algorithm."},{"type":"text","text":" "},{"code":"combined","type":"codeVoice"},{"type":"text","text":": Hillshade algorithm whose intensity scales with slope. Similar"},{"type":"text","text":" "},{"type":"text","text":"to GDAL’s "},{"code":"gdaldem","type":"codeVoice"},{"type":"text","text":" with "},{"code":"-combined","type":"codeVoice"},{"type":"text","text":" option."},{"type":"text","text":" "},{"code":"igor","type":"codeVoice"},{"type":"text","text":": Hillshade algorithm which tries to minimize effects on other map"},{"type":"text","text":" "},{"type":"text","text":"features beneath. Similar to GDAL’s "},{"code":"gdaldem","type":"codeVoice"},{"type":"text","text":" with "},{"code":"-igor","type":"codeVoice"},{"type":"text","text":" option."},{"type":"text","text":" "},{"code":"multidirectional","type":"codeVoice"},{"type":"text","text":": Hillshade with multiple illumination directions. Uses"},{"type":"text","text":" "},{"type":"text","text":"the basic hillshade model with multiple independent light sources."},{"type":"text","text":" "},{"type":"text","text":"Predefined functions, including mathematical and string operators"},{"type":"text","text":" "},{"type":"text","text":"Conditional expressions"},{"type":"text","text":" "},{"type":"text","text":"Variable assignments and references to assigned variables"},{"type":"text","text":" "},{"type":"text","text":"Step functions applied to the "},{"code":"$zoomLevel","type":"codeVoice"},{"type":"text","text":" variable"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property does not support applying interpolation functions to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable or applying interpolation or step functions to feature"},{"type":"text","text":" "},{"type":"text","text":"attributes."}]}]}],"abstract":[{"text":"The hillshade algorithm to use, one of ","type":"text"},{"type":"codeVoice","code":"MLNHillshadeMethodStandard"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"MLNHillshadeMethodBasic"},{"text":", ","type":"text"},{"type":"codeVoice","code":"MLNHillshadeMethodCombined"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"MLNHillshadeMethodIgor"},{"text":", or ","type":"text"},{"type":"codeVoice","code":"MLNHillshadeMethodMultidirectional"},{"text":".","type":"text"},{"text":" ","type":"text"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyleLayer":{"url":"\/documentation\/maplibre\/mlnhillshadestylelayer","abstract":[{"type":"text","text":"An "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"},{"type":"text","text":" is a style layer that renders raster "},{"type":"text","text":"digital elevation"},{"type":"text","text":" "},{"type":"text","text":"model"},{"type":"text","text":" (DEM) tiles on the map."}],"type":"topic","fragments":[{"kind":"identifier","text":"MLNHillshadeStyleLayer"}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","kind":"symbol","title":"MLNHillshadeStyleLayer"},"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyle