":"text"},{"text":" ","type":"text"},{"text":"Variable assignments and references to assigned variables","type":"text"},{"text":" ","type":"text"},{"text":"Step functions applied to the ","type":"text"},{"code":"$zoomLevel","type":"codeVoice"},{"text":" variable","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This property does not support applying interpolation functions to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable or applying interpolation or step functions to feature"},{"type":"text","text":" "},{"type":"text","text":"attributes."}],"type":"paragraph"}]}],"metadata":{"modules":[{"name":"MapLibre"}],"symbolKind":"property","navigatorTitle":[{"text":"hillshadeMethod","kind":"identifier"}],"title":"hillshadeMethod","externalID":"c:objc(cs)MLNHillshadeStyleLayer(py)hillshadeMethod","fragments":[{"text":"hillshadeMethod","kind":"identifier"}],"role":"symbol","roleHeading":"Instance Property"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyleLayer":{"kind":"symbol","role":"symbol","title":"MLNHillshadeStyleLayer","type":"topic","abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","isActive":true},{"type":"text","text":" is a style layer that renders raster "},{"type":"text","text":"digital elevation"},{"type":"text","text":" "},{"type":"text","text":"model"},{"type":"text","text":" (DEM) tiles on the map."}],"url":"\/documentation\/maplibre\/mlnhillshadestylelayer","fragments":[{"text":"MLNHillshadeStyleLayer","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLib