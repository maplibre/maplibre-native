{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSExpression","text":"NSExpression"},{"kind":"text","text":" * "},{"kind":"identifier","text":"hillshadeMethod"},{"kind":"text","text":";"}],"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default value of this property is an expression that evaluates to"},{"type":"text","text":" "},{"code":"standard","type":"codeVoice"},{"type":"text","text":". Set this property to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" to reset it to the default value."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can set this property to an expression containing any of the following:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Constant "},{"type":"codeVoice","code":"MLNHillshadeMethod"},{"text":" values","type":"text"},{"text":" ","type":"text"},{"text":"Any of the following constant string values:","type":"text"},{"text":" ","type":"text"},{"code":"standard","type":"codeVoice"},{"text":": The legacy hillshade method.","type":"text"},{"text":" ","type":"text"},{"code":"basic","type":"codeVoice"},{"text":": Basic hillshade. Uses a simple physics model where the reflected","type":"text"},{"text":" ","type":"text"},{"text":"light intensity is proportional to the cosine of the angle between the incident","type":"text"},{"text":" ","type":"text"},{"text":"light and the surface normal. Similar to GDAL’s ","type":"text"},{"code":"gdaldem","type":"codeVoice"},{"text":" default algorithm.","type":"text"},{"text":" ","type":"text"},{"code":"combined","type":"codeVoice"},{"text":": Hillshade algorithm whose intensity scales with slope. Similar","type":"text"},{"text":" ","type":"text"},{"text":"to GDAL’s ","type":"text"},{"type":"codeVoice","code":"gdaldem"},{"type":"text","text":" with "},{"type":"codeVoice","code":"-combined"},{"type":"text","text":" option."},{"type":"text","text":" "},{"type":"codeVoice","code":"igor"},{"type":"text","text":": Hillshade algorithm which tries to minimize effects on other map"},{"type":"text","text":" "},{"type":"text","text":"features beneath. Similar to GDAL’s "},{"type":"codeVoice","code":"gdaldem"},{"text":" with ","type":"text"},{"type":"codeVoice","code":"-igor"},{"text":" option.","type":"text"},{"text":" ","type":"text"},{"code":"multidirectional","type":"codeVoice"},{"text":": Hillshade with multiple illumination directions. Uses","type":"text"},{"text":" ","type":"text"},{"text":"the basic hillshade model with multiple independent light sources.","type":"text"},{"type":"text","text":" "},{"text":"Predefined functions, including mathematical and string operators","type":"text"},{"type":"text","text":" "},{"text":"Conditional expressions","type":"text"},{"text":" ","type":"text"},{"text":"Variable assignments and references to assigned variables","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Step functions applied to the "},{"code":"$zoomLevel","type":"codeVoice"},{"type":"text","text":" variable"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property does not support applying interpolation functions to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable or applying interpolation or step functions to feature"},{"text":" ","type":"text"},{"text":"attributes.","type":"text"}]}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/maplibr