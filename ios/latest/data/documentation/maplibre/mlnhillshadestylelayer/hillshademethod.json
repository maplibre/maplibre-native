{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"]]},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSExpression","text":"NSExpression","kind":"typeIdentifier"},{"text":" * ","kind":"text"},{"text":"hillshadeMethod","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS","iPadOS","Mac Catalyst"]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"text":"The default value of this property is an expression that evaluates to","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"standard"},{"text":". Set this property to ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" to reset it to the default value.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"You can set this property to an expression containing any of the following:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Constant ","type":"text"},{"type":"codeVoice","code":"MLNHillshadeMethod"},{"text":" values","type":"text"},{"text":" ","type":"text"},{"text":"Any of the following constant string values:","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"standard"},{"text":": The legacy hillshade method.","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"basic"},{"text":": Basic hillshade. Uses a simple physics model where the reflected","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"light intensity is proportional to the cosine of the angle between the incident"},{"type":"text","text":" "},{"type":"text","text":"light and the surface normal. Similar to GDAL’s "},{"type":"codeVoice","code":"gdaldem"},{"type":"text","text":" default algorithm."},{"type":"text","text":" "},{"type":"codeVoice","code":"combined"},{"type":"text","text":": Hillshade algorithm whose intensity scales with slope. Similar"},{"type":"text","text":" "},{"type":"text","text":"to GDAL’s "},{"type":"codeVoice","code":"gdaldem"},{"type":"text","text":" with "},{"type":"codeVoice","code":"-combined"},{"type":"text","text":" option."},{"type":"text","text":" "},{"type":"codeVoice","code":"igor"},{"type":"text","text":": Hillshade algorithm which tries to minimize effects on other map"},{"type":"text","text":" "},{"type":"text","text":"features beneath. Similar to GDAL’s "},{"type":"codeVoice","code":"gdaldem"},{"type":"text","text":" with "},{"type":"codeVoice","code":"-igor"},{"type":"text","text":" option."},{"type":"text","text":" "},{"type":"codeVoice","code":"multidirectional"},{"type":"text","text":": Hillshade with multiple illumination directions. Uses"},{"type":"text","text":" "},{"type":"text","text":"the basic hillshade model with multiple independent light sources."},{"type":"text","text":" "},{"type":"text","text":"Predefined functions, including mathematical and string operators"},{"type":"text","text":" "},{"type":"text","text":"Conditional expressions"},{"type":"text","text":" "},{"type":"text","text":"Variable assignments and references to assigned variables"},{"type":"text","text":" "},{"type":"text","text":"Step functions applied to the "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This property does not support applying interpolation functions to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable or applying interpolation or step functions to feature"},{"type":"text","text":" "},{"type":"text","text":"attributes."}],"type":"paragraph"}]}],"metadata":{"externalID":"c:objc(cs)MLNHillshadeStyleLayer(py)hillshadeMethod",