{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"]]},"abstract":[{"type":"text","text":"The hillshade algorithm to use, one of "},{"code":"MLNHillshadeMethodStandard","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"MLNHillshadeMethodBasic","type":"codeVoice"},{"type":"text","text":", "},{"code":"MLNHillshadeMethodCombined","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"MLNHillshadeMethodIgor","type":"codeVoice"},{"type":"text","text":", or "},{"code":"MLNHillshadeMethodMultidirectional","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "}],"sections":[],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer\/hillshadeMethod"},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSExpression","text":"NSExpression"},{"kind":"text","text":" * "},{"kind":"identifier","text":"hillshadeMethod"},{"kind":"text","text":";"}],"languages":["occ"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"The default value of this property is an expression that evaluates to"},{"type":"text","text":" "},{"type":"codeVoice","code":"standard"},{"type":"text","text":". Set this property to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to reset it to the default value."}],"type":"paragraph"},{"inlineContent":[{"text":"You can set this property to an expression containing any of the following:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Constant ","type":"text"},{"code":"MLNHillshadeMethod","type":"codeVoice"},{"text":" values","type":"text"},{"text":" ","type":"text"},{"text":"Any of the following constant string values:","type":"text"},{"text":" ","type":"text"},{"code":"standard","type":"codeVoice"},{"text":": The legacy hillshade method.","type":"text"},{"text":" ","type":"text"},{"code":"basic","type":"codeVoice"},{"text":": Basic hillshade. Uses a simple physics model where the reflected","type":"text"},{"text":" ","type":"text"},{"text":"light intensity is proportional to the cosine of the angle between the incident","type":"text"},{"text":" ","type":"text"},{"text":"light and the surface normal. Similar to GDAL’s ","type":"text"},{"code":"gdaldem","type":"codeVoice"},{"text":" default algorithm.","type":"text"},{"text":" ","type":"text"},{"code":"combined","type":"codeVoice"},{"text":": Hillshade algorithm whose intensity scales with slope. Similar","type":"text"},{"text":" ","type":"text"},{"text":"to GDAL’s ","type":"text"},{"code":"gdaldem","type":"codeVoice"},{"text":" with ","type":"text"},{"code":"-combined","type":"codeVoice"},{"text":" option.","type":"text"},{"text":" ","type":"text"},{"code":"igor","type":"codeVoice"},{"text":": Hillshade algorithm which tries to minimize effects on other map","type":"text"},{"text":" ","type":"text"},{"text":"features beneath. Similar to GDAL’s ","type":"text"},{"code":"gdaldem","type":"codeVoice"},{"text":" with ","type":"text"},{"code":"-igor","type":"codeVoice"},{"text":" option.","type":"text"},{"text":" ","type":"text"},{"code":"multidirectional","type":"codeVoice"},{"text":": Hillshade with multiple illumination directions. Uses","type":"text"},{"text":" ","type":"text"},{"text":"the basic hillshade model with multiple independent light sources.","type":"text"},{"text":" ","type":"text"},{"text":"Predefined functions, including mathematical and string operators","type":"text"},{"text":" ","type":"text"},{"text":"Conditional expressions","type":"text"},{"text":" ","type":"text"},