ext","text":" option."},{"type":"text","text":" "},{"type":"codeVoice","code":"multidirectional"},{"type":"text","text":": Hillshade with multiple illumination directions. Uses"},{"type":"text","text":" "},{"type":"text","text":"the basic hillshade model with multiple independent light sources."},{"type":"text","text":" "},{"type":"text","text":"Predefined functions, including mathematical and string operators"},{"type":"text","text":" "},{"type":"text","text":"Conditional expressions"},{"text":" ","type":"text"},{"type":"text","text":"Variable assignments and references to assigned variables"},{"type":"text","text":" "},{"text":"Step functions applied to the ","type":"text"},{"type":"codeVoice","code":"$zoomLevel"},{"text":" variable","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property does not support applying interpolation functions to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable or applying interpolation or step functions to feature"},{"type":"text","text":" "},{"type":"text","text":"attributes."}]}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyleLayer/hillshadeMethod":{"kind":"symbol","fragments":[{"kind":"identifier","text":"hillshadeMethod"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer\/hillshadeMethod","role":"symbol","title":"hillshadeMethod","type":"topic","url":"\/documentation\/maplibre\/mlnhillshadestylelayer\/hillshademethod","abstract":[{"text":"The hillshade algorithm to use, one of ","type":"text"},{"type":"codeVoice","code":"MLNHillshadeMethodStandard"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"MLNHillshadeMethodBasic"},{"text":", ","type":"text"},{"type":"codeVoice","code":"MLNHillshadeMethodCombined"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"MLNHillsh