{"sections":[],"kind":"symbol","abstract":[{"type":"text","text":"The hillshade algorithm to use, one of "},{"type":"codeVoice","code":"MLNHillshadeMethodStandard"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"MLNHillshadeMethodBasic"},{"type":"text","text":", "},{"type":"codeVoice","code":"MLNHillshadeMethodCombined"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"MLNHillshadeMethodIgor"},{"type":"text","text":", or "},{"type":"codeVoice","code":"MLNHillshadeMethodMultidirectional"},{"type":"text","text":"."},{"type":"text","text":" "}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer\/hillshadeMethod"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"paths":["\/documentation\/maplibre\/mlnhillshadestylelayer\/hillshademethod"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"symbolKind":"property","title":"hillshadeMethod","fragments":[{"kind":"identifier","text":"hillshadeMethod"}],"externalID":"c:objc(cs)MLNHillshadeStyleLayer(py)hillshadeMethod","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"hillshadeMethod"}],"modules":[{"name":"MapLibre"}],"roleHeading":"Instance Property"},"primaryContentSections":[{"declarations":[{"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSExpression","text":"NSExpression","kind":"typeIdentifier"},{"text":" * ","kind":"text"},{"text":"hillshadeMethod","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"The default value of this property is an expression that evaluates to"},{"type":"text","text":" "},{"code":"standard","type":"codeVoice"},{"type":"text","text":". Set this property to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" to reset it to the default value."}],"type":"paragraph"},{"inlineContent":[{"text":"You can set this property to an expression containing any of the following:","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Constant "},{"type":"codeVoice","code":"MLNHillshadeMethod"},{"type":"text","text":" values"},{"type":"text","text":" "},{"type":"text","text":"Any of the following constant string values:"},{"type":"text","text":" "},{"type":"codeVoice","code":"standard"},{"type":"text","text":": The legacy hillshade method."},{"type":"text","text":" "},{"type":"codeVoice","code":"basic"},{"type":"text","text":": Basic hillshade. Uses a simple physics model where the reflected"},{"type":"text","text":" "},{"type":"text","text":"light intensity is proportional to the cosine of the angle between the incident"},{"type":"text","text":" "},{"type":"text","text":"light and the surface normal. Similar to GDAL’s "},{"code":"gdaldem","type":"codeVoice"},{"type":"text","text":" default algorithm."},{"type":"text","text":" "},{"code":"combined","type":"codeVoice"},{"type":"text","text":": Hillshade algorithm whose intensity scales with slope. Similar"},{"type":"text","text":" "},{"type":"text","text":"to GDAL’s "},{"code":"gdaldem","type":"codeVoice"},{"type":"text","text":" with "},{"code":"-combined","type":"codeVoice"},{"type":"text","text":" option."},{"type":"text","text":" "},{"code":"igor","type":"codeVoice"},{"type":"text","text":": Hillshade algorithm which tries to minimize effects on other map"},{"type":"text","text":" "},{"type":"text","text":"features beneath. Similar to GDAL’s "},{"code":"gdaldem","type":"codeVoice"},{"type":"text","text":" with "},{"code":"-igor","type":"codeVoice"},{"type":"text","text":" option."},{"type":"text","text":" "},{"code":"multidirectional","type":"codeVoice"},{"type":"text","text":": Hillshade with multiple illumination directions. Uses"},{"type":"text","text":" "},{"type":"text","text":"the basic hillshade model with multiple independent light sources."},{"type":"text","text":" "},{"type":"text","text":"Predefined functions, including mathematical and string operators"},{"type":"text","text":" "},{"type":"text","text":"Conditional expressions"},{"type":"text","text":" "},{"type":"text","text":"Variable assignments and references to assigned variables"},{"type":"text","text":" "},{"type":"text","text":"Step functions applied to the "},{"code":"$zoomLevel","type":"codeVoice"},{"type":"text","text":" variable"}]},{"type":"paragraph","inlineContent":[{"text":"This property does not support applying interpolation functions to the","type":"text"},{"text":" ","type":"text"},{"code":"$zoomLevel","type":"codeVoice"},{"text":" variable or applying interpolation or step functions to feature","type":"text"},{"text":" ","type":"text"},{"text":"attributes.","type":"text"}]}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","kind":"symbol","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"role":"collection","type":"topic","title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyleLayer":{"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","fragments":[{"text":"MLNHillshadeStyleLayer","kind":"identifier"}],"kind":"symbol","type":"topic","title":"MLNHillshadeStyleLayer","url":"\/documentation\/maplibre\/mlnhillshadestylelayer","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","isActive":true,"type":"reference"},{"type":"text","text":" is a style layer that renders raster "},{"type":"text","text":"digital elevation"},{"type":"text","text":" "},{"type":"text","text":"model"},{"type":"text","text":" (DEM) tiles on the map."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyleLayer/hillshadeMethod":{"abstract":[{"text":"The hillshade algorithm to use, one of ","type":"text"},{"code":"MLNHillshadeMethodStandard","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"MLNHillshadeMethodBasic","type":"codeVoice"},{"text":", ","type":"text"},{"code":"MLNHillshadeMethodCombined","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"MLNHillshadeMethodIgor","type":"codeVoice"},{"text":", or ","type":"text"},{"code":"MLNHillshadeMethodMultidirectional","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"}],"kind":"symbol","fragments":[{"text":"hillshadeMethod","kind":"identifier"}],"role":"symbol","url":"\/documentation\/maplibre\/mlnhillshadestylelayer\/hillshademethod","title":"hillshadeMethod","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer\/hillshadeMethod"}}}