{"kind":"symbol","sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnhillshadestylelayer\/hillshademethod"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"The hillshade algorithm to use, one of "},{"type":"codeVoice","code":"MLNHillshadeMethodStandard"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"MLNHillshadeMethodBasic"},{"type":"text","text":", "},{"type":"codeVoice","code":"MLNHillshadeMethodCombined"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"MLNHillshadeMethodIgor"},{"type":"text","text":", or "},{"type":"codeVoice","code":"MLNHillshadeMethodMultidirectional"},{"type":"text","text":"."},{"type":"text","text":" "}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer\/hillshadeMethod","interfaceLanguage":"occ"},"metadata":{"role":"symbol","fragments":[{"kind":"identifier","text":"hillshadeMethod"}],"title":"hillshadeMethod","navigatorTitle":[{"kind":"identifier","text":"hillshadeMethod"}],"roleHeading":"Instance Property","modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNHillshadeStyleLayer(py)hillshadeMethod","symbolKind":"property"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"text":"NSExpression","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSExpression"},{"text":" * ","kind":"text"},{"text":"hillshadeMethod","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default value of this property is an expression that evaluates to"},{"type":"text","text":" "},{"type":"codeVoice","code":"standard"},{"type":"text","text":". Set this property to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to reset it to the default value."}]},{"type":"paragraph","inlineContent":[{"text":"You can set this property to an expression containing any of the following:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Constant "},{"code":"MLNHillshadeMethod","type":"codeVoice"},{"type":"text","text":" values"},{"type":"text","text":" "},{"type":"text","text":"Any of the following constant string values:"},{"type":"text","text":" "},{"code":"standard","type":"codeVoice"},{"type":"text","text":": The legacy hillshade method."},{"type":"text","text":" "},{"code":"basic","type":"codeVoice"},{"type":"text","text":": Basic hillshade. Uses a simple physics model where the reflected"},{"type":"text","text":" "},{"type":"text","text":"light intensity is proportional to the cosine of the angle between the incident"},{"type":"text","text":" "},{"type":"text","text":"light and the surface normal. Similar to GDAL’s "},{"code":"gdaldem","type":"codeVoice"},{"type":"text","text":" default algorithm."},{"type":"text","text":" "},{"code":"combined","type":"codeVoice"},{"type":"text","text":": Hillshade algorithm whose intensity scales with slope. Similar"},{"type":"text","text":" "},{"type":"text","text":"to GDAL’s "},{"code":"gdaldem","type":"codeVoice"},{"type":"text","text":" with "},{"code":"-combined","type":"codeVoice"},{"type":"text","text":" option."},{"type":"text","text":" "},{"code":"igor","type":"codeVoice"},{"type":"text","text":": Hillshade algorithm which tries to minimize effects on other map"},{"type":"text","text":" "},{"type":"text","text":"features beneath. Similar to GDAL’s "},{"code":"gdaldem","type":"codeVoice"},{"type":"text","text":" with "},{"code":"-igor","type":"codeVoice"},{"type":"text","text":" option."},{"type":"text","text":" "},{"code":"multidirectional","type":"codeVoice"},{"type":"text","text":": Hillshade with multiple illumination directions. Uses"},{"type":"text","text":" "},{"type":"text","text":"the basic hillshade model with multiple independent light sources."},{"type":"text","text":" "},{"type":"text","text":"Predefined functions, including mathematical and string operators"},{"type":"text","text":" "},{"type":"text","text":"Conditional expressions"},{"type":"text","text":" "},{"type":"text","text":"Variable assignments and references to assigned variables"},{"type":"text","text":" "},{"type":"text","text":"Step functions applied to the "},{"code":"$zoomLevel","type":"codeVoice"},{"type":"text","text":" variable"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property does not support applying interpolation functions to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable or applying interpolation or step functions to feature"},{"type":"text","text":" "},{"type":"text","text":"attributes."}]}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyleLayer":{"abstract":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"},{"type":"text","text":" is a style layer that renders raster "},{"type":"text","text":"digital elevation"},{"type":"text","text":" "},{"type":"text","text":"model"},{"type":"text","text":" (DEM) tiles on the map."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","type":"topic","fragments":[{"kind":"identifier","text":"MLNHillshadeStyleLayer"}],"role":"symbol","url":"\/documentation\/maplibre\/mlnhillshadestylelayer","kind":"symbol","title":"MLNHillshadeStyleLayer"},"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyle