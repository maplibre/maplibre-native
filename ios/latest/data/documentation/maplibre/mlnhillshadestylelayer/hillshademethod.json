":"codeVoice","code":"standard"},{"type":"text","text":". Set this property to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to reset it to the default value."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can set this property to an expression containing any of the following:"}],"type":"paragraph"},{"inlineContent":[{"text":"Constant ","type":"text"},{"type":"codeVoice","code":"MLNHillshadeMethod"},{"text":" values","type":"text"},{"text":" ","type":"text"},{"text":"Any of the following constant string values:","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"standard"},{"text":": The legacy hillshade method.","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"basic"},{"text":": Basic hillshade. Uses a simple physics model where the reflected","type":"text"},{"text":" ","type":"text"},{"text":"light intensity is proportional to the cosine of the angle between the incident","type":"text"},{"text":" ","type":"text"},{"text":"light and the surface normal. Similar to GDAL’s ","type":"text"},{"type":"codeVoice","code":"gdaldem"},{"text":" default algorithm.","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"combined"},{"text":": Hillshade algorithm whose intensity scales with slope. Similar","type":"text"},{"text":" ","type":"text"},{"text":"to GDAL’s ","type":"text"},{"type":"codeVoice","code":"gdaldem"},{"text":" with ","type":"text"},{"type":"codeVoice","code":"-combined"},{"text":" option.","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"igor"},{"text":": Hillshade algorithm which tries to minimize effects on other map","type":"text"},{"text":" ","type":"text"},{"text":"features beneath. Similar to GDAL’s ","type":"text"},{"type":"codeVoice","code":"gdaldem"},{"text":" with ","type":"text"},{"type":"codeVoice","code":"-igor"},{"text":" option.","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"multidirectional"},{"text":": Hillsha