{"variants":[{"paths":["\/documentation\/maplibre\/mlnhillshadestylelayer\/hillshademethod"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"modules":[{"name":"MapLibre"}],"title":"hillshadeMethod","roleHeading":"Instance Property","symbolKind":"property","externalID":"c:objc(cs)MLNHillshadeStyleLayer(py)hillshadeMethod","navigatorTitle":[{"kind":"identifier","text":"hillshadeMethod"}],"fragments":[{"text":"hillshadeMethod","kind":"identifier"}],"role":"symbol"},"abstract":[{"type":"text","text":"The hillshade algorithm to use, one of "},{"type":"codeVoice","code":"MLNHillshadeMethodStandard"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"MLNHillshadeMethodBasic"},{"type":"text","text":", "},{"type":"codeVoice","code":"MLNHillshadeMethodCombined"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"MLNHillshadeMethodIgor"},{"type":"text","text":", or "},{"type":"codeVoice","code":"MLNHillshadeMethodMultidirectional"},{"type":"text","text":"."},{"type":"text","text":" "}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer\/hillshadeMethod","interfaceLanguage":"occ"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSExpression","text":"NSExpression"},{"kind":"text","text":" * "},{"kind":"identifier","text":"hillshadeMethod"},{"kind":"text","text":";"}],"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default value of this property is an expression that evaluates to"},{"type":"text","text":" "},{"code":"standard","type":"codeVoice"},{"type":"text","text":". Set this property to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" to reset it to the default value."}]},{"inlineContent":[{"type":"text","text":"You can set this property to an expression containing any of the following:"}],"type":"paragraph"},{"inlineContent":[{"text":"Constant ","type":"text"},{"code":"MLNHillshadeMethod","type":"codeVoice"},{"text":" values","type":"text"},{"text":" ","type":"text"},{"text":"Any of the following constant string values:","type":"text"},{"text":" ","type":"text"},{"code":"standard","type":"codeVoice"},{"text":": The legacy hillshade method.","type":"text"},{"text":" ","type":"text"},{"code":"basic","type":"codeVoice"},{"text":": Basic hillshade. Uses a simple physics model where the reflected","type":"text"},{"text":" ","type":"text"},{"text":"light intensity is proportional to the cosine of the angle between the incident","type":"text"},{"text":" ","type":"text"},{"text":"light and the surface normal. Similar to GDAL’s ","type":"text"},{"code":"gdaldem","type":"codeVoice"},{"text":" default algorithm.","type":"text"},{"text":" ","type":"text"},{"code":"combined","type":"codeVoice"},{"text":": Hillshade algorithm whose intensity scales with slope. Similar","type":"text"},{"text":" ","type":"text"},{"text":"to GDAL’s ","type":"text"},{"code":"gdaldem","type":"codeVoice"},{"text":" with ","type":"text"},{"code":"-combined","type":"codeVoice"},{"text":" option.","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"igor"},{"type":"text","text":": Hillshade algorithm which tries to minimize effects on other map"},{"type":"text","text":" "},{"type":"text","text":"features beneath. Similar to GDAL’s "},{"type":"codeVoice","code":"gdaldem"},{"type":"text","text":" with "},{"type":"codeVoice","code":"-igor"},{"type":"text","text":" option."},{"type":"text","text":" "},{"type":"codeVoice","code":"multidirectional"},{"type":"text","text":": Hillshade with multiple illumination directions. Uses"},{"type":"text","text":" "},{"type":"text","text":"the basic hillshade model with multiple independent light sources."},{"type":"text","text":" "},{"type":"text","text":"Predefined functions, including mathematical and string operators"},{"type":"text","text":" "},{"type":"text","text":"Conditional expressions"},{"type":"text","text":" "},{"type":"text","text":"Variable assignments and references to assigned variables"},{"type":"text","text":" "},{"type":"text","text":"Step functions applied to the "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property does not support applying interpolation functions to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable or applying interpolation or step functions to feature"},{"type":"text","text":" "},{"type":"text","text":"attributes."}]}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","role":"collection","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","type":"topic","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyleLayer":{"title":"MLNHillshadeStyleLayer","kind":"symbol","fragments":[{"text":"MLNHillshadeStyleLayer","kind":"identifier"}],"abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","isActive":true},{"type":"text","text":" is a style layer that renders raster "},{"type":"text","text":"digital elevation"},{"type":"text","text":" "},{"type":"text","text":"model"},{"type":"text","text":" (DEM) tiles on the map."}],"role":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","url":"\/documentation\/maplibre\/mlnhillshadestylelayer"},"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyleLayer/hillshadeMethod":{"title":"hillshadeMethod","fragments":[{"kind":"identifier","text":"hillshadeMethod"}],"url":"\/documentation\/maplibre\/mlnhillshadestylelayer\/hillshademethod","role":"symbol","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"The hillshade algorithm to use, one of "},{"code":"MLNHillshadeMethodStandard","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"MLNHillshadeMethodBasic","type":"codeVoice"},{"type":"text","text":", "},{"code":"MLNHillshadeMethodCombined","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"MLNHillshadeMethodIgor","type":"codeVoice"},{"type":"text","text":", or "},{"code":"MLNHillshadeMethodMultidirectional","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer\/hillshadeMethod"}}}