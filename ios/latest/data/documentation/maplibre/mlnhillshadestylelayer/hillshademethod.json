{"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"text":"NSExpression","preciseIdentifier":"c:objc(cs)NSExpression","kind":"typeIdentifier"},{"text":" * ","kind":"text"},{"text":"hillshadeMethod","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default value of this property is an expression that evaluates to"},{"type":"text","text":" "},{"type":"codeVoice","code":"standard"},{"type":"text","text":". Set this property to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to reset it to the default value."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can set this property to an expression containing any of the following:"}]},{"type":"paragraph","inlineContent":[{"text":"Constant ","type":"text"},{"code":"MLNHillshadeMethod","type":"codeVoice"},{"text":" values","type":"text"},{"text":" ","type":"text"},{"text":"Any of the following constant string values:","type":"text"},{"text":" ","type":"text"},{"code":"standard","type":"codeVoice"},{"text":": The legacy hillshade method.","type":"text"},{"text":" ","type":"text"},{"code":"basic","type":"codeVoice"},{"text":": Basic hillshade. Uses a simple physics model where the reflected","type":"text"},{"text":" ","type":"text"},{"text":"light intensity is proportional to the cosine of the angle between the incident","type":"text"},{"text":" ","type":"text"},{"text":"light and the surface normal. Similar to GDAL’s ","type":"text"},{"code":"gdaldem","type":"codeVoice"},{"text":" default algorithm.","type":"text"},{"text":" ","type":"text"},{"code":"combined","type":"codeVoice"},{"text":": Hillshade algorithm whose intensity scales with slope. Similar","type":"text"},{"text":" ","type":"text"},{"text":"to GDAL’s ","type":"text"},{"code":"gdaldem","type":"codeVoice"},{"text":" with ","type":"text"},{"code":"-combined","type":"codeVoice"},{"text":" option.","type":"text"},{"text":" ","type":"text"},{"code":"igor","type":"codeVoice"},{"text":": Hillshade algorithm which tries to minimize effects on other map","type":"text"},{"text":" ","type":"text"},{"text":"features beneath. Similar to GDAL’s ","type":"text"},{"code":"gdaldem","type":"codeVoice"},{"text":" with ","type":"text"},{"code":"-igor","type":"codeVoice"},{"text":" option.","type":"text"},{"text":" ","type":"text"},{"code":"multidirectional","type":"codeVoice"},{"text":": Hillshade with multiple illumination directions. Uses","type":"text"},{"text":" ","type":"text"},{"text":"the basic hillshade model with multiple independent light sources.","type":"text"},{"text":" ","type":"text"},{"text":"Predefined functions, including mathematical and string operators","type":"text"},{"text":" ","type":"text"},{"text":"Conditional expressions","type":"text"},{"text":" ","type":"text"},{"text":"Variable assignments and references to assigned variables","type":"text"},{"text":" ","type":"text"},{"text":"Step functions applied to the ","type":"text"},{"code":"$zoomLevel","type":"codeVoice"},{"text":" variable","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property does not support applying interpolation functions to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable or applying interpolation or step functions to feature"},{"type":"text","text":" "},{"type":"text","text":"attributes."}]}],"kind":"content"}],"abstract":[{"type":"text","text":"The hillshade algorithm to use, one of "},{"code":"MLNHillshadeMethodStandard","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"MLNHillshadeMethodBasic","type":"codeVoice"},{"type":"text","text":", "},{"code":"MLNHillshadeMethodCombined","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"MLNHillshadeMethodIgor","type":"codeVoice"},{"type":"text","text":", or "},{"type":"codeVoice","code":"MLNHillshadeMethodMultidirectional"},{"type":"text","text":"."},{"type":"text","text":" "}],"kind":"symbol","metadata":{"symbolKind":"property","navigatorTitle":[{"text":"hillshadeMethod","kind":"identifier"}],"roleHeading":"Instance Property","role":"symbol","fragments":[{"text":"hillshadeMethod","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"title":"hillshadeMethod","externalID":"c:objc(cs)MLNHillshadeStyleLayer(py)hillshadeMethod"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"]]},"variants":[{"paths":["\/documentation\/maplibre\/mlnhillshadestylelayer\/hillshademethod"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer\/hillshadeMethod","interfaceLanguage":"occ"},"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyleLayer/hillshadeMethod":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer\/hillshadeMethod","kind":"symbol","fragments":[{"kind":"identifier","text":"hillshadeMethod"}],"url":"\/documentation\/maplibre\/mlnhillshadestylelayer\/hillshademethod","type":"topic","abstract":[{"text":"The hillshade algorithm to use, one of ","type":"text"},{"code":"MLNHillshadeMethodStandard","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"MLNHillshadeMethodBasic","type":"codeVoice"},{"text":", ","type":"text"},{"code":"MLNHillshadeMethodCombined","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"MLNHillshadeMethodIgor","type":"codeVoice"},{"text":", or ","type":"text"},{"code":"MLNHillshadeMethodMultidirectional","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"}],"role":"symbol","title":"hillshadeMethod"},"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","url":"\/documentation\/maplibre","kind":"symbol","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyleLayer":{"type":"topic","title":"MLNHillshadeStyleLayer","url":"\/documentation\/maplibre\/mlnhillshadestylelayer","role":"symbol","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","abstract":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"},{"type":"text","text":" is a style layer that renders raster "},{"type":"text","text":"digital elevation"},{"type":"text","text":" "},{"type":"text","text":"model"},{"type":"text","text":" (DEM) tiles on the map."}],"fragments":[{"text":"MLNHillshadeStyleLayer","kind":"identifier"}]}}}