{"abstract":[{"type":"text","text":"The hillshade algorithm to use, one of "},{"code":"MLNHillshadeMethodStandard","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"MLNHillshadeMethodBasic","type":"codeVoice"},{"type":"text","text":", "},{"code":"MLNHillshadeMethodCombined","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"MLNHillshadeMethodIgor","type":"codeVoice"},{"type":"text","text":", or "},{"code":"MLNHillshadeMethodMultidirectional","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "}],"kind":"symbol","metadata":{"fragments":[{"text":"hillshadeMethod","kind":"identifier"}],"externalID":"c:objc(cs)MLNHillshadeStyleLayer(py)hillshadeMethod","navigatorTitle":[{"kind":"identifier","text":"hillshadeMethod"}],"role":"symbol","modules":[{"name":"MapLibre"}],"title":"hillshadeMethod","roleHeading":"Instance Property","symbolKind":"property"},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer\/hillshadeMethod"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"text":"NSExpression","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSExpression"},{"text":" * ","kind":"text"},{"text":"hillshadeMethod","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"The default value of this property is an expression that evaluates to","type":"text"},{"text":" ","type":"text"},{"code":"standard","type":"codeVoice"},{"text":". Set this property to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" to reset it to the default value.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can set this property to an expression containing any of the following:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Constant "},{"code":"MLNHillshadeMethod","type":"codeVoice"},{"type":"text","text":" values"},{"type":"text","text":" "},{"type":"text","text":"Any of the following constant string values:"},{"type":"text","text":" "},{"code":"standard","type":"codeVoice"},{"type":"text","text":": The legacy hillshade method."},{"type":"text","text":" "},{"code":"basic","type":"codeVoice"},{"type":"text","text":": Basic hillshade. Uses a simple physics model where the reflected"},{"type":"text","text":" "},{"type":"text","text":"light intensity is proportional to the cosine of the angle between the incident"},{"type":"text","text":" "},{"type":"text","text":"light and the surface normal. Similar to GDAL’s "},{"code":"gdaldem","type":"codeVoice"},{"type":"text","text":" default algorithm."},{"type":"text","text":" "},{"code":"combined","type":"codeVoice"},{"type":"text","text":": Hillshade algorithm whose intensity scales with slope. Similar"},{"type":"text","text":" "},{"type":"text","text":"to GDAL’s "},{"code":"gdaldem","type":"codeVoice"},{"type":"text","text":" with "},{"code":"-combined","type":"codeVoice"},{"type":"text","text":" option."},{"type":"text","text":" "},{"code":"igor","type":"codeVoice"},{"type":"text","text":": Hillshade algorithm which tries to minimize effects on other map"},{"type":"text","text":" "},{"type":"text","text":"features beneath. Similar to GDAL’s "},{"code":"gdaldem","type":"codeVoice"},{"type":"text","text":" with "},{"code":"-igor","type":"codeVoice"},{"type":"text","text":" option."},{"type":"text","text":" "},{"code":"multidirectional","type":"codeVoice"},{"type":"text","text":": Hillshade with multiple illumination directions. Uses"},{"type":"text","text":" "},{"type":"text","text":"the basic hillshade model with multiple independent light sources."},{"type":"text","text":" "},{"type":"text","text":"Predefined functions, including mathematical and string operators"},{"type":"text","text":" "},{"type":"text","text":"Conditional expressions"},{"type":"text","text":" "},{"type":"text","text":"Variable assignments and references to assigned variables"},{"type":"text","text":" "},{"type":"text","text":"Step functions applied to the "},{"code":"$zoomLevel","type":"codeVoice"},{"type":"text","text":" variable"}]},{"type":"paragraph","inlineContent":[{"text":"This property does not support applying interpolation functions to the","type":"text"},{"text":" ","type":"text"},{"code":"$zoomLevel","type":"codeVoice"},{"text":" variable or applying interpolation or step functions to feature","type":"text"},{"text":" ","type":"text"},{"text":"attributes.","type":"text"}]}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"]]},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnhillshadestylelayer\/hillshademethod"]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyleLayer/hillshadeMethod":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer\/hillshadeMethod","url":"\/documentation\/maplibre\/mlnhillshadestylelayer\/hillshademethod","type":"topic","title":"hillshadeMethod","kind":"symbol","fragments":[{"kind":"identifier","text":"hillshadeMethod"}],"abstract":[{"type":"text","text":"The hillshade algorithm to use, one of "},{"type":"codeVoice","code":"MLNHillshadeMethodStandard"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"MLNHillshadeMethodBasic"},{"type":"text","text":", "},{"type":"codeVoice","code":"MLNHillshadeMethodCombined"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"MLNHillshadeMethodIgor"},