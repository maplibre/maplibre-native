{"abstract":[{"text":"The hillshade algorithm to use, one of ","type":"text"},{"code":"MLNHillshadeMethodStandard","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"MLNHillshadeMethodBasic","type":"codeVoice"},{"text":", ","type":"text"},{"code":"MLNHillshadeMethodCombined","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"MLNHillshadeMethodIgor","type":"codeVoice"},{"text":", or ","type":"text"},{"code":"MLNHillshadeMethodMultidirectional","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer\/hillshadeMethod","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"]]},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSExpression","text":"NSExpression"},{"kind":"text","text":" * "},{"kind":"identifier","text":"hillshadeMethod"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"text":"The default value of this property is an expression that evaluates to","type":"text"},{"text":" ","type":"text"},{"code":"standard","type":"codeVoice"},{"text":". Set this property to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" to reset it to the default value.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can set this property to an expression containing any of the following:"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Constant "},{"code":"MLNHillshadeMethod","type":"codeVoice"},{"type":"text","text":" values"},{"type":"text","text":" "},{"type":"text","text":"Any of the following constant string values:"},{"type":"text","text":" "},{"code":"standard","type":"codeVoice"},{"type":"text","text":": The legacy hillshade method."},{"type":"text","text":" "},{"code":"basic","type":"codeVoice"},{"type":"text","text":": Basic hillshade. Uses a simple physics model where the reflected"},{"type":"text","text":" "},{"type":"text","text":"light intensity is proportional to the cosine of the angle between the incident"},{"type":"text","text":" "},{"type":"text","text":"light and the surface normal. Similar to GDAL’s "},{"code":"gdaldem","type":"codeVoice"},{"type":"text","text":" default algorithm."},{"type":"text","text":" "},{"code":"combined","type":"codeVoice"},{"type":"text","text":": Hillshade algorithm whose intensity scales with slope. Similar"},{"type":"text","text":" "},{"type":"text","text":"to GDAL’s "},{"code":"gdaldem","type":"codeVoice"},{"type":"text","text":" with "},{"code":"-combined","type":"codeVoice"},{"type":"text","text":" option."},{"type":"text","text":" "},{"code":"igor","type":"codeVoice"},{"type":"text","text":": Hillshade algorithm which tries to minimize effects on other map"},{"type":"text","text":" "},{"type":"text","text":"features beneath. Similar to GDAL’s "},{"code":"gdaldem","type":"codeVoice"},{"type":"text","text":" with "},{"code":"-igor","type":"codeVoice"},{"type":"text","text":" option."},{"type":"text","text":" "},{"code":"multidirectional","type":"codeVoice"},{"type":"text","text":": Hillshade with multiple illumination directions. Uses"},{"type":"text","text":" "},{"type":"text","text":"the basic hillshade model with multiple independent light sources."},{"type":"text","text":" "},{"type":"text","text":"Predefined functions, including mathematical and string operators"},{"type":"text","text":" "},{"type":"text","text":"Conditional expressions"},{"type":"text","text":" "},{"type":"text","text":"Variable assignments and references to assigned variables"},{"type":"text","text":" "},{"type":"text","text":"Step functions applied to the "},{"code":"$zoomLevel","type":"codeVoice"},{"type":"text","text":" variable"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This property does not support applying interpolation functions to the"},{"type":"text","text":" "},{"code":"$zoomLevel","type":"codeVoice"},{"type":"text","text":" variable or applying interpolation or step functions to feature"},{"type":"text","text":" "},{"type":"text","text":"attributes."}],"type":"paragraph"}]}],"metadata":{"title":"hillshadeMethod","externalID":"c:objc(cs)MLNHillshadeStyleLayer(py)hillshadeMethod","symbolKind":"property","modules":[{"name":"MapLibre"}],"fragments":[{"text":"hillshadeMethod","kind":"identifier"}],"roleHeading":"Instance Property","navigatorTitle":[{"text":"hillshadeMethod","kind":"identifier"}],"role":"symbol"},"variants":[{"paths":["\/documentation\/maplibre\/mlnhillshadestylelayer\/hillshademethod"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyleLayer":{"title":"MLNHillshadeStyleLayer","type":"topic","role":"symbol","url":"\/documentation\/maplibre\/mlnhillshadestylelayer","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","kind":"symbol","fragments":[{"text":"MLNHillshadeStyleLayer","kind":"identifier"}],"abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","isActive":true},{"type":"text","text":" is a style layer that renders raster "},{"type":"text","text":"digital elevation"},{"type":"text","text":" "},{"type":"text","text":"model"},{"type":"text","text":" (DEM) tiles on the map."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyle