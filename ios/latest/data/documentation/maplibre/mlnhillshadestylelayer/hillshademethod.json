 "},{"code":"MLNHillshadeMethodIgor","type":"codeVoice"},{"type":"text","text":", or "},{"code":"MLNHillshadeMethodMultidirectional","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "}],"role":"symbol","url":"\/documentation\/maplibre\/mlnhillshadestylelayer\/hillshademethod","type":"topic","kind":"symbol","fragments":[{"kind":"identifier","text":"hillshadeMethod"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer\/hillshadeMethod","title":"hillshadeMethod"},"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyleLayer":{"url":"\/documentation\/maplibre\/mlnhillshadestylelayer","fragments":[{"text":"MLNHillshadeStyleLayer","kind":"identifier"}],"title":"MLNHillshadeStyleLayer","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","abstract":[{"text":"An ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"},{"text":" is a style layer that renders raster ","type":"text"},{"text":"digital elevation","type":"text"},{"text":" ","type":"text"},{"text":"model","type":"text"},{"text":" (DEM) tiles on the map.","type":"text"}],"role":"symbol","kind":"symbol"}}}