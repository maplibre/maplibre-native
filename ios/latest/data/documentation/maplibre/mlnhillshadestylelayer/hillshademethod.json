{"abstract":[{"type":"text","text":"The hillshade algorithm to use, one of "},{"code":"MLNHillshadeMethodStandard","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"MLNHillshadeMethodBasic","type":"codeVoice"},{"type":"text","text":", "},{"code":"MLNHillshadeMethodCombined","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"MLNHillshadeMethodIgor","type":"codeVoice"},{"type":"text","text":", or "},{"code":"MLNHillshadeMethodMultidirectional","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer\/hillshadeMethod"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"kind":"typeIdentifier","text":"NSExpression","preciseIdentifier":"c:objc(cs)NSExpression"},{"kind":"text","text":" * "},{"kind":"identifier","text":"hillshadeMethod"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}]},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"text":"The default value of this property is an expression that evaluates to","type":"text"},{"text":" ","type":"text"},{"code":"standard","type":"codeVoice"},{"text":". Set this property to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" to reset it to the default value.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"You can set this property to an expression containing any of the following:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Constant ","type":"text"},{"code":"MLNHillshadeMethod","type":"codeVoice"},{"text":" values","type":"text"},{"text":" ","type":"text"},{"text":"Any of the following constant string values:","type":"text"},{"text":" ","type":"text"},{"code":"standard","type":"codeVoice"},{"text":": The legacy hillshade method.","type":"text"},{"text":" ","type":"text"},{"code":"basic","type":"codeVoice"},{"text":": Basic hillshade. Uses a simple physics model where the reflected","type":"text"},{"text":" ","type":"text"},{"text":"light intensity is proportional to the cosine of the angle between the incident","type":"text"},{"text":" ","type":"text"},{"text":"light and the surface normal. Similar to GDAL’s ","type":"text"},{"code":"gdaldem","type":"codeVoice"},{"text":" default algorithm.","type":"text"},{"text":" ","type":"text"},{"code":"combined","type":"codeVoice"},{"text":": Hillshade algorithm whose intensity scales with slope. Similar","type":"text"},{"text":" ","type":"text"},{"text":"to GDAL’s ","type":"text"},{"code":"gdaldem","type":"codeVoice"},{"text":" with ","type":"text"},{"code":"-combined","type":"codeVoice"},{"text":" option.","type":"text"},{"text":" ","type":"text"},{"code":"igor","type":"codeVoice"},{"text":": Hillshade algorithm which tries to minimize effects on other map","type":"text"},{"text":" ","type":"text"},{"text":"features beneath. Similar to GDAL’s ","type":"text"},{"code":"gdaldem","type":"codeVoice"},{"text":" with ","type":"text"},{"code":"-igor","type":"codeVoice"},{"text":" option.","type":"text"},{"text":" ","type":"text"},{"code":"multidirectional","type":"codeVoice"},{"text":": Hillshade with multiple illumination directions. Uses","type":"text"},{"text":" ","type":"text"},{"text":"the basic hillshade model with multiple independent light sources.","type":"text"},{"text":" ","type":"text"},{"text":"Predefined functions, including mathematical and string operators","type":"text"},{"text":" ","type":"text"},{"text":"Conditional expressions","type":"text"},{"text":" ","type":"text"},{"text":"Variable assignments and references to assigned variables","type":"text"},{"text":" ","type":"text"},{"text":"Step functions applied to the ","type":"text"},{"code":"$zoomLevel","type":"codeVoice"},{"text":" variable","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This property does not support applying interpolation functions to the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"$zoomLevel"},{"text":" variable or applying interpolation or step functions to feature","type":"text"},{"text":" ","type":"text"},{"text":"attributes.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"metadata":{"roleHeading":"Instance Property","externalID":"c:objc(cs)MLNHillshadeStyleLayer(py)hillshadeMethod","symbolKind":"property","fragments":[{"kind":"identifier","text":"hillshadeMethod"}],"title":"hillshadeMethod","role":"symbol","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"kind":"identifier","text":"hillshadeMethod"}]},"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnhillshadestylelayer\/hillshademethod"]}],"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","title":"MapLibre","type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","url":"\/documentation\/maplibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyleLayer":{"fragments":[{"kind":"identifier","text":"MLNHillshadeStyleLayer"}],"title":"MLNHillshadeStyleLayer","abstract":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"},{"type":"text","text":" is a style layer that renders raster "},{"type":"text","text":"digital elevation"},{"type":"text",