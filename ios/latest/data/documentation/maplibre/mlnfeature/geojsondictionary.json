ectorTileSource"}],"title":"MLNVectorTileSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNFeature":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature","title":"MLNFeature","type":"topic","kind":"symbol","url":"\/documentation\/maplibre\/mlnfeature","abstract":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature","type":"reference"},{"type":"text","text":"  protocol is used to provide details about geographic features"},{"type":"text","text":" "},{"type":"text","text":"contained in an "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference"},{"type":"text","text":" or "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","type":"reference"},{"type":"text","text":" object. Each concrete"},{"type":"text","text":" "},{"type":"text","text":"subclass of "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference"},{"type":"text","text":" in turn has a subclass that conforms to this protocol. A"},{"type":"text","text":" "},{"type":"text","text":"feature object associates a shape with an optional identifier and attributes."}],"fragments":[{"text":"MLNFeature","kind":"identifier"}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNFeature/geoJSONDictionary":{"url":"\/documentation\/maplibre\/mlnfeature\/geojsondictionary","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature\/geoJSONDictionary","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"geoJSONDictionary"}],"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"geoJSONDictionary"}],"type":"topic","title":"geoJSONDictionary","abstract":[{"type":"text","text":"Returns a dictionary that can be serialized as a GeoJSON Feature representation"},{"type":"text","text