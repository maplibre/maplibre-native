,"text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the shape source. You"},{"type":"text","text":" "},{"type":"text","text":"can update a shape source by setting its "},{"type":"codeVoice","code":"shape"},{"type":"text","text":" or "},{"type":"codeVoice","code":"URL"},{"type":"text","text":" property."}],"type":"topic","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNFeature/geoJSONDictionary":{"abstract":[{"type":"text","text":"Returns a dictionary that can be serialized as a GeoJSON Feature representation"},{"type":"text","text":" "},{"type":"text","text":"of an instance of an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature"},{"type":"text","text":" subclass."}],"role":"symbol","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"geoJSONDictionary"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature\/geoJSONDictionary","navigatorTitle":[{"kind":"identifier","text":"geoJSONDictionary"}],"url":"\/documentation\/maplibre\/mlnfeature\/geojsondictionary","kind":"symbol","title":"geoJSONDictionary"}}}