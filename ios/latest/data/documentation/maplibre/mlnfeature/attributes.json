","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer\/predicate"},{"text":" to an","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/nspredicate"},{"text":" with the format","type":"text"},{"text":" ","type":"text"},{"code":"importance > 50","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can also configure many layout and paint attributes of an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyleLayer","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"object to match the value of an attribute in this dictionary whenever it"},{"type":"text","text":" "},{"type":"text","text":"renders this feature. For example, if you display features in an"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"type":"text","text":" using an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCircleStyleLayer","type":"reference","isActive":true},{"type":"text","text":", you can assign a "},{"code":"halfway","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"attribute to each of the source’s features, then set"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCircleStyleLayer\/circleRadius","type":"reference","isActive":true},{"type":"text","text":" to an expression for the key path "},{"code":"halfway","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/text","type":"reference"},{"type":"text",