deVoice"},{"text":" ","type":"text"},{"text":"attribute to each of the source’s features, then set","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCircleStyleLayer\/circleRadius","isActive":true,"type":"reference"},{"text":" to an expression for the key path ","type":"text"},{"code":"halfway","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/text","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/iconImageName","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"properties allow you to use attributes yet another way. For example, to label","type":"text"},{"type":"text","text":" "},{"text":"features in an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true,"type":"reference"},{"text":" object by their names, you can assign a ","type":"text"},{"code":"name","type":"codeVoice"},{"text":" ","type":"text"},{"text":"attribute to each of the source’s features, then set","type":"text"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/text"},{"type":"text","text":" to an expression for the constant string value"},{"type":"text","text":" "},{"type":"codeVoice","code":"{name}"},{"type":"text","text":". See the"},{"type":"text","text":" "},{"type":"text","text":"Predicates and Expressions"},{"type":"text","text":" "},{"type":"text","text":"guide for more information about expressions."}]},{"type":"paragraph","inlineContent":[{"text":"In vector tiles loaded by ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource"},{"type":"text","text":" objects, the keys and values of"},{"type":"text","text":" "},{"type":"text","text":"each feature’s attribute dictionary are determined by the source. Each"},{"type":"text","text":" "},{"text":"attribute name is a string, while each attribute value may be a null value,","type":"text"},{"text":" ","type":"text"},{"text":"Boolean value, integer, floating-point number, or string. These data types are","type":"text"},{"text":" ","type":"text"},{"text":"mapped to instances of the following Foundation classes:","type":"text"}]},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"In the tile source"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"In this dictionary"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Null"}]}],[{"inlineContent":[{"code":"NSNull","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"boolValue","type":"codeVoice"},{"type":"text","text":" property)"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"code":"NSNumber","type":"codeVoice"},{"type":"text","text":" (use the "},{"code":"unsignedLongLongValue","type":"codeVoice"},{"type":"text","text":" or "},{"code":"longLongValue","type":"codeVoice"},{"type":"text","text":" property)"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"text":"number","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" (use the "},{"type":"codeVoice","code":"doubleValue"},{"type":"text","text":" property)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"String"}]}],[{"inlineContent":[{"code":"NSString","type":"codeVoice"}],"type":"paragraph"}]]]},{"inlineContent":[{"type":"text","text":"When adding a feature to an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true,"type":"reference"},{"type":"text","text":", use the same Foundation types"},{"type":"text","text":" "},{"type":"text","text":"listed above for each attribute value. In addition to the Foundation types, you"},{"type":"text","text":" "},{"type":"text","text":"may also set an attribute to an "},{"code":"NSColor","type":"codeVoice"},{"type":"text","text":" (macOS) or "},{"code":"UIColor","type":"codeVoice"},{"type":"text","text":" (iOS), which"},{"type":"text","text":" "},{"type":"text","text":"will be converted into its"},{"type":"text","text":" "},{"type":"text","text":"CSS string representation"},{"type":"text","text":" "},{"type":"text","text":"when the feature is added to an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true,"type":"reference"},{"type":"text","text":". This can be convenient when"},{"type":"text","text":" "},{"type":"text","text":"using the attribute to supply a value for a color-typed layout or paint"},{"type":"text","text":" "},{"type":"text","text":"attribute via a key path expression."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that while it is possible to change this value on feature"},{"type":"text","text":" "},{"type":"text","text":"instances obtained from "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/visibleFeaturesAtPoint:","type":"reference","isActive":true},{"type":"text","text":" and related"},{"type":"text","text":" "},{"type":"text","text":"methods, there will be no effect on the map. Setting this value can be useful"},{"type":"text","text":" "},{"type":"text","text":"when the feature instance is used to initialize an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true},{"type":"text","text":" and that"},{"type":"text","text":" "},{"type":"text","text":"source is added to the map and styled."}],"type":"paragraph"}]}],"kind"