":"text","text":"CSS string representation"},{"type":"text","text":" "},{"type":"text","text":"when the feature is added to an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":". This can be convenient when"},{"type":"text","text":" "},{"type":"text","text":"using the attribute to supply a value for a color-typed layout or paint"},{"type":"text","text":" "},{"type":"text","text":"attribute via a key path expression."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that while it is possible to change this value on feature"},{"type":"text","text":" "},{"type":"text","text":"instances obtained from "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/visibleFeaturesAtPoint:","type":"reference","isActive":true},{"type":"text","text":" and related"},{"type":"text","text":" "},{"type":"text","text":"methods, there will be no effect on the map. Setting this value can be useful"},{"type":"text","text":" "},{"type":"text","text":"when the feature instance is used to initialize an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"type":"text","text":" and that"},{"type":"text","text":" "},{"type":"text","text":"source is added to the map and styled."}]}],"kind":"content"}],"metadata":{"role":"symbol","fragments":[{"kind":"identifier","text":"attributes"}],"modules":[{"name":"MapLibre"}],"navigatorTitle":[{"kind":"identifier","text":"attributes"}],"title":"attributes","roleHeading":"Instance Property","externalID":"c:objc(pl)MLNFeature(py)attributes","symbolKind":"property"},"abstract":[{"type":"text","text":"A dictionary of attributes for this feature."}],"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature"]]},"variants":[{"traits":[{"interfaceLanguage