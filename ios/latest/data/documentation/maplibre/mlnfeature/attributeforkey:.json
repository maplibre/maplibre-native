\/MLNVectorStyleLayer","type":"reference","isActive":true},{"type":"text","text":" objects. A vector style layer defines the appearance of"},{"type":"text","text":" "},{"type":"text","text":"any content supplied by the vector tile source."}],"title":"MLNVectorTileSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNFeature/attributes":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature\/attributes","role":"symbol","fragments":[{"text":"attributes","kind":"identifier"}],"kind":"symbol","type":"topic","title":"attributes","url":"\/documentation\/maplibre\/mlnfeature\/attributes","abstract":[{"type":"text","text":"A dictionary of attributes for this feature."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNFeature/attributeForKey:":{"abstract":[{"type":"text","text":"Returns the feature attribute for the given attribute name."}],"url":"\/documentation\/maplibre\/mlnfeature\/attributeforkey:","role":"symbol","type":"topic","fragments":[{"text":"- ","kind":"text"},{"text":"attributeForKey:","kind":"identifier"}],"title":"attributeForKey:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature\/attributeForKey:","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","url":"\/documentation\/maplibre","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNFeature":{"fragments":[{"text":"MLNFeature","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnfeature","role":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature","abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature","type":"reference","isActive":true},{"type":"text","text":"  protocol is used to provide details about geographic features"},{"type":"text","text":" "},{"type":"text","text":"contained in an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"type":"text","text":" or "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","type":"reference","isActive":true},{"type":"text","text":" object. Each concrete"},{"type":"text","text":" "},{"type":"text","text":"subclass of "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":" in turn has a subclass that conforms to this protocol. A"},{"type":"text","text":" "},{"type":"text","text":"feature object associates a shape with an optional identifier and attributes."}],"title":"MLNFeature"}}}