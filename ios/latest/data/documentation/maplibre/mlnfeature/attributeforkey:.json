yProject\/documentation\/MapLibre\/MLNFeature"},{"text":"  protocol is used to provide details about geographic features","type":"text"},{"text":" ","type":"text"},{"text":"contained in an ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"text":" or ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource"},{"text":" object. Each concrete","type":"text"},{"text":" ","type":"text"},{"text":"subclass of ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"text":" in turn has a subclass that conforms to this protocol. A","type":"text"},{"text":" ","type":"text"},{"text":"feature object associates a shape with an optional identifier and attributes.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature","type":"topic","kind":"symbol","url":"\/documentation\/maplibre\/mlnfeature","title":"MLNFeature"},"doc://org.swift.MyProject/documentation/MapLibre/MLNFeature/attributeForKey:":{"url":"\/documentation\/maplibre\/mlnfeature\/attributeforkey:","type":"topic","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"attributeForKey:"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"attributeForKey:"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature\/attributeForKey:","abstract":[{"text":"Returns the feature attribute for the given attribute name.","type":"text"}],"role":"symbol","title":"attributeForKey:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorTileSource":{"fragments":[{"text":"MLNVectorTileSource","kind":"identifier"}],"type":"topic","url":"\/documentation\/maplibre\/mlnvectortilesource","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","kind":"symb