ect. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the shape source. You"},{"type":"text","text":" "},{"type":"text","text":"can update a shape source by setting its "},{"code":"shape","type":"codeVoice"},{"type":"text","text":" or "},{"code":"URL","type":"codeVoice"},{"type":"text","text":" property."}],"role":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeSource"}],"title":"MLNShapeSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNFeature/attributes":{"url":"\/documentation\/maplibre\/mlnfeature\/attributes","kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"A dictionary of attributes for this feature."}],"fragments":[{"text":"attributes","kind":"identifier"}],"title":"attributes","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature\/attributes"}}}