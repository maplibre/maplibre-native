lied by the vector tile source."}],"url":"\/documentation\/maplibre\/mlnvectortilesource","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNFeature/attributeForKey:":{"title":"attributeForKey:","kind":"symbol","url":"\/documentation\/maplibre\/mlnfeature\/attributeforkey:","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature\/attributeForKey:","fragments":[{"text":"- ","kind":"text"},{"text":"attributeForKey:","kind":"identifier"}],"abstract":[{"type":"text","text":"Returns the feature attribute for the given attribute name."}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNFeature/attributes":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature\/attributes","type":"topic","title":"attributes","fragments":[{"kind":"identifier","text":"attributes"}],"kind":"symbol","abstract":[{"type":"text","text":"A dictionary of attributes for this feature."}],"url":"\/documentation\/maplibre\/mlnfeature\/attributes","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"topic","title":"MLNShapeSource","fragments":[{"text":"MLNShapeSource","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":" is a map content source that supplies vector shapes to be"},{"type":"text","text":" "},{"type":"text","text":"shown on the map. The shapes may be instances of "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":" or "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"or they may be defined by local or external"},{"text":" ","type":"text"},{"text":"GeoJSON","type":"text"},{"text":" code. A shape source is added to an","type":"text"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object along with an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the shape source. You"},{"type":"text","text":" "},{"type":"text","text":"can update a shape source by setting its "},{"type":"codeVoice","code":"shape"},{"type":"text","text":" or "},{"type":"codeVoice","code":"URL"},{"type":"text","text":" property."}],"url":"\/documentation\/maplibre\/mlnshapesource","role":"symbol"}}}