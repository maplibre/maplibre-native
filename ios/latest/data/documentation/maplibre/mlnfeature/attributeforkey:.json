urce by setting its "},{"type":"codeVoice","code":"shape"},{"type":"text","text":" or "},{"type":"codeVoice","code":"URL"},{"type":"text","text":" property."}],"title":"MLNShapeSource","kind":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeSource"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNFeature/attributeForKey:":{"title":"attributeForKey:","type":"topic","navigatorTitle":[{"kind":"identifier","text":"attributeForKey:"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature\/attributeForKey:","role":"symbol","abstract":[{"text":"Returns the feature attribute for the given attribute name.","type":"text"}],"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"attributeForKey:"}],"url":"\/documentation\/maplibre\/mlnfeature\/attributeforkey:","kind":"symbol"}}}