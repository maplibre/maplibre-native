y or by an external file that"},{"type":"text","text":" "},{"type":"text","text":"conforms to the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A raster DEM source is added to an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"},{"type":"text","text":" or "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNColorReliefStyleLayer"},{"type":"text","text":" objects. Use a hillshade"},{"type":"text","text":" "},{"type":"text","text":"style layer to control the appearance of content supplied by the raster DEM source,"},{"type":"text","text":" "},{"type":"text","text":"or a color relief style layer to render elevation data with a color ramp."}],"kind":"symbol","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSource/setFeatures:inTileAtX:y:zoomLevel:":{"kind":"symbol","title":"setFeatures:inTileAtX:y:zoomLevel:","role":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"setFeatures:inTileAtX:y:zoomLevel:","kind":"identifier"}],"navigatorTitle":[{"text":"setFeatures:inTileAtX:y:zoomLevel:","kind":"identifier"}],"abstract":[{"text":"Set a new set of features for a tile. This method can be invkoed from background threads.","type":"text"},{"text":" ","type":"text"},{"text":"For best performance, use this method only to update tiles that have already been requested","type":"text"},{"text":" ","type":"text"},{"text":"through ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource","type":"reference","isActive":true}],"type":"topic","identif