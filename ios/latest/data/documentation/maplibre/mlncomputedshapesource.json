urrent style.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","title":"addSource:","url":"\/documentation\/maplibre\/mlnstyle\/addsource:"}}}