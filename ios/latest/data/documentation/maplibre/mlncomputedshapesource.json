","kind":"symbol","abstract":[{"type":"text","text":"Invalidates all the features and properties intersecting with or contained in"},{"type":"text","text":" "},{"type":"text","text":"the specified bounds. New fetch requests will immediately be invoked on the"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource"},{"type":"text","text":"."}],"title":"invalidateBounds:","navigatorTitle":[{"text":"invalidateBounds:","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource\/invalidateBounds:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/sourceWithIdentifier:":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/sourceWithIdentifier:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"sourceWithIdentifier:"}],"title":"sourceWithIdentifier:","kind":"symbol","abstract":[{"text":"Returns a source with the given identifier in the current style.","type":"text"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"sourceWithIdentifier:"}],"role":"symbol","url":"\/documentation\/maplibre\/mlnstyle\/sourcewithidentifier:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/setImage:forName:":{"kind":"symbol","abstract":[{"type":"text","text":"Adds or overrides an image used by the style’s layers."}],"role":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"setImage:forName:"}],"url":"\/documentation\/maplibre\/mlnstyle\/setimage:forname:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"setImage:forName:"}],"title":"setImage:forName:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/setImage:forName:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterDEMSource":{"kind":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterDEMSource","role":"symbol","fragments":[{"text":"MLNRasterDEMSource","kind":"identifier"}],"abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterDEMSource","isActive":true,"type":"reference"},{"text":" is a map content source that supplies rasterized","type":"text"},{"text":" ","type":"text"},{"text":"digital elevation model","type":"text"},{"text":" ","type":"text"},{"text":"(DEM) tiles to be shown on the map. The location of and metadata about the","type":"text"},{"text":" ","type":"text"},{"text":"tiles are defined either by an option dictionary or by an external file that","type":"text"},{"text":" ","type":"text"},{"text":"conforms to the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A raster DEM source is added to an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","type":"reference","isActive":true},{"type":"text","text":" or "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNColorReliefStyleLayer","type":"reference","isActive":true},{"type":"text","text":" objects. Use a hillshade"},{"type":"text","text":" "},{"type":"text","text":"style layer to control the appearance of content supplied by the raster DEM source,"},{"type":"text","text":" "},{"type":"text","text":"or a color relief style layer to render elevation data with a color ramp."}],"title":"MLNRasterDEMSource","url":"\/documentation\/maplibre\/mlnrasterdemsource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSource":{"role":"symbol","fragments":[{"text":"MLNComputedShapeSource","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlncomputedshapeso