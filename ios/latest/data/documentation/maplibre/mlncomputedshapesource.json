pe":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource"}],"url":"\/documentation\/maplibre\/mlncomputedshapesource\/setfeatures:intileatx:y:zoomlevel:","fragments":[{"text":"- ","kind":"text"},{"text":"setFeatures:inTileAtX:y:zoomLevel:","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"url":"\/documentation\/maplibre\/mlnshapesource","kind":"symbol","abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true},{"type":"text","text":" is a map content source that supplies vector shapes to be"},{"type":"text","text":" "},{"type":"text","text":"shown on the map. The shapes may be instances of "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or they may be defined by local or external"},{"type":"text","text":" "},{"type":"text","text":"GeoJSON"},{"type":"text","text":" code. A shape source is added to an"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object along with an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the shape source. You"},{"type":"text","text":" "},{"type":"text","text":"can update a shape source by setting its "},{"type":"codeVoice","code":"shape"},{"type":"text","text":" or "},{"type":"codeVoice","code":"URL"},{"type":"text","text":" property."}],"title":"MLNShapeSource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","role":"symbol","fragments":[{"text":"MLNShapeSource","kind":"identifier"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterDEMSource":{"fragments":[{"text":"MLNRasterDEMSource","kind":"identifier"}],"title":"MLNRasterDEMSource","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterDEMSource","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterDEMSource","type":"reference","isActive":true},{"type":"text","text":" is a map content source that supplies rasterized"},{"type":"text","text":" "},{"type":"text","text":"digital elevation model"},{"type":"text","text":" "},{"type":"text","text":"(DEM) tiles to be shown on the map. The location of and metadata about the"},{"type":"text","text":" "},{"type":"text","text":"tiles are defined either by an option dictionary or by an external file that"},{"type":"text","text":" "},{"type":"text","text":"conforms to the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A raster DEM source is added to an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","type":"reference","isActive":true},{"type":"text","text":" objects. Use a hillshade style layer to control the"},{"type":"text","text":" "},{"type":"text","text":"appearance of content supplied by the raster DEM source."}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnrasterdemsource","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNImageSource":{"kind":"symbol","identifier":"doc:\/\/org.swift.