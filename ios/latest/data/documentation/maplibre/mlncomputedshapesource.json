nImage","type":"reference","isActive":true},{"text":" class.","type":"text"}],"title":"MLNImageSource","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/setImage:forName:":{"fragments":[{"text":"- ","kind":"text"},{"text":"setImage:forName:","kind":"identifier"}],"navigatorTitle":[{"text":"setImage:forName:","kind":"identifier"}],"title":"setImage:forName:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/setImage:forName:","kind":"symbol","url":"\/documentation\/maplibre\/mlnstyle\/setimage:forname:","role":"symbol","abstract":[{"text":"Adds or overrides an image used by the style’s layers.","type":"text"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSourceDataSource":{"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource","role":"symbol","fragments":[{"text":"MLNComputedShapeSourceDataSource","kind":"identifier"}],"abstract":[{"type":"text","text":"Data source for "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","type":"reference","isActive":true},{"type":"text","text":". This protocol defines two optional methods for fetching"},{"type":"text","text":" "},{"type":"text","text":"data, one based on tile coordinates, and one based on a bounding box. Classes that implement this"},{"type":"text","text":" "},{"type":"text","text":"protocol must implement one, and only one of the methods. Methods on this protocol will not be"},{"type":"text","text":" "},{"type":"text","text":"called on main thread, they will be called on the caller’s "},{"type":"codeVoice","code":"requestQueue"},{"type":"text","text":"."}],"title":"MLNComputedShapeSourceDataSource","url":"\/documentation\/maplibre\/mlncomputedshapesourcedatasource","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","titl