Active":true},{"type":"text","text":" is a map content source that supplies rasterized"},{"type":"text","text":" "},{"type":"text","text":"digital elevation model"},{"type":"text","text":" "},{"type":"text","text":"(DEM) tiles to be shown on the map. The location of and metadata about the"},{"type":"text","text":" "},{"type":"text","text":"tiles are defined either by an option dictionary or by an external file that"},{"type":"text","text":" "},{"type":"text","text":"conforms to the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A raster DEM source is added to an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNColorReliefStyleLayer","isActive":true},{"type":"text","text":" objects. Use a hillshade"},{"type":"text","text":" "},{"type":"text","text":"style layer to control the appearance of content supplied by the raster DEM source,"},{"type":"text","text":" "},{"type":"text","text":"or a color relief style layer to render elevation data with a color ramp."}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterDEMSource","type":"topic","fragments":[{"text":"MLNRasterDEMSource","kind":"identifier"}],"title":"MLNRasterDEMSource","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/addSource:":{"abstract":[{"text":"Adds a new source to the current style.","type":"text"}],"title":"addSource:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","url":"\/documentation\/mapli