\/MapLibre\/MLNUserLocation","abstract":[{"text":"The MLNUserLocation class defines a specific type of annotation that identifies","type":"text"},{"text":" ","type":"text"},{"text":"the user’s current location. You do not create instances of this class","type":"text"},{"text":" ","type":"text"},{"text":"directly. Instead, you retrieve an existing ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocation"},{"text":" object from the","type":"text"},{"text":" ","type":"text"},{"code":"userLocation","type":"codeVoice"},{"text":" property of the map view displayed in your application.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserTrackingMode/MLNUserTrackingModeFollowWithHeading":{"url":"\/documentation\/maplibre\/mlnusertrackingmode\/mlnusertrackingmodefollowwithheading","fragments":[{"text":"MLNUserTrackingModeFollowWithHeading","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserTrackingMode\/MLNUserTrackingModeFollowWithHeading","abstract":[{"text":"The map follows the user location and rotates when the heading changes.","type":"text"},{"text":" ","type":"text"},{"text":"The default user location annotation displays a fan-shaped indicator with","type":"text"},{"text":" ","type":"text"},{"text":"the current heading. The heading indicator represents the direction the","type":"text"},{"text":" ","type":"text"},{"text":"device is facing, which is sized according to the reported accuracy.","type":"text"}],"title":"MLNUserTrackingModeFollowWithHeading","kind":"symbol","type":"topic","role":"symbol"}}}