{"abstract":[{"type":"text","text":"Determines whether overlapping symbols in the same layer are rendered in the"},{"text":" ","type":"text"},{"text":"order that they appear in the data source or by their y-position relative to","type":"text"},{"text":" ","type":"text"},{"text":"the viewport. To control the order and prioritization of symbols otherwise, use","type":"text"},{"text":" ","type":"text"},{"code":"symbolSortKey","type":"codeVoice"},{"text":".","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"externalID":"c:objc(cs)MLNSymbolStyleLayer(py)symbolZOrder","title":"symbolZOrder","modules":[{"name":"MapLibre"}],"role":"symbol","symbolKind":"property","fragments":[{"kind":"identifier","text":"symbolZOrder"}],"navigatorTitle":[{"text":"symbolZOrder","kind":"identifier"}],"roleHeading":"Instance Property"},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/symbolZOrder","interfaceLanguage":"occ"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"preciseIdentifier":"c:objc(cs)NSExpression","kind":"typeIdentifier","text":"NSExpression"},{"kind":"text","text":" * "},{"kind":"identifier","text":"symbolZOrder"},{"kind":"text","text":";"}],"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The default value of this property is an expression that evaluates to ","type":"text"},{"code":"auto","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Set this property to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" to reset it to the default value.","type":"text"}]},{"inlineContent":[{"text":"You can set this property to an expression containing any of the followi