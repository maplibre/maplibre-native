{"variants":[{"paths":["\/documentation\/maplibre\/mlnsymbolstylelayer\/symbolplacement"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer"]]},"sections":[],"kind":"symbol","metadata":{"modules":[{"name":"MapLibre"}],"role":"symbol","roleHeading":"Instance Property","navigatorTitle":[{"kind":"identifier","text":"symbolPlacement"}],"externalID":"c:objc(cs)MLNSymbolStyleLayer(py)symbolPlacement","fragments":[{"kind":"identifier","text":"symbolPlacement"}],"symbolKind":"property","title":"symbolPlacement"},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/symbolPlacement"},"abstract":[{"type":"text","text":"Label placement relative to its geometry."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSExpression","text":"NSExpression"},{"kind":"text","text":" * "},{"kind":"identifier","text":"symbolPlacement"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default value of this property is an expression that evaluates to "},{"code":"point","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Set this property to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" to reset it to the default value."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can set this property to an expression containing any of the following:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Constant "},{"code":"MLNSymbolPlacement","type":"codeVoice"},{"type":"text","text":" values"},{"type":"text","text":" "},{"type":"text","text":"Any of the following constant string values:"},{"type":"text","text":" "},{"code":"point","type":"codeVoice"},{"type":"text","text":": The label is placed at the point where the geometry is located."},{"type":"text","text":" "},{"code":"line","type":"codeVoice"},{"type":"text","text":": The label is placed along the line of the geometry. Can only be"},{"type":"text","text":" "},{"type":"text","text":"used on "},{"code":"LineString","type":"codeVoice"},{"type":"text","text":" and "},{"code":"Polygon","type":"codeVoice"},{"type":"text","text":" geometries."},{"type":"text","text":" "},{"code":"line-center","type":"codeVoice"},{"type":"text","text":": The label is placed at the center of the line of the"},{"type":"text","text":" "},{"type":"text","text":"geometry. Can only be used on "},{"code":"LineString","type":"codeVoice"},{"type":"text","text":" and "},{"code":"Polygon","type":"codeVoice"},{"type":"text","text":" geometries. Note that"},{"type":"text","text":" "},{"type":"text","text":"a single feature in a vector tile may contain multiple line geometries."},{"type":"text","text":" "},{"type":"text","text":"Predefined functions, including mathematical and string operators"},{"type":"text","text":" "},{"type":"text","text":"Conditional expressions"},{"type":"text","text":" "},{"type":"text","text":"Variable assignments and references to assigned variables"},{"type":"text","text":" "},{"type":"text","text":"Step functions applied to the "},{"code":"$zoomLevel","type":"codeVoice"},{"type":"text","text":" variable"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property does not support applying interpolation functions to the"},{"type":"text","text":" "},{"code":"$zoomLevel","type":"codeVoice"},{"type":"text","text":" variable or applying interpolation or step functions to feature"},{"type":"text","text":" "},{"type":"text","text":"attributes."}]}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","role":"collection","kind":"symbol","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"url":"\/documentation\/maplibre","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer","isActive":true,"type":"reference"},{"text":" is a style layer that renders icon and text labels","type":"text"},{"text":" ","type":"text"},{"text":"at points or along lines on the map.","type":"text"}],"role":"symbol","url":"\/documentation\/maplibre\/mlnsymbolstylelayer","kind":"symbol","fragments":[{"kind":"identifier","text":"MLNSymbolStyleLayer"}],"title":"MLNSymbolStyleLayer","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer/symbolPlacement":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/symbolPlacement","abstract":[{"text":"Label placement relative to its geometry.","type":"text"}],"role":"symbol","url":"\/documentation\/maplibre\/mlnsymbolstylelayer\/symbolplacement","kind":"symbol","fragments":[{"text":"symbolPlacement","kind":"identifier"}],"title":"symbolPlacement","type":"topic"}}}