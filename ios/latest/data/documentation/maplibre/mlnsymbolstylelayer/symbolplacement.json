{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer"]]},"abstract":[{"type":"text","text":"Label placement relative to its geometry."}],"metadata":{"roleHeading":"Instance Property","symbolKind":"property","fragments":[{"text":"symbolPlacement","kind":"identifier"}],"navigatorTitle":[{"text":"symbolPlacement","kind":"identifier"}],"title":"symbolPlacement","role":"symbol","externalID":"c:objc(cs)MLNSymbolStyleLayer(py)symbolPlacement","modules":[{"name":"MapLibre"}]},"kind":"symbol","sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnsymbolstylelayer\/symbolplacement"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/symbolPlacement"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSExpression","text":"NSExpression"},{"kind":"text","text":" * "},{"kind":"identifier","text":"symbolPlacement"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default value of this property is an expression that evaluates to "},{"type":"codeVoice","code":"point"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Set this property to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to reset it to the default value."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can set this property to an expression containing any of the following:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Constant "},{"type":"codeVoice","code":"MLNSymbolPlacement"},{"type":"text","text":" values"},{"type":"text","text":" "},{"type":"text","text":"Any of the following constant string values:"},{"type":"text","text":" "},{"type":"codeVoice","code":"point"},{"type":"text","text":": The label is placed at the point where the geometry is located."},{"type":"text","text":" "},{"type":"codeVoice","code":"line"},{"type":"text","text":": The label is placed along the line of the geometry. Can only be"},{"type":"text","text":" "},{"type":"text","text":"used on "},{"type":"codeVoice","code":"LineString"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Polygon"},{"type":"text","text":" geometries."},{"type":"text","text":" "},{"type":"codeVoice","code":"line-center"},{"type":"text","text":": The label is placed at the center of the line of the"},{"type":"text","text":" "},{"type":"text","text":"geometry. Can only be used on "},{"type":"codeVoice","code":"LineString"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Polygon"},{"type":"text","text":" geometries. Note that"},{"type":"text","text":" "},{"type":"text","text":"a single feature in a vector tile may contain multiple line geometries."},{"type":"text","text":" "},{"type":"text","text":"Predefined functions, including mathematical and string operators"},{"type":"text","text":" "},{"type":"text","text":"Conditional expressions"},{"type":"text","text":" "},{"type":"text","text":"Variable assignments and references to assigned variables"},{"type":"text","text":" "},{"type":"text","text":"Step functions applied to the "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property does not support applying interpolation functions to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable or applying interpolation or step functions to feature"},{"type":"text","text":" "},{"type":"text","text":"attributes."}]}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","type":"topic","url":"\/documentation\/maplibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"title":"MapLibre","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer/symbolPlacement":{"fragments":[{"text":"symbolPlacement","kind":"identifier"}],"title":"symbolPlacement","type":"topic","abstract":[{"text":"Label placement relative to its geometry.","type":"text"}],"role":"symbol","kind":"symbol","url":"\/documentation\/maplibre\/mlnsymbolstylelayer\/symbolplacement","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/symbolPlacement"},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer":{"url":"\/documentation\/maplibre\/mlnsymbolstylelayer","role":"symbol","fragments":[{"text":"MLNSymbolStyleLayer","kind":"identifier"}],"abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer","type":"reference","isActive":true},{"type":"text","text":" is a style layer that renders icon and text labels"},{"type":"text","text":" "},{"type":"text","text":"at points or along lines on the map."}],"title":"MLNSymbolStyleLayer","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer","kind":"symbol","type":"topic"}}}