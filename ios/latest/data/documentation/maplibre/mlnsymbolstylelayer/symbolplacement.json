xt":"Constant ","type":"text"},{"type":"codeVoice","code":"MLNSymbolPlacement"},{"text":" values","type":"text"},{"text":" ","type":"text"},{"text":"Any of the following constant string values:","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"point"},{"text":": The label is placed at the point where the geometry is located.","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"line"},{"text":": The label is placed along the line of the geometry. Can only be","type":"text"},{"text":" ","type":"text"},{"text":"used on ","type":"text"},{"type":"codeVoice","code":"LineString"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"Polygon"},{"text":" geometries.","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"line-center"},{"text":": The label is placed at the center of the line of the","type":"text"},{"text":" ","type":"text"},{"text":"geometry. Can only be used on ","type":"text"},{"type":"codeVoice","code":"LineString"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"Polygon"},{"text":" geometries. Note that","type":"text"},{"text":" ","type":"text"},{"text":"a single feature in a vector tile may contain multiple line geometries.","type":"text"},{"text":" ","type":"text"},{"text":"Predefined functions, including mathematical and string operators","type":"text"},{"text":" ","type":"text"},{"text":"Conditional expressions","type":"text"},{"text":" ","type":"text"},{"text":"Variable assignments and references to assigned variables","type":"text"},{"text":" ","type":"text"},{"text":"Step functions applied to the ","type":"text"},{"type":"codeVoice","code":"$zoomLevel"},{"text":" variable","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property does not support applying interpolation functions to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable or applying interpolation or step functions to feature"},{"ty