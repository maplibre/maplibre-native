ce","code":"line-center"},{"type":"text","text":": The label is placed at the center of the line of the"},{"type":"text","text":" "},{"type":"text","text":"geometry. Can only be used on "},{"type":"codeVoice","code":"LineString"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Polygon"},{"type":"text","text":" geometries. Note that"},{"type":"text","text":" "},{"type":"text","text":"a single feature in a vector tile may contain multiple line geometries."},{"type":"text","text":" "},{"type":"text","text":"Predefined functions, including mathematical and string operators"},{"type":"text","text":" "},{"type":"text","text":"Conditional expressions"},{"type":"text","text":" "},{"type":"text","text":"Variable assignments and references to assigned variables"},{"type":"text","text":" "},{"type":"text","text":"Step functions applied to the "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This property does not support applying interpolation functions to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable or applying interpolation or step functions to feature"},{"type":"text","text":" "},{"type":"text","text":"attributes."}],"type":"paragraph"}],"kind":"content"}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/symbolPlacement","interfaceLanguage":"occ"},"kind":"symbol","variants":[{"paths":["\/documentation\/maplibre\/mlnsymbolstylelayer\/symbolplacement"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"title":"symbolPlacement","modules":[{"name":"MapLibre"}],"symbolKind":"property","roleHeading":"Instance Property","fragments":[{"text":"symbolPlacement","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"text":"symbolPlacement","kind":"identifier"}],"externalID":"c:objc(cs)MLNSymbolStyleLayer(py)symbolPlacement"},"abstract":[{"text":"Label placement relative 