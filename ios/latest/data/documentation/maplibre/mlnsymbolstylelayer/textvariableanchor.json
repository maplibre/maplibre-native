type":"text"},{"text":"the anchor.","type":"text"},{"text":" ","type":"text"},{"text":"Predefined functions, including mathematical and string operators","type":"text"},{"text":" ","type":"text"},{"text":"Conditional expressions","type":"text"},{"text":" ","type":"text"},{"text":"Variable assignments and references to assigned variables","type":"text"},{"text":" ","type":"text"},{"text":"Step functions applied to the ","type":"text"},{"code":"$zoomLevel","type":"codeVoice"},{"text":" variable","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This property does not support applying interpolation functions to the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"$zoomLevel"},{"text":" variable or applying interpolation or step functions to feature","type":"text"},{"text":" ","type":"text"},{"text":"attributes.","type":"text"}],"type":"paragraph"}]}],"abstract":[{"type":"text","text":"To increase the chance of placing high-priority labels on the map, you can"},{"type":"text","text":" "},{"type":"text","text":"provide an array of "},{"type":"codeVoice","code":"textAnchor"},{"type":"text","text":" locations: the renderer will attempt to place"},{"type":"text","text":" "},{"type":"text","text":"the label at each location, in order, before moving onto the next label. Use"},{"type":"text","text":" "},{"type":"codeVoice","code":"textJustify: auto"},{"type":"text","text":" to choose justification based on anchor position. To apply"},{"type":"text","text":" "},{"type":"text","text":"an offset, use the "},{"type":"codeVoice","code":"textRadialOffset"},{"type":"text","text":" or the two-dimensional "},{"type":"codeVoice","code":"textOffset"},{"type":"text","text":"."}],"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer":{"type":"topic","title":"MLNSymbolStyleLayer","url":"\/documentation\/maplibre\/mlnsymbolstylelayer","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolSty