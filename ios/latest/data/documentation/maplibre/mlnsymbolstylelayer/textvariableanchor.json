{"abstract":[{"type":"text","text":"To increase the chance of placing high-priority labels on the map, you can"},{"type":"text","text":" "},{"type":"text","text":"provide an array of "},{"type":"codeVoice","code":"textAnchor"},{"type":"text","text":" locations: the renderer will attempt to place"},{"type":"text","text":" "},{"type":"text","text":"the label at each location, in order, before moving onto the next label. Use"},{"type":"text","text":" "},{"type":"codeVoice","code":"textJustify: auto"},{"type":"text","text":" to choose justification based on anchor position. To apply"},{"type":"text","text":" "},{"type":"text","text":"an offset, use the "},{"type":"codeVoice","code":"textRadialOffset"},{"type":"text","text":" or the two-dimensional "},{"type":"codeVoice","code":"textOffset"},{"type":"text","text":"."}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer"]]},"sections":[],"metadata":{"role":"symbol","navigatorTitle":[{"text":"textVariableAnchor","kind":"identifier"}],"title":"textVariableAnchor","symbolKind":"property","externalID":"c:objc(cs)MLNSymbolStyleLayer(py)textVariableAnchor","roleHeading":"Instance Property","modules":[{"name":"MapLibre"}],"fragments":[{"text":"textVariableAnchor","kind":"identifier"}]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnsymbolstylelayer\/textvariableanchor"]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textVariableAnchor","interfaceLanguage":"occ"},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"text":"NSExpression","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSExpression"},{"text":" * ","kind":"text"},{"text":"textVariableAnchor","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"This property is only applied to the style if ","type":"text"},{"code":"text","type":"codeVoice"},{"text":" is non-","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"code":"symbolPlacement","type":"codeVoice"},{"text":" is set to an expression that evaluates to or","type":"text"},{"text":" ","type":"text"},{"code":"MLNSymbolPlacementPoint","type":"codeVoice"},{"text":". Otherwise, it is ignored.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You can set this property to an expression containing any of the following:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Constant "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextAnchor","type":"reference"},{"type":"text","text":" array values"},{"type":"text","text":" "},{"type":"text","text":"Constant array, in which each element is any of the following constant string"},{"type":"text","text":" "},{"type":"text","text":"values:"},{"type":"text","text":" "},{"code":"center","type":"codeVoice"},{"type":"text","text":": The center of the text is placed closest to the anchor."},{"type":"text","text":" "},{"code":"left","type":"codeVoice"},{"type":"text","text":": The left side of the text is placed closest to the anchor."},{"type":"text","text":" "},{"code":"right","type":"codeVoice"},{"type":"text","text":": The right side of the text is placed closest to the anchor."},{"type":"text","text":" "},{"code":"top","type":"codeVoice"},{"type":"text","text":": The top of the text is placed closest to the anchor."},{"type":"text","text":" "},{"code":"bottom","type":"codeVoice"},{"type":"text","text":": The bottom of the text is placed closest to the anchor."},{"type":"text","text":" "},{"code":"top-left","type":"codeVoice"},{"type":"text","text":": The top left corner of the text is placed closest to the"},{"type":"text","text":" "},{"type":"text","text":"anchor."},{"type":"text","text":" "},{"code":"top-right","type":"codeVoice"},{"type":"text","text":": The top right corner of the text is placed closest to the"},{"type":"text","text":" "},{"type":"text","text":"anchor."},{"type":"text","text":" "},{"code":"bottom-left","type":"codeVoice"},{"type":"text","text":": The bottom left corner of the text is placed closest to the"},{"type":"text","text":" "},{"type":"text","text":"anchor."},{"type":"text","text":" "},{"code":"bottom-right","type":"codeVoice"},{"type":"text","text":": The bottom right corner of the text is placed closest to"},{"type":"text","text":" "},{"type":"text","text":"the anchor."},{"type":"text","text":" "},{"type":"text","text":"Predefined functions, including mathematical and string operators"},{"type":"text","text":" "},{"type":"text","text":"Conditional expressions"},{"type":"text","text":" "},{"type":"text","text":"Variable assignments and references to assigned variables"},{"type":"text","text":" "},{"type":"text","text":"Step functions applied to the "},{"code":"$zoomLevel","type":"codeVoice"},{"type":"text","text":" variable"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property does not support applying interpolation functions to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable or applying interpolation or step functions to feature"},{"type":"text","text":" "},{"type":"text","text":"attributes."}]}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer/textVariableAnchor":{"type":"topic","role":"symbol","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textVariableAnchor","frag