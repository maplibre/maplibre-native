{"sections":[],"abstract":[{"type":"text","text":"To increase the chance of placing high-priority labels on the map, you can"},{"type":"text","text":" "},{"type":"text","text":"provide an array of "},{"type":"codeVoice","code":"textAnchor"},{"type":"text","text":" locations: the renderer will attempt to place"},{"type":"text","text":" "},{"type":"text","text":"the label at each location, in order, before moving onto the next label. Use"},{"type":"text","text":" "},{"type":"codeVoice","code":"textJustify: auto"},{"type":"text","text":" to choose justification based on anchor position. To apply"},{"type":"text","text":" "},{"type":"text","text":"an offset, use the "},{"type":"codeVoice","code":"textRadialOffset"},{"type":"text","text":" or the two-dimensional "},{"type":"codeVoice","code":"textOffset"},{"type":"text","text":"."}],"metadata":{"roleHeading":"Instance Property","externalID":"c:objc(cs)MLNSymbolStyleLayer(py)textVariableAnchor","title":"textVariableAnchor","navigatorTitle":[{"kind":"identifier","text":"textVariableAnchor"}],"modules":[{"name":"MapLibre"}],"role":"symbol","symbolKind":"property","fragments":[{"kind":"identifier","text":"textVariableAnchor"}]},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textVariableAnchor","interfaceLanguage":"occ"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"text":"NSExpression","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSExpression"},{"text":" * ","kind":"text"},{"text":"textVariableAnchor","kind":"identifier"},{"text":";","kind":"text"}]}]},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"This property is only applied to the style if "},{"code":"text","type":"codeVoice"},{"type":"text","text":" is non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", and"},{"type":"text","text":" "},{"code":"symbolPlacement","type":"codeVoice"},{"type":"text","text":" is set to an expression that evaluates to or"},{"type":"text","text":" "},{"code":"MLNSymbolPlacementPoint","type":"codeVoice"},{"type":"text","text":". Otherwise, it is ignored."}],"type":"paragraph"},{"inlineContent":[{"text":"You can set this property to an expression containing any of the following:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Constant ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextAnchor","type":"reference"},{"text":" array values","type":"text"},{"text":" ","type":"text"},{"text":"Constant array, in which each element is any of the following constant string","type":"text"},{"text":" ","type":"text"},{"text":"values:","type":"text"},{"text":" ","type":"text"},{"code":"center","type":"codeVoice"},{"text":": The center of the text is placed closest to the anchor.","type":"text"},{"text":" ","type":"text"},{"code":"left","type":"codeVoice"},{"text":": The left side of the text is placed closest to the anchor.","type":"text"},{"text":" ","type":"text"},{"code":"right","type":"codeVoice"},{"text":": The right side of the text is placed closest to the anchor.","type":"text"},{"text":" ","type":"text"},{"code":"top","type":"codeVoice"},{"text":": The top of the text is placed closest to the anchor.","type":"text"},{"text":" ","type":"text"},{"code":"bottom","type":"codeVoice"},{"text":": The bottom of the text is placed closest to the anchor.","type":"text"},{"text":" ","type":"text"},{"code":"top-left","type":"codeVoice"},{"text":": The top left corner of the text is placed closest to the","type":"text"},{"text":" ","type":"text"},{"text":"anchor.","type":"text"},{"text":" ","type":"text"},{"code":"top-right","type":"codeVoice"},{"text":": The top right corner of the text is placed closest to the","type":"text"},{"text":" ","type":"text"},{"text":"anchor.","type":"text"},{"text":" ","type":"text"},{"code":"bottom-left","type":"codeVoice"},{"text":": The bottom left corner of the text is placed closest to the","type":"text"},{"text":" ","type":"text"},{"text":"anchor.","type":"text"},{"text":" ","type":"text"},{"code":"bottom-right","type":"codeVoice"},{"text":": The bottom right corner of the text is placed closest to","type":"text"},{"text":" ","type":"text"},{"text":"the anchor.","type":"text"},{"text":" ","type":"text"},{"text":"Predefined functions, including mathematical and string operators","type":"text"},{"text":" ","type":"text"},{"text":"Conditional expressions","type":"text"},{"text":" ","type":"text"},{"text":"Variable assignments and references to assigned variables","type":"text"},{"text":" ","type":"text"},{"text":"Step functions applied to the ","type":"text"},{"code":"$zoomLevel","type":"codeVoice"},{"text":" variable","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This property does not support applying interpolation functions to the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"$zoomLevel"},{"text":" variable or applying interpolation or step functions to feature","type":"text"},{"text":" ","type":"text"},{"text":"attributes.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnsymbolstylelayer\/textvariableanchor"]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer/textVariableAnchor":{"title":"textVariableAnchor","kind":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnsymbolstylelayer\/textvariableanchor","identifier":"doc:\/\/org.