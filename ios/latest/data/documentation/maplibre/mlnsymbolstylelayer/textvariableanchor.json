{"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textVariableAnchor","interfaceLanguage":"occ"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"kind":"typeIdentifier","text":"NSExpression","preciseIdentifier":"c:objc(cs)NSExpression"},{"kind":"text","text":" * "},{"kind":"identifier","text":"textVariableAnchor"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"This property is only applied to the style if "},{"code":"text","type":"codeVoice"},{"type":"text","text":" is non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", and"},{"type":"text","text":" "},{"code":"symbolPlacement","type":"codeVoice"},{"type":"text","text":" is set to an expression that evaluates to or"},{"type":"text","text":" "},{"code":"MLNSymbolPlacementPoint","type":"codeVoice"},{"type":"text","text":". Otherwise, it is ignored."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can set this property to an expression containing any of the following:"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Constant "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextAnchor","isActive":true},{"type":"text","text":" array values"},{"type":"text","text":" "},{"type":"text","text":"Constant array, in which each element is any of the following constant string"},{"type":"text","text":" "},{"type":"text","text":"values:"},{"type":"text","text":" "},{"code":"center","type":"codeVoice"},{"type":"text","text":": The center of the text is placed closest to the anchor."},{"type":"text","text":" "},{"code":"left","type":"codeVoice"},{"type":"text","text":": The left side of the text is placed closest to the anchor."},{"type":"text","text":" "},{"code":"right","type":"codeVoice"},{"type":"text","text":": The right side of the text is placed closest to the anchor."},{"type":"text","text":" "},{"code":"top","type":"codeVoice"},{"type":"text","text":": The top of the text is placed closest to the anchor."},{"type":"text","text":" "},{"code":"bottom","type":"codeVoice"},{"type":"text","text":": The bottom of the text is placed closest to the anchor."},{"type":"text","text":" "},{"code":"top-left","type":"codeVoice"},{"type":"text","text":": The top left corner of the text is placed closest to the"},{"type":"text","text":" "},{"type":"text","text":"anchor."},{"type":"text","text":" "},{"code":"top-right","type":"codeVoice"},{"type":"text","text":": The top right corner of the text is placed closest to the"},{"type":"text","text":" "},{"type":"text","text":"anchor."},{"type":"text","text":" "},{"code":"bottom-left","type":"codeVoice"},{"type":"text","text":": The bottom left corner of the text is placed closest to the"},{"type":"text","text":" "},{"type":"text","text":"anchor."},{"type":"text","text":" "},{"code":"bottom-right","type":"codeVoice"},{"type":"text","text":": The bottom right corner of the text is placed closest to"},{"type":"text","text":" "},{"type":"text","text":"the anchor."},{"type":"text","text":" "},{"type":"text","text":"Predefined functions, including mathematical and string operators"},{"type":"text","text":" "},{"type":"text","text":"Conditional expressions"},{"type":"text","text":" "},{"type":"text","text":"Variable assignments and references to assigned variables"},{"type":"text","text":" "},{"type":"text","text":"Step functions applied to the "},{"code":"$zoomLevel","type":"codeVoice"},{"type":"text","text":" variable"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This property does not support applying interpolation functions to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable or applying interpolation or step functions to feature"},{"type":"text","text":" "},{"type":"text","text":"attributes."}],"type":"paragraph"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer"]]},"abstract":[{"type":"text","text":"To increase the chance of placing high-priority labels on the map, you can"},{"type":"text","text":" "},{"type":"text","text":"provide an array of "},{"type":"codeVoice","code":"textAnchor"},{"type":"text","text":" locations: the renderer will attempt to place"},{"type":"text","text":" "},{"type":"text","text":"the label at each location, in order, before moving onto the next label. Use"},{"type":"text","text":" "},{"type":"codeVoice","code":"textJustify: auto"},{"type":"text","text":" to choose justification based on anchor position. To apply"},{"type":"text","text":" "},{"type":"text","text":"an offset, use the "},{"type":"codeVoice","code":"textRadialOffset"},{"type":"text","text":" or the two-dimensional "},{"type":"codeVoice","code":"textOffset"},{"type":"text","text":"."}],"metadata":{"externalID":"c:objc(cs)MLNSymbolStyleLayer(py)textVariableAnchor","title":"textVariableAnchor","roleHeading":"Instance Property","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"kind":"identifier","text":"textVariableAnchor"}],"role":"symbol","symbolKind":"property","fragments":[{"text":"textVariableAnchor","kind":"identifier"}]},"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnsymbolstylelayer\/textvariableanchor"]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"type":"topic","url":"\/documentation\/maplibre","