attributes.","type":"text"}]}],"kind":"content"}],"sections":[],"kind":"symbol","abstract":[{"type":"text","text":"To increase the chance of placing high-priority labels on the map, you can"},{"type":"text","text":" "},{"type":"text","text":"provide an array of "},{"type":"codeVoice","code":"textAnchor"},{"type":"text","text":" locations: the renderer will attempt to place"},{"type":"text","text":" "},{"type":"text","text":"the label at each location, in order, before moving onto the next label. Use"},{"type":"text","text":" "},{"type":"codeVoice","code":"textJustify: auto"},{"type":"text","text":" to choose justification based on anchor position. To apply"},{"type":"text","text":" "},{"type":"text","text":"an offset, use the "},{"type":"codeVoice","code":"textRadialOffset"},{"type":"text","text":" or the two-dimensional "},{"type":"codeVoice","code":"textOffset"},{"type":"text","text":"."}],"metadata":{"externalID":"c:objc(cs)MLNSymbolStyleLayer(py)textVariableAnchor","role":"symbol","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"text":"textVariableAnchor","kind":"identifier"}],"symbolKind":"property","fragments":[{"text":"textVariableAnchor","kind":"identifier"}],"roleHeading":"Instance Property","title":"textVariableAnchor"},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textVariableAnchor","interfaceLanguage":"occ"},"variants":[{"paths":["\/documentation\/maplibre\/mlnsymbolstylelayer\/textvariableanchor"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","type":"topic","abstract":[{"type":"text","text":"Powerful,