{"abstract":[{"type":"text","text":"To increase the chance of placing high-priority labels on the map, you can"},{"type":"text","text":" "},{"type":"text","text":"provide an array of "},{"code":"textAnchor","type":"codeVoice"},{"type":"text","text":" locations: the renderer will attempt to place"},{"type":"text","text":" "},{"type":"text","text":"the label at each location, in order, before moving onto the next label. Use"},{"type":"text","text":" "},{"code":"textJustify: auto","type":"codeVoice"},{"type":"text","text":" to choose justification based on anchor position. To apply"},{"type":"text","text":" "},{"type":"text","text":"an offset, use the "},{"code":"textRadialOffset","type":"codeVoice"},{"type":"text","text":" or the two-dimensional "},{"code":"textOffset","type":"codeVoice"},{"type":"text","text":"."}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer"]]},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnsymbolstylelayer\/textvariableanchor"]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textVariableAnchor"},"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"fragments":[{"kind":"identifier","text":"textVariableAnchor"}],"navigatorTitle":[{"kind":"identifier","text":"textVariableAnchor"}],"symbolKind":"property","externalID":"c:objc(cs)MLNSymbolStyleLayer(py)textVariableAnchor","role":"symbol","title":"textVariableAnchor","roleHeading":"Instance Property","modules":[{"name":"MapLibre"}]},"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSExpression","text":"NSExpression","kind":"typeIdentifier"},{"text":" * ","kind":"text"},{"text"