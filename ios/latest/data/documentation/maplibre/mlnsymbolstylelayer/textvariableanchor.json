 to the ","type":"text"},{"type":"codeVoice","code":"$zoomLevel"},{"text":" variable","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This property does not support applying interpolation functions to the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"$zoomLevel"},{"text":" variable or applying interpolation or step functions to feature","type":"text"},{"text":" ","type":"text"},{"text":"attributes.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"sections":[],"abstract":[{"type":"text","text":"To increase the chance of placing high-priority labels on the map, you can"},{"type":"text","text":" "},{"type":"text","text":"provide an array of "},{"type":"codeVoice","code":"textAnchor"},{"type":"text","text":" locations: the renderer will attempt to place"},{"type":"text","text":" "},{"type":"text","text":"the label at each location, in order, before moving onto the next label. Use"},{"type":"text","text":" "},{"type":"codeVoice","code":"textJustify: auto"},{"type":"text","text":" to choose justification based on anchor position. To apply"},{"type":"text","text":" "},{"type":"text","text":"an offset, use the "},{"type":"codeVoice","code":"textRadialOffset"},{"type":"text","text":" or the two-dimensional "},{"type":"codeVoice","code":"textOffset"},{"type":"text","text":"."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"symbolKind":"property","navigatorTitle":[{"kind":"identifier","text":"textVariableAnchor"}],"roleHeading":"Instance Property","title":"textVariableAnchor","fragments":[{"kind":"identifier","text":"textVariableAnchor"}],"role":"symbol","modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNSymbolStyleLayer(py)textVariableAnchor"},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documen