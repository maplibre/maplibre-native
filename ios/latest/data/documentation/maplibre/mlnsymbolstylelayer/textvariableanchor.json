{"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnsymbolstylelayer\/textvariableanchor"]}],"metadata":{"role":"symbol","externalID":"c:objc(cs)MLNSymbolStyleLayer(py)textVariableAnchor","title":"textVariableAnchor","fragments":[{"text":"textVariableAnchor","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"textVariableAnchor"}],"symbolKind":"property","modules":[{"name":"MapLibre"}],"roleHeading":"Instance Property"},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textVariableAnchor","interfaceLanguage":"occ"},"primaryContentSections":[{"declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSExpression","text":"NSExpression","kind":"typeIdentifier"},{"text":" * ","kind":"text"},{"text":"textVariableAnchor","kind":"identifier"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"This property is only applied to the style if ","type":"text"},{"code":"text","type":"codeVoice"},{"text":" is non-","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"code":"symbolPlacement","type":"codeVoice"},{"text":" is set to an expression that evaluates to or","type":"text"},{"text":" ","type":"text"},{"code":"MLNSymbolPlacementPoint","type":"codeVoice"},{"text":". Otherwise, it is ignored.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You can set this property to an expression containing any of the following:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Constant "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextAnchor","isActive":true},{"type":"text","text":" array values"},{"type":"text","text":" "},{"type":"text","text":"Constant array, in which each element is any of the following constant string"},{"type":"text","text":" "},{"type":"text","text":"values:"},{"type":"text","text":" "},{"type":"codeVoice","code":"center"},{"type":"text","text":": The center of the text is placed closest to the anchor."},{"type":"text","text":" "},{"type":"codeVoice","code":"left"},{"type":"text","text":": The left side of the text is placed closest to the anchor."},{"type":"text","text":" "},{"code":"right","type":"codeVoice"},{"type":"text","text":": The right side of the text is placed closest to the anchor."},{"type":"text","text":" "},{"code":"top","type":"codeVoice"},{"type":"text","text":": The top of the text is placed closest to the anchor."},{"type":"text","text":" "},{"code":"bottom","type":"codeVoice"},{"type":"text","text":": The bottom of the text is placed closest to the anchor."},{"type":"text","text":" "},{"code":"top-left","type":"codeVoice"},{"type":"text","text":": The top left corner of the text is placed closest to the"},{"type":"text","text":" "},{"type":"text","text":"anchor."},{"type":"text","text":" "},{"code":"top-right","type":"codeVoice"},{"type":"text","text":": The top right corner of the text is placed closest to the"},{"type":"text","text":" "},{"type":"text","text":"anchor."},{"type":"text","text":" "},{"code":"bottom-left","type":"codeVoice"},{"type":"text","text":": The bottom left corner of the text is placed closest to the"},{"type":"text","text":" "},{"type":"text","text":"anchor."},{"type":"text","text":" "},{"code":"bottom-right","type":"codeVoice"},{"type":"text","text":": The bottom right corner of the text is placed closest to"},{"type":"text","text":" "},{"type":"text","text":"the anchor."},{"type":"text","text":" "},{"type":"text","text":"Predefined functions, including mathematical and string operators"},{"type":"text","text":" "},{"type":"text","text":"Conditional expressions"},{"type":"text","text":" "},{"type":"text","text":"Variable assignments and references to assigned variables"},{"type":"text","text":" "},{"type":"text","text":"Step functions applied to the "},{"code":"$zoomLevel","type":"codeVoice"},{"type":"text","text":" variable"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property does not support applying interpolation functions to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable or applying interpolation or step functions to feature"},{"type":"text","text":" "},{"type":"text","text":"attributes."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer"]]},"abstract":[{"type":"text","text":"To increase the chance of placing high-priority labels on the map, you can"},{"type":"text","text":" "},{"type":"text","text":"provide an array of "},{"code":"textAnchor","type":"codeVoice"},{"type":"text","text":" locations: the renderer will attempt to place"},{"type":"text","text":" "},{"type":"text","text":"the label at each location, in order, before moving onto the next label. Use"},{"type":"text","text":" "},{"code":"textJustify: auto","type":"codeVoice"},{"type":"text","text":" to choose justification based on anchor position. To apply"},{"type":"text","text":" "},{"type":"text","text":"an offset, use the "},{"code":"textRadialOffset","type":"codeVoice"},{"type":"text","text":" or the two-dimensional "},{"code":"textOffset","type":"codeVoice"},{"type":"text","text":"."}],"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNTextAnchor":{"role":"symbol","kind":"symbol","fragments":[{"text":"MLNTextAnchor","kind":"identifier"}],"abstract":[{"type":"text","text":"Part of the text placed closest to t