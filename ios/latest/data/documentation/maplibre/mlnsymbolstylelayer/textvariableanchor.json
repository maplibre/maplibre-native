{"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"text":"To increase the chance of placing high-priority labels on the map, you can","type":"text"},{"text":" ","type":"text"},{"text":"provide an array of ","type":"text"},{"type":"codeVoice","code":"textAnchor"},{"text":" locations: the renderer will attempt to place","type":"text"},{"text":" ","type":"text"},{"text":"the label at each location, in order, before moving onto the next label. Use","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"textJustify: auto"},{"text":" to choose justification based on anchor position. To apply","type":"text"},{"text":" ","type":"text"},{"text":"an offset, use the ","type":"text"},{"type":"codeVoice","code":"textRadialOffset"},{"text":" or the two-dimensional ","type":"text"},{"type":"codeVoice","code":"textOffset"},{"text":".","type":"text"}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textVariableAnchor","interfaceLanguage":"occ"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"kind":"typeIdentifier","text":"NSExpression","preciseIdentifier":"c:objc(cs)NSExpression"},{"kind":"text","text":" * "},{"kind":"identifier","text":"textVariableAnchor"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}]},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"This property is only applied to the style if "},{"code":"text","type":"codeVoice"},{"type":"text","text":" is non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", and"},{"type":"text","text":" "},{"code":"symbolPlacement","type":"codeVoice"},{"type":"text","text":" is set to an expression that evaluates to or"},{"type":"text","text":" "},{"code":"MLNSymbolPlacem