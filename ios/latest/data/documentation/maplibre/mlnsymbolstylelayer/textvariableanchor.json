{"variants":[{"paths":["\/documentation\/maplibre\/mlnsymbolstylelayer\/textvariableanchor"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textVariableAnchor"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer"]]},"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"kind":"typeIdentifier","text":"NSExpression","preciseIdentifier":"c:objc(cs)NSExpression"},{"kind":"text","text":" * "},{"kind":"identifier","text":"textVariableAnchor"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"This property is only applied to the style if "},{"type":"codeVoice","code":"text"},{"type":"text","text":" is non-"},{"type":"codeVoice","code":"nil"},{"type":"text","text":", and"},{"type":"text","text":" "},{"type":"codeVoice","code":"symbolPlacement"},{"type":"text","text":" is set to an expression that evaluates to or"},{"type":"text","text":" "},{"type":"codeVoice","code":"MLNSymbolPlacementPoint"},{"type":"text","text":". Otherwise, it is ignored."}],"type":"paragraph"},{"inlineContent":[{"text":"You can set this property to an expression containing any of the following:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Constant ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextAnchor","isActive":true},{"text":" array values","type":"text"},{"text":" ","type":"text"},{"text":"Constant array, in which each element is any of the following constant string","type":"text"},{"text":" "