{"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"text":"Whether symbols in this layer avoid colliding with symbols in adjacent tiles.","type":"text"}],"metadata":{"modules":[{"name":"MapLibre"}],"roleHeading":"Instance Property","symbolKind":"property","externalID":"c:objc(cs)MLNSymbolStyleLayer(py)symbolAvoidsEdges","navigatorTitle":[{"text":"symbolAvoidsEdges","kind":"identifier"}],"role":"symbol","title":"symbolAvoidsEdges","fragments":[{"text":"symbolAvoidsEdges","kind":"identifier"}]},"sections":[],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/symbolAvoidsEdges"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer"]]},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnsymbolstylelayer\/symbolavoidsedges"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"text":"NSExpression","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSExpression"},{"text":" * ","kind":"text"},{"text":"symbolAvoidsEdges","kind":"identifier"},{"text":";","kind":"text"}]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"If this property is set to "},{"code":"true","type":"codeVoice"},{"type":"text","text":", symbols in this layer avoid crossing the"},{"type":"text","text":" "},{"type":"text","text":"edge of a tile. You should set this property to "},{"code":"true","type":"codeVoice"},{"type":"text","text":" if the backing vector"},{"type":"text","text":" "},{"type":"text","text":"tiles don’t have enough padding to prevent collisions, or if this layer’s"},{"type":"text","text":" "},{"code":"symbolPlacement","type":"codeVoice"},{"type":"text","text":" property is set to"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolPlacement\/MLNSymbolPlacementPoint","isActive":true},{"type":"text","text":" but this layer is above a symbol"},{"type":"text","text":" "},{"type":"text","text":"layer whose "},{"code":"symbolPlacement","type":"codeVoice"},{"type":"text","text":" property is set to"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolPlacement\/MLNSymbolPlacementPoint","isActive":true},{"type":"text","text":". You do not need to enable this"},{"type":"text","text":" "},{"type":"text","text":"property to prevent clipped labels at tile boundaries."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The default value of this property is an expression that evaluates to "},{"type":"codeVoice","code":"NO"},{"type":"text","text":". Set"},{"type":"text","text":" "},{"type":"text","text":"this property to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to reset it to the default value."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This attribute corresponds to the "},{"type":"text","text":"symbol-avoid-edges"},{"type":"text","text":" "},{"type":"text","text":"layout property in the MapLibre Style Spec."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can set this property to an expression containing any of the following:"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Constant Boolean values"},{"type":"text","text":" "},{"type":"text","text":"Predefined functions, including mathematical and string operators"},{"type":"text","text":" "},{"type":"text","text":"Conditional expressions"},{"type":"text","text":" "},{"type":"text","text":"Variable assignments and references to assigned variables"},{"type":"text","text":" "},{"type":"text","text":"Step functions applied to the "},{"type":"codeVoice","code":"$zoomLevel"},{"type":"text","text":" variable"}],"type":"paragraph"},{"inlineContent":[{"text":"This property does not support applying interpolation functions to the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"$zoomLevel"},{"text":" variable or applying interpolation or step functions to feature","type":"text"},{"text":" ","type":"text"},{"text":"attributes.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolPlacement/MLNSymbolPlacementPoint":{"title":"MLNSymbolPlacementPoint","kind":"symbol","abstract":[],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolPlacement\/MLNSymbolPlacementPoint","role":"symbol","url":"\/documentation\/maplibre\/mlnsymbolplacement\/mlnsymbolplacementpoint","fragments":[{"text":"MLNSymbolPlacementPoint","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection","url":"\/documentation\/maplibre","kind":"symbol","title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer":{"kind":"symbol","role":"symbol","fragments":[{"kind":"identifier","text":"MLNSymbolStyleLayer"}],"abstract":[{"text":"An ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer","type":"reference"},{"text":" is a style layer that renders icon and text labels","type":"text"},{"text":" ","type":"text"},{"text":"at points or along lines on the map.","type":"text"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer","url":"\/documentation\/maplibre\/mlns