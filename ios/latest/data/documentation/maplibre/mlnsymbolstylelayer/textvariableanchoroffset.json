{"sections":[],"abstract":[{"type":"text","text":"To increase the chance of placing high-priority labels on the map, you can"},{"type":"text","text":" "},{"type":"text","text":"provide an array of "},{"type":"codeVoice","code":"textAnchor"},{"type":"text","text":" locations, each paired with an offset value."},{"type":"text","text":" "},{"type":"text","text":"The renderer will attempt to place the label at each location, in order, before"},{"type":"text","text":" "},{"type":"text","text":"moving on to the next location+offset. Use "},{"type":"codeVoice","code":"textJustify: auto"},{"type":"text","text":" to choose"},{"type":"text","text":" "},{"type":"text","text":"justification based on anchor position."}],"metadata":{"externalID":"c:objc(cs)MLNSymbolStyleLayer(py)textVariableAnchorOffset","navigatorTitle":[{"text":"textVariableAnchorOffset","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"symbolKind":"property","roleHeading":"Instance Property","role":"symbol","fragments":[{"kind":"identifier","text":"textVariableAnchorOffset"}],"title":"textVariableAnchorOffset"},"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"kind":"typeIdentifier","text":"NSExpression","preciseIdentifier":"c:objc(cs)NSExpression"},{"kind":"text","text":" * "},{"kind":"identifier","text":"textVariableAnchorOffset"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The length of the array must be even, and must alternate between enum and"},{"type":"text","text":" "},{"type":"text","text":"point entries. i.e., each anchor location must be accompanied by a point, and"},{"type":"text","text":" "},{"type":"text","text":"that point defines the offset when the corresponding anchor location is used."},{"type":"text","text":" "},{"type":"text","text":"Positive offset values indicate right and down, while negative values indicate"},{"type":"text","text":" "},{"type":"text","text":"left and up. Anchor locations may repeat, allowing the renderer to try multiple"},{"type":"text","text":" "},{"type":"text","text":"offsets to try and place a label using the same anchor."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When present, this property takes precedence over "},{"type":"codeVoice","code":"textAnchor"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"textVariableAnchor"},{"type":"text","text":", "},{"type":"codeVoice","code":"textOffset"},{"type":"text","text":", and "},{"type":"codeVoice","code":"textRadialOffset"},{"type":"text","text":"."}]},{"code":["","{ \"text-variable-anchor-offset\": [\"top\", [0, 4], \"left\", [3,0], \"bottom\", [1,","1]] } ",""],"syntax":"json","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the renderer chooses the "},{"type":"codeVoice","code":"top"},{"type":"text","text":" anchor, "},{"type":"codeVoice","code":"[0, 4]"},{"type":"text","text":" will be used for"},{"type":"text","text":" "},{"type":"codeVoice","code":"textOffset"},{"type":"text","text":"; the text will be shifted down by 4 ems."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the renderer chooses the "},{"type":"codeVoice","code":"left"},{"type":"text","text":" anchor, "},{"type":"codeVoice","code":"[3, 0]"},{"type":"text","text":" will be used for"},{"type":"text","text":" "},{"type":"codeVoice","code":"textOffset"},{"type":"text","text":"; the text will be shifted right by 3 ems."}]},{"type":"paragraph","inlineContent":[{"text":"This property is only applied to the style if ","type":"text"},{"code":"text","type":"codeVoice"},{"text":" is non-","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"code":"symbolPlacement","type":"codeVoice"},{"text":" is set to an expression that evaluates to or","type":"text"},{"text":" ","type":"text"},{"code":"MLNSymbolPlacementPoint","type":"codeVoice"},{"text":". Otherwise, it is ignored.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You can set this property to an expression containing any of the following:","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Constant interleaved ","type":"text"},{"code":"MLNTextAnchor","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"CGVector","type":"codeVoice"},{"text":" array values","type":"text"},{"text":" ","type":"text"},{"text":"Predefined functions, including mathematical and string operators","type":"text"},{"text":" ","type":"text"},{"text":"Conditional expressions","type":"text"},{"text":" ","type":"text"},{"text":"Variable assignments and references to assigned variables","type":"text"},{"text":" ","type":"text"},{"text":"Interpolation and step functions applied to the ","type":"text"},{"code":"$zoomLevel","type":"codeVoice"},{"text":" variable and\/or","type":"text"},{"text":" ","type":"text"},{"text":"feature attributes","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnsymbolstylelayer\/textvariableanchoroffset"]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\/textVariableAnchorOffset"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer/textVariableAnchorOffset":{"title":"textVariableAnchorOffset","kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer\