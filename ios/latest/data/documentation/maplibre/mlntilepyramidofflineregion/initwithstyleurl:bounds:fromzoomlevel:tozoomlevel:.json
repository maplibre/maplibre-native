omLevel"},{"type":"text","text":" parameter. For each required tile source, if this"},{"type":"text","text":" "},{"text":"parameter is set to a value greater than the tile source’s minimum zoom","type":"text"},{"text":" ","type":"text"},{"text":"level, the download covers zoom levels up to the tile source’s maximum zoom","type":"text"},{"text":" ","type":"text"},{"text":"level.","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"This is the designated initializer for "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTilePyramidOfflineRegion","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","variants":[{"paths":["\/documentation\/maplibre\/mlntilepyramidofflineregion\/initwithstyleurl:bounds:fromzoomlevel:tozoomlevel:"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"initWithStyleURL:bounds:fromZoomLevel:toZoomLevel:"}],"navigatorTitle":[{"text":"- ","kind":"text"},{"text":"initWithStyleURL:bounds:fromZoomLevel:toZoomLevel:","kind":"identifier"}],"externalID":"c:objc(cs)MLNTilePyramidOfflineRegion(im)initWithStyleURL:bounds:fromZoomLevel:toZoomLevel:","title":"initWithStyleURL:bounds:fromZoomLevel:toZoomLevel:","symbolKind":"method","roleHeading":"Instance Method","role":"symbol","modules":[{"name":"MapLibre"}]},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","title":"MapLibre","url":"\/documentation\/maplibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre"},"doc://org.swift.MyProject/documentation/Map