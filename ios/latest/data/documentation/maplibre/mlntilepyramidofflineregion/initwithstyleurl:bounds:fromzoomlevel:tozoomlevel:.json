imumZoomLevel"},{"type":"text","text":" parameter. For each required tile source, if this"},{"type":"text","text":" "},{"type":"text","text":"parameter is set to a value greater than the tile source’s minimum zoom"},{"type":"text","text":" "},{"type":"text","text":"level, the download covers zoom levels up to the tile source’s maximum zoom"},{"type":"text","text":" "},{"text":"level.","type":"text"}],"type":"paragraph"}],"name":"maximumZoomLevel"}],"kind":"parameters"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"This is the designated initializer for "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTilePyramidOfflineRegion","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTilePyramidOfflineRegion"]]},"metadata":{"fragments":[{"text":"- ","kind":"text"},{"text":"initWithStyleURL:bounds:fromZoomLevel:toZoomLevel:","kind":"identifier"}],"role":"symbol","modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNTilePyramidOfflineRegion(im)initWithStyleURL:bounds:fromZoomLevel:toZoomLevel:","symbolKind":"method","roleHeading":"Instance Method","title":"initWithStyleURL:bounds:fromZoomLevel:toZoomLevel:","navigatorTitle":[{"kind":"identifier","text":"initWithStyleURL:bounds:fromZoomLevel:toZoomLevel:"}]},"kind":"symbol","references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNTilePyramidOfflineRegion/initWithStyleURL:bounds:fromZoomLevel:toZoomLevel:":{"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"initWithStyleURL:bounds:fromZoomLevel:toZoomLevel:"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTilePyramidOfflineRegion\/initWithStyleURL:bounds:fromZoomLevel:toZoomLevel:","type":"topic","url":"\/documentation\/maplibre\/ml