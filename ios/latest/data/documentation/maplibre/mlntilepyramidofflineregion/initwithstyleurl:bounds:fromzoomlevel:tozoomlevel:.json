xt","text":" parameter. For each required tile source, if"},{"type":"text","text":" "},{"type":"text","text":"this parameter is set to a value less than the tile source’s minimum zoom"},{"type":"text","text":" "},{"type":"text","text":"level, the download covers zoom levels down to the tile source’s minimum"},{"type":"text","text":" "},{"type":"text","text":"zoom level."}],"type":"paragraph"}],"name":"minimumZoomLevel"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The maximum zoom level to be covered by the downloaded"},{"type":"text","text":" "},{"type":"text","text":"tiles. This parameter should be set to at least the value of the"},{"type":"text","text":" "},{"type":"codeVoice","code":"minimumZoomLevel"},{"type":"text","text":" parameter. For each required tile source, if this"},{"type":"text","text":" "},{"type":"text","text":"parameter is set to a value greater than the tile source’s minimum zoom"},{"type":"text","text":" "},{"type":"text","text":"level, the download covers zoom levels up to the tile source’s maximum zoom"},{"type":"text","text":" "},{"type":"text","text":"level."}]}],"name":"maximumZoomLevel"}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is the designated initializer for "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTilePyramidOfflineRegion","isActive":true},{"type":"text","text":"."}]}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNTilePyramidOfflineRegion":{"title":"MLNTilePyramidOfflineRegion","url":"\/documentation\/maplibre\/mlntilepyramidofflineregion","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTilePyramidOfflineRegion","fragments":[{"kind":"identifier","text":"MLNTilePyramidOfflineRegion"}],"abstract":[{"type":"text","text":"An offline region defined by a style URL, geographic c