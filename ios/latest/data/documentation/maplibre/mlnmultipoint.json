umentation/MapLibre/MLNMultiPoint/pointCount":{"type":"topic","kind":"symbol","fragments":[{"kind":"identifier","text":"pointCount"}],"url":"\/documentation\/maplibre\/mlnmultipoint\/pointcount","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint\/pointCount","title":"pointCount","abstract":[{"type":"text","text":"The number of vertices in the shape."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNPointAnnotation":{"type":"topic","kind":"symbol","fragments":[{"kind":"identifier","text":"MLNPointAnnotation"}],"url":"\/documentation\/maplibre\/mlnpointannotation","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation","title":"MLNPointAnnotation","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation","type":"reference","isActive":true},{"type":"text","text":" object represents a one-dimensional shape located at a"},{"type":"text","text":" "},{"type":"text","text":"single geographical coordinate. Depending on how it is used, an"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation","type":"reference","isActive":true},{"type":"text","text":" object is known as a point annotation or point shape. For"},{"type":"text","text":" "},{"type":"text","text":"example, you could use a point shape to represent a city at low zoom levels, an"},{"type":"text","text":" "},{"type":"text","text":"address at high zoom levels, or the location of a long press gesture."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeCollectionFeature":{"title":"MLNShapeCollectionFeature","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollectionFeature","kind":"symbol","url":"\/documentation\/maplibre\/mlnshapecollectionfeature","fragments":[{"text":"MLNShapeCollectionFeature","kind":"identifier"}],"type":"topic","abstract":[{"typ