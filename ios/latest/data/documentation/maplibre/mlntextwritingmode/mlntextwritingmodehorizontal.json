{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"abstract":[{"type":"text","text":"If a text’s language supports horizontal writing mode, symbols with point"},{"type":"text","text":" "},{"type":"text","text":"placement would be laid out horizontally."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"tokens":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"languages":["occ"]}]}],"sections":[],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal"]}],"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"modules":[{"name":"MapLibre"}],"title":"MLNTextWritingModeHorizontal","symbolKind":"case","role":"symbol","fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"roleHeading":"Enumeration Case","externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeHorizontal","navigatorTitle":[{"kind":"identifier","text":"MLNTextWritingModeHorizontal"}]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeHorizontal":{"abstract":[{"type":"text","text":"If a text’s language supports horizontal writing mode, symbols with point"},{"type":"text","text":" "},{"type":"text","text":"placement would be laid out horizontally."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal","kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal","title":"MLNTextWritingModeHorizontal","type":"topic","fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"kind":"symbol","role":"symbol","type":"topic","abstract":[{"type":"text","text":"The property allows control over a symbol’s orientation. Note that the property"},{"type":"text","text":" "},{"type":"text","text":"values act as a hint, so that a symbol whose language doesn’t support the"},{"type":"text","text":" "},{"type":"text","text":"provided orientation will be laid out in its natural orientation. Example:"},{"type":"text","text":" "},{"type":"text","text":"English point symbol will be rendered horizontally even if array value contains"},{"type":"text","text":" "},{"type":"text","text":"single ‘vertical’ enum value. The order of elements in an array define priority"},{"type":"text","text":" "},{"type":"text","text":"order for the placement of an orientation variant."}],"url":"\/documentation\/maplibre\/mlntextwritingmode","title":"MLNTextWritingMode","fragments":[{"kind":"identifier","text":"MLNTextWritingMode"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"},"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","title":"MapLibre","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"url":"\/documentation\/maplibre","type":"topic"}}}