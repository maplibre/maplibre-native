{"variants":[{"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"MLNTextWritingModeHorizontal"}],"title":"MLNTextWritingModeHorizontal","externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeHorizontal","symbolKind":"case","roleHeading":"Enumeration Case","fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"modules":[{"name":"MapLibre"}]},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS","iPadOS","Mac Catalyst"],"tokens":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}]}],"kind":"declarations"}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal","interfaceLanguage":"occ"},"kind":"symbol","sections":[],"abstract":[{"type":"text","text":"If a text’s language supports horizontal writing mode, symbols with point"},{"type":"text","text":" "},{"type":"text","text":"placement would be laid out horizontally."}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeHorizontal":{"type":"topic","url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal","role":"symbol","title":"MLNTextWritingModeHorizontal","fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal","kind":"symbol","abstract":[{"type":"text","text":"If a text’s language supports horizontal writing mode, symbols with point"},{"type":"text","text":" "},{"type":"text","text":"placement would be laid out horizontally."}]},"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","url":"\/documentation\/maplibre","role":"collection","title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"type":"topic","url":"\/documentation\/maplibre\/mlntextwritingmode","role":"symbol","title":"MLNTextWritingMode","fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","kind":"symbol","abstract":[{"type":"text","text":"The property allows control over a symbol’s orientation. Note that the property"},{"type":"text","text":" "},{"type":"text","text":"values act as a hint, so that a symbol whose language doesn’t support the"},{"type":"text","text":" "},{"type":"text","text":"provided orientation will be laid out in its natural orientation. Example:"},{"type":"text","text":" "},{"type":"text","text":"English point symbol will be rendered horizontally even if array value contains"},{"type":"text","text":" "},{"type":"text","text":"single ‘vertical’ enum value. The order of elements in an array define priority"},{"type":"text","text":" "},{"type":"text","text":"order for the placement of an orientation variant."}]}}}