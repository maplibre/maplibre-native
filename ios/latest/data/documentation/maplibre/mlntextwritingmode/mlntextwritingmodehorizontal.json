{"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal","interfaceLanguage":"occ"},"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"roleHeading":"Enumeration Case","title":"MLNTextWritingModeHorizontal","modules":[{"name":"MapLibre"}],"externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeHorizontal","role":"symbol","symbolKind":"case","fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"navigatorTitle":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}]},"kind":"symbol","sections":[],"variants":[{"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"syntax":null,"type":"codeListing","code":[" If a text's language supports horizontal writing mode, symbols with point"," placement would be laid out horizontally."]}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic","title":"MapLibre","url":"\/documentation\/maplibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeHorizontal":{"url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal","abstract":[],"title":"MLNTextWritingModeHorizontal","type":"topic","role":"symbol","kind":"symbol","fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"url":"\/documentation\/maplibre\/mlntextwritingmode","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","role":"symbol","title":"MLNTextWritingMode","type":"topic","abstract":[{"type":"text","text":"The property allows control over a symbol’s orientation. Note that the property"},{"type":"text","text":" "},{"type":"text","text":"values act as a hint, so that a symbol whose language doesn’t support the"},{"type":"text","text":" "},{"type":"text","text":"provided orientation will be laid out in its natural orientation. Example:"},{"type":"text","text":" "},{"type":"text","text":"English point symbol will be rendered horizontally even if array value contains"},{"type":"text","text":" "},{"type":"text","text":"single ‘vertical’ enum value. The order of elements in an array define priority"},{"type":"text","text":" "},{"type":"text","text":"order for the placement of an orientation variant."}],"kind":"symbol","fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}]}}}