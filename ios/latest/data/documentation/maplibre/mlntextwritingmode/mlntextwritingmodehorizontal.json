{"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal"]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal","interfaceLanguage":"occ"},"kind":"symbol","metadata":{"symbolKind":"case","externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeHorizontal","role":"symbol","navigatorTitle":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"roleHeading":"Enumeration Case","fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"title":"MLNTextWritingModeHorizontal"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"code":[" If a text's language supports horizontal writing mode, symbols with point"," placement would be laid out horizontally."],"type":"codeListing","syntax":null}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","role":"symbol","kind":"symbol","type":"topic","abstract":[{"text":"The property allows control over a symbol’s orientation. Note that the property","type":"text"},{"text":" ","type":"text"},{"text":"values act as a hint, so that a symbol whose language doesn’t support the","type":"text"},{"text":" ","type":"text"},{"text":"provided orientation will be laid out in its natural orientation. Example:","type":"text"},{"text":" ","type":"text"},{"text":"English point symbol will be rendered horizontally even if array value contains","type":"text"},{"text":" ","type":"text"},{"text":"single ‘vertical’ enum value. The order of elements in an array define priority","type":"text"},{"text":" ","type":"text"},{"text":"order for the placement of an orientation variant.","type":"text"}],"fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlntextwritingmode","title":"MLNTextWritingMode"},"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeHorizontal":{"url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal","kind":"symbol","title":"MLNTextWritingModeHorizontal","abstract":[],"type":"topic","role":"symbol","fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal"}}}