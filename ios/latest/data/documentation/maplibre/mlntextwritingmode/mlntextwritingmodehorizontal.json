{"metadata":{"navigatorTitle":[{"kind":"identifier","text":"MLNTextWritingModeHorizontal"}],"externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeHorizontal","fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"title":"MLNTextWritingModeHorizontal","modules":[{"name":"MapLibre"}],"role":"symbol","symbolKind":"case","roleHeading":"Enumeration Case"},"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"code":[" If a text's language supports horizontal writing mode, symbols with point"," placement would be laid out horizontally."],"type":"codeListing","syntax":null}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal"]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeHorizontal":{"url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal","type":"topic","kind":"symbol","title":"MLNTextWritingModeHorizontal","abstract":[],"fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","title":"MapLibre","type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"kind":"symbol","fragments":[{"kind":"identifier","text":"MLNTextWritingMode"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","url":"\/documentation\/maplibre\/mlntextwritingmode","type":"topic","abstract":[{"type":"text","text":"The property allows control over a symbol’s orientation. Note that the property"},{"type":"text","text":" "},{"type":"text","text":"values act as a hint, so that a symbol whose language doesn’t support the"},{"type":"text","text":" "},{"type":"text","text":"provided orientation will be laid out in its natural orientation. Example:"},{"type":"text","text":" "},{"type":"text","text":"English point symbol will be rendered horizontally even if array value contains"},{"type":"text","text":" "},{"type":"text","text":"single ‘vertical’ enum value. The order of elements in an array define priority"},{"type":"text","text":" "},{"type":"text","text":"order for the placement of an orientation variant."}],"title":"MLNTextWritingMode","role":"symbol"}}}