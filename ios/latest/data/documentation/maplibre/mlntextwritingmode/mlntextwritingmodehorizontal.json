{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal"},"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeHorizontal","title":"MLNTextWritingModeHorizontal","role":"symbol","navigatorTitle":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"symbolKind":"case","roleHeading":"Enumeration Case","fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}]},"variants":[{"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"identifier","text":"MLNTextWritingModeHorizontal"}]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"code":[" If a text's language supports horizontal writing mode, symbols with point"," placement would be laid out horizontally."],"syntax":null,"type":"codeListing"}],"kind":"content"}],"kind":"symbol","references":{"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","kind":"symbol","url":"\/documentation\/maplibre","title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeHorizontal":{"fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal","abstract":[],"type":"topic","title":"MLNTextWritingModeHorizontal","url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"kind":"symbol","abstract":[{"type":"text","text":"The property allows control over a symbol’s orientation. Note that the property"},{"type":"text","text":" "},{"type":"text","text":"values act as a hint, so that a symbol whose language doesn’t support the"},{"type":"text","text":" "},{"type":"text","text":"provided orientation will be laid out in its natural orientation. Example:"},{"type":"text","text":" "},{"type":"text","text":"English point symbol will be rendered horizontally even if array value contains"},{"type":"text","text":" "},{"type":"text","text":"single ‘vertical’ enum value. The order of elements in an array define priority"},{"type":"text","text":" "},{"type":"text","text":"order for the placement of an orientation variant."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","role":"symbol","url":"\/documentation\/maplibre\/mlntextwritingmode","type":"topic","title":"MLNTextWritingMode","fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}]}}}