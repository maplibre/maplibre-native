{"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal","interfaceLanguage":"occ"},"metadata":{"title":"MLNTextWritingModeHorizontal","symbolKind":"case","externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeHorizontal","role":"symbol","modules":[{"name":"MapLibre"}],"fragments":[{"kind":"identifier","text":"MLNTextWritingModeHorizontal"}],"navigatorTitle":[{"kind":"identifier","text":"MLNTextWritingModeHorizontal"}],"roleHeading":"Enumeration Case"},"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"variants":[{"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"identifier","text":"MLNTextWritingModeHorizontal"}]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"syntax":null,"type":"codeListing","code":[" If a text's language supports horizontal writing mode, symbols with point"," placement would be laid out horizontally."]}]}],"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","title":"MapLibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection","url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"fragments":[{"kind":"identifier","text":"MLNTextWritingMode"}],"role":"symbol","title":"MLNTextWritingMode","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","type":"topic","abstract":[{"type":"text","text":"The property allows control over a symbol’s orientation. Note that the property"},{"type":"text","text":" "},{"type":"text","text":"values act as a hint, so that a symbol whose language doesn’t support the"},{"type":"text","text":" "},{"type":"text","text":"provided orientation will be laid out in its natural orientation. Example:"},{"type":"text","text":" "},{"type":"text","text":"English point symbol will be rendered horizontally even if array value contains"},{"type":"text","text":" "},{"type":"text","text":"single ‘vertical’ enum value. The order of elements in an array define priority"},{"type":"text","text":" "},{"type":"text","text":"order for the placement of an orientation variant."}],"url":"\/documentation\/maplibre\/mlntextwritingmode","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeHorizontal":{"title":"MLNTextWritingModeHorizontal","url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal","kind":"symbol","abstract":[],"type":"topic","role":"symbol","fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal"}}}