{"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"metadata":{"navigatorTitle":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeHorizontal","title":"MLNTextWritingModeHorizontal","role":"symbol","roleHeading":"Enumeration Case","modules":[{"name":"MapLibre"}],"fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"symbolKind":"case"},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"identifier","text":"MLNTextWritingModeHorizontal"}]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"syntax":null,"code":[" If a text's language supports horizontal writing mode, symbols with point"," placement would be laid out horizontally."],"type":"codeListing"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"kind":"symbol","identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal","interfaceLanguage":"occ"},"variants":[{"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","url":"\/documentation\/maplibre","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"title":"MapLibre","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlntextwritingmode","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","kind":"symbol","title":"MLNTextWritingMode","abstract":[{"type":"text","text":"The property allows control over a symbol’s orientation. Note that the property"},{"type":"text","text":" "},{"type":"text","text":"values act as a hint, so that a symbol whose language doesn’t support the"},{"type":"text","text":" "},{"type":"text","text":"provided orientation will be laid out in its natural orientation. Example:"},{"type":"text","text":" "},{"type":"text","text":"English point symbol will be rendered horizontally even if array value contains"},{"type":"text","text":" "},{"type":"text","text":"single ‘vertical’ enum value. The order of elements in an array define priority"},{"type":"text","text":" "},{"type":"text","text":"order for the placement of an orientation variant."}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeHorizontal":{"type":"topic","abstract":[],"title":"MLNTextWritingModeHorizontal","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal","fragments":[{"kind":"identifier","text":"MLNTextWritingModeHorizontal"}],"url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal","role":"symbol","kind":"symbol"}}}