{"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal"]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"languages":["occ"],"platforms":["iOS"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"syntax":null,"type":"codeListing","code":[" If a text's language supports horizontal writing mode, symbols with point"," placement would be laid out horizontally."]}]}],"metadata":{"fragments":[{"kind":"identifier","text":"MLNTextWritingModeHorizontal"}],"symbolKind":"case","role":"symbol","externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeHorizontal","modules":[{"name":"MapLibre"}],"title":"MLNTextWritingModeHorizontal","roleHeading":"Enumeration Case","navigatorTitle":[{"kind":"identifier","text":"MLNTextWritingModeHorizontal"}]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeHorizontal":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal","fragments":[{"kind":"identifier","text":"MLNTextWritingModeHorizontal"}],"role":"symbol","kind":"symbol","abstract":[],"title":"MLNTextWritingModeHorizontal","url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","role":"symbol","type":"topic","abstract":[{"type":"text","text":"The property allows control over a symbol’s orientation. Note that the property"},{"type":"text","text":" "},{"type":"text","text":"values act as a hint, so that a symbol whose language doesn’t support the"},{"type":"text","text":" "},{"type":"text","text":"provided orientation will be laid out in its natural orientation. Example:"},{"type":"text","text":" "},{"type":"text","text":"English point symbol will be rendered horizontally even if array value contains"},{"type":"text","text":" "},{"type":"text","text":"single ‘vertical’ enum value. The order of elements in an array define priority"},{"type":"text","text":" "},{"type":"text","text":"order for the placement of an orientation variant."}],"kind":"symbol","url":"\/documentation\/maplibre\/mlntextwritingmode","title":"MLNTextWritingMode"},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","role":"collection","type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"url":"\/documentation\/maplibre"}}}