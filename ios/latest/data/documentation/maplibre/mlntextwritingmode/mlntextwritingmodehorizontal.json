t the property"},{"type":"text","text":" "},{"type":"text","text":"values act as a hint, so that a symbol whose language doesn’t support the"},{"type":"text","text":" "},{"type":"text","text":"provided orientation will be laid out in its natural orientation. Example:"},{"type":"text","text":" "},{"type":"text","text":"English point symbol will be rendered horizontally even if array value contains"},{"type":"text","text":" "},{"type":"text","text":"single ‘vertical’ enum value. The order of elements in an array define priority"},{"type":"text","text":" "},{"type":"text","text":"order for the placement of an orientation variant."}],"title":"MLNTextWritingMode","role":"symbol","type":"topic","kind":"symbol","fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeHorizontal":{"url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal","abstract":[{"type":"text","text":"If a text’s language supports horizontal writing mode, symbols with point"},{"type":"text","text":" "},{"type":"text","text":"placement would be laid out horizontally."}],"title":"MLNTextWritingModeHorizontal","role":"symbol","type":"topic","kind":"symbol","fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}]}}}