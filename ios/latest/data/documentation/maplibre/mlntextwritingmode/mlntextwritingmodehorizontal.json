{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"sections":[],"metadata":{"role":"symbol","modules":[{"name":"MapLibre"}],"roleHeading":"Enumeration Case","symbolKind":"case","fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"navigatorTitle":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"title":"MLNTextWritingModeHorizontal","externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeHorizontal"},"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"syntax":null,"code":[" If a text's language supports horizontal writing mode, symbols with point"," placement would be laid out horizontally."],"type":"codeListing"}],"kind":"content"}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal","interfaceLanguage":"occ"},"kind":"symbol","variants":[{"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeHorizontal":{"title":"MLNTextWritingModeHorizontal","abstract":[],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal","url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal","role":"symbol","fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"url":"\/documentation\/maplibre","title":"MapLibre","kind":"symbol","type":"topic","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"type":"topic","url":"\/documentation\/maplibre\/mlntextwritingmode","role":"symbol","abstract":[{"type":"text","text":"The property allows control over a symbol’s orientation. Note that the property"},{"type":"text","text":" "},{"type":"text","text":"values act as a hint, so that a symbol whose language doesn’t support the"},{"type":"text","text":" "},{"type":"text","text":"provided orientation will be laid out in its natural orientation. Example:"},{"type":"text","text":" "},{"type":"text","text":"English point symbol will be rendered horizontally even if array value contains"},{"type":"text","text":" "},{"type":"text","text":"single ‘vertical’ enum value. The order of elements in an array define priority"},{"type":"text","text":" "},{"type":"text","text":"order for the placement of an orientation variant."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","title":"MLNTextWritingMode","kind":"symbol","fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}]}}}