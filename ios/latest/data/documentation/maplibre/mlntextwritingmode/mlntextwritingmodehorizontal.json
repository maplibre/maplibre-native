{"abstract":[{"text":"If a text’s language supports horizontal writing mode, symbols with point","type":"text"},{"type":"text","text":" "},{"text":"placement would be laid out horizontally.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS","iPadOS","Mac Catalyst"],"tokens":[{"kind":"identifier","text":"MLNTextWritingModeHorizontal"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal"]}],"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal","interfaceLanguage":"occ"},"metadata":{"navigatorTitle":[{"kind":"identifier","text":"MLNTextWritingModeHorizontal"}],"roleHeading":"Enumeration Case","externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeHorizontal","modules":[{"name":"MapLibre"}],"symbolKind":"case","title":"MLNTextWritingModeHorizontal","role":"symbol","fragments":[{"kind":"identifier","text":"MLNTextWritingModeHorizontal"}]},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","title":"MapLibre","kind":"symbol","type":"topic","url":"\/documentation\/maplibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlntextwritingmode","type":"topic","title":"MLNTextWritingMode","role":"symbol","abstract":[{"text":"The property allows control over a symbol’s orientation. Note that the property","type":"text"},{"text":" ","type":"text"},{"text":"values act as a hint, so that a symbol whose language doesn’t support the","type":"text"},{"text":" ","type":"text"},{"text":"provided orientation will be laid out in its natural orientation. Example:","type":"text"},{"type":"text","text":" "},{"type":"text","text":"English point symbol will be rendered horizontally even if array value contains"},{"type":"text","text":" "},{"type":"text","text":"single ‘vertical’ enum value. The order of elements in an array define priority"},{"type":"text","text":" "},{"type":"text","text":"order for the placement of an orientation variant."}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeHorizontal":{"fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal","type":"topic","title":"MLNTextWritingModeHorizontal","role":"symbol","abstract":[{"type":"text","text":"If a text’s language supports horizontal writing mode, symbols with point"},{"type":"text","text":" "},{"type":"text","text":"placement would be laid out horizontally."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal","kind":"symbol"}}}