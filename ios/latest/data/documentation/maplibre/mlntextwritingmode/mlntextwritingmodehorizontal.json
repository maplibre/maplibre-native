{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"title":"MLNTextWritingModeHorizontal","roleHeading":"Enumeration Case","navigatorTitle":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"symbolKind":"case","role":"symbol","fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeHorizontal"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"identifier","text":"MLNTextWritingModeHorizontal"}],"languages":["occ"],"platforms":["iOS"]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"codeListing","syntax":null,"code":[" If a text's language supports horizontal writing mode, symbols with point"," placement would be laid out horizontally."]}]}],"sections":[],"variants":[{"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","abstract":[{"type":"text","text":"The property allows control over a symbol’s orientation. Note that the property"},{"type":"text","text":" "},{"text":"values act as a hint, so that a symbol whose language doesn’t support the","type":"text"},{"text":" ","type":"text"},{"text":"provided orientation will be laid out in its natural orientation. Example:","type":"text"},{"text":" ","type":"text"},{"text":"English point symbol will be rendered horizontally even if array value contains","type":"text"},{"text":" ","type":"text"},{"text":"single ‘vertical’ enum value. The order of elements in an array define priority","type":"text"},{"text":" ","type":"text"},{"text":"order for the placement of an orientation variant.","type":"text"}],"kind":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlntextwritingmode","fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}],"title":"MLNTextWritingMode","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"kind":"symbol","type":"topic","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeHorizontal":{"fragments":[{"kind":"identifier","text":"MLNTextWritingModeHorizontal"}],"abstract":[],"kind":"symbol","role":"symbol","title":"MLNTextWritingModeHorizontal","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal","type":"topic","url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal"}}}