{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"metadata":{"modules":[{"name":"MapLibre"}],"fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"roleHeading":"Enumeration Case","title":"MLNTextWritingModeHorizontal","symbolKind":"case","role":"symbol","externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeHorizontal","navigatorTitle":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"code":[" If a text's language supports horizontal writing mode, symbols with point"," placement would be laid out horizontally."],"type":"codeListing","syntax":null}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal","interfaceLanguage":"occ"},"kind":"symbol","variants":[{"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection","title":"MapLibre","kind":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeHorizontal":{"title":"MLNTextWritingModeHorizontal","type":"topic","kind":"symbol","role":"symbol","abstract":[],"fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"role":"symbol","title":"MLNTextWritingMode","kind":"symbol","fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlntextwritingmode","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","type":"topic","abstract":[{"text":"The property allows control over a symbol’s orientation. Note that the property","type":"text"},{"text":" ","type":"text"},{"text":"values act as a hint, so that a symbol whose language doesn’t support the","type":"text"},{"text":" ","type":"text"},{"text":"provided orientation will be laid out in its natural orientation. Example:","type":"text"},{"text":" ","type":"text"},{"text":"English point symbol will be rendered horizontally even if array value contains","type":"text"},{"text":" ","type":"text"},{"text":"single ‘vertical’ enum value. The order of elements in an array define priority","type":"text"},{"text":" ","type":"text"},{"text":"order for the placement of an orientation variant.","type":"text"}]}}}