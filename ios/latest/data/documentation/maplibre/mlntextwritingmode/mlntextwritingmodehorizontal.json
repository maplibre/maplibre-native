{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal","interfaceLanguage":"occ"},"variants":[{"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"],"tokens":[{"kind":"identifier","text":"MLNTextWritingModeHorizontal"}]}],"kind":"declarations"}],"metadata":{"fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"symbolKind":"case","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"kind":"identifier","text":"MLNTextWritingModeHorizontal"}],"roleHeading":"Enumeration Case","role":"symbol","externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeHorizontal","title":"MLNTextWritingModeHorizontal"},"abstract":[{"text":"If a text’s language supports horizontal writing mode, symbols with point","type":"text"},{"text":" ","type":"text"},{"text":"placement would be laid out horizontally.","type":"text"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"title":"MLNTextWritingMode","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","url":"\/documentation\/maplibre\/mlntextwritingmode","type":"topic","role":"symbol","fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}],"abstract":[{"text":"The property allows control over a symbol’s orientation. Note that the property","type":"text"},{"text":" ","type":"text"},{"text":"values act as a hint, so that a symbol whose language doesn’t support the","type":"text"},{"text":" ","type":"text"},{"text":"provided orientation will be laid out in