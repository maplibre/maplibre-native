{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"kind":"symbol","identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal","interfaceLanguage":"occ"},"metadata":{"navigatorTitle":[{"kind":"identifier","text":"MLNTextWritingModeHorizontal"}],"modules":[{"name":"MapLibre"}],"fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"symbolKind":"case","externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeHorizontal","role":"symbol","roleHeading":"Enumeration Case","title":"MLNTextWritingModeHorizontal"},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"languages":["occ"]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"code":[" If a text's language supports horizontal writing mode, symbols with point"," placement would be laid out horizontally."],"syntax":null,"type":"codeListing"}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal"]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","url":"\/documentation\/maplibre","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","role":"collection","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"type":"topic","url":"\/documentation\/maplibre\/mlntextwritingmode","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","abstract":[{"text":"The property allows control over a symbol’s orientation. Note that the property","type":"text"},{"text":" ","type":"text"},{"text":"values act as a hint, so that a symbol whose language doesn’t support the","type":"text"},{"text":" ","type":"text"},{"text":"provided orientation will be laid out in its natural orientation. Example:","type":"text"},{"text":" ","type":"text"},{"text":"English point symbol will be rendered horizontally even if array value contains","type":"text"},{"text":" ","type":"text"},{"text":"single ‘vertical’ enum value. The order of elements in an array define priority","type":"text"},{"text":" ","type":"text"},{"text":"order for the placement of an orientation variant.","type":"text"}],"role":"symbol","title":"MLNTextWritingMode","fragments":[{"kind":"identifier","text":"MLNTextWritingMode"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeHorizontal":{"title":"MLNTextWritingModeHorizontal","fragments":[{"text":"MLNTextWritingModeHorizontal","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeHorizontal","kind":"symbol","url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodehorizontal","type":"topic","role":"symbol","abstract":[]}}}