{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical"},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}],"languages":["occ"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"syntax":null,"code":[" If a text's language supports vertical writing mode, symbols with point"," placement would be laid out vertically."],"type":"codeListing"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeVertical","role":"symbol","modules":[{"name":"MapLibre"}],"roleHeading":"Enumeration Case","symbolKind":"case","title":"MLNTextWritingModeVertical","fragments":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"navigatorTitle":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}]},"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeVertical":{"url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical","kind":"symbol","type":"topic","role":"symbol","fragments":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}],"abstract":[],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical","title":"MLNTextWritingModeVertical"},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"type":"topic","kind":"symbol","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"abstract":[{"type":"text","text":"The property allows control over a symbol’s orientation. Note that the property"},{"type":"text","text":" "},{"type":"text","text":"values act as a hint, so that a symbol whose language doesn’t support the"},{"type":"text","text":" "},{"type":"text","text":"provided orientation will be laid out in its natural orientation. Example:"},{"type":"text","text":" "},{"type":"text","text":"English point symbol will be rendered horizontally even if array value contains"},{"type":"text","text":" "},{"type":"text","text":"single ‘vertical’ enum value. The order of elements in an array define priority"},{"type":"text","text":" "},{"type":"text","text":"order for the placement of an orientation variant."}],"type":"topic","role":"symbol","kind":"symbol","fragments":[{"kind":"identifier","text":"MLNTextWritingMode"}],"url":"\/documentation\/maplibre\/mlntextwritingmode","title":"MLNTextWritingMode","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"}}}