wift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical","abstract":[],"fragments":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","abstract":[{"type":"text","text":"The property allows control over a symbol’s orientation. Note that the property"},{"type":"text","text":" "},{"type":"text","text":"values act as a hint, so that a symbol whose language doesn’t support the"},{"type":"text","text":" "},{"type":"text","text":"provided orientation will be laid out in its natural orientation. Example:"},{"type":"text","text":" "},{"type":"text","text":"English point symbol will be rendered horizontally even if array value contains"},{"type":"text","text":" "},{"type":"text","text":"single ‘vertical’ enum value. The order of elements in an array define priority"},{"type":"text","text":" "},{"type":"text","text":"order for the placement of an orientation variant."}],"kind":"symbol","title":"MLNTextWritingMode","url":"\/documentation\/maplibre\/mlntextwritingmode","type":"topic","role":"symbol","fragments":[{"kind":"identifier","text":"MLNTextWritingMode"}]}}}