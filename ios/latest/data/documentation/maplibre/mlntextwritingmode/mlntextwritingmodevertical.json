rt the","type":"text"},{"text":" ","type":"text"},{"text":"provided orientation will be laid out in its natural orientation. Example:","type":"text"},{"text":" ","type":"text"},{"text":"English point symbol will be rendered horizontally even if array value contains","type":"text"},{"text":" ","type":"text"},{"text":"single ‘vertical’ enum value. The order of elements in an array define priority","type":"text"},{"text":" ","type":"text"},{"text":"order for the placement of an orientation variant.","type":"text"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","url":"\/documentation\/maplibre\/mlntextwritingmode","kind":"symbol","fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}],"title":"MLNTextWritingMode","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeVertical":{"url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical","abstract":[],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical","role":"symbol","kind":"symbol","title":"MLNTextWritingModeVertical","fragments":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}]}}}