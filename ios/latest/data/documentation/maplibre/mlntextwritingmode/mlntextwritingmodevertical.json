{"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"modules":[{"name":"MapLibre"}],"externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeVertical","title":"MLNTextWritingModeVertical","fragments":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}],"roleHeading":"Enumeration Case","symbolKind":"case","role":"symbol","navigatorTitle":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical"]}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"codeListing","code":[" If a text's language supports vertical writing mode, symbols with point"," placement would be laid out vertically."],"syntax":null}]}],"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"url":"\/documentation\/maplibre","type":"topic","role":"collection","title":"MapLibre","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeVertical":{"type":"topic","fragments":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"abstract":[],"kind":"symbol","url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical","title":"MLNTextWritingModeVertical","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"fragments":[{"kind":"identifier","text":"MLNTextWritingMode"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","url":"\/documentation\/maplibre\/mlntextwritingmode","title":"MLNTextWritingMode","abstract":[{"type":"text","text":"The property allows control over a symbol’s orientation. Note that the property"},{"type":"text","text":" "},{"type":"text","text":"values act as a hint, so that a symbol whose language doesn’t support the"},{"type":"text","text":" "},{"type":"text","text":"provided orientation will be laid out in its natural orientation. Example:"},{"type":"text","text":" "},{"type":"text","text":"English point symbol will be rendered horizontally even if array value contains"},{"type":"text","text":" "},{"type":"text","text":"single ‘vertical’ enum value. The order of elements in an array define priority"},{"type":"text","text":" "},{"type":"text","text":"order for the placement of an orientation variant."}],"role":"symbol","kind":"symbol"}}}