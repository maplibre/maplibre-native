{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"primaryContentSections":[{"declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"],"tokens":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}]}],"kind":"declarations"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical"},"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"abstract":[{"type":"text","text":"If a text’s language supports vertical writing mode, symbols with point"},{"type":"text","text":" "},{"type":"text","text":"placement would be laid out vertically."}],"variants":[{"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeVertical","roleHeading":"Enumeration Case","fragments":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"title":"MLNTextWritingModeVertical","modules":[{"name":"MapLibre"}],"symbolKind":"case"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeVertical":{"role":"symbol","type":"topic","title":"MLNTextWritingModeVertical","abstract":[{"type":"text","text":"If a text’s language supports vertical writing mode, symbols with point"},{"type":"text","text":" "},{"type":"text","text":"placement would be laid out vertically."}],"kind":"symbol","fragments":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}],"url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical"},"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","url":"\/documentation\/maplibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","kind":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"role":"symbol","type":"topic","abstract":[{"type":"text","text":"The property allows control over a symbol’s orientation. Note that the property"},{"type":"text","text":" "},{"type":"text","text":"values act as a hint, so that a symbol whose language doesn’t support the"},{"type":"text","text":" "},{"type":"text","text":"provided orientation will be laid out in its natural orientation. Example:"},{"type":"text","text":" "},{"type":"text","text":"English point symbol will be rendered horizontally even if array value contains"},{"type":"text","text":" "},{"type":"text","text":"single ‘vertical’ enum value. The order of elements in an array define priority"},{"type":"text","text":" "},{"type":"text","text":"order for the placement of an orientation variant."}],"title":"MLNTextWritingMode","kind":"symbol","fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlntextwritingmode","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"}}}