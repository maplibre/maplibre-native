{"kind":"symbol","variants":[{"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"title":"MLNTextWritingModeVertical","roleHeading":"Enumeration Case","modules":[{"name":"MapLibre"}],"fragments":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"navigatorTitle":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"symbolKind":"case","externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeVertical","role":"symbol"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"languages":["occ"]}]},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"codeListing","code":[" If a text's language supports vertical writing mode, symbols with point"," placement would be laid out vertically."],"syntax":null}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical"},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"kind":"symbol","url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"title":"MLNTextWritingMode","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","abstract":[{"type":"text","text":"The property allows control over a symbol’s orientation. Note that the property"},{"type":"text","text":" "},{"type":"text","text":"values act as a hint, so that a symbol whose language doesn’t support the"},{"type":"text","text":" "},{"type":"text","text":"provided orientation will be laid out in its natural orientation. Example:"},{"type":"text","text":" "},{"type":"text","text":"English point symbol will be rendered horizontally even if array value contains"},{"type":"text","text":" "},{"type":"text","text":"single ‘vertical’ enum value. The order of elements in an array define priority"},{"type":"text","text":" "},{"type":"text","text":"order for the placement of an orientation variant."}],"role":"symbol","type":"topic","fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlntextwritingmode"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeVertical":{"fragments":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"kind":"symbol","abstract":[],"url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical","role":"symbol","title":"MLNTextWritingModeVertical"}}}