rg.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical","kind":"symbol","type":"topic","title":"MLNTextWritingModeVertical","abstract":[]},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"role":"symbol","url":"\/documentation\/maplibre\/mlntextwritingmode","abstract":[{"text":"The property allows control over a symbol’s orientation. Note that the property","type":"text"},{"text":" ","type":"text"},{"text":"values act as a hint, so that a symbol whose language doesn’t support the","type":"text"},{"text":" ","type":"text"},{"text":"provided orientation will be laid out in its natural orientation. Example:","type":"text"},{"text":" ","type":"text"},{"text":"English point symbol will be rendered horizontally even if array value contains","type":"text"},{"text":" ","type":"text"},{"text":"single ‘vertical’ enum value. The order of elements in an array define priority","type":"text"},{"text":" ","type":"text"},{"text":"order for the placement of an orientation variant.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","title":"MLNTextWritingMode","fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}],"type":"topic","kind":"symbol"}}}