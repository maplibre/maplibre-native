{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical","interfaceLanguage":"occ"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"code":[" If a text's language supports vertical writing mode, symbols with point"," placement would be laid out vertically."],"syntax":null,"type":"codeListing"}],"kind":"content"}],"kind":"symbol","metadata":{"title":"MLNTextWritingModeVertical","role":"symbol","navigatorTitle":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"symbolKind":"case","modules":[{"name":"MapLibre"}],"externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeVertical","roleHeading":"Enumeration Case","fragments":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeVertical":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical","abstract":[],"role":"symbol","fragments":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}],"kind":"symbol","title":"MLNTextWritingModeVertical","url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"role":"collection","title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","kind":"symbol","url":"\/documentation\/maplibre\/mlntextwritingmode","title":"MLNTextWritingMode","abstract":[{"text":"The property allows control over a symbol’s orientation. Note that the property","type":"text"},{"text":" ","type":"text"},{"text":"values act as a hint, so that a symbol whose language doesn’t support the","type":"text"},{"text":" ","type":"text"},{"text":"provided orientation will be laid out in its natural orientation. Example:","type":"text"},{"text":" ","type":"text"},{"text":"English point symbol will be rendered horizontally even if array value contains","type":"text"},{"text":" ","type":"text"},{"text":"single ‘vertical’ enum value. The order of elements in an array define priority","type":"text"},{"text":" ","type":"text"},{"text":"order for the placement of an orientation variant.","type":"text"}],"type":"topic","role":"symbol","fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}]}}}