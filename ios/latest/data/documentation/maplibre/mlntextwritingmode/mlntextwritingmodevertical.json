{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","metadata":{"modules":[{"name":"MapLibre"}],"roleHeading":"Enumeration Case","externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeVertical","navigatorTitle":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}],"role":"symbol","symbolKind":"case","fragments":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}],"title":"MLNTextWritingModeVertical"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}]}]},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"code":[" If a text's language supports vertical writing mode, symbols with point"," placement would be laid out vertically."],"type":"codeListing","syntax":null}],"kind":"content"}],"variants":[{"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical","interfaceLanguage":"occ"},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"type":"topic","fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}],"role":"symbol","abstract":[{"text":"The property allows control over a symbol’s orientation. Note that the property","type":"text"},{"text":