{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}],"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"]}]}],"abstract":[{"type":"text","text":"If a text’s language supports vertical writing mode, symbols with point"},{"type":"text","text":" "},{"text":"placement would be laid out vertically.","type":"text"}],"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"fragments":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}],"symbolKind":"case","role":"symbol","title":"MLNTextWritingModeVertical","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}],"roleHeading":"Enumeration Case","externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeVertical"},"variants":[{"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeVertical":{"title":"MLNTextWritingModeVertical","kind":"symbol","abstract":[{"type":"text","text":"If a text’s language supports vertical writing mode, symbols with point"},{"type":"text","text":" "},{"type":"text","text":"placement would be laid out vertically."}],"type":"topic","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical","url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical","fragments":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"title":"MLNTextWritingMode","fragments":[{"kind":"identifier","text":"MLNTextWritingMode"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"The property allows control over a symbol’s orientation. Note that the property"},{"type":"text","text":" "},{"type":"text","text":"values act as a hint, so that a symbol whose language doesn’t support the"},{"type":"text","text":" "},{"type":"text","text":"provided orientation will be laid out in its natural orientation. Example:"},{"type":"text","text":" "},{"type":"text","text":"English point symbol will be rendered horizontally even if array value contains"},{"type":"text","text":" "},{"type":"text","text":"single ‘vertical’ enum value. The order of elements in an array define priority"},{"type":"text","text":" "},{"type":"text","text":"order for the placement of an orientation variant."}],"url":"\/documentation\/maplibre\/mlntextwritingmode","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","role":"collection","url":"\/documentation\/maplibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre"}}}