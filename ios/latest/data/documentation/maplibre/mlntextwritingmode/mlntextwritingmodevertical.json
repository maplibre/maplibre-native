{"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"metadata":{"externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeVertical","roleHeading":"Enumeration Case","title":"MLNTextWritingModeVertical","navigatorTitle":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}],"symbolKind":"case","fragments":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}],"modules":[{"name":"MapLibre"}],"role":"symbol"},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical"]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"languages":["occ"],"platforms":["iOS"]}]},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"code":[" If a text's language supports vertical writing mode, symbols with point"," placement would be laid out vertically."],"syntax":null,"type":"codeListing"}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"kind":"symbol","type":"topic","role":"symbol","title":"MLNTextWritingMode","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}],"abstract":[{"text":"The property allows control over a symbol’s orientation. Note that the property","type":"text"},{"text":" ","type":"text"},{"text":"values act as a hint, so that a symbol whose language doesn’t support the","type":"text"},{"text":" ","type":"text"},{"text":"provided orientation will be laid out in its natural orientation. Example:","type":"text"},{"text":" ","type":"text"},{"text":"English point symbol will be rendered horizontally even if array value contains","type":"text"},{"text":" ","type":"text"},{"text":"single ‘vertical’ enum value. The order of elements in an array define priority","type":"text"},{"text":" ","type":"text"},{"text":"order for the placement of an orientation variant.","type":"text"}],"url":"\/documentation\/maplibre\/mlntextwritingmode"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeVertical":{"url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical","fragments":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"type":"topic","title":"MLNTextWritingModeVertical","abstract":[],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","kind":"symbol","url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"role":"collection","type":"topic"}}}