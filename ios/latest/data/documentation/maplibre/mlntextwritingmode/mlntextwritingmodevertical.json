{"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical","interfaceLanguage":"occ"},"kind":"symbol","metadata":{"fragments":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"role":"symbol","roleHeading":"Enumeration Case","externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeVertical","title":"MLNTextWritingModeVertical","navigatorTitle":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"symbolKind":"case"},"abstract":[{"type":"text","text":"If a text’s language supports vertical writing mode, symbols with point"},{"type":"text","text":" "},{"type":"text","text":"placement would be laid out vertically."}],"primaryContentSections":[{"declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"tokens":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"languages":["occ"]}],"kind":"declarations"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical"]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeVertical":{"type":"topic","role":"symbol","title":"MLNTextWritingModeVertical","fragments":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical","abstract":[{"text":"If a text’s language supports vertical writing mode, symbols with point","type":"text"},{"text":" ","type":"text"},{"text":"placement would be laid out vertically.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical"},"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","title":"MapLibre","url":"\/documentation\/maplibre","role":"collection","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"url":"\/documentation\/maplibre\/mlntextwritingmode","fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"text","text":"The property allows control over a symbol’s orientation. Note that the property"},{"type":"text","text":" "},{"type":"text","text":"values act as a hint, so that a symbol whose language doesn’t support the"},{"type":"text","text":" "},{"type":"text","text":"provided orientation will be laid out in its natural orientation. Example:"},{"type":"text","text":" "},{"type":"text","text":"English point symbol will be rendered horizontally even if array value contains"},{"type":"text","text":" "},{"type":"text","text":"single ‘vertical’ enum value. The order of elements in an array define priority"},{"type":"text","text":" "},{"type":"text","text":"order for the placement of an orientation variant."}],"title":"MLNTextWritingMode","type":"topic","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"}}}