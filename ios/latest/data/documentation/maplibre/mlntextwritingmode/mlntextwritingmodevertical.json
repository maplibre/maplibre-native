{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"],"tokens":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}]}]}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"title":"MLNTextWritingModeVertical","navigatorTitle":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeVertical","fragments":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"roleHeading":"Enumeration Case","symbolKind":"case","role":"symbol"},"abstract":[{"type":"text","text":"If a text’s language supports vertical writing mode, symbols with point"},{"type":"text","text":" "},{"type":"text","text":"placement would be laid out vertically."}],"variants":[{"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"symbol","identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical","interfaceLanguage":"occ"},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","title":"MapLibre","type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"url":"\/documentation\/maplibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeVertical":{"abstract":[{"type":"text","text":"If a text’s language supports vertical writing mode, symbols with point"},{"type":"text","text":" "},{"type":"text","text":"placement would be laid out vertically."}],"type":"topic","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical","title":"MLNTextWritingModeVertical","kind":"symbol","fragments":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"url":"\/documentation\/maplibre\/mlntextwritingmode","title":"MLNTextWritingMode","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","role":"symbol","fragments":[{"kind":"identifier","text":"MLNTextWritingMode"}],"kind":"symbol","abstract":[{"text":"The property allows control over a symbol’s orientation. Note that the property","type":"text"},{"text":" ","type":"text"},{"text":"values act as a hint, so that a symbol whose language doesn’t support the","type":"text"},{"text":" ","type":"text"},{"text":"provided orientation will be laid out in its natural orientation. Example:","type":"text"},{"text":" ","type":"text"},{"text":"English point symbol will be rendered horizontally even if array value contains","type":"text"},{"text":" ","type":"text"},{"text":"single ‘vertical’ enum value. The order of elements in an array define priority","type":"text"},{"text":" ","type":"text"},{"text":"order for the placement of an orientation variant.","type":"text"}],"type":"topic"}}}