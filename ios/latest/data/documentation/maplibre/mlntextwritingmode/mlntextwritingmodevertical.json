ngMode","url":"\/documentation\/maplibre\/mlntextwritingmode","abstract":[{"type":"text","text":"The property allows control over a symbol’s orientation. Note that the property"},{"type":"text","text":" "},{"type":"text","text":"values act as a hint, so that a symbol whose language doesn’t support the"},{"type":"text","text":" "},{"type":"text","text":"provided orientation will be laid out in its natural orientation. Example:"},{"type":"text","text":" "},{"type":"text","text":"English point symbol will be rendered horizontally even if array value contains"},{"type":"text","text":" "},{"type":"text","text":"single ‘vertical’ enum value. The order of elements in an array define priority"},{"type":"text","text":" "},{"type":"text","text":"order for the placement of an orientation variant."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeVertical":{"title":"MLNTextWritingModeVertical","url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical","role":"symbol","kind":"symbol","abstract":[],"fragments":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}]}}}