{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"metadata":{"symbolKind":"case","modules":[{"name":"MapLibre"}],"roleHeading":"Enumeration Case","role":"symbol","fragments":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeVertical","title":"MLNTextWritingModeVertical","navigatorTitle":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"languages":["occ"],"platforms":["iOS"]}]},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"syntax":null,"type":"codeListing","code":[" If a text's language supports vertical writing mode, symbols with point"," placement would be laid out vertically."]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical","interfaceLanguage":"occ"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeVertical":{"role":"symbol","title":"MLNTextWritingModeVertical","fragments":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical","type":"topic","abstract":[]},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","kind":"symbol","type":"topic","url":"\/documentation\/maplibre","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"abstract":[{"type":"text","text":"The property allows control over a symbol’s orientation. Note that the property"},{"type":"text","text":" "},{"type":"text","text":"values act as a hint, so that a symbol whose language doesn’t support the"},{"type":"text","text":" "},{"type":"text","text":"provided orientation will be laid out in its natural orientation. Example:"},{"type":"text","text":" "},{"type":"text","text":"English point symbol will be rendered horizontally even if array value contains"},{"type":"text","text":" "},{"type":"text","text":"single ‘vertical’ enum value. The order of elements in an array define priority"},{"type":"text","text":" "},{"type":"text","text":"order for the placement of an orientation variant."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","title":"MLNTextWritingMode","url":"\/documentation\/maplibre\/mlntextwritingmode","role":"symbol","type":"topic","kind":"symbol","fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}]}}}