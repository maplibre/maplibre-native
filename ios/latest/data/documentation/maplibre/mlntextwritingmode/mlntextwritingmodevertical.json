{"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical","interfaceLanguage":"occ"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"languages":["occ"]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"code":[" If a text's language supports vertical writing mode, symbols with point"," placement would be laid out vertically."],"syntax":null,"type":"codeListing"}]}],"variants":[{"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeVertical","symbolKind":"case","title":"MLNTextWritingModeVertical","role":"symbol","navigatorTitle":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"fragments":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"roleHeading":"Enumeration Case"},"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeVertical":{"role":"symbol","title":"MLNTextWritingModeVertical","url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical","type":"topic","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical","abstract":[],"fragments":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","title":"MapLibre","type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"kind":"symbol","url":"\/documentation\/maplibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"The property allows control over a symbol’s orientation. Note that the property"},{"type":"text","text":" "},{"type":"text","text":"values act as a hint, so that a symbol whose language doesn’t support the"},{"type":"text","text":" "},{"type":"text","text":"provided orientation will be laid out in its natural orientation. Example:"},{"type":"text","text":" "},{"type":"text","text":"English point symbol will be rendered horizontally even if array value contains"},{"type":"text","text":" "},{"type":"text","text":"single ‘vertical’ enum value. The order of elements in an array define priority"},{"type":"text","text":" "},{"type":"text","text":"order for the placement of an orientation variant."}],"url":"\/documentation\/maplibre\/mlntextwritingmode","type":"topic","title":"MLNTextWritingMode"}}}