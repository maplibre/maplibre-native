t":[{"type":"text","text":"The property allows control over a symbol’s orientation. Note that the property"},{"type":"text","text":" "},{"text":"values act as a hint, so that a symbol whose language doesn’t support the","type":"text"},{"text":" ","type":"text"},{"text":"provided orientation will be laid out in its natural orientation. Example:","type":"text"},{"text":" ","type":"text"},{"text":"English point symbol will be rendered horizontally even if array value contains","type":"text"},{"text":" ","type":"text"},{"text":"single ‘vertical’ enum value. The order of elements in an array define priority","type":"text"},{"text":" ","type":"text"},{"text":"order for the placement of an orientation variant.","type":"text"}],"fragments":[{"kind":"identifier","text":"MLNTextWritingMode"}],"title":"MLNTextWritingMode","type":"topic","role":"symbol","url":"\/documentation\/maplibre\/mlntextwritingmode"},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","role":"collection","url":"\/documentation\/maplibre","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}]}}}