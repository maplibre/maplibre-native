{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"If a text’s language supports vertical writing mode, symbols with point","type":"text"},{"text":" ","type":"text"},{"text":"placement would be laid out vertically.","type":"text"}],"variants":[{"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical","interfaceLanguage":"occ"},"sections":[],"kind":"symbol","metadata":{"fragments":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"symbolKind":"case","externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeVertical","navigatorTitle":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"title":"MLNTextWritingModeVertical","roleHeading":"Enumeration Case","modules":[{"name":"MapLibre"}],"role":"symbol"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS","iPadOS","Mac Catalyst"],"tokens":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}]}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeVertical":{"fragments":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical","url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical","type":"topic","role":"symbol","abstract":[{"type":"text","text":"If a text’s language supports vertical writing mode, symbols with point"},{"type":"text","text":" "},{"type":"text","text":"placement would be laid out vertically."}],"title":"MLNTextWritingModeVertical","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","role":"collection","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"title":"MLNTextWritingMode","role":"symbol","fragments":[{"text":"MLNTextWritingMode","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","url":"\/documentation\/maplibre\/mlntextwritingmode","abstract":[{"type":"text","text":"The property allows control over a symbol’s orientation. Note that the property"},{"type":"text","text":" "},{"type":"text","text":"values act as a hint, so that a symbol whose language doesn’t support the"},{"type":"text","text":" "},{"type":"text","text":"provided orientation will be laid out in its natural orientation. Example:"},{"type":"text","text":" "},{"type":"text","text":"English point symbol will be rendered horizontally even if array value contains"},{"type":"text","text":" "},{"type":"text","text":"single ‘vertical’ enum value. The order of elements in an array define priority"},{"type":"text","text":" "},{"type":"text","text":"order for the placement of an orientation variant."}],"kind":"symbol"}}}