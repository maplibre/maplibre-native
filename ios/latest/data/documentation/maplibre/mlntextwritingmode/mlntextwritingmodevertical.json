{"metadata":{"title":"MLNTextWritingModeVertical","symbolKind":"case","externalID":"c:@E@MLNTextWritingMode@MLNTextWritingModeVertical","role":"symbol","modules":[{"name":"MapLibre"}],"fragments":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}],"navigatorTitle":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}],"roleHeading":"Enumeration Case"},"sections":[],"kind":"symbol","variants":[{"paths":["\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"MLNTextWritingModeVertical","kind":"identifier"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"codeListing","code":[" If a text's language supports vertical writing mode, symbols with point"," placement would be laid out vertically."],"syntax":null}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode/MLNTextWritingModeVertical":{"url":"\/documentation\/maplibre\/mlntextwritingmode\/mlntextwritingmodevertical","role":"symbol","type":"topic","abstract":[],"fragments":[{"kind":"identifier","text":"MLNTextWritingModeVertical"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode\/MLNTextWritingModeVertical","title":"MLNTextWritingModeVertical","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTextWritingMode":{"type":"topic","url":"\/documentation\/maplibre\/mlntextwritingmode","fragments":[{"kind":"identifier","text":"MLNTextWritingMode"}],"abstract":[{"text":"The property allows control over a symbol’s orientation. Note that the property","type":"text"},{"text":" ","type":"text"},{"text":"values act as a hint, so that a symbol whose language doesn’t support the","type":"text"},{"text":" ","type":"text"},{"text":"provided orientation will be laid out in its natural orientation. Example:","type":"text"},{"text":" ","type":"text"},{"text":"English point symbol will be rendered horizontally even if array value contains","type":"text"},{"text":" ","type":"text"},{"text":"single ‘vertical’ enum value. The order of elements in an array define priority","type":"text"},{"text":" ","type":"text"},{"text":"order for the placement of an orientation variant.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTextWritingMode","role":"symbol","title":"MLNTextWritingMode"},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","title":"MapLibre","type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","url":"\/documentation\/maplibre"}}}