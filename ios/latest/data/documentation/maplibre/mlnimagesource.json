then add a computed shape source to an"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"type":"text","text":" object along with an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the computed shape"},{"type":"text","text":" "},{"type":"text","text":"source."}],"fragments":[{"text":"MLNComputedShapeSource","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlncomputedshapesource","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNCoordinateQuad":{"title":"MLNCoordinateQuad","role":"symbol","url":"\/documentation\/maplibre\/mlncoordinatequad","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateQuad","fragments":[{"text":"MLNCoordinateQuad","kind":"identifier"}],"abstract":[{"type":"text","text":"A quadrilateral area as measured on a two-dimensional map projection."},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateQuad","type":"reference","isActive":true},{"type":"text","text":" differs from "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateQuad","type":"reference","isActive":true},{"type":"text","text":" in that it allows"},{"type":"text","text":" "},{"type":"text","text":"representation of non-axis aligned bounds and non-rectangular quadrilaterals."},{"type":"text","text":" "},{"type":"text","text":"The coordinates are described in counter clockwise order from top left."}],"kind":"symbol"}}}