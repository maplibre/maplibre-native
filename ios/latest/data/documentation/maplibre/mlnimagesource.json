ge:forName:","type":"topic","navigatorTitle":[{"text":"setImage:forName:","kind":"identifier"}],"title":"setImage:forName:","abstract":[{"type":"text","text":"Adds or overrides an image used by the style’s layers."}],"fragments":[{"text":"- ","kind":"text"},{"text":"setImage:forName:","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnstyle\/setimage:forname:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNImageSource":{"title":"MLNImageSource","url":"\/documentation\/maplibre\/mlnimagesource","role":"symbol","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNImageSource","type":"reference","isActive":true},{"type":"text","text":" is a content source that is used for a georeferenced raster"},{"type":"text","text":" "},{"type":"text","text":"image to be shown on the map. The georeferenced image scales and rotates as the"},{"type":"text","text":" "},{"type":"text","text":"user zooms and rotates the map. Images may also be used as icons or patterns"},{"type":"text","text":" "},{"type":"text","text":"in a style layer. To register an image for use as an icon or pattern,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/setImage:forName:","type":"reference","isActive":true},{"type":"text","text":" method. To configure a point"},{"type":"text","text":" "},{"type":"text","text":"annotation’s image, use the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage","type":"reference","isActive":true},{"type":"text","text":" class."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNImageSource","type":"topic","fragments":[{"text":"MLNImageSource","kind":"identifier"}],"kind":"symbol"}}}