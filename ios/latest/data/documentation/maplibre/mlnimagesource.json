cumentation\/maplibre\/mlnsource","abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSource","isActive":true},{"type":"text","text":" is an abstract base class for map content sources. A map content"},{"type":"text","text":" "},{"type":"text","text":"source supplies content to be shown on the map. A source is added to an"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object along with an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object. The"},{"type":"text","text":" "},{"type":"text","text":"foreground style layer defines the appearance of any content supplied by the"},{"type":"text","text":" "},{"type":"text","text":"source."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSource","title":"MLNSource","fragments":[{"kind":"identifier","text":"MLNSource"}],"kind":"symbol","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterStyleLayer":{"type":"topic","title":"MLNRasterStyleLayer","abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","isActive":true},{"type":"text","text":" is a style layer that renders georeferenced raster"},{"type":"text","text":" "},{"type":"text","text":"imagery on the map, especially raster tiles."}],"fragments":[{"kind":"identifier","text":"MLNRasterStyleLayer"}],"url":"\/documentation\/maplibre\/mlnrasterstylelayer","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","role":"symbol","kind":"symbol"}}}