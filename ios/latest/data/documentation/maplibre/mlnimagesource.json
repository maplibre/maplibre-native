MyProject/documentation/MapLibre/MLNShape":{"fragments":[{"text":"MLNShape","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnshape","title":"MLNShape","kind":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":" is an abstract class that represents a shape or annotation. Shapes"},{"type":"text","text":" "},{"type":"text","text":"constitute the content of a map — not only the overlays atop the map, but also"},{"type":"text","text":" "},{"type":"text","text":"the content that forms the base map."}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNCoordinateQuad":{"abstract":[{"type":"text","text":"A quadrilateral area as measured on a two-dimensional map projection."},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateQuad","isActive":true,"type":"reference"},{"type":"text","text":" differs from "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateQuad","isActive":true,"type":"reference"},{"type":"text","text":" in that it allows"},{"type":"text","text":" "},{"text":"representation of non-axis aligned bounds and non-rectangular quadrilaterals.","type":"text"},{"text":" ","type":"text"},{"text":"The coordinates are described in counter clockwise order from top left.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateQuad","url":"\/documentation\/maplibre\/mlncoordinatequad","kind":"symbol","title":"MLNCoordinateQuad","fragments":[{"text":"MLNCoordinateQuad","kind":"identifier"}],"role":"symbol","type":"topic"}}}