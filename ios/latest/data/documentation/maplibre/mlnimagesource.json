:"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","isActive":true},{"text":" or ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNColorReliefStyleLayer","isActive":true},{"text":" objects. Use a hillshade","type":"text"},{"text":" ","type":"text"},{"text":"style layer to control the appearance of content supplied by the raster DEM source,","type":"text"},{"text":" ","type":"text"},{"text":"or a color relief style layer to render elevation data with a color ramp.","type":"text"}],"role":"symbol","title":"MLNRasterDEMSource","fragments":[{"kind":"identifier","text":"MLNRasterDEMSource"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnrasterdemsource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSourceDataSource":{"fragments":[{"text":"MLNComputedShapeSourceDataSource","kind":"identifier"}],"role":"symbol","abstract":[{"text":"Data source for ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","isActive":true},{"text":". This protocol defines two optional methods for fetching","type":"text"},{"text":" ","type":"text"},{"text":"data, one based on tile coordinates, and one based on a bounding box. Classes that implement this","type":"text"},{"text":" ","type":"text"},{"text":"protocol must implement one, and only one of the methods. Methods on this protocol will not be","type":"text"},{"text":" ","type":"text"},{"text":"called on main thread, they will be called on the caller’s ","type":"text"},{"type":"codeVoice","code":"requestQueue"},{"text":".","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource","kind":"symbol","type":"topic","title":"MLNComputedShapeSourceDataSource","url":"\/documentation\/maplibre\/mlncomputedshapesourcedatasource"}}}