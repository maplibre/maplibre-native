/MapLibre\/MLNComputedShapeSource"},{"text":". This protocol defines two optional methods for fetching","type":"text"},{"text":" ","type":"text"},{"text":"data, one based on tile coordinates, and one based on a bounding box. Classes that implement this","type":"text"},{"text":" ","type":"text"},{"text":"protocol must implement one, and only one of the methods. Methods on this protocol will not be","type":"text"},{"text":" ","type":"text"},{"text":"called on main thread, they will be called on the caller’s ","type":"text"},{"type":"codeVoice","code":"requestQueue"},{"text":".","type":"text"}],"type":"topic","url":"\/documentation\/maplibre\/mlncomputedshapesourcedatasource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource","title":"MLNComputedShapeSourceDataSource","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotationImage":{"abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage","isActive":true},{"type":"text","text":" class is responsible for presenting point-based"},{"type":"text","text":" "},{"type":"text","text":"annotations visually on a map view. Annotation image objects wrap "},{"type":"codeVoice","code":"UIImage"},{"type":"text","text":" "},{"type":"text","text":"objects and may be recycled later and put into a reuse queue that is maintained"},{"type":"text","text":" "},{"type":"text","text":"by the map view."}],"kind":"symbol","fragments":[{"text":"MLNAnnotationImage","kind":"identifier"}],"type":"topic","url":"\/documentation\/maplibre\/mlnannotationimage","title":"MLNAnnotationImage","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage"}}}