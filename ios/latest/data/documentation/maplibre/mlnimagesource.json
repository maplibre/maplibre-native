{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNColorReliefStyleLayer"},{"type":"text","text":" objects. Use a hillshade"},{"type":"text","text":" "},{"type":"text","text":"style layer to control the appearance of content supplied by the raster DEM source,"},{"type":"text","text":" "},{"type":"text","text":"or a color relief style layer to render elevation data with a color ramp."}],"fragments":[{"kind":"identifier","text":"MLNRasterDEMSource"}],"role":"symbol","url":"\/documentation\/maplibre\/mlnrasterdemsource","title":"MLNRasterDEMSource","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterDEMSource","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNCoordinateQuad":{"type":"topic","url":"\/documentation\/maplibre\/mlncoordinatequad","fragments":[{"text":"MLNCoordinateQuad","kind":"identifier"}],"title":"MLNCoordinateQuad","role":"symbol","abstract":[{"type":"text","text":"A quadrilateral area as measured on a two-dimensional map projection."},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateQuad","isActive":true},{"type":"text","text":" differs from "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateQuad","isActive":true},{"type":"text","text":" in that it allows"},{"type":"text","text":" "},{"type":"text","text":"representation of non-axis aligned bounds and non-rectangular quadrilaterals."},{"type":"text","text":" "},{"type":"text","text":"The coordinates are described in counter clockwise order from top left."}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateQuad"}}}