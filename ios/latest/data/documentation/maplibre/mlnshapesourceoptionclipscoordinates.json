 one based on tile coordinates, and one based on a bounding box. Classes that implement this"},{"type":"text","text":" "},{"type":"text","text":"protocol must implement one, and only one of the methods. Methods on this protocol will not be"},{"type":"text","text":" "},{"type":"text","text":"called on main thread, they will be called on the caller’s "},{"code":"requestQueue","type":"codeVoice"},{"type":"text","text":"."}],"type":"topic","title":"MLNComputedShapeSourceDataSource","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource","fragments":[{"text":"MLNComputedShapeSourceDataSource","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionClipsCoordinates":{"abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing a Boolean value; specifies whether the shape of","type":"text"},{"text":" ","type":"text"},{"text":"an ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource"},{"text":" should be clipped at the edge of each tile. The","type":"text"},{"text":" ","type":"text"},{"text":"default value is ","type":"text"},{"code":"NO","type":"codeVoice"},{"text":".","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClipsCoordinates","role":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionclipscoordinates","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionClipsCoordinates"}],"type":"topic","title":"MLNShapeSourceOptionClipsCoordinates","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"title":"MLNStyle","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","kind":"symbol","fragments":[{"text":"MLNStyle","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnstyle","type":"topic","role":"symbol","abstract":