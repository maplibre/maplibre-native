xt","text":" "},{"type":"text","text":"the content that forms the base map."}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionClipsCoordinates":{"role":"symbol","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing a Boolean value; specifies whether the shape of"},{"type":"text","text":" "},{"type":"text","text":"an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","isActive":true},{"type":"text","text":" should be clipped at the edge of each tile. The"},{"type":"text","text":" "},{"type":"text","text":"default value is "},{"type":"codeVoice","code":"NO"},{"type":"text","text":"."}],"fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionClipsCoordinates"}],"url":"\/documentation\/maplibre\/mlnshapesourceoptionclipscoordinates","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClipsCoordinates","kind":"symbol","type":"topic","title":"MLNShapeSourceOptionClipsCoordinates"},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSourceDataSource":{"role":"symbol","abstract":[{"type":"text","text":"Data source for "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","isActive":true},{"type":"text","text":". This protocol defines two optional methods for fetching"},{"type":"text","text":" "},{"type":"text","text":"data, one based on tile coordinates, and one based on a bounding box. Classes that implement this"},{"type":"text","text":" "},{"type":"text","text":"protocol must implement one, and only one of the methods. Methods on this protocol will not be"},{"type":"text","text":" "},{"type":"text","text":"called on main thread, they will be called on the caller’s "},{"type":"codeVoice","code":"requestQueue"},{"type":"text","text":"."}],"fragments":[{"kind":"identifier","text":"MLNComputedShapeSourceDataSource"}],"url":"\/documentation\/maplibre\/mlncomputedshapesourcedatasource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource","kind":"symbol","type":"topic","title":"MLNComputedShapeSourceDataSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"title":"MLNShapeSource","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","fragments":[{"kind":"identifier","text":"MLNShapeSource"}],"url":"\/documentation\/maplibre\/mlnshapesource","type":"topic","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"type":"text","text":" is a map content source that supplies vector shapes to be"},{"type":"text","text":" "},{"type":"text","text":"shown on the map. The shapes may be instances of "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":" or "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or they may be defined by local or external"},{"type":"text","text":" "},{"type":"text","text":"GeoJSON"},{"type":"text","text":" code. A shape source is added to an"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"type":"text","text":" object along with an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the shape source. You"},{"type":"text","text":" "},{"type":"text","text":"can update a shape source by setting its "},{"type":"codeVoice","code":"shape"},{"type":"text","text":" or "},{"type":"codeVoice","code":"URL"},{"type":"text","text":" property."}],"role":"symbol"}}}