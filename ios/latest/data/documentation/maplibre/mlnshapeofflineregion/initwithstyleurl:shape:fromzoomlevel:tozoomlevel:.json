 of the"},{"type":"text","text":" "},{"code":"minimumZoomLevel","type":"codeVoice"},{"type":"text","text":" parameter. For each required tile source, if this"},{"type":"text","text":" "},{"type":"text","text":"parameter is set to a value greater than the tile source’s minimum zoom"},{"type":"text","text":" "},{"type":"text","text":"level, the download covers zoom levels up to the tile source’s maximum zoom"},{"type":"text","text":" "},{"type":"text","text":"level."}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"This is the designated initializer for ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeOfflineRegion","type":"reference"},{"text":".","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnshapeofflineregion\/initwithstyleurl:shape:fromzoomlevel:tozoomlevel:"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeOfflineRegion"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeOfflineRegion\/initWithStyleURL:shape:fromZoomLevel:toZoomLevel:"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeOfflineRegion/initWithStyleURL:shape:fromZoomLevel:toZoomLevel:":{"role":"symbol","abstract":[{"text":"Initializes a newly created offline region with the given style URL, geometry,","type":"text"},{"text":" ","type":"text"},{"text":"and range of zoom levels.","type":"text"}],"title":"initWithStyleURL:shape:fromZoomLevel:toZoomLevel:","fragments":[{"text":"- ","kind":"text"},{"text":"initWithStyleURL:shape:fromZoomLevel:toZoomLevel:","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/org.