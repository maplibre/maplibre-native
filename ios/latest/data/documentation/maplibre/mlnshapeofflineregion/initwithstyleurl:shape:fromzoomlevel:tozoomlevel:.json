Level"},{"type":"text","text":" parameter. For each required tile source, if this"},{"type":"text","text":" "},{"type":"text","text":"parameter is set to a value greater than the tile source’s minimum zoom"},{"type":"text","text":" "},{"type":"text","text":"level, the download covers zoom levels up to the tile source’s maximum zoom"},{"type":"text","text":" "},{"type":"text","text":"level."}]}]}]},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"This is the designated initializer for ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeOfflineRegion"},{"text":".","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/maplibre\/mlnshapeofflineregion\/initwithstyleurl:shape:fromzoomlevel:tozoomlevel:"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"role":"symbol","title":"initWithStyleURL:shape:fromZoomLevel:toZoomLevel:","externalID":"c:objc(cs)MLNShapeOfflineRegion(im)initWithStyleURL:shape:fromZoomLevel:toZoomLevel:","modules":[{"name":"MapLibre"}],"roleHeading":"Instance Method","symbolKind":"method","fragments":[{"text":"- ","kind":"text"},{"text":"initWithStyleURL:shape:fromZoomLevel:toZoomLevel:","kind":"identifier"}],"navigatorTitle":[{"text":"initWithStyleURL:shape:fromZoomLevel:toZoomLevel:","kind":"identifier"}]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeOfflineRegion":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeOfflineRegion","title":"MLNShapeOfflineRegion","type":"topic","fragments":[{"kind":"identifier","text":"MLNShapeOfflineRegion"}],"url":"\/documentation\/maplibre\/mlnshapeofflineregion","kind":"symbol","abstract":[{"text":"An offline region defined by a style URL, geographic shape, and","type":"text"},{"text":" ","type":"text"},{"text":"range of zoom levels.","type":"text"}],"role":"symbol"},"doc://org.swi