oaded","type":"text"},{"text":" ","type":"text"},{"text":"tiles. This parameter should be set to at least the value of the","type":"text"},{"text":" ","type":"text"},{"code":"minimumZoomLevel","type":"codeVoice"},{"text":" parameter. For each required tile source, if this","type":"text"},{"text":" ","type":"text"},{"text":"parameter is set to a value greater than the tile source’s minimum zoom","type":"text"},{"text":" ","type":"text"},{"text":"level, the download covers zoom levels up to the tile source’s maximum zoom","type":"text"},{"text":" ","type":"text"},{"text":"level.","type":"text"}]}],"name":"maximumZoomLevel"}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"This is the designated initializer for "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeOfflineRegion"},{"type":"text","text":"."}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeOfflineRegion\/initWithStyleURL:shape:fromZoomLevel:toZoomLevel:"},"abstract":[{"text":"Initializes a newly created offline region with the given style URL, geometry,","type":"text"},{"text":" ","type":"text"},{"text":"and range of zoom levels.","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","title":"MapLibre","url":"\/documentation\/maplibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeOfflineRegion/initWithStyleURL:shape:fromZoomLevel:toZoomLevel:":{"url":"\/documentation\/maplibre\/mlnshapeofflineregion\/initwithstyleurl:sh