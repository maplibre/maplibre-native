 tile source, if"},{"type":"text","text":" "},{"type":"text","text":"this parameter is set to a value less than the tile source’s minimum zoom"},{"type":"text","text":" "},{"type":"text","text":"level, the download covers zoom levels down to the tile source’s minimum"},{"type":"text","text":" "},{"type":"text","text":"zoom level."}]}],"name":"minimumZoomLevel"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The maximum zoom level to be covered by the downloaded"},{"type":"text","text":" "},{"type":"text","text":"tiles. This parameter should be set to at least the value of the"},{"type":"text","text":" "},{"type":"codeVoice","code":"minimumZoomLevel"},{"type":"text","text":" parameter. For each required tile source, if this"},{"type":"text","text":" "},{"type":"text","text":"parameter is set to a value greater than the tile source’s minimum zoom"},{"type":"text","text":" "},{"type":"text","text":"level, the download covers zoom levels up to the tile source’s maximum zoom"},{"type":"text","text":" "},{"type":"text","text":"level."}]}],"name":"maximumZoomLevel"}]},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"This is the designated initializer for "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeOfflineRegion"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","title":"MapLibre","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","kind":"symbol","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeOfflineRegion":{"role":"symbol","title":"MLNShapeOfflineRegion","type":"topic","fragments"