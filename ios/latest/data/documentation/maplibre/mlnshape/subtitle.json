ject/documentation/MapLibre/MLNFeature":{"fragments":[{"kind":"identifier","text":"MLNFeature"}],"abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature"},{"type":"text","text":"  protocol is used to provide details about geographic features"},{"type":"text","text":" "},{"type":"text","text":"contained in an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":" or "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource"},{"type":"text","text":" object. Each concrete"},{"type":"text","text":" "},{"type":"text","text":"subclass of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":" in turn has a subclass that conforms to this protocol. A"},{"type":"text","text":" "},{"type":"text","text":"feature object associates a shape with an optional identifier and attributes."}],"url":"\/documentation\/maplibre\/mlnfeature","type":"topic","title":"MLNFeature","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature","kind":"symbol","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape/subtitle":{"role":"symbol","abstract":[{"type":"text","text":"The subtitle of the shape annotation. The default value of this property is"},{"type":"text","text":" "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}],"fragments":[{"kind":"identifier","text":"subtitle"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape\/subtitle","kind":"symbol","type":"topic","title":"subtitle","url":"\/documentation\/maplibre\/mlnshape\/subtitle"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"role":"symbol","title":"MLNShapeSource","abstract":[{"type":"referenc