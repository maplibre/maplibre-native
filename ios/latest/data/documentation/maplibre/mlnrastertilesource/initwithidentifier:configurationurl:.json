t":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A raster tile source is added to an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer"},{"type":"text","text":" objects. Use a raster style layer to control the"},{"type":"text","text":" "},{"type":"text","text":"appearance of content supplied by the raster tile source."}],"kind":"symbol","role":"symbol","title":"MLNRasterTileSource","url":"\/documentation\/maplibre\/mlnrastertilesource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","fragments":[{"kind":"identifier","text":"MLNRasterTileSource"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterStyleLayer":{"kind":"symbol","url":"\/documentation\/maplibre\/mlnrasterstylelayer","abstract":[{"type":"text","text":"An "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","type":"reference"},{"type":"text","text":" is a style layer that renders georeferenced raster"},{"type":"text","text":" "},{"type":"text","text":"imagery on the map, especially raster tiles."}],"title":"MLNRasterStyleLayer","role":"symbol","fragments":[{"kind":"identifier","text":"MLNRasterStyleLayer"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer"},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol","role":"collection","type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTileSourceOptionTileSize":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize","role":"symbol","url":"\/documentation\/maplibre\/mlntilesourceoptiontilesize","abstract":[{"text":"An ","type":"text"},{"type":"codeVoice","code":"NSNumber"},{"text":" object containing a floating-point number that specifies the","type":"text"},{"text":" ","type":"text"},{"text":"width and height (measured in points) at which the map displays each raster","type":"text"},{"text":" ","type":"text"},{"text":"image tile when the map’s zoom level is an integer. The raster tile source","type":"text"},{"text":" ","type":"text"},{"text":"scales its images up or down when the map’s zoom level falls between two","type":"text"},{"text":" ","type":"text"},{"text":"integers.","type":"text"}],"kind":"symbol","type":"topic","fragments":[{"text":"MLNTileSourceOptionTileSize","kind":"identifier"}],"title":"MLNTileSourceOptionTileSize"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/addSource:":{"abstract":[{"text":"Adds a new source to the current style.","type":"text"}],"type":"topic","fragments":[{"text":"- ","kind":"text"},{"text":"addSource:","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnstyle\/addsource:","navigatorTitle":[{"text":"addSource:","kind":"identifier"}],"title":"addSource:","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","role":"symbol"}}}