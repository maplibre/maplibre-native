"},{"type":"text","text":" "},{"type":"text","text":"width and height (measured in points) at which the map displays each raster"},{"type":"text","text":" "},{"type":"text","text":"image tile when the map’s zoom level is an integer. The raster tile source"},{"type":"text","text":" "},{"type":"text","text":"scales its images up or down when the map’s zoom level falls between two"},{"type":"text","text":" "},{"type":"text","text":"integers."}],"fragments":[{"text":"MLNTileSourceOptionTileSize","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlntilesourceoptiontilesize","kind":"symbol","title":"MLNTileSourceOptionTileSize"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/addSource:":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","url":"\/documentation\/maplibre\/mlnstyle\/addsource:","title":"addSource:","abstract":[{"type":"text","text":"Adds a new source to the current style."}],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"addSource:","kind":"identifier"}],"navigatorTitle":[{"text":"addSource:","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"abstract":[{"text":"The proxy object for the current map style.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","url":"\/documentation\/maplibre\/mlnstyle","type":"topic","kind":"symbol","title":"MLNStyle","role":"symbol","fragments":[{"text":"MLNStyle","kind":"identifier"}]}}}