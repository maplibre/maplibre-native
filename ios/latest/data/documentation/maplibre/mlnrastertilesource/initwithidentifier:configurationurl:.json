th an identifier and configuration"},{"type":"text","text":" "},{"type":"text","text":"URL."}],"title":"initWithIdentifier:configurationURL:","url":"\/documentation\/maplibre\/mlnrastertilesource\/initwithidentifier:configurationurl:","role":"symbol","type":"topic","navigatorTitle":[{"text":"initWithIdentifier:configurationURL:","kind":"identifier"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterStyleLayer":{"url":"\/documentation\/maplibre\/mlnrasterstylelayer","fragments":[{"kind":"identifier","text":"MLNRasterStyleLayer"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","kind":"symbol","abstract":[{"text":"An ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer"},{"text":" is a style layer that renders georeferenced raster","type":"text"},{"text":" ","type":"text"},{"text":"imagery on the map, especially raster tiles.","type":"text"}],"role":"symbol","title":"MLNRasterStyleLayer","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/addSource:":{"url":"\/documentation\/maplibre\/mlnstyle\/addsource:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","abstract":[{"type":"text","text":"Adds a new source to the current style."}],"fragments":[{"text":"- ","kind":"text"},{"text":"addSource:","kind":"identifier"}],"type":"topic","kind":"symbol","navigatorTitle":[{"text":"addSource:","kind":"identifier"}],"role":"symbol","title":"addSource:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource":{"url":"\/documentation\/maplibre\/mlnrastertilesource","kind":"symbol","role":"symbol","type":"topic","title":"MLNRasterTileSource","fragments":[{"text":"MLNRasterTileSource","kind":"identifier"}],"abstract":[{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","type":"reference"},{"text":" is a map content source that supplies raster image tiles","type":"text"},{"text":" ","type":"text"},{"text":"to be shown on the map. The location of and metadata about the tiles are","type":"text"},{"text":" ","type":"text"},{"text":"defined either by an option dictionary or by an external file that conforms to","type":"text"},{"text":" ","type":"text"},{"text":"the","type":"text"},{"text":" ","type":"text"},{"text":"TileJSON specification","type":"text"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"A raster tile source is added to an ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference"},{"text":" object along with one or more","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","type":"reference"},{"text":" objects. Use a raster style layer to control the","type":"text"},{"text":" ","type":"text"},{"text":"appearance of content supplied by the raster tile source.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource"},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","type":"topic","url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol"}}}