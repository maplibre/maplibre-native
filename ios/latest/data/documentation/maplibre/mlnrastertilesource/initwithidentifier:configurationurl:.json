{"kind":"symbol","abstract":[{"type":"text","text":"Returns a raster tile source initialized with an identifier and configuration"},{"type":"text","text":" "},{"type":"text","text":"URL."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource\/initWithIdentifier:configurationURL:","interfaceLanguage":"occ"},"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"- (","kind":"text"},{"text":"instancetype","kind":"keyword"},{"text":") ","kind":"text"},{"text":"initWithIdentifier:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSString","text":"NSString","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"identifier","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"configurationURL:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSURL","text":"NSURL","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"configurationURL","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"parameters":[{"content":[{"inlineContent":[{"text":"A string that uniquely identifies the source in the style to","type":"text"},{"text":" ","type":"text"},{"text":"which it is added.","type":"text"}],"type":"paragraph"}],"name":"identifier"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A URL to a TileJSON configuration file describing the","type":"text"},{"text":" ","type":"text"},{"text":"source’s contents and other metadata.","type":"text"}]}],"name":"configurationURL"}],"kind":"parameters"},{"content":[{"level":2,"text":"Return Value","anchor":"return-value","type":"heading"},{"inlineContent":[{"type":"text","text":"An initialized raster tile source."}],"type":"paragraph"}],"kind":"content"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"After initializing and configuring the source, add it to a map view’s style"},{"type":"text","text":" "},{"type":"text","text":"using the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","type":"reference","isActive":true},{"type":"text","text":" method."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The URL may be a full HTTP or HTTPS URL or canonical URL. The URL should"},{"type":"text","text":" "},{"type":"text","text":"point to a JSON file that conforms to the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"If a Mapbox URL is specified, this source uses a tile size of 256. For all","type":"text"},{"text":" ","type":"text"},{"text":"other tilesets, the default value is 512. (See the","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize","isActive":true},{"text":" documentation for more information about tile","type":"text"},{"text":" ","type":"text"},{"text":"sizes.) If you need to use a tile size other than the default, use the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"-initWithIdentifier:configurationURL:tileSize:"},{"text":" method.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"metadata":{"navigatorTitle":[{"text":"initWithIdentifier:configurationURL:","kind":"identifier"}],"externalID":"c:objc(cs)MLNRasterTileSource(im)initWithIdentifier:configurationURL:","fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:configurationURL:","kind":"identifier"}],"symbolKind":"method","role":"symbol","roleHeading":"Instance Method","title":"initWithIdentifier:configurationURL:","modules":[{"name":"MapLibre"}]},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnrastertilesource\/initwithidentifier:configurationurl:"]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/addSource:":{"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"addSource:"}],"abstract":[{"type":"text","text":"Adds a new source to the current style."}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnstyle\/addsource:","type":"topic","title":"addSource:","navigatorTitle":[{"kind":"identifier","text":"addSource:"}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource/initWithIdentifier:configurationURL:":{"role":"symbol","title":"initWithIdentifier:configurationURL:","navigatorTitle":[{"text":"initWithIdentifier:configurationURL:","kind":"identifier"}],"fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:configurationURL:","kind":"identifier"}],"abstract":[{"text":"Returns a raster tile source initialized with an identifier and configuration","type":"text"},{"text":" ","type":"text"},{"text":"URL.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource\/initWithIdentifier:configurationURL:","kind":"symbol","url":"\/documentation\/maplibre\/mlnrastertilesource\/initwithidentifier:configurationurl:","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"kind":"symbol","type":"topic","role":"symbol","url":"\/documentation\/maplibre\/mlnstyle","title":"MLNStyle","fragments":[{"text":"MLNStyle","kind":"identifier"}],"abstract":[{"text":"The proxy object for the current map style.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTileSourceOptionTileSize":{"title":"MLNTileSourceOptionTileSize","kind":"symbol","abstract":[{"type":"text","text":"An "},{"code":"NSNumber","type":"codeVoice"},{"type":"text","text":" object containing a floating-point number that specifies the"},{"type":"text","text":" "},{"type":"text","text":"width and height (measured in points) at which the map displays each raster"},{"type":"text","text":" "},{"type":"text","text":"image tile when the map’s zoom level is an integer. The raster tile source"},{"type":"text","text":" "},{"type":"text","text":"scales its images up or down when the map’s zoom level falls between two"},{"type":"text","text":" "},{"type":"text","text":"integers."}],"fragments":[{"kind":"identifier","text":"MLNTileSourceOptionTileSize"}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize","type":"topic","url":"\/documentation\/maplibre\/mlntilesourceoptiontilesize"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource":{"type":"topic","fragments":[{"kind":"identifier","text":"MLNRasterTileSource"}],"url":"\/documentation\/maplibre\/mlnrastertilesource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","type":"reference","isActive":true},{"text":" is a map content source that supplies raster image tiles","type":"text"},{"text":" ","type":"text"},{"text":"to be shown on the map. The location of and metadata about the tiles are","type":"text"},{"text":" ","type":"text"},{"text":"defined either by an option dictionary or by an external file that conforms to","type":"text"},{"text":" ","type":"text"},{"text":"the","type":"text"},{"text":" ","type":"text"},{"text":"TileJSON specification","type":"text"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"A raster tile source is added to an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"text":" object along with one or more","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","type":"reference","isActive":true},{"text":" objects. Use a raster style layer to control the","type":"text"},{"text":" ","type":"text"},{"text":"appearance of content supplied by the raster tile source.","type":"text"}],"kind":"symbol","title":"MLNRasterTileSource","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterStyleLayer":{"url":"\/documentation\/maplibre\/mlnrasterstylelayer","role":"symbol","kind":"symbol","fragments":[{"text":"MLNRasterStyleLayer","kind":"identifier"}],"abstract":[{"text":"An ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","isActive":true},{"text":" is a style layer that renders georeferenced raster","type":"text"},{"text":" ","type":"text"},{"text":"imagery on the map, especially raster tiles.","type":"text"}],"title":"MLNRasterStyleLayer","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","kind":"symbol","url":"\/documentation\/maplibre","title":"MapLibre"}}}