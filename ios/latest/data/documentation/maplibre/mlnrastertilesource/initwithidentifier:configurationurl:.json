apLibre\/MLNRasterStyleLayer","type":"reference","isActive":true},{"text":" objects. Use a raster style layer to control the","type":"text"},{"text":" ","type":"text"},{"text":"appearance of content supplied by the raster tile source.","type":"text"}],"kind":"symbol","role":"symbol","title":"MLNRasterTileSource","fragments":[{"text":"MLNRasterTileSource","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","kind":"symbol","role":"collection","url":"\/documentation\/maplibre","type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource/initWithIdentifier:configurationURL:":{"url":"\/documentation\/maplibre\/mlnrastertilesource\/initwithidentifier:configurationurl:","title":"initWithIdentifier:configurationURL:","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"initWithIdentifier:configurationURL:"}],"abstract":[{"type":"text","text":"Returns a raster tile source initialized with an identifier and configuration"},{"type":"text","text":" "},{"type":"text","text":"URL."}],"type":"topic","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource\/initWithIdentifier:configurationURL:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"initWithIdentifier:configurationURL:"}]}}}