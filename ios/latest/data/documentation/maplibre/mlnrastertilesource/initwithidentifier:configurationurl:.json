that specifies the","type":"text"},{"text":" ","type":"text"},{"text":"width and height (measured in points) at which the map displays each raster","type":"text"},{"text":" ","type":"text"},{"text":"image tile when the map’s zoom level is an integer. The raster tile source","type":"text"},{"text":" ","type":"text"},{"text":"scales its images up or down when the map’s zoom level falls between two","type":"text"},{"text":" ","type":"text"},{"text":"integers.","type":"text"}],"title":"MLNTileSourceOptionTileSize","role":"symbol","fragments":[{"kind":"identifier","text":"MLNTileSourceOptionTileSize"}],"kind":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","abstract":[{"type":"text","text":"The proxy object for the current map style."}],"fragments":[{"kind":"identifier","text":"MLNStyle"}],"title":"MLNStyle","kind":"symbol","url":"\/documentation\/maplibre\/mlnstyle","type":"topic","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/addSource:":{"navigatorTitle":[{"kind":"identifier","text":"addSource:"}],"url":"\/documentation\/maplibre\/mlnstyle\/addsource:","role":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","kind":"symbol","title":"addSource:","fragments":[{"text":"- ","kind":"text"},{"text":"addSource:","kind":"identifier"}],"abstract":[{"type":"text","text":"Adds a new source to the current style."}]}}}