ects. Use a raster style layer to control the"},{"type":"text","text":" "},{"type":"text","text":"appearance of content supplied by the raster tile source."}],"fragments":[{"text":"MLNRasterTileSource","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","title":"MLNRasterTileSource","role":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnrastertilesource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"title":"MLNStyle","kind":"symbol","url":"\/documentation\/maplibre\/mlnstyle","abstract":[{"type":"text","text":"The proxy object for the current map style."}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","fragments":[{"kind":"identifier","text":"MLNStyle"}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterStyleLayer":{"title":"MLNRasterStyleLayer","type":"topic","abstract":[{"text":"An ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","type":"reference"},{"text":" is a style layer that renders georeferenced raster","type":"text"},{"text":" ","type":"text"},{"text":"imagery on the map, especially raster tiles.","type":"text"}],"url":"\/documentation\/maplibre\/mlnrasterstylelayer","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","fragments":[{"text":"MLNRasterStyleLayer","kind":"identifier"}],"kind":"symbol","role":"symbol"}}}