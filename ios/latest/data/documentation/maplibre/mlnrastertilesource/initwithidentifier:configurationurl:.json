\/MLNRasterTileSource\/initWithIdentifier:configurationURL:"},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","kind":"symbol","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"role":"collection","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTileSourceOptionTileSize":{"url":"\/documentation\/maplibre\/mlntilesourceoptiontilesize","role":"symbol","title":"MLNTileSourceOptionTileSize","abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing a floating-point number that specifies the","type":"text"},{"text":" ","type":"text"},{"text":"width and height (measured in points) at which the map displays each raster","type":"text"},{"text":" ","type":"text"},{"text":"image tile when the map’s zoom level is an integer. The raster tile source","type":"text"},{"text":" ","type":"text"},{"text":"scales its images up or down when the map’s zoom level falls between two","type":"text"},{"text":" ","type":"text"},{"text":"integers.","type":"text"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize","kind":"symbol","fragments":[{"text":"MLNTileSourceOptionTileSize","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/addSource:":{"kind":"symbol","abstract":[{"type":"text","text":"Adds a new source to the current style."}],"title":"addSource:","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","navigatorTitle":[{"text":"addSource:","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnstyle\/addsource:","fragments":[{"text":"- ","kind":"text"},{"text":"addSource:","kind":"identifier"}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource":{"title":"MLNRasterTileSource","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource"},{"type":"text","text":" is a map content source that supplies raster image tiles"},{"type":"text","text":" "},{"type":"text","text":"to be shown on the map. The location of and metadata about the tiles are"},{"type":"text","text":" "},{"type":"text","text":"defined either by an option dictionary or by an external file that conforms to"},{"type":"text","text":" "},{"type":"text","text":"the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A raster tile source is added to an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer"},{"type":"text","text":" objects. Use a raster style layer to control the"},{"type":"text","text":" "},{"type":"text","text":"appearance of content supplied by the raster tile source."}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","url":"\/documentation\/maplibre\/mlnrastertilesource","type":"topic","fragments":[{"kind":"identifier","text":"MLNRasterTileSource"}],"kind":"symbol"}}}