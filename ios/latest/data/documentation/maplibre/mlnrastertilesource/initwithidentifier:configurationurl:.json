{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource\/initWithIdentifier:configurationURL:"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"text","text":"- ("},{"kind":"keyword","text":"instancetype"},{"kind":"text","text":") "},{"kind":"identifier","text":"initWithIdentifier:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"NSString","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"identifier"},{"kind":"text","text":" "},{"kind":"identifier","text":"configurationURL:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"NSURL","preciseIdentifier":"c:objc(cs)NSURL"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"configurationURL"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"name":"identifier","content":[{"inlineContent":[{"text":"A string that uniquely identifies the source in the style to","type":"text"},{"text":" ","type":"text"},{"text":"which it is added.","type":"text"}],"type":"paragraph"}]},{"name":"configurationURL","content":[{"type":"paragraph","inlineContent":[{"text":"A URL to a TileJSON configuration file describing the","type":"text"},{"text":" ","type":"text"},{"text":"source’s contents and other metadata.","type":"text"}]}]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Return Value","anchor":"return-value"},{"inlineContent":[{"type":"text","text":"An initialized raster tile source."}],"type":"paragraph"}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"After initializing and configuring the source, add it to a map view’s style","type":"text"},{"text":" ","type":"text"},{"text":"using the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","type":"reference"},{"text":" method.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The URL may be a full HTTP or HTTPS URL or canonical URL. The URL should","type":"text"},{"text":" ","type":"text"},{"text":"point to a JSON file that conforms to the","type":"text"},{"text":" ","type":"text"},{"text":"TileJSON specification","type":"text"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If a Mapbox URL is specified, this source uses a tile size of 256. For all"},{"type":"text","text":" "},{"type":"text","text":"other tilesets, the default value is 512. (See the"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize","isActive":true,"type":"reference"},{"type":"text","text":" documentation for more information about tile"},{"type":"text","text":" "},{"type":"text","text":"sizes.) If you need to use a tile size other than the default, use the"},{"type":"text","text":" "},{"code":"-initWithIdentifier:configurationURL:tileSize:","type":"codeVoice"},{"type":"text","text":" method."}],"type":"paragraph"}]}],"sections":[],"abstract":[{"type":"text","text":"Returns a raster tile source initialized with an identifier and configuration"},{"type":"text","text":" "},{"type":"text","text":"URL."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnrastertilesource\/initwithidentifier:configurationurl:"]}],"metadata":{"externalID":"c:objc(cs)MLNRasterTileSource(im)initWithIdentifier:configurationURL:","roleHeading":"Instance Method","title":"initWithIdentifier:configurationURL:","navigatorTitle":[{"text":"initWithIdentifier:configurationURL:","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"role":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:configurationURL:","kind":"identifier"}],"symbolKind":"method"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource/initWithIdentifier:configurationURL:":{"url":"\/documentation\/maplibre\/mlnrastertilesource\/initwithidentifier:configurationurl:","role":"symbol","kind":"symbol","title":"initWithIdentifier:configurationURL:","navigatorTitle":[{"kind":"identifier","text":"initWithIdentifier:configurationURL:"}],"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"initWithIdentifier:configurationURL:"}],"abstract":[{"text":"Returns a raster tile source initialized with an identifier and configuration","type":"text"},{"text":" ","type":"text"},{"text":"URL.","type":"text"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource\/initWithIdentifier:configurationURL:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource":{"url":"\/documentation\/maplibre\/mlnrastertilesource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","title":"MLNRasterTileSource","role":"symbol","fragments":[{"text":"MLNRasterTileSource","kind":"identifier"}],"abstract":[{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","type":"reference"},{"text":" is a map content source that supplies raster image tiles","type":"text"},{"text":" ","type":"text"},{"text":"to be shown on the map. The location of and metadata about the tiles are","type":"text"},{"text":" ","type":"text"},{"text":"defined either by an option dictionary or by an external file that conforms to","type":"text"},{"text":" ","type":"text"},{"text":"the","type":"text"},{"text":" ","type":"text"},{"text":"TileJSON specification","type":"text"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"A raster tile source is added to an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer"},{"type":"text","text":" objects. Use a raster style layer to control the"},{"type":"text","text":" "},{"type":"text","text":"appearance of content supplied by the raster tile source."}],"type":"topic","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"abstract":[{"type":"text","text":"The proxy object for the current map style."}],"title":"MLNStyle","url":"\/documentation\/maplibre\/mlnstyle","role":"symbol","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"topic","fragments":[{"kind":"identifier","text":"MLNStyle"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNTileSourceOptionTileSize":{"fragments":[{"text":"MLNTileSourceOptionTileSize","kind":"identifier"}],"title":"MLNTileSourceOptionTileSize","role":"symbol","url":"\/documentation\/maplibre\/mlntilesourceoptiontilesize","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize","kind":"symbol","type":"topic","abstract":[{"text":"An ","type":"text"},{"type":"codeVoice","code":"NSNumber"},{"text":" object containing a floating-point number that specifies the","type":"text"},{"text":" ","type":"text"},{"text":"width and height (measured in points) at which the map displays each raster","type":"text"},{"text":" ","type":"text"},{"text":"image tile when the map’s zoom level is an integer. The raster tile source","type":"text"},{"text":" ","type":"text"},{"text":"scales its images up or down when the map’s zoom level falls between two","type":"text"},{"text":" ","type":"text"},{"text":"integers.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/addSource:":{"abstract":[{"text":"Adds a new source to the current style.","type":"text"}],"type":"topic","title":"addSource:","kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlnstyle\/addsource:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","fragments":[{"text":"- ","kind":"text"},{"text":"addSource:","kind":"identifier"}],"navigatorTitle":[{"text":"addSource:","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterStyleLayer":{"fragments":[{"kind":"identifier","text":"MLNRasterStyleLayer"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","role":"symbol","kind":"symbol","title":"MLNRasterStyleLayer","type":"topic","url":"\/documentation\/maplibre\/mlnrasterstylelayer","abstract":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","isActive":true,"type":"reference"},{"type":"text","text":" is a style layer that renders georeferenced raster"},{"type":"text","text":" "},{"type":"text","text":"imagery on the map, especially raster tiles."}]}}}