ft.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","type":"reference","isActive":true},{"text":" method.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The URL may be a full HTTP or HTTPS URL or canonical URL. The URL should"},{"type":"text","text":" "},{"type":"text","text":"point to a JSON file that conforms to the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If a Mapbox URL is specified, this source uses a tile size of 256. For all"},{"type":"text","text":" "},{"type":"text","text":"other tilesets, the default value is 512. (See the"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize","type":"reference"},{"type":"text","text":" documentation for more information about tile"},{"type":"text","text":" "},{"type":"text","text":"sizes.) If you need to use a tile size other than the default, use the"},{"type":"text","text":" "},{"code":"-initWithIdentifier:configurationURL:tileSize:","type":"codeVoice"},{"type":"text","text":" method."}]}],"kind":"content"}],"abstract":[{"type":"text","text":"Returns a raster tile source initialized with an identifier and configuration"},{"type":"text","text":" "},{"type":"text","text":"URL."}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource\/initWithIdentifier:configurationURL:","interfaceLanguage":"occ"},"metadata":{"navigatorTitle":[{"text":"initWithIdentifier:configurationURL:","kind":"identifier"}],"title":"initWithIdentifier:configurationURL:","roleHeading":"Instance Method","symbolKind":"method","modules":[{"name":"MapLibre"}],"fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:configurationURL:","kind":"identifier"}],"role":"symbol","externalID":"c:objc(cs)MLNRasterTileSource(im)initWithIdentifier:configurationURL:"},"kind":"symbol","variants":[{"paths":["\/documentation\/maplibre\/mlnrastertilesource\/initwithidentifier:configurationurl:"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"abstract":[{"type":"text","text":"The proxy object for the current map style."}],"title":"MLNStyle","kind":"symbol","fragments":[{"text":"MLNStyle","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnstyle","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterStyleLayer":{"abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","isActive":true},{"type":"text","text":" is a style layer that renders georeferenced raster"},{"type":"text","text":" "},{"type":"text","text":"imagery on the map, especially raster tiles."}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","url":"\/documentation\/maplibre\/mlnrasterstylelayer","kind":"symbol","role":"symbol","fragments":[{"kind":"identifier","text":"MLNRasterStyleLayer"}],"title":"MLNRasterStyleLayer"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTileSourceOptionTileSize":{"type":"topic","title":"MLNTileSourceOptionTileSize","kind":"symbol","url":"\/documentation\/maplibre\/mlntilesourceoptiontilesize","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing a floating-point number that specifies the"},{"type":"text","text":" "},{"type":"text","text":"width and height (measured in points) at which the map displays each raster"},{"type":"text","text":" "},{"type":"text","text":"image tile when the map’s zoom level is an integer. The raster tile source"},{"type":"text","text":" "},{"type":"text","text":"scales its images up or down when the map’s zoom level falls between two"},{"type":"text","text":" "},{"type":"text","text":"integers."}],"fragments":[{"text":"MLNTileSourceOptionTileSize","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource":{"type":"topic","role":"symbol","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","isActive":true,"type":"reference"},{"text":" is a map content source that supplies raster image tiles","type":"text"},{"text":" ","type":"text"},{"text":"to be shown on the map. The location of and metadata about the tiles are","type":"text"},{"text":" ","type":"text"},{"text":"defined either by an option dictionary or by an external file that conforms to","type":"text"},{"text":" ","type":"text"},{"text":"the","type":"text"},{"text":" ","type":"text"},{"text":"TileJSON specification","type":"text"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"A raster tile source is added to an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true,"type":"reference"},{"text":" object along with one or more","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","isActive":true,"type":"reference"},{"text":" objects. Use a raster style layer to control the","type":"text"},{"text":" ","type":"text"},{"text":"appearance of content supplied by the raster tile source.","type":"text"}],"title":"MLNRasterTileSource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","url":"\/documentation\/maplibre\/mlnrastertilesource","fragments":[{"text":"MLNRasterTileSource","kind":"identifier"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","type":"topic","abstract":[{"text":"Powerful, free and ope