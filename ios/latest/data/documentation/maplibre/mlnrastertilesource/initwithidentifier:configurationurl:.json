niquely identifies the source in the style to","type":"text"},{"text":" ","type":"text"},{"text":"which it is added.","type":"text"}],"type":"paragraph"}],"name":"identifier"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A URL to a TileJSON configuration file describing the","type":"text"},{"text":" ","type":"text"},{"text":"source’s contents and other metadata.","type":"text"}]}],"name":"configurationURL"}]},{"kind":"content","content":[{"text":"Return Value","type":"heading","level":2,"anchor":"return-value"},{"type":"paragraph","inlineContent":[{"text":"An initialized raster tile source.","type":"text"}]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"After initializing and configuring the source, add it to a map view’s style"},{"type":"text","text":" "},{"type":"text","text":"using the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:"},{"type":"text","text":" method."}],"type":"paragraph"},{"inlineContent":[{"text":"The URL may be a full HTTP or HTTPS URL or canonical URL. The URL should","type":"text"},{"text":" ","type":"text"},{"text":"point to a JSON file that conforms to the","type":"text"},{"text":" ","type":"text"},{"text":"TileJSON specification","type":"text"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If a Mapbox URL is specified, this source uses a tile size of 256. For all","type":"text"},{"text":" ","type":"text"},{"text":"other tilesets, the default value is 512. (See the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize"},{"text":" documentation for more information about tile","type":"text"},{"text":" ","type":"text"},{"text":"sizes.) If you need to use a tile size other than the default, use the","type":"text"},{"text":" ","type":"text"},{"code":"-initWithIdentifier:configurationURL:tileSize:","type":"codeVoice"},{"text":" method.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol","type":"topic","title":"MapLibre","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTileSourceOptionTileSize":{"url":"\/documentation\/maplibre\/mlntilesourceoptiontilesize","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing a floating-point number that specifies the"},{"type":"text","text":" "},{"type":"text","text":"width and height (measured in points) at which the map displays each raster"},{"type":"text","text":" "},{"type":"text","text":"image tile when the map’s zoom level is an integer. The raster tile source"},{"type":"text","text":" "},{"type":"text","text":"scales its images up or down when the map’s zoom level falls between two"},{"type":"text","text":" "},{"type":"text","text":"integers."}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize","type":"topic","fragments":[{"kind":"identifier","text":"MLNTileSourceOptionTileSize"}],"title":"MLNTileSourceOptionTileSize","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","title":"MLNRasterTileSource","fragments":[{"kind":"identifier","text":"MLNRasterTileSource"}],"role":"symbol","url":"\/documentation\/maplibre\/mlnrastertilesource","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","type":