ionary or by an external file that conforms to","type":"text"},{"text":" ","type":"text"},{"text":"the","type":"text"},{"text":" ","type":"text"},{"text":"TileJSON specification","type":"text"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"A raster tile source is added to an ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference"},{"text":" object along with one or more","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","type":"reference"},{"text":" objects. Use a raster style layer to control the","type":"text"},{"text":" ","type":"text"},{"text":"appearance of content supplied by the raster tile source.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","title":"MLNRasterTileSource","type":"topic","fragments":[{"kind":"identifier","text":"MLNRasterTileSource"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource/initWithIdentifier:configurationURL:":{"url":"\/documentation\/maplibre\/mlnrastertilesource\/initwithidentifier:configurationurl:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"initWithIdentifier:configurationURL:"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource\/initWithIdentifier:configurationURL:","role":"symbol","title":"initWithIdentifier:configurationURL:","abstract":[{"text":"Returns a raster tile source initialized with an identifier and configuration","type":"text"},{"text":" ","type":"text"},{"text":"URL.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNTileSourceOptionTileSize":{"url":"\/documentation\/maplibre\/mlntilesourceoptiontilesize","role":"symbol","kind":"symbol","abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing a floating-point number that specifies the","type":"text"},{"text":" ","type":"text"},{"text":"width and height (measured in points) at which the map displays each raster","type":"text"},{"text":" ","type":"text"},{"text":"image tile when the map’s zoom level is an integer. The raster tile source","type":"text"},{"text":" ","type":"text"},{"text":"scales its images up or down when the map’s zoom level falls between two","type":"text"},{"text":" ","type":"text"},{"text":"integers.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize","title":"MLNTileSourceOptionTileSize","type":"topic","fragments":[{"kind":"identifier","text":"MLNTileSourceOptionTileSize"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterStyleLayer":{"url":"\/documentation\/maplibre\/mlnrasterstylelayer","role":"symbol","kind":"symbol","abstract":[{"text":"An ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","type":"reference"},{"text":" is a style layer that renders georeferenced raster","type":"text"},{"text":" ","type":"text"},{"text":"imagery on the map, especially raster tiles.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","title":"MLNRasterStyleLayer","type":"topic","fragments":[{"kind":"identifier","text":"MLNRasterStyleLayer"}]}}}