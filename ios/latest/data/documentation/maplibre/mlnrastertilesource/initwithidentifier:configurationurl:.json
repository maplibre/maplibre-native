yProject\/documentation\/MapLibre\/MLNRasterStyleLayer","isActive":true},{"type":"text","text":" objects. Use a raster style layer to control the"},{"type":"text","text":" "},{"type":"text","text":"appearance of content supplied by the raster tile source."}],"title":"MLNRasterTileSource","kind":"symbol","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/addSource:":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","title":"addSource:","role":"symbol","url":"\/documentation\/maplibre\/mlnstyle\/addsource:","type":"topic","navigatorTitle":[{"kind":"identifier","text":"addSource:"}],"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"addSource:"}],"abstract":[{"type":"text","text":"Adds a new source to the current style."}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterStyleLayer":{"fragments":[{"kind":"identifier","text":"MLNRasterStyleLayer"}],"title":"MLNRasterStyleLayer","kind":"symbol","abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","isActive":true},{"type":"text","text":" is a style layer that renders georeferenced raster"},{"type":"text","text":" "},{"type":"text","text":"imagery on the map, especially raster tiles."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","type":"topic","url":"\/documentation\/maplibre\/mlnrasterstylelayer","role":"symbol"}}}