","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"After initializing and configuring the source, add it to a map view’s style","type":"text"},{"text":" ","type":"text"},{"text":"using the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","type":"reference"},{"text":" method.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The URL may be a full HTTP or HTTPS URL or canonical URL. The URL should"},{"type":"text","text":" "},{"type":"text","text":"point to a JSON file that conforms to the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"If a Mapbox URL is specified, this source uses a tile size of 256. For all","type":"text"},{"text":" ","type":"text"},{"text":"other tilesets, the default value is 512. (See the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize","type":"reference","isActive":true},{"text":" documentation for more information about tile","type":"text"},{"text":" ","type":"text"},{"text":"sizes.) If you need to use a tile size other than the default, use the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"-initWithIdentifier:configurationURL:tileSize:"},{"text":" method.","type":"text"}],"type":"paragraph"}]}],"kind":"symbol","abstract":[{"text":"Returns a raster tile source initialized with an identifier and configuration","type":"text"},{"text":" ","type":"text"},{"text":"URL.","type":"text"}],"metadata":{"role":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:configurationURL:","kind":"identifier"}],"navigatorTitle":[{"text":"initWithIdentifier:configurationURL:","kind":"identifier"}],"roleHeading":"Instance Method","modules":[{"name":"MapLibre"}],"e