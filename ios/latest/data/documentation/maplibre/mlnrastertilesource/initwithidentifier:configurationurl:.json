ecifies the"},{"type":"text","text":" "},{"type":"text","text":"width and height (measured in points) at which the map displays each raster"},{"type":"text","text":" "},{"type":"text","text":"image tile when the map’s zoom level is an integer. The raster tile source"},{"type":"text","text":" "},{"type":"text","text":"scales its images up or down when the map’s zoom level falls between two"},{"type":"text","text":" "},{"type":"text","text":"integers."}],"url":"\/documentation\/maplibre\/mlntilesourceoptiontilesize","title":"MLNTileSourceOptionTileSize","fragments":[{"kind":"identifier","text":"MLNTileSourceOptionTileSize"}],"role":"symbol","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"type":"topic","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol","title":"MapLibre","url":"\/documentation\/maplibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/addSource:":{"kind":"symbol","abstract":[{"text":"Adds a new source to the current style.","type":"text"}],"type":"topic","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"addSource:"}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","url":"\/documentation\/maplibre\/mlnstyle\/addsource:","navigatorTitle":[{"kind":"identifier","text":"addSource:"}],"title":"addSource:"}}}