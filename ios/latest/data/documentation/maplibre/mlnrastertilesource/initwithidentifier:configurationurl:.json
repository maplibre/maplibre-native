{"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnrastertilesource\/initwithidentifier:configurationurl:"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource\/initWithIdentifier:configurationURL:","interfaceLanguage":"occ"},"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"- ("},{"kind":"keyword","text":"instancetype"},{"kind":"text","text":") "},{"kind":"identifier","text":"initWithIdentifier:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"NSString","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"identifier"},{"kind":"text","text":" "},{"kind":"identifier","text":"configurationURL:"},{"kind":"text","text":"("},{"text":"NSURL","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSURL"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"configurationURL"},{"kind":"text","text":";"}],"languages":["occ"]}],"kind":"declarations"},{"parameters":[{"name":"identifier","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A string that uniquely identifies the source in the style to"},{"type":"text","text":" "},{"type":"text","text":"which it is added."}]}]},{"name":"configurationURL","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A URL to a TileJSON configuration file describing the"},{"type":"text","text":" "},{"type":"text","text":"source’s contents and other metadata."}]}]}],"kind":"parameters"},{"content":[{"level":2,"text":"Return Value","type":"heading","anchor":"return-value"},{"inlineContent":[{"text":"An initialized raster tile source.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"After initializing and configuring the source, add it to a map view’s style"},{"type":"text","text":" "},{"type":"text","text":"using the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:"},{"type":"text","text":" method."}]},{"type":"paragraph","inlineContent":[{"text":"The URL may be a full HTTP or HTTPS URL or canonical URL. The URL should","type":"text"},{"text":" ","type":"text"},{"text":"point to a JSON file that conforms to the","type":"text"},{"text":" ","type":"text"},{"text":"TileJSON specification","type":"text"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If a Mapbox URL is specified, this source uses a tile size of 256. For all"},{"type":"text","text":" "},{"type":"text","text":"other tilesets, the default value is 512. (See the"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize","isActive":true},{"type":"text","text":" documentation for more information about tile"},{"type":"text","text":" "},{"type":"text","text":"sizes.) If you need to use a tile size other than the default, use the"},{"type":"text","text":" "},{"type":"codeVoice","code":"-initWithIdentifier:configurationURL:tileSize:"},{"type":"text","text":" method."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource"]]},"abstract":[{"text":"Returns a raster tile source initialized with an identifier and configuration","type":"text"},{"text":" ","type":"text"},{"text":"URL.","type":"text"}],"metadata":{"roleHeading":"Instance Method","fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:configurationURL:","kind":"identifier"}],"role":"symbol","title":"initWithIdentifier:configurationURL:","modules":[{"name":"MapLibre"}],"symbolKind":"method","navigatorTitle":[{"text":"initWithIdentifier:configurationURL:","kind":"identifier"}],"externalID":"c:objc(cs)MLNRasterTileSource(im)initWithIdentifier:configurationURL:"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource/initWithIdentifier:configurationURL:":{"type":"topic","abstract":[{"text":"Returns a raster tile source initialized with an identifier and configuration","type":"text"},{"text":" ","type":"text"},{"text":"URL.","type":"text"}],"title":"initWithIdentifier:configurationURL:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource\/initWithIdentifier:configurationURL:","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"initWithIdentifier:configurationURL:"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnrastertilesource\/initwithidentifier:configurationurl:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"initWithIdentifier:configurationURL:"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","url":"\/documentation\/maplibre","title":"MapLibre","role":"collection","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"fragments":[{"kind":"identifier","text":"MLNStyle"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","title":"MLNStyle","url":"\/documentation\/maplibre\/mlnstyle","kind":"symbol","type":"topic","role":"symbol","abstract":[{"text":"The proxy object for the current map style.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/addSource:":{"url":"\/documentation\/maplibre\/mlnstyle\/addsource:","title":"addSource:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","type":"topic","kind":"symbol","navigatorTitle":[{"text":"addSource:","kind":"identifier"}],"fragments":[{"text":"- ","kind":"text"},{"text":"addSource:","kind":"identifier"}],"role":"symbol","abstract":[{"text":"Adds a new source to the current style.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterStyleLayer":{"abstract":[{"text":"An ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer"},{"text":" is a style layer that renders georeferenced raster","type":"text"},{"text":" ","type":"text"},{"text":"imagery on the map, especially raster tiles.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","title":"MLNRasterStyleLayer","type":"topic","url":"\/documentation\/maplibre\/mlnrasterstylelayer","fragments":[{"text":"MLNRasterStyleLayer","kind":"identifier"}],"role":"symbol","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTileSourceOptionTileSize":{"kind":"symbol","type":"topic","fragments":[{"text":"MLNTileSourceOptionTileSize","kind":"identifier"}],"abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing a floating-point number that specifies the","type":"text"},{"text":" ","type":"text"},{"text":"width and height (measured in points) at which the map displays each raster","type":"text"},{"text":" ","type":"text"},{"text":"image tile when the map’s zoom level is an integer. The raster tile source","type":"text"},{"text":" ","type":"text"},{"text":"scales its images up or down when the map’s zoom level falls between two","type":"text"},{"text":" ","type":"text"},{"text":"integers.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize","url":"\/documentation\/maplibre\/mlntilesourceoptiontilesize","title":"MLNTileSourceOptionTileSize","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource":{"url":"\/documentation\/maplibre\/mlnrastertilesource","fragments":[{"text":"MLNRasterTileSource","kind":"identifier"}],"kind":"symbol","title":"MLNRasterTileSource","role":"symbol","type":"topic","abstract":[{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","type":"reference"},{"text":" is a map content source that supplies raster image tiles","type":"text"},{"text":" ","type":"text"},{"text":"to be shown on the map. The location of and metadata about the tiles are","type":"text"},{"text":" ","type":"text"},{"text":"defined either by an option dictionary or by an external file that conforms to","type":"text"},{"text":" ","type":"text"},{"text":"the","type":"text"},{"text":" ","type":"text"},{"text":"TileJSON specification","type":"text"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"A raster tile source is added to an ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"text":" object along with one or more","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer"},{"text":" objects. Use a raster style layer to control the","type":"text"},{"text":" ","type":"text"},{"text":"appearance of content supplied by the raster tile source.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource"}}}