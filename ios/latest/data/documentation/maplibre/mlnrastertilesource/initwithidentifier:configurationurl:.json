{"sections":[],"kind":"symbol","variants":[{"paths":["\/documentation\/maplibre\/mlnrastertilesource\/initwithidentifier:configurationurl:"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"Returns a raster tile source initialized with an identifier and configuration","type":"text"},{"text":" ","type":"text"},{"text":"URL.","type":"text"}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource\/initWithIdentifier:configurationURL:","interfaceLanguage":"occ"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"text","text":"- ("},{"kind":"keyword","text":"instancetype"},{"kind":"text","text":") "},{"kind":"identifier","text":"initWithIdentifier:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"NSString","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"identifier"},{"kind":"text","text":" "},{"kind":"identifier","text":"configurationURL:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"NSURL","preciseIdentifier":"c:objc(cs)NSURL"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"configurationURL"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"identifier","content":[{"inlineContent":[{"type":"text","text":"A string that uniquely identifies the source in the style to"},{"type":"text","text":" "},{"type":"text","text":"which it is added."}],"type":"paragraph"}]},{"name":"configurationURL","content":[{"inlineContent":[{"type":"text","text":"A URL to a TileJSON configuration file describing the"},{"type":"text","text":" "},{"type":"text","text":"source’s contents and other metadata."}],"type":"paragraph"}]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Return Value","anchor":"return-value"},{"inlineContent":[{"type":"text","text":"An initialized raster tile source."}],"type":"paragraph"}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"text":"After initializing and configuring the source, add it to a map view’s style","type":"text"},{"text":" ","type":"text"},{"text":"using the ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","isActive":true},{"text":" method.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The URL may be a full HTTP or HTTPS URL or canonical URL. The URL should"},{"type":"text","text":" "},{"type":"text","text":"point to a JSON file that conforms to the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"If a Mapbox URL is specified, this source uses a tile size of 256. For all","type":"text"},{"text":" ","type":"text"},{"text":"other tilesets, the default value is 512. (See the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize","type":"reference"},{"text":" documentation for more information about tile","type":"text"},{"text":" ","type":"text"},{"text":"sizes.) If you need to use a tile size other than the default, use the","type":"text"},{"text":" ","type":"text"},{"code":"-initWithIdentifier:configurationURL:tileSize:","type":"codeVoice"},{"text":" method.","type":"text"}],"type":"paragraph"}]}],"metadata":{"title":"initWithIdentifier:configurationURL:","navigatorTitle":[{"text":"initWithIdentifier:configurationURL:","kind":"identifier"}],"externalID":"c:objc(cs)MLNRasterTileSource(im)initWithIdentifier:configurationURL:","role":"symbol","modules":[{"name":"MapLibre"}],"roleHeading":"Instance Method","symbolKind":"method","fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:configurationURL:","kind":"identifier"}]},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/addSource:":{"type":"topic","abstract":[{"type":"text","text":"Adds a new source to the current style."}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnstyle\/addsource:","title":"addSource:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","navigatorTitle":[{"kind":"identifier","text":"addSource:"}],"role":"symbol","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"addSource:"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","url":"\/documentation\/maplibre","kind":"symbol","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic","title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource/initWithIdentifier:configurationURL:":{"title":"initWithIdentifier:configurationURL:","abstract":[{"text":"Returns a raster tile source initialized with an identifier and configuration","type":"text"},{"text":" ","type":"text"},{"text":"URL.","type":"text"}],"navigatorTitle":[{"text":"initWithIdentifier:configurationURL:","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnrastertilesource\/initwithidentifier:configurationurl:","role":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:configurationURL:","kind":"identifier"}],"type":"topic","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource\/initWithIdentifier:configurationURL:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterStyleLayer":{"abstract":[{"text":"An ","type":"text"},{"isActive":true,"type":"reference","identi