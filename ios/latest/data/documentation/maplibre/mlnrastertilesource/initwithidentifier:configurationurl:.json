ctive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer"},{"type":"text","text":" is a style layer that renders georeferenced raster"},{"type":"text","text":" "},{"type":"text","text":"imagery on the map, especially raster tiles."}],"role":"symbol","type":"topic","kind":"symbol","title":"MLNRasterStyleLayer","url":"\/documentation\/maplibre\/mlnrasterstylelayer","fragments":[{"kind":"identifier","text":"MLNRasterStyleLayer"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource/initWithIdentifier:configurationURL:":{"title":"initWithIdentifier:configurationURL:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource\/initWithIdentifier:configurationURL:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"initWithIdentifier:configurationURL:"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"initWithIdentifier:configurationURL:"}],"url":"\/documentation\/maplibre\/mlnrastertilesource\/initwithidentifier:configurationurl:","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Returns a raster tile source initialized with an identifier and configuration"},{"type":"text","text":" "},{"type":"text","text":"URL."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNTileSourceOptionTileSize":{"type":"topic","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize","role":"symbol","abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"text":" object containing a floating-point number that specifies the","type":"text"},{"text":" ","type":"text"},{"text":"width and height (measured in points) at which the map displays each raster","type":"text"},{"text":" ","type":"text"},{"text":"image tile when the map’s zoom level is an integer. The raster tile source","type":"text"},{"text":" ","type":"text"},{"text":"scales its images up or down when the map’s zoom level falls between two","type":"text"},{"text":" ","type":"text"},{"text":"integers.","type":"text"}],"title":"MLNTileSourceOptionTileSize","url":"\/documentation\/maplibre\/mlntilesourceoptiontilesize","fragments":[{"kind":"identifier","text":"MLNTileSourceOptionTileSize"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"type":"topic","role":"symbol","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","abstract":[{"type":"text","text":"The proxy object for the current map style."}],"fragments":[{"kind":"identifier","text":"MLNStyle"}],"url":"\/documentation\/maplibre\/mlnstyle","title":"MLNStyle"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/addSource:":{"navigatorTitle":[{"text":"addSource:","kind":"identifier"}],"title":"addSource:","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","url":"\/documentation\/maplibre\/mlnstyle\/addsource:","abstract":[{"type":"text","text":"Adds a new source to the current style."}],"type":"topic","role":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"addSource:","kind":"identifier"}]}}}