string that uniquely identifies the source in the style to"},{"type":"text","text":" "},{"type":"text","text":"which it is added."}]}],"name":"identifier"},{"content":[{"inlineContent":[{"text":"A URL to a TileJSON configuration file describing the","type":"text"},{"text":" ","type":"text"},{"text":"source’s contents and other metadata.","type":"text"}],"type":"paragraph"}],"name":"configurationURL"}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","text":"Return Value","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"An initialized raster tile source."}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"After initializing and configuring the source, add it to a map view’s style","type":"text"},{"text":" ","type":"text"},{"text":"using the ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","isActive":true,"type":"reference"},{"text":" method.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The URL may be a full HTTP or HTTPS URL or canonical URL. The URL should"},{"type":"text","text":" "},{"type":"text","text":"point to a JSON file that conforms to the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If a Mapbox URL is specified, this source uses a tile size of 256. For all"},{"type":"text","text":" "},{"type":"text","text":"other tilesets, the default value is 512. (See the"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize","type":"reference","isActive":true},{"type":"text","text":" documentation for more information about tile"},{"type":"text","text":" "},{"type":"text","text":"sizes.) If you need to use a tile size other than the default, use the"},{"type":"text","text":" "},{"type":"codeVoice","code":"-initWithIdentifier:configurationURL:tileSize:"},{"type":"text","text":" method."}]}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"fragments":[{"kind":"identifier","text":"MLNStyle"}],"url":"\/documentation\/maplibre\/mlnstyle","abstract":[{"text":"The proxy object for the current map style.","type":"text"}],"title":"MLNStyle","role":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/addSource:":{"url":"\/documentation\/maplibre\/mlnstyle\/addsource:","abstract":[{"text":"Adds a new source to the current style.","type":"text"}],"title":"addSource:","kind":"symbol","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"addSource:"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"addSource:"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","title":"MapLibre","kind":"symbol","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"url":"\/documentation\/maplibre","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterStyleLayer":{"role":"symbol","url":"\/documentation\/maplibre\/mlnrasterstylelayer","kind":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","abstract":[{"text":"An ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","isActive":true},{"text":" is a style layer that renders georeferenced raster","type":"text"},{"text":" ","type":"text"},{"text":"imagery on the map, especially raster tiles.","type":"text"}],"fragments":[{"kind":"identifier","text":"MLNRasterStyleLayer"}],"title":"MLNRasterStyleLayer"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource":{"kind":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnrastertilesource","title":"MLNRasterTileSource","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","fragments":[{"kind":"identifier","text":"MLNRasterTileSource"}],"abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","type":"reference","isActive":true},{"type":"text","text":" is a map content source that supplies raster image tiles"},{"type":"text","text":" "},{"type":"text","text":"to be shown on the map. The location of and metadata about the tiles are"},{"type":"text","text":" "},{"type":"text","text":"defined either by an option dictionary or by an external file that conforms to"},{"type":"text","text":" "},{"type":"text","text":"the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A raster tile source is added to an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","type":"reference","isActive":true},{"type":"text","text":" objects. Use a raster style layer to control the"},{"type":"text","text":" "},{"type":"text","text":"appearance of content supplied by the raster tile source."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource/initWithIdentifier:configurationURL:":{"title":"initWithIdentifier:configurationURL:","kind":"symbol","abstract":[{"text":"Returns a raster tile source initialized with an identifier and configuration","type":"text"},{"text":" ","type":"text"},{"text":"URL.","type":"text"}],"fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:configurationURL:","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource\/initWithIdentifier:configurationURL:","role":"symbol","navigatorTitle":[{"text":"initWithIdentifier:configurationURL:","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnrastertilesource\/initwithidentifier:configurationurl:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTileSourceOptionTileSize":{"kind":"symbol","title":"MLNTileSourceOptionTileSize","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize","role":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlntilesourceoptiontilesize","abstract":[{"text":"An ","type":"text"},{"code":"NSNumber","type":"codeVoice"},{"type":"text","text":" object containing a floating-point number that specifies the"},{"type":"text","text":" "},{"type":"text","text":"width and height (measured in points) at which the map displays each raster"},{"type":"text","text":" "},{"type":"text","text":"image tile when the map’s zoom level is an integer. The raster tile source"},{"type":"text","text":" "},{"type":"text","text":"scales its images up or down when the map’s zoom level falls between two"},{"type":"text","text":" "},{"type":"text","text":"integers."}],"fragments":[{"text":"MLNTileSourceOptionTileSize","kind":"identifier"}]}}}