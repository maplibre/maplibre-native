"},{"text":"tileSize:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:@T@CGFloat","text":"CGFloat","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"tileSize","kind":"internalParam"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A string that uniquely identifies the source in the style to"},{"type":"text","text":" "},{"type":"text","text":"which it is added."}]}],"name":"identifier"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A URL to a TileJSON configuration file describing the"},{"type":"text","text":" "},{"type":"text","text":"source’s contents and other metadata."}]}],"name":"configurationURL"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The width and height (measured in points) of each tiled image"},{"type":"text","text":" "},{"type":"text","text":"in the raster tile source. See the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize"},{"type":"text","text":" "},{"type":"text","text":"documentation for details."}]}],"name":"tileSize"}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"text":"Return Value","type":"heading","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An initialized raster tile source."}]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"After initializing and configuring the source, add it to a map view’s style"},{"type":"text","text":" "},{"type":"text","text":"using the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:"},{"type":"text","text":" method."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The URL may be a full HTTP or HTTPS URL or, canonical URL. The URL should"},{"type":"text","text":" "},{"type":"text","text":"point to a JSON file that conforms to the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."}]}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNTileSourceOptionTileSize":{"type":"topic","fragments":[{"text":"MLNTileSourceOptionTileSize","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize","kind":"symbol","title":"MLNTileSourceOptionTileSize","url":"\/documentation\/maplibre\/mlntilesourceoptiontilesize","abstract":[{"type":"text","text":"An "},{"code":"NSNumber","type":"codeVoice"},{"type":"text","text":" object containing a floating-point number that specifies the"},{"type":"text","text":" "},{"type":"text","text":"width and height (measured in points) at which the map displays each raster"},{"type":"text","text":" "},{"type":"text","text":"image tile when the map’s zoom level is an integer. The raster tile source"},{"type":"text","text":" "},{"type":"text","text":"scales its images up or down when the map’s zoom level falls between two"},{"type":"text","text":" "},{"type":"text","text":"integers."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterStyleLayer":{"url":"\/documentation\/maplibre\/mlnrasterstylelayer","role":"symbol","fragments":[{"text":"MLNRasterStyleLayer","kind":"identifier"}],"title":"MLNRasterStyleLayer","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","kind":"symbol","abstract":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer"},{"type":"text","text":" is a style layer that renders georeferenced raster"},{"type":"text","text":" "},{"type":"text","text":"imagery on the map, especially raster tiles."}]},"doc://org.swift.MyProj