":"text"},{"text":"point to a JSON file that conforms to the","type":"text"},{"text":" ","type":"text"},{"text":"TileJSON specification","type":"text"},{"text":".","type":"text"}]}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","kind":"symbol","role":"collection","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/addSource:":{"navigatorTitle":[{"kind":"identifier","text":"addSource:"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"addSource:"}],"role":"symbol","url":"\/documentation\/maplibre\/mlnstyle\/addsource:","title":"addSource:","type":"topic","abstract":[{"type":"text","text":"Adds a new source to the current style."}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","abstract":[{"text":"The proxy object for the current map style.","type":"text"}],"title":"MLNStyle","url":"\/documentation\/maplibre\/mlnstyle","type":"topic","fragments":[{"kind":"identifier","text":"MLNStyle"}],"kind":"symbol","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTileSourceOptionTileSize":{"type":"topic","kind":"symbol","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing a floating-point number that specifies the"},{"type":"text","text":" "},{"type":"text","text":"width and height (measured in points) at which the map displays each raster"},{"type":"text","text":" "},{"type":"text","text":"image tile when the map’s zoom level is an integer. The raster tile source"},{"type":"text","text":" "},{"type":"text","text":"scales its images up or down when the map’s zoom level falls between two"},{"type":"text","text":" "},{"type":"text","text":"integers."}],"fragments":[{"text":"MLNTileSourceOptionTileSize","kind":"identifier"}],"title":"MLNTileSourceOptionTileSize","url":"\/documentation\/maplibre\/mlntilesourceoptiontilesize","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource/initWithIdentifier:configurationURL:tileSize:":{"url":"\/documentation\/maplibre\/mlnrastertilesource\/initwithidentifier:configurationurl:tilesize:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource\/initWithIdentifier:configurationURL:tileSize:","title":"initWithIdentifier:configurationURL:tileSize:","type":"topic","abstract":[{"type":"text","text":"Returns a raster tile source initialized with an identifier, configuration URL,"},{"type":"text","text":" "},{"type":"text","text":"and tile size."}],"role":"symbol","navigatorTitle":[{"text":"initWithIdentifier:configurationURL:tileSize:","kind":"identifier"}],"kind":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:configurationURL:tileSize:","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterStyleLayer":{"url":"\/documentation\/maplibre\/mlnrasterstylelayer","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","fragments":[{"text":"MLNRasterStyleLayer","kind":"identifier"}],"abstract":[{"text":"An ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer"},{"text":" is a style layer that renders georeferenced raster","type":"text"},{"text":" ","type":"text"},{"text":"imagery on the map, especially raster tiles.","type":"text"}],"kind":"symbol","title":"MLNRasterStyleLayer","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource":{"abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","isActive":true,"type":"reference"},{"text":" is a map content source that supplies raster image tiles","type":"text"},{"text":" ","type":"text"},{"text":"to be shown on the map. The location of and metadata about the tiles are","type":"text"},{"text":" ","type":"text"},{"text":"defined either by an option dictionary or by an external file that conforms to","type":"text"},{"text":" ","type":"text"},{"text":"the","type":"text"},{"text":" ","type":"text"},{"text":"TileJSON specification","type":"text"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"A raster tile source is added to an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true,"type":"reference"},{"text":" object along with one or more","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","isActive":true,"type":"reference"},{"text":" objects. Use a raster style layer to control the","type":"text"},{"text":" ","type":"text"},{"text":"appearance of content supplied by the raster tile source.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","role":"symbol","kind":"symbol","url":"\/documentation\/maplibre\/mlnrastertilesource","title":"MLNRasterTileSource","type":"topic","fragments":[{"text":"MLNRasterTileSource","kind":"identifier"}]}}}