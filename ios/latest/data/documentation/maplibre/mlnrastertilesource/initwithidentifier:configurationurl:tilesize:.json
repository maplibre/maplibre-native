n external file that conforms to","type":"text"},{"text":" ","type":"text"},{"text":"the","type":"text"},{"text":" ","type":"text"},{"text":"TileJSON specification","type":"text"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"A raster tile source is added to an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true,"type":"reference"},{"text":" object along with one or more","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer","isActive":true,"type":"reference"},{"text":" objects. Use a raster style layer to control the","type":"text"},{"text":" ","type":"text"},{"text":"appearance of content supplied by the raster tile source.","type":"text"}],"type":"topic","kind":"symbol","url":"\/documentation\/maplibre\/mlnrastertilesource","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource","fragments":[{"text":"MLNRasterTileSource","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource/initWithIdentifier:configurationURL:tileSize:":{"kind":"symbol","url":"\/documentation\/maplibre\/mlnrastertilesource\/initwithidentifier:configurationurl:tilesize:","abstract":[{"type":"text","text":"Returns a raster tile source initialized with an identifier, configuration URL,"},{"type":"text","text":" "},{"type":"text","text":"and tile size."}],"role":"symbol","title":"initWithIdentifier:configurationURL:tileSize:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource\/initWithIdentifier:configurationURL:tileSize:","type":"topic","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"initWithIdentifier:configurationURL:tileSize:"}],"navigatorTitle":[{"kind":"identifier","text":"initWithIdentifier:configurationURL:tileSize:"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterStyleLayer":{"titl