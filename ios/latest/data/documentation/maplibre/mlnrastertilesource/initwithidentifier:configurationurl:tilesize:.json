":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","title":"MLNStyle","fragments":[{"text":"MLNStyle","kind":"identifier"}],"type":"topic","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/addSource:":{"url":"\/documentation\/maplibre\/mlnstyle\/addsource:","abstract":[{"type":"text","text":"Adds a new source to the current style."}],"role":"symbol","kind":"symbol","title":"addSource:","navigatorTitle":[{"text":"addSource:","kind":"identifier"}],"type":"topic","fragments":[{"text":"- ","kind":"text"},{"text":"addSource:","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource/initWithIdentifier:configurationURL:tileSize:":{"role":"symbol","title":"initWithIdentifier:configurationURL:tileSize:","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource\/initWithIdentifier:configurationURL:tileSize:","navigatorTitle":[{"kind":"identifier","text":"initWithIdentifier:configurationURL:tileSize:"}],"abstract":[{"type":"text","text":"Returns a raster tile source initialized with an identifier, configuration URL,"},{"type":"text","text":" "},{"type":"text","text":"and tile size."}],"url":"\/documentation\/maplibre\/mlnrastertilesource\/initwithidentifier:configurationurl:tilesize:","type":"topic","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"initWithIdentifier:configurationURL:tileSize:"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"url":"\/documentation\/maplibre","role":"collection","title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTileSourceOptionTileSize