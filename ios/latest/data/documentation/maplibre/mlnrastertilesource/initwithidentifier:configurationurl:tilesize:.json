Libre/MLNRasterTileSource/initWithIdentifier:configurationURL:tileSize:":{"type":"topic","fragments":[{"text":"- ","kind":"text"},{"text":"initWithIdentifier:configurationURL:tileSize:","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource\/initWithIdentifier:configurationURL:tileSize:","kind":"symbol","title":"initWithIdentifier:configurationURL:tileSize:","url":"\/documentation\/maplibre\/mlnrastertilesource\/initwithidentifier:configurationurl:tilesize:","abstract":[{"text":"Returns a raster tile source initialized with an identifier, configuration URL,","type":"text"},{"text":" ","type":"text"},{"text":"and tile size.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/addSource:":{"url":"\/documentation\/maplibre\/mlnstyle\/addsource:","title":"addSource:","fragments":[{"text":"- ","kind":"text"},{"text":"addSource:","kind":"identifier"}],"kind":"symbol","abstract":[{"text":"Adds a new source to the current style.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:","type":"topic","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","url":"\/documentation\/maplibre","kind":"symbol","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic"}}}