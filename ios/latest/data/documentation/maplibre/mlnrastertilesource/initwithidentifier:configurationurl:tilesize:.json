 "},{"type":"text","text":"defined either by an option dictionary or by an external file that conforms to"},{"type":"text","text":" "},{"type":"text","text":"the"},{"type":"text","text":" "},{"type":"text","text":"TileJSON specification"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A raster tile source is added to an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object along with one or more"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterStyleLayer"},{"type":"text","text":" objects. Use a raster style layer to control the"},{"type":"text","text":" "},{"type":"text","text":"appearance of content supplied by the raster tile source."}],"type":"topic","title":"MLNRasterTileSource","role":"symbol","fragments":[{"kind":"identifier","text":"MLNRasterTileSource"}],"url":"\/documentation\/maplibre\/mlnrastertilesource","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNRasterTileSource/initWithIdentifier:configurationURL:tileSize:":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"initWithIdentifier:configurationURL:tileSize:"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNRasterTileSource\/initWithIdentifier:configurationURL:tileSize:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"initWithIdentifier:configurationURL:tileSize:"}],"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Returns a raster tile source initialized with an identifier, configuration URL,"},{"type":"text","text":" "},{"type":"text","text":"and tile size."}],"title":"initWithIdentifier:configurationURL:tileSize:","url":"\/documentation\/maplibre\/mlnrastertilesource\/initwithidentifier:configurationurl:tilesize:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTileSourceOptionTileSize