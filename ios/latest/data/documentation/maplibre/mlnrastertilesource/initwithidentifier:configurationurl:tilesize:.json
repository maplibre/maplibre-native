pe":"text","text":"imagery on the map, especially raster tiles."}],"kind":"symbol","title":"MLNRasterStyleLayer"},"doc://org.swift.MyProject/documentation/MapLibre/MLNTileSourceOptionTileSize":{"url":"\/documentation\/maplibre\/mlntilesourceoptiontilesize","role":"symbol","type":"topic","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSNumber"},{"type":"text","text":" object containing a floating-point number that specifies the"},{"type":"text","text":" "},{"type":"text","text":"width and height (measured in points) at which the map displays each raster"},{"type":"text","text":" "},{"type":"text","text":"image tile when the map’s zoom level is an integer. The raster tile source"},{"type":"text","text":" "},{"type":"text","text":"scales its images up or down when the map’s zoom level falls between two"},{"type":"text","text":" "},{"type":"text","text":"integers."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNTileSourceOptionTileSize","kind":"symbol","title":"MLNTileSourceOptionTileSize","fragments":[{"text":"MLNTileSourceOptionTileSize","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle/addSource:":{"role":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"addSource:","kind":"identifier"}],"title":"addSource:","kind":"symbol","abstract":[{"type":"text","text":"Adds a new source to the current style."}],"navigatorTitle":[{"text":"addSource:","kind":"identifier"}],"type":"topic","url":"\/documentation\/maplibre\/mlnstyle\/addsource:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle\/addSource:"}}}