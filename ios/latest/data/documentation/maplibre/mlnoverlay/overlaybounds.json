{"metadata":{"title":"overlayBounds","role":"symbol","fragments":[{"kind":"identifier","text":"overlayBounds"}],"navigatorTitle":[{"kind":"identifier","text":"overlayBounds"}],"externalID":"c:objc(pl)MLNOverlay(py)overlayBounds","roleHeading":"Instance Property","symbolKind":"property","modules":[{"name":"MapLibre"}]},"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"readonly","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:@S@MLNCoordinateBounds","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateBounds","text":"MLNCoordinateBounds","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"overlayBounds","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"This property contains the smallest rectangle that completely encompasses the"},{"type":"text","text":" "},{"type":"text","text":"overlay. Implementers of this protocol must set this area when implementing"},{"type":"text","text":" "},{"type":"text","text":"their overlay class, and after setting it, you must not change it."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If this overlay spans the antimeridian, its bounds may extend west of −180 degrees"},{"type":"text","text":" "},{"type":"text","text":"longitude or east of 180 degrees longitude. For example, an overlay covering the"},{"type":"text","text":" "},{"type":"text","text":"Pacific Ocean from Tokyo to San Francisco might have a bounds extending"},{"type":"text","text":" "},{"type":"text","text":"from (35.68476, −220.24257) to (37.78428, −122.41310)."}],"type":"paragraph"}]}],"abstr