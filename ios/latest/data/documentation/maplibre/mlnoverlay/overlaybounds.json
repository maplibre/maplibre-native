{"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay\/overlayBounds","interfaceLanguage":"occ"},"variants":[{"paths":["\/documentation\/maplibre\/mlnoverlay\/overlaybounds"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay"]]},"sections":[],"metadata":{"modules":[{"name":"MapLibre"}],"role":"symbol","roleHeading":"Instance Property","navigatorTitle":[{"text":"overlayBounds","kind":"identifier"}],"title":"overlayBounds","fragments":[{"text":"overlayBounds","kind":"identifier"}],"symbolKind":"property","externalID":"c:objc(pl)MLNOverlay(py)overlayBounds"},"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"readonly","kind":"keyword"},{"text":") ","kind":"text"},{"text":"MLNCoordinateBounds","kind":"typeIdentifier","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateBounds","preciseIdentifier":"c:@S@MLNCoordinateBounds"},{"text":" ","kind":"text"},{"text":"overlayBounds","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"This property contains the smallest rectangle that completely encompasses the","type":"text"},{"text":" ","type":"text"},{"text":"overlay. Implementers of this protocol must set this area when implementing","type":"text"},{"text":" ","type":"text"},{"text":"their overlay class, and after setting it, you must not change it.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If this overlay spans the antimeridian, its bounds may extend west of −180 degrees"},{"type":"text","text":" "},{"type":"text","text":"longitude or east of 180 degrees longitude. For example, an overlay covering the"},{"type":"text","text":" "},{"type":"text","text":"Pacific Ocean from Tokyo to San Francisco might have a bounds extending"},{"type":"text","text":" "},{"type":"text","text":"from (35.68476, −220.24257) to (37.78428, −122.41310)."}]}]}],"abstract":[{"text":"The cooordinate rectangle that encompasses the overlay. (required) (read-only)","type":"text"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOverlay":{"abstract":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay","isActive":true},{"text":" protocol defines a specific type of annotation that represents","type":"text"},{"text":" ","type":"text"},{"text":"both a point and an area on a map. Overlay objects are essentially data objects","type":"text"},{"text":" ","type":"text"},{"text":"that contain the geographic data needed to represent the map area. Overlays can","type":"text"},{"text":" ","type":"text"},{"text":"take the form of a polyline or polygon.","type":"text"}],"role":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnoverlay","fragments":[{"text":"MLNOverlay","kind":"identifier"}],"kind":"symbol","title":"MLNOverlay","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOverlay/overlayBounds":{"fragments":[{"kind":"identifier","text":"overlayBounds"}],"url":"\/documentation\/maplibre\/mlnoverlay\/overlaybounds","kind":"symbol","abstract":[{"type":"text","text":"The cooordinate rectangle that encompasses the overlay. (required) (read-only)"}],"title":"overlayBounds","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay\/overlayBounds","role":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"kind":"symbol","title":"MapLibre","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNCoordinateBounds":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateBounds","title":"MLNCoordinateBounds","fragments":[{"kind":"identifier","text":"MLNCoordinateBounds"}],"type":"topic","url":"\/documentation\/maplibre\/mlncoordinatebounds","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"A rectangular area as measured on a two-dimensional map projection."}]}}}