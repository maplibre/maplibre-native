,"fragments":[{"text":"MLNCoordinateBounds","kind":"identifier"}],"abstract":[{"text":"A rectangular area as measured on a two-dimensional map projection.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateBounds"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOverlay/overlayBounds":{"title":"overlayBounds","fragments":[{"text":"overlayBounds","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnoverlay\/overlaybounds","type":"topic","abstract":[{"type":"text","text":"The cooordinate rectangle that encompasses the overlay. (required) (read-only)"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay\/overlayBounds","role":"symbol"}}}