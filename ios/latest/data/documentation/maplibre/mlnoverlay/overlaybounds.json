","type":"text"},{"text":"take the form of a polyline or polygon.","type":"text"}],"url":"\/documentation\/maplibre\/mlnoverlay","role":"symbol","kind":"symbol","title":"MLNOverlay","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOverlay/overlayBounds":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay\/overlayBounds","url":"\/documentation\/maplibre\/mlnoverlay\/overlaybounds","role":"symbol","kind":"symbol","fragments":[{"text":"overlayBounds","kind":"identifier"}],"title":"overlayBounds","abstract":[{"type":"text","text":"The cooordinate rectangle that encompasses the overlay. (required) (read-only)"}]}}}