{"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"readonly","kind":"keyword"},{"text":") ","kind":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateBounds","preciseIdentifier":"c:@S@MLNCoordinateBounds","text":"MLNCoordinateBounds","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"overlayBounds","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property contains the smallest rectangle that completely encompasses the"},{"type":"text","text":" "},{"type":"text","text":"overlay. Implementers of this protocol must set this area when implementing"},{"type":"text","text":" "},{"type":"text","text":"their overlay class, and after setting it, you must not change it."}]},{"type":"paragraph","inlineContent":[{"text":"If this overlay spans the antimeridian, its bounds may extend west of −180 degrees","type":"text"},{"text":" ","type":"text"},{"text":"longitude or east of 180 degrees longitude. For example, an overlay covering the","type":"text"},{"text":" ","type":"text"},{"text":"Pacific Ocean from Tokyo to San Francisco might have a bounds extending","type":"text"},{"text":" ","type":"text"},{"text":"from (35.68476, −220.24257) to (37.78428, −122.41310).","type":"text"}]}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay\/overlayBounds"},"sections":[],"metadata":{"fragments":[{"text":"overlayBounds","kind":"identifier"}],"roleHeading":"Instance Property","role":"symbol","modules":[{"name":"MapLibre"}],"externalID":"c:objc(pl)MLNOverlay(py)overlayBounds","symbolKind":"property","title":"overlayBounds","navigatorTitle":[{"text":"overlayBounds","kind":"identifier"}]},"kind":"symbol","variants":[{"paths":["\/documentation\/maplibre\/mlnoverlay\/overlaybounds"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay"]]},"abstract":[{"text":"The cooordinate rectangle that encompasses the overlay. (required) (read-only)","type":"text"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOverlay":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay","role":"symbol","type":"topic","title":"MLNOverlay","fragments":[{"text":"MLNOverlay","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnoverlay","kind":"symbol","abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay","isActive":true},{"type":"text","text":" protocol defines a specific type of annotation that represents"},{"type":"text","text":" "},{"type":"text","text":"both a point and an area on a map. Overlay objects are essentially data objects"},{"type":"text","text":" "},{"type":"text","text":"that contain the geographic data needed to represent the map area. Overlays can"},{"type":"text","text":" "},{"type":"text","text":"take the form of a polyline or polygon."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNCoordinateBounds":{"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateBounds","fragments":[{"text":"MLNCoordinateBounds","kind":"identifier"}],"abstract":[{"type":"text","text":"A rectangular area as measured on a two-dimensional map projection."}],"kind":"symbol","type":"topic","title":"MLNCoordinateBounds","url":"\/documentation\/maplibre\/mlncoordinatebounds"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOverlay/overlayBounds":{"fragments":[{"text":"overlayBounds","kind":"identifier"}],"type":"topic","kind":"symbol","url":"\/documentation\/maplibre\/mlnoverlay\/overlaybounds","title":"overlayBounds","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay\/overlayBounds","role":"symbol","abstract":[{"type":"text","text":"The cooordinate rectangle that encompasses the overlay. (required) (read-only)"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","type":"topic","url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"title":"MapLibre"}}}