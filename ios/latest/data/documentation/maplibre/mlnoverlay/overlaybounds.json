{"abstract":[{"type":"text","text":"The cooordinate rectangle that encompasses the overlay. (required) (read-only)"}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"readonly","kind":"keyword"},{"text":") ","kind":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateBounds","preciseIdentifier":"c:@S@MLNCoordinateBounds","text":"MLNCoordinateBounds","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"overlayBounds","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"This property contains the smallest rectangle that completely encompasses the","type":"text"},{"text":" ","type":"text"},{"text":"overlay. Implementers of this protocol must set this area when implementing","type":"text"},{"text":" ","type":"text"},{"text":"their overlay class, and after setting it, you must not change it.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If this overlay spans the antimeridian, its bounds may extend west of −180 degrees"},{"type":"text","text":" "},{"type":"text","text":"longitude or east of 180 degrees longitude. For example, an overlay covering the"},{"type":"text","text":" "},{"type":"text","text":"Pacific Ocean from Tokyo to San Francisco might have a bounds extending"},{"type":"text","text":" "},{"type":"text","text":"from (35.68476, −220.24257) to (37.78428, −122.41310)."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","metadata":{"modules":[{"name":"MapLibre"}],"role":"symbol","symbolKind":"property","navigatorTitle":[{"text":"overlayBounds","kind":"identifier"}],"title":"overlayBounds","roleHeading":"Instance Property","fragments":[{"text":"overlayBounds","kind":"identifier"}],"externalID":"c:objc(pl)MLNOverlay(py)overlayBounds"},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay\/overlayBounds"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnoverlay\/overlaybounds"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNCoordinateBounds":{"type":"topic","fragments":[{"text":"MLNCoordinateBounds","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateBounds","title":"MLNCoordinateBounds","abstract":[{"type":"text","text":"A rectangular area as measured on a two-dimensional map projection."}],"kind":"symbol","url":"\/documentation\/maplibre\/mlncoordinatebounds","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOverlay/overlayBounds":{"url":"\/documentation\/maplibre\/mlnoverlay\/overlaybounds","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay\/overlayBounds","type":"topic","role":"symbol","fragments":[{"text":"overlayBounds","kind":"identifier"}],"kind":"symbol","title":"overlayBounds","abstract":[{"text":"The cooordinate rectangle that encompasses the overlay. (required) (read-only)","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","role":"collection","title":"MapLibre","url":"\/documentation\/maplibre","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOverlay":{"fragments":[{"kind":"identifier","text":"MLNOverlay"}],"title":"MLNOverlay","abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay","isActive":true,"type":"reference"},{"type":"text","text":" protocol defines a specific type of annotation that represents"},{"type":"text","text":" "},{"type":"text","text":"both a point and an area on a map. Overlay objects are essentially data objects"},{"type":"text","text":" "},{"type":"text","text":"that contain the geographic data needed to represent the map area. Overlays can"},{"type":"text","text":" "},{"type":"text","text":"take the form of a polyline or polygon."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay","kind":"symbol","type":"topic","role":"symbol","url":"\/documentation\/maplibre\/mlnoverlay"}}}