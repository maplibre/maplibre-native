{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"The cooordinate rectangle that encompasses the overlay. (required) (read-only)"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnoverlay\/overlaybounds"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"readonly","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:@S@MLNCoordinateBounds","text":"MLNCoordinateBounds","kind":"typeIdentifier","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateBounds"},{"text":" ","kind":"text"},{"text":"overlayBounds","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"This property contains the smallest rectangle that completely encompasses the","type":"text"},{"text":" ","type":"text"},{"text":"overlay. Implementers of this protocol must set this area when implementing","type":"text"},{"text":" ","type":"text"},{"text":"their overlay class, and after setting it, you must not change it.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If this overlay spans the antimeridian, its bounds may extend west of −180 degrees"},{"type":"text","text":" "},{"type":"text","text":"longitude or east of 180 degrees longitude. For example, an overlay covering the"},{"type":"text","text":" "},{"type":"text","text":"Pacific Ocean from Tokyo to San Francisco might have a bounds extending"},{"type":"text","text":" "},{"type":"text","text":"from (35.68476, −220.24257) to (37.78428, −122.41310)."}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay\/overlayBounds","interfaceLanguage":"occ"},"kind":"symbol","sections":[],"metadata":{"title":"overlayBounds","externalID":"c:objc(pl)MLNOverlay(py)overlayBounds","symbolKind":"property","roleHeading":"Instance Property","role":"symbol","fragments":[{"kind":"identifier","text":"overlayBounds"}],"navigatorTitle":[{"kind":"identifier","text":"overlayBounds"}],"modules":[{"name":"MapLibre"}]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOverlay":{"type":"topic","url":"\/documentation\/maplibre\/mlnoverlay","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay","title":"MLNOverlay","fragments":[{"text":"MLNOverlay","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay","type":"reference"},{"type":"text","text":" protocol defines a specific type of annotation that represents"},{"type":"text","text":" "},{"type":"text","text":"both a point and an area on a map. Overlay objects are essentially data objects"},{"type":"text","text":" "},{"type":"text","text":"that contain the geographic data needed to represent the map area. Overlays can"},{"type":"text","text":" "},{"type":"text","text":"take the form of a polyline or polygon."}]},"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol","type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"title":"MapLibre","url":"\/documentation\/maplibre","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNCoordinateBounds":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateBounds","kind":"symbol","url":"\/documentation\/maplibre\/mlncoordinatebounds","type":"topic","abstract":[{"text":"A rectangular area as measured on a two-dimensional map projection.","type":"text"}],"role":"symbol","title":"MLNCoordinateBounds","fragments":[{"kind":"identifier","text":"MLNCoordinateBounds"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOverlay/overlayBounds":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay\/overlayBounds","type":"topic","role":"symbol","fragments":[{"text":"overlayBounds","kind":"identifier"}],"abstract":[{"text":"The cooordinate rectangle that encompasses the overlay. (required) (read-only)","type":"text"}],"title":"overlayBounds","kind":"symbol","url":"\/documentation\/maplibre\/mlnoverlay\/overlaybounds"}}}