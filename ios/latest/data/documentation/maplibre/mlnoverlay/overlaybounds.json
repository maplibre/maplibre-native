{"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay\/overlayBounds","interfaceLanguage":"occ"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnoverlay\/overlaybounds"]}],"abstract":[{"text":"The cooordinate rectangle that encompasses the overlay. (required) (read-only)","type":"text"}],"metadata":{"roleHeading":"Instance Property","externalID":"c:objc(pl)MLNOverlay(py)overlayBounds","symbolKind":"property","title":"overlayBounds","fragments":[{"kind":"identifier","text":"overlayBounds"}],"navigatorTitle":[{"text":"overlayBounds","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"role":"symbol"},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"readonly","kind":"keyword"},{"text":") ","kind":"text"},{"text":"MLNCoordinateBounds","kind":"typeIdentifier","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateBounds","preciseIdentifier":"c:@S@MLNCoordinateBounds"},{"text":" ","kind":"text"},{"text":"overlayBounds","kind":"identifier"},{"text":";","kind":"text"}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"This property contains the smallest rectangle that completely encompasses the","type":"text"},{"text":" ","type":"text"},{"text":"overlay. Implementers of this protocol must set this area when implementing","type":"text"},{"text":" ","type":"text"},{"text":"their overlay class, and after setting it, you must not change it.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If this overlay spans the antimeridian, its bounds may extend west of −180 degrees"},{"type":"text","text":" "},{"type":"text","text":"longitude or east of 180 degrees longitude. For example, an overlay covering the"},{"type":"text","text":" "},{"type":"text","text":"Pacific Ocean from Tokyo to San Francisco might have a bounds extending"},{"type":"text","text":" "},{"type":"text","text":"from (35.68476, −220.24257) to (37.78428, −122.41310)."}],"type":"paragraph"}]}],"kind":"symbol","references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOverlay/overlayBounds":{"title":"overlayBounds","role":"symbol","fragments":[{"text":"overlayBounds","kind":"identifier"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay\/overlayBounds","abstract":[{"text":"The cooordinate rectangle that encompasses the overlay. (required) (read-only)","type":"text"}],"url":"\/documentation\/maplibre\/mlnoverlay\/overlaybounds"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOverlay":{"url":"\/documentation\/maplibre\/mlnoverlay","kind":"symbol","fragments":[{"text":"MLNOverlay","kind":"identifier"}],"role":"symbol","type":"topic","abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay"},{"type":"text","text":" protocol defines a specific type of annotation that represents"},{"type":"text","text":" "},{"type":"text","text":"both a point and an area on a map. Overlay objects are essentially data objects"},{"type":"text","text":" "},{"type":"text","text":"that contain the geographic data needed to represent the map area. Overlays can"},{"type":"text","text":" "},{"type":"text","text":"take the form of a polyline or polygon."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay","title":"MLNOverlay"},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbo