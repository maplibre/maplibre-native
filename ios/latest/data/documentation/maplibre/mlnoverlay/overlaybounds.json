{"abstract":[{"type":"text","text":"The cooordinate rectangle that encompasses the overlay. (required) (read-only)"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay\/overlayBounds"},"variants":[{"paths":["\/documentation\/maplibre\/mlnoverlay\/overlaybounds"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"readonly"},{"kind":"text","text":") "},{"kind":"typeIdentifier","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateBounds","text":"MLNCoordinateBounds","preciseIdentifier":"c:@S@MLNCoordinateBounds"},{"kind":"text","text":" "},{"kind":"identifier","text":"overlayBounds"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"This property contains the smallest rectangle that completely encompasses the","type":"text"},{"text":" ","type":"text"},{"text":"overlay. Implementers of this protocol must set this area when implementing","type":"text"},{"text":" ","type":"text"},{"text":"their overlay class, and after setting it, you must not change it.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If this overlay spans the antimeridian, its bounds may extend west of −180 degrees"},{"type":"text","text":" "},{"type":"text","text":"longitude or east of 180 degrees longitude. For example, an overlay covering the"},{"type":"text","text":" "},{"type":"text","text":"Pacific Ocean from Tokyo to San Francisco might have a bounds extending"},{"type":"text","text":" "},{"type":"text","text":"from (35.68476, −220.24257) to (37.78428, −122.41310)."}]}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","sections":[],"metadata":{"modules":[{"name":"MapLibre"}],"navigatorTitle":[{"text":"overlayBounds","kind":"identifier"}],"roleHeading":"Instance Property","symbolKind":"property","title":"overlayBounds","externalID":"c:objc(pl)MLNOverlay(py)overlayBounds","role":"symbol","fragments":[{"kind":"identifier","text":"overlayBounds"}]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOverlay":{"role":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay","kind":"symbol","title":"MLNOverlay","fragments":[{"text":"MLNOverlay","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay","isActive":true,"type":"reference"},{"type":"text","text":" protocol defines a specific type of annotation that represents"},{"type":"text","text":" "},{"type":"text","text":"both a point and an area on a map. Overlay objects are essentially data objects"},{"type":"text","text":" "},{"type":"text","text":"that contain the geographic data needed to represent the map area. Overlays can"},{"type":"text","text":" "},{"type":"text","text":"take the form of a polyline or polygon."}],"url":"\/documentation\/maplibre\/mlnoverlay"},"doc://org.swift.MyProject/documentation/MapLibre/MLNCoordinateBounds":{"type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"MLNCoordinateBounds","kind":"identifier"}],"abstract":[{"text":"A rectangular area as measured on a two-dimensional map projection.","type":"text"}],"url":"\/documentation\/maplibre\/mlncoordinatebounds","title":"MLNCoordinateBounds","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateBounds"},"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","kind":"symbol","role":"collection","title":"MapLibre","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOverlay/overlayBounds":{"type":"topic","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay\/overlayBounds","title":"overlayBounds","abstract":[{"text":"The cooordinate rectangle that encompasses the overlay. (required) (read-only)","type":"text"}],"url":"\/documentation\/maplibre\/mlnoverlay\/overlaybounds","role":"symbol","fragments":[{"kind":"identifier","text":"overlayBounds"}]}}}