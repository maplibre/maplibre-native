{"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay\/overlayBounds","interfaceLanguage":"occ"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"readonly"},{"kind":"text","text":") "},{"preciseIdentifier":"c:@S@MLNCoordinateBounds","kind":"typeIdentifier","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateBounds","text":"MLNCoordinateBounds"},{"kind":"text","text":" "},{"kind":"identifier","text":"overlayBounds"},{"kind":"text","text":";"}]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property contains the smallest rectangle that completely encompasses the"},{"type":"text","text":" "},{"type":"text","text":"overlay. Implementers of this protocol must set this area when implementing"},{"type":"text","text":" "},{"type":"text","text":"their overlay class, and after setting it, you must not change it."}]},{"type":"paragraph","inlineContent":[{"text":"If this overlay spans the antimeridian, its bounds may extend west of −180 degrees","type":"text"},{"text":" ","type":"text"},{"text":"longitude or east of 180 degrees longitude. For example, an overlay covering the","type":"text"},{"text":" ","type":"text"},{"text":"Pacific Ocean from Tokyo to San Francisco might have a bounds extending","type":"text"},{"text":" ","type":"text"},{"text":"from (35.68476, −220.24257) to (37.78428, −122.41310).","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/maplibre\/mlnoverlay\/overlaybounds"],"traits":[{"interfac