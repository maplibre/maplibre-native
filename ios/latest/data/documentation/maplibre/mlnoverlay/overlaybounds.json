{"abstract":[{"type":"text","text":"The cooordinate rectangle that encompasses the overlay. (required) (read-only)"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/maplibre\/mlnoverlay\/overlaybounds"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay"]]},"kind":"symbol","metadata":{"symbolKind":"property","role":"symbol","externalID":"c:objc(pl)MLNOverlay(py)overlayBounds","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"kind":"identifier","text":"overlayBounds"}],"fragments":[{"text":"overlayBounds","kind":"identifier"}],"title":"overlayBounds","roleHeading":"Instance Property"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"kind":"text","text":", "},{"text":"readonly","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:@S@MLNCoordinateBounds","text":"MLNCoordinateBounds","kind":"typeIdentifier","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateBounds"},{"text":" ","kind":"text"},{"text":"overlayBounds","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"This property contains the smallest rectangle that completely encompasses the"},{"type":"text","text":" "},{"type":"text","text":"overlay. Implementers of this protocol must set this area when implementing"},{"type":"text","text":" "},{"type":"text","text":"their overlay class, and after setting it, you must not change it."}],"type":"paragraph"},{"inlineContent":[{"text":"If this overlay spans the antimeridian, its bounds may extend west of −180 degrees","type":"text"},{"text":" ","type":"text"},{"text":"longitude or east of 180 degrees longitude. For example, an overlay covering the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Pacific Ocean from Tokyo to San Francisco might have a bounds extending"},{"type":"text","text":" "},{"text":"from (35.68476, −220.24257) to (37.78428, −122.41310).","type":"text"}],"type":"paragraph"}]}],"sections":[],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay\/overlayBounds","interfaceLanguage":"occ"},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","title":"MapLibre","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"url":"\/documentation\/maplibre","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOverlay/overlayBounds":{"abstract":[{"text":"The cooordinate rectangle that encompasses the overlay. (required) (read-only)","type":"text"}],"url":"\/documentation\/maplibre\/mlnoverlay\/overlaybounds","fragments":[{"text":"overlayBounds","kind":"identifier"}],"kind":"symbol","title":"overlayBounds","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay\/overlayBounds","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNCoordinateBounds":{"abstract":[{"type":"text","text":"A rectangular area as measured on a two-dimensional map projection."}],"url":"\/documentation\/maplibre\/mlncoordinatebounds","fragments":[{"text":"MLNCoordinateBounds","kind":"identifier"}],"kind":"symbol","title":"MLNCoordinateBounds","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCoordinateBounds","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOverlay":{"url":"\/documentation\/maplibre\/mlnoverlay","kind":"symbol","type":"topic","abstract":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay","type":"reference"},{"text":" protocol defines a specific type of annotation that represents","type":"text"},{"text":" ","type":"text"},{"text":"both a point and an area on a map. Overlay objects are essentially data objects","type":"text"},{"text":" ","type":"text"},{"text":"that contain the geographic data needed to represent the map area. Overlays can","type":"text"},{"text":" ","type":"text"},{"text":"take the form of a polyline or polygon.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay","fragments":[{"text":"MLNOverlay","kind":"identifier"}],"role":"symbol","title":"MLNOverlay"}}}