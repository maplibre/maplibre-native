aphic data needed to represent the map area. Overlays can"},{"type":"text","text":" "},{"type":"text","text":"take the form of a polyline or polygon."}],"title":"MLNOverlay","role":"symbol","type":"topic","kind":"symbol","fragments":[{"text":"MLNOverlay","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOverlay/overlayBounds":{"abstract":[{"type":"text","text":"The cooordinate rectangle that encompasses the overlay. (required) (read-only)"}],"type":"topic","role":"symbol","kind":"symbol","fragments":[{"kind":"identifier","text":"overlayBounds"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay\/overlayBounds","title":"overlayBounds","url":"\/documentation\/maplibre\/mlnoverlay\/overlaybounds"}}}