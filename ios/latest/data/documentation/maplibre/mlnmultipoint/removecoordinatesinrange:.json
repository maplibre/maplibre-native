":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"fragments":[{"text":"MLNStyle","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnstyle","kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","abstract":[{"text":"The proxy object for the current map style.","type":"text"}],"title":"MLNStyle","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPoint/removeCoordinatesInRange:":{"kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlnmultipoint\/removecoordinatesinrange:","fragments":[{"text":"- ","kind":"text"},{"text":"removeCoordinatesInRange:","kind":"identifier"}],"title":"removeCoordinatesInRange:","abstract":[{"text":"Removes the vertices at the given range from the shape.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint\/removeCoordinatesInRange:","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","kind":"symbol","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"title":"MapLibre","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"fragments":[{"text":"MLNShape","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnshape","kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":" is an abstract class that represents a shape or annotation. Shapes"},{"type":"text","text":" "},{"type":"text","text":"constitute the content of a map — not only the overlays atop the map, but also"},{"type":"text","text":" "},{"type":"text","text":"the content that forms the base map."}],"title":"MLNShape","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/shape":{"fragments":[{"text":"shape","kind":"identifier"}],"abstract":[{"text":"The contents of the source. A shape can represent a GeoJSON geometry, a","type":"text"},{"text":" ","type":"text"},{"text":"feature, or a collection of features.","type":"text"}],"kind":"symbol","title":"shape","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape","url":"\/documentation\/maplibre\/mlnshapesource\/shape","type":"topic","role":"symbol"}}}