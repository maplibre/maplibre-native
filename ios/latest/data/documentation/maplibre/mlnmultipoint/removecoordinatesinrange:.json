isible on the map as an annotation, it is redrawn","type":"text"},{"text":" ","type":"text"},{"text":"immediately. If the shape is part of an ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"text":" object, you must","type":"text"},{"text":" ","type":"text"},{"text":"explicitly set the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape"},{"text":" property in order for any style","type":"text"},{"text":" ","type":"text"},{"text":"layers that use the source to be redrawn.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"range"},{"text":" extends beyond the shape’s ","type":"text"},{"type":"codeVoice","code":"coordinates"},{"text":" property, an","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"NSRangeException"},{"text":" is raised.","type":"text"}]}],"kind":"content"}],"abstract":[{"text":"Removes the vertices at the given range from the shape.","type":"text"}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint\/removeCoordinatesInRange:","interfaceLanguage":"occ"},"schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"paths":["\/documentation\/maplibre\/mlnmultipoint\/removecoordinatesinrange:"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPoint":{"fragments":[{"text":"MLNMultiPoint","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnmultipoint","kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint","abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint"},{"type":"text","text":" class is an abstract superclass used to defi