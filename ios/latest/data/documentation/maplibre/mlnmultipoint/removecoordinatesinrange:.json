":"reference"},{"text":" property in order for any style","type":"text"},{"text":" ","type":"text"},{"text":"layers that use the source to be redrawn.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"range","type":"codeVoice"},{"text":" extends beyond the shape’s ","type":"text"},{"code":"coordinates","type":"codeVoice"},{"text":" property, an","type":"text"},{"text":" ","type":"text"},{"code":"NSRangeException","type":"codeVoice"},{"text":" is raised.","type":"text"}]}]}],"metadata":{"role":"symbol","title":"removeCoordinatesInRange:","navigatorTitle":[{"text":"- ","kind":"text"},{"text":"removeCoordinatesInRange:","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNMultiPoint(im)removeCoordinatesInRange:","symbolKind":"method","fragments":[{"text":"- ","kind":"text"},{"text":"removeCoordinatesInRange:","kind":"identifier"}],"roleHeading":"Instance Method"},"abstract":[{"type":"text","text":"Removes the vertices at the given range from the shape."}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint\/removeCoordinatesInRange:","interfaceLanguage":"occ"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmultipoint\/removecoordinatesinrange:"]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"url":"\/documentation\/maplibre\/mlnshape","type":"topic","fragments":[{"kind":"identifier","text":"MLNShape"}],"abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"text":" is an abstract class that represents a shape or annotation. Shapes","type":"text"},{"text":" ","type":"text"},{"text":"constitute the content of a map — not only the overlays atop the map, but also","type":"t