 ","type":"text"},{"text":"being the second vertex, and so on. The ","type":"text"},{"code":"length","type":"codeVoice"},{"type":"text","text":" field indicates the number"},{"text":" ","type":"text"},{"type":"text","text":"of vertices to replace."}]}]},{"name":"coords","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The array of coordinates defining part of the shape. The data in"},{"type":"text","text":" "},{"text":"this array is copied to the shape’s ","type":"text"},{"code":"coordinates","type":"codeVoice"},{"text":" property.","type":"text"}]}]},{"name":"count","content":[{"type":"paragraph","inlineContent":[{"text":"The number of coordinates from the ","type":"text"},{"code":"coords","type":"codeVoice"},{"text":" array to insert in","type":"text"},{"text":" ","type":"text"},{"text":"place of the coordinates in ","type":"text"},{"code":"range","type":"codeVoice"},{"text":". The sum of ","type":"text"},{"code":"range","type":"codeVoice"},{"text":"’s length and this","type":"text"},{"text":" ","type":"text"},{"text":"count must not exceed the number of items currently in the ","type":"text"},{"code":"coordinates","type":"codeVoice"},{"text":" ","type":"text"},{"text":"property.","type":"text"}]}]}]},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the shape is currently visible on the map as an annotation, it is redrawn"},{"type":"text","text":" "},{"type":"text","text":"immediately. If the shape is part of an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true},{"type":"text","text":" object, you must"},{"type":"text","text":" "},{"type":"text","text":"explicitly set the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape","isActive":true},{"type":"text","text":" property in order for any style"},{"type":"text","te