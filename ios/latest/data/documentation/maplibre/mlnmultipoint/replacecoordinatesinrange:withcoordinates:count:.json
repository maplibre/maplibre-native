text":"property.","type":"text"}]}]}]},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"text":"If the shape is currently visible on the map as an annotation, it is redrawn","type":"text"},{"text":" ","type":"text"},{"text":"immediately. If the shape is part of an ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference"},{"text":" object, you must","type":"text"},{"text":" ","type":"text"},{"text":"explicitly set the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape","type":"reference"},{"text":" property in order for any style","type":"text"},{"text":" ","type":"text"},{"text":"layers that use the source to be redrawn.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"code":"count","type":"codeVoice"},{"text":" is greater than the ","type":"text"},{"code":"length","type":"codeVoice"},{"text":" field of ","type":"text"},{"code":"range","type":"codeVoice"},{"text":", some vertices will","type":"text"},{"text":" ","type":"text"},{"text":"effectively be inserted into the shape. On the other hand, if ","type":"text"},{"code":"count","type":"codeVoice"},{"text":" is less","type":"text"},{"text":" ","type":"text"},{"text":"than the ","type":"text"},{"code":"length","type":"codeVoice"},{"text":" field of ","type":"text"},{"code":"range","type":"codeVoice"},{"text":", some vertices will effectively be removed.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"range"},{"type":"text","text":" extends beyond the shape’s "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" property, an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSRangeException"},{"type":"text","text":" is raised. If you want to append new vertices to the shape,"},{"type":"text","te