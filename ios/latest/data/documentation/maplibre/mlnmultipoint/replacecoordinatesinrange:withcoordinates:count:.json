use the source to be redrawn.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"count","type":"codeVoice"},{"text":" is greater than the ","type":"text"},{"code":"length","type":"codeVoice"},{"text":" field of ","type":"text"},{"code":"range","type":"codeVoice"},{"text":", some vertices will","type":"text"},{"text":" ","type":"text"},{"text":"effectively be inserted into the shape. On the other hand, if ","type":"text"},{"code":"count","type":"codeVoice"},{"text":" is less","type":"text"},{"text":" ","type":"text"},{"text":"than the ","type":"text"},{"code":"length","type":"codeVoice"},{"text":" field of ","type":"text"},{"code":"range","type":"codeVoice"},{"text":", some vertices will effectively be removed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"range"},{"type":"text","text":" extends beyond the shape’s "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" property, an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSRangeException"},{"type":"text","text":" is raised. If you want to append new vertices to the shape,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"type":"codeVoice","code":"-appendCoordinates:count:"},{"type":"text","text":" method."}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint\/replaceCoordinatesInRange:withCoordinates:count:"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmultipoint\/replacecoordinatesinrange:withcoordinates:count:"]}],"metadata":{"modules":[{"name":"MapLibre"}],"role":"symbol","title":"replaceCoordinatesInRange:withCoordinates:count:","navigatorTitle":[{"text":"replaceCoordinatesInRange:withCoordinates:count:","kind":"identifier"}],"symbolKind":"method","externalID":"c:objc(cs)MLNMultiPoint(im)replaceCoordinatesInRange:withC