","text":" field of "},{"code":"range","type":"codeVoice"},{"type":"text","text":", some vertices will"},{"type":"text","text":" "},{"type":"text","text":"effectively be inserted into the shape. On the other hand, if "},{"code":"count","type":"codeVoice"},{"type":"text","text":" is less"},{"type":"text","text":" "},{"type":"text","text":"than the "},{"code":"length","type":"codeVoice"},{"type":"text","text":" field of "},{"code":"range","type":"codeVoice"},{"text":", some vertices will effectively be removed.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"range","type":"codeVoice"},{"type":"text","text":" extends beyond the shape’s "},{"code":"coordinates","type":"codeVoice"},{"type":"text","text":" property, an"},{"type":"text","text":" "},{"code":"NSRangeException","type":"codeVoice"},{"type":"text","text":" is raised. If you want to append new vertices to the shape,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"code":"-appendCoordinates:count:","type":"codeVoice"},{"type":"text","text":" method."}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"text":"Replaces the vertices at the given range in the shape with the specified number","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of vertices from a given C array."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmultipoint\/replacecoordinatesinrange:withcoordinates:count:"]}],"metadata":{"modules":[{"name":"MapLibre"}],"navigatorTitle":[{"text":"- ","kind":"text"},{"text":"replaceCoordinatesInRange:withCoordinates:count:","kind":"identifier"}],"symbolKind":"method","externalID":"c:objc(cs)MLNMultiPoint(im)replaceCoordinatesInRange:withCoordinates:count:","fragments":[{"text":"- ","kind":"text"},{"kind":"identifier","text":"replaceCoordinatesInRange:withCoordinates:count:"}],"role":"symbol","title":"replaceCoordinatesInRange:withCoordinates:count:","roleHeading":"Instance Method"},"sc