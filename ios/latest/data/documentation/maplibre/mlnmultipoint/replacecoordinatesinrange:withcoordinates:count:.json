":"paragraph"}]}],"kind":"parameters"},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"If the shape is currently visible on the map as an annotation, it is redrawn"},{"type":"text","text":" "},{"type":"text","text":"immediately. If the shape is part of an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":" object, you must"},{"type":"text","text":" "},{"type":"text","text":"explicitly set the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape"},{"type":"text","text":" property in order for any style"},{"type":"text","text":" "},{"type":"text","text":"layers that use the source to be redrawn."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"count"},{"type":"text","text":" is greater than the "},{"type":"codeVoice","code":"length"},{"type":"text","text":" field of "},{"type":"codeVoice","code":"range"},{"type":"text","text":", some vertices will"},{"type":"text","text":" "},{"type":"text","text":"effectively be inserted into the shape. On the other hand, if "},{"type":"codeVoice","code":"count"},{"type":"text","text":" is less"},{"type":"text","text":" "},{"type":"text","text":"than the "},{"type":"codeVoice","code":"length"},{"type":"text","text":" field of "},{"type":"codeVoice","code":"range"},{"type":"text","text":", some vertices will effectively be removed."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"range"},{"type":"text","text":" extends beyond the shape’s "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" property, an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSRangeException"},{"type":"text","text":" is raised. If you want to append new vertices to the shape,"},{"type":"text","te