he shape. The data in"},{"type":"text","text":" "},{"type":"text","text":"this array is copied to the shape’s "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" property."}]}]},{"name":"count","content":[{"type":"paragraph","inlineContent":[{"text":"The number of coordinates from the ","type":"text"},{"code":"coords","type":"codeVoice"},{"text":" array to insert in","type":"text"},{"text":" ","type":"text"},{"text":"place of the coordinates in ","type":"text"},{"code":"range","type":"codeVoice"},{"text":". The sum of ","type":"text"},{"code":"range","type":"codeVoice"},{"text":"’s length and this","type":"text"},{"text":" ","type":"text"},{"text":"count must not exceed the number of items currently in the ","type":"text"},{"code":"coordinates","type":"codeVoice"},{"text":" ","type":"text"},{"text":"property.","type":"text"}]}]}]},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"If the shape is currently visible on the map as an annotation, it is redrawn","type":"text"},{"text":" ","type":"text"},{"text":"immediately. If the shape is part of an ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference"},{"text":" object, you must","type":"text"},{"text":" ","type":"text"},{"text":"explicitly set the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape","type":"reference"},{"text":" property in order for any style","type":"text"},{"text":" ","type":"text"},{"text":"layers that use the source to be redrawn.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"count"},{"text":" is greater than the ","type":"text"},{"type":"codeVoice","code":"length"},{"text":" field of ","type":"text"},{"type":"codeVoice","code":"range"},{"text":", some vertices will","type":"text"},{"text":" ","type":"text"},{"text":"effectively be inserted into the shape. On the other hand, if ","type":"text"},{"type":"codeVoice","code":"count"},{"text":" is less","type":"text"},{"type":"text","text":" "},{"type":"text","text":"than the "},{"code":"length","type":"codeVoice"},{"type":"text","text":" field of "},{"code":"range","type":"codeVoice"},{"type":"text","text":", some vertices will effectively be removed."}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"range"},{"text":" extends beyond the shape’s ","type":"text"},{"type":"codeVoice","code":"coordinates"},{"text":" property, an","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"NSRangeException"},{"text":" is raised. If you want to append new vertices to the shape,","type":"text"},{"text":" ","type":"text"},{"text":"use the ","type":"text"},{"type":"codeVoice","code":"-appendCoordinates:count:"},{"type":"text","text":" method."}]}],"kind":"content"}],"sections":[],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint\/replaceCoordinatesInRange:withCoordinates:count:","interfaceLanguage":"occ"},"metadata":{"symbolKind":"method","externalID":"c:objc(cs)MLNMultiPoint(im)replaceCoordinatesInRange:withCoordinates:count:","roleHeading":"Instance Method","modules":[{"name":"MapLibre"}],"fragments":[{"text":"- ","kind":"text"},{"text":"replaceCoordinatesInRange:withCoordinates:count:","kind":"identifier"}],"navigatorTitle":[{"text":"replaceCoordinatesInRange:withCoordinates:count:","kind":"identifier"}],"title":"replaceCoordinatesInRange:withCoordinates:count:","role":"symbol"},"abstract":[{"text":"Replaces the vertices at the given range in the shape with the specified number","type":"text"},{"text":" ","type":"text"},{"text":"of vertices from a given C array.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmultipoint\/replacecoordinatesinrange:with