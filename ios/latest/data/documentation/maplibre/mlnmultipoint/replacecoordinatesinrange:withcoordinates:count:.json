ntifier","preciseIdentifier":"c:@T@NSUInteger"},{"text":") ","kind":"text"},{"text":"count","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The range of vertices to replace. The "},{"code":"location","type":"codeVoice"},{"type":"text","text":" field indicates"},{"type":"text","text":" "},{"type":"text","text":"the first vertex you are replacing, with "},{"code":"0","type":"codeVoice"},{"type":"text","text":" being the first vertex, "},{"code":"1","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"being the second vertex, and so on. The "},{"code":"length","type":"codeVoice"},{"type":"text","text":" field indicates the number"},{"type":"text","text":" "},{"type":"text","text":"of vertices to replace."}],"type":"paragraph"}],"name":"range"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The array of coordinates defining part of the shape. The data in","type":"text"},{"text":" ","type":"text"},{"text":"this array is copied to the shape’s ","type":"text"},{"code":"coordinates","type":"codeVoice"},{"text":" property.","type":"text"}]}],"name":"coords"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The number of coordinates from the "},{"type":"codeVoice","code":"coords"},{"type":"text","text":" array to insert in"},{"type":"text","text":" "},{"type":"text","text":"place of the coordinates in "},{"type":"codeVoice","code":"range"},{"type":"text","text":". The sum of "},{"type":"codeVoice","code":"range"},{"type":"text","text":"’s length and this"},{"type":"text","text":" "},{"type":"text","text":"count must not exceed the number of items currently in the "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" "},{"type":"text","text":"property."}]}],"name":"count"}],"kind":"parameters"},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"If the shape is currently visible on the map as an annotation, it is redrawn"},{"type":"text","text":" "},{"type":"text","text":"immediately. If the shape is part of an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":" object, you must"},{"type":"text","text":" "},{"type":"text","text":"explicitly set the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape"},{"type":"text","text":" property in order for any style"},{"type":"text","text":" "},{"type":"text","text":"layers that use the source to be redrawn."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"count"},{"type":"text","text":" is greater than the "},{"type":"codeVoice","code":"length"},{"type":"text","text":" field of "},{"type":"codeVoice","code":"range"},{"type":"text","text":", some vertices will"},{"type":"text","text":" "},{"type":"text","text":"effectively be inserted into the shape. On the other hand, if "},{"type":"codeVoice","code":"count"},{"type":"text","text":" is less"},{"text":" ","type":"text"},{"text":"than the ","type":"text"},{"code":"length","type":"codeVoice"},{"text":" field of ","type":"text"},{"code":"range","type":"codeVoice"},{"text":", some vertices will effectively be removed.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"range"},{"type":"text","text":" extends beyond the shape’s "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" property, an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSRangeException"},{"type":"text","text":" is raised. If you want to append new vertices to the shape,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"type":"codeVoice","code":"-appendCoordinates:count:"},{"type":"text","text":" method."}],"type":"paragraph"}],"kind":"co