{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint\/replaceCoordinatesInRange:withCoordinates:count:"},"abstract":[{"text":"Replaces the vertices at the given range in the shape with the specified number","type":"text"},{"text":" ","type":"text"},{"text":"of vertices from a given C array.","type":"text"}],"variants":[{"paths":["\/documentation\/maplibre\/mlnmultipoint\/replacecoordinatesinrange:withcoordinates:count:"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"- (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"replaceCoordinatesInRange:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSRange","preciseIdentifier":"c:@S@_NSRange","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"range","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"withCoordinates:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"const","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CLLocationCoordinate2D","preciseIdentifier":"c:@S@CLLocationCoordinate2D","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"coords","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"count:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSUInteger","preciseIdentifier":"c:@T@NSUInteger","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"count","kind":"internalParam"},{"text":";","kind":"text"}]}]},{"kind":"parameters","parameters":[{"name":"range","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The range of vertices to replace. The "},{"type":"codeVoice","code":"location"},{"type":"text","text":" field indicates"},{"type":"text","text":" "},{"type":"text","text":"the first vertex you are replacing, with "},{"type":"codeVoice","code":"0"},{"type":"text","text":" being the first vertex, "},{"type":"codeVoice","code":"1"},{"type":"text","text":" "},{"type":"text","text":"being the second vertex, and so on. The "},{"type":"codeVoice","code":"length"},{"type":"text","text":" field indicates the number"},{"type":"text","text":" "},{"type":"text","text":"of vertices to replace."}]}]},{"name":"coords","content":[{"inlineContent":[{"type":"text","text":"The array of coordinates defining part of the shape. The data in"},{"type":"text","text":" "},{"type":"text","text":"this array is copied to the shape’s "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" property."}],"type":"paragraph"}]},{"name":"count","content":[{"type":"paragraph","inlineContent":[{"text":"The number of coordinates from the ","type":"text"},{"type":"codeVoice","code":"coords"},{"text":" array to insert in","type":"text"},{"text":" ","type":"text"},{"text":"place of the coordinates in ","type":"text"},{"type":"codeVoice","code":"range"},{"text":". The sum of ","type":"text"},{"type":"codeVoice","code":"range"},{"text":"’s length and this","type":"text"},{"text":" ","type":"text"},{"text":"count must not exceed the number of items currently in the ","type":"text"},{"type":"codeVoice","code":"coordinates"},{"text":" ","type":"text"},{"text":"property.","type":"text"}]}]}]},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"If the shape is currently visible on the map as an annotation, it is redrawn"},{"type":"text","text":" "},{"type":"text","text":"immediately. If the shape is part of an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true},{"type":"text","text":" object, you must"},{"type":"text","text":" "},{"type":"text","text":"explicitly set the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape","isActive":true},{"type":"text","text":" property in order for any style"},{"type":"text","text":" "},{"type":"text","text":"layers that use the source to be redrawn."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"count"},{"type":"text","text":" is greater than the "},{"type":"codeVoice","code":"length"},{"type":"text","text":" field of "},{"type":"codeVoice","code":"range"},{"type":"text","text":", some vertices will"},{"type":"text","text":" "},{"type":"text","text":"effectively be inserted into the shape. On the other hand, if "},{"type":"codeVoice","code":"count"},{"type":"text","text":" is less"},{"type":"text","text":" "},{"type":"text","text":"than the "},{"type":"codeVoice","code":"length"},{"type":"text","text":" field of "},{"type":"codeVoice","code":"range"},{"type":"text","text":", some vertices will effectively be removed."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"range"},{"type":"text","text":" extends beyond the shape’s "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" property, an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSRangeException"},{"type":"text","text":" is raised. If you want to append new vertices to the shape,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"type":"codeVoice","code":"-appendCoordinates:count:"},{"text":" method.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"metadata":{"role":"symbol","navigatorTitle":[{"text":"replaceCoordinatesInRange:withCoordinates:count:","kind":"identifier"}],"fragments":[{"text":"- ","kind":"text"},{"text":"replaceCoordinatesInRange:withCoordinates:count:","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"roleHeading":"Instance Method"