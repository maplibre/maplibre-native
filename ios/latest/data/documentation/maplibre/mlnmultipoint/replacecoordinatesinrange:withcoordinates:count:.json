{"abstract":[{"type":"text","text":"Replaces the vertices at the given range in the shape with the specified number"},{"type":"text","text":" "},{"type":"text","text":"of vertices from a given C array."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmultipoint\/replacecoordinatesinrange:withcoordinates:count:"]}],"metadata":{"roleHeading":"Instance Method","navigatorTitle":[{"kind":"identifier","text":"replaceCoordinatesInRange:withCoordinates:count:"}],"symbolKind":"method","fragments":[{"text":"- ","kind":"text"},{"text":"replaceCoordinatesInRange:withCoordinates:count:","kind":"identifier"}],"title":"replaceCoordinatesInRange:withCoordinates:count:","role":"symbol","modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNMultiPoint(im)replaceCoordinatesInRange:withCoordinates:count:"},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint\/replaceCoordinatesInRange:withCoordinates:count:","interfaceLanguage":"occ"},"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint"]]},"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"- (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"replaceCoordinatesInRange:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSRange","kind":"typeIdentifier","preciseIdentifier":"c:@S@_NSRange"},{"text":") ","kind":"text"},{"text":"range","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"withCoordinates:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"const","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CLLocationCoordinate2D","kind":"typeIdentifier","preciseIdentifier":"c:@S@CLLocationCoordinate2D"},{"text":" *) ","kind":"text"},{"text":"coords","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"count:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSUInteger","kind":"typeIdentifier","preciseIdentifier":"c:@T@NSUInteger"},{"text":") ","kind":"text"},{"text":"count","kind":"internalParam"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The range of vertices to replace. The ","type":"text"},{"type":"codeVoice","code":"location"},{"text":" field indicates","type":"text"},{"text":" ","type":"text"},{"text":"the first vertex you are replacing, with ","type":"text"},{"type":"codeVoice","code":"0"},{"text":" being the first vertex, ","type":"text"},{"type":"codeVoice","code":"1"},{"text":" ","type":"text"},{"text":"being the second vertex, and so on. The ","type":"text"},{"type":"codeVoice","code":"length"},{"text":" field indicates the number","type":"text"},{"text":" ","type":"text"},{"text":"of vertices to replace.","type":"text"}]}],"name":"range"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The array of coordinates defining part of the shape. The data in","type":"text"},{"text":" ","type":"text"},{"text":"this array is copied to the shape’s ","type":"text"},{"code":"coordinates","type":"codeVoice"},{"text":" property.","type":"text"}]}],"name":"coords"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The number of coordinates from the "},{"type":"codeVoice","code":"coords"},{"type":"text","text":" array to insert in"},{"type":"text","text":" "},{"type":"text","text":"place of the coordinates in "},{"type":"codeVoice","code":"range"},{"type":"text","text":". The sum of "},{"type":"codeVoice","code":"range"},{"type":"text","text":"’s length and this"},{"type":"text","text":" "},{"type":"text","text":"count must not exceed the number of items currently in the "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" "},{"type":"text","text":"property."}]}],"name":"count"}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"If the shape is currently visible on the map as an annotation, it is redrawn"},{"type":"text","text":" "},{"type":"text","text":"immediately. If the shape is part of an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true},{"type":"text","text":" object, you must"},{"type":"text","text":" "},{"type":"text","text":"explicitly set the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape","isActive":true},{"type":"text","text":" property in order for any style"},{"type":"text","text":" "},{"type":"text","text":"layers that use the source to be redrawn."}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"code":"count","type":"codeVoice"},{"text":" is greater than the ","type":"text"},{"code":"length","type":"codeVoice"},{"text":" field of ","type":"text"},{"code":"range","type":"codeVoice"},{"text":", some vertices will","type":"text"},{"text":" ","type":"text"},{"text":"effectively be inserted into the shape. On the other hand, if ","type":"text"},{"code":"count","type":"codeVoice"},{"text":" is less","type":"text"},{"type":"text","text":" "},{"type":"text","text":"than the "},{"type":"codeVoice","code":"length"},{"type":"text","text":" field of "},{"type":"codeVoice","code":"range"},{"type":"text","text":", some vertices will effectively be removed."}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"code":"range","type":"codeVoice"},{"text":" extends beyond the shape’s ","type":"text"},{"code":"coordinates","type":"codeVoice"},{"text":" property, an","type":"text"},{"text":" ","type":"text"},{"code":"NSRangeException","type":"codeVoice"},{"text":" is raised. If you want to append new vertices to the shape,","type":"text"},{"text":" ","type":"text"},{"text":"use the ","type":"text"},{"code":"-appendCoordinates:count:","type":"codeVoice"},{"type":"text","text":" method."}],"type":"paragraph"}]}],"kind":"symbol","sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPoint":{"title":"MLNMultiPoint","kind":"symbol","url":"\/documentation\/maplibre\/mlnmultipoint","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint","fragments":[{"kind":"identifier","text":"MLNMultiPoint"}],"type":"topic","abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint"},{"type":"text","text":" class is an abstract superclass used to define shapes"},{"type":"text","text":" "},{"type":"text","text":"composed of multiple vertices."}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"kind":"symbol","role":"collection","url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/shape":{"type":"topic","abstract":[{"type":"text","text":"The contents of the source. A shape can represent a GeoJSON geometry, a"},{"type":"text","text":" "},{"type":"text","text":"feature, or a collection of features."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape","role":"symbol","fragments":[{"kind":"identifier","text":"shape"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesource\/shape","title":"shape"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPoint/replaceCoordinatesInRange:withCoordinates:count:":{"fragments":[{"text":"- ","kind":"text"},{"text":"replaceCoordinatesInRange:withCoordinates:count:","kind":"identifier"}],"role":"symbol","abstract":[{"type":"text","text":"Replaces the vertices at the given range in the shape with the specified number"},{"type":"text","text":" "},{"type":"text","text":"of vertices from a given C array."}],"title":"replaceCoordinatesInRange:withCoordinates:count:","url":"\/documentation\/maplibre\/mlnmultipoint\/replacecoordinatesinrange:withcoordinates:count:","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint\/replaceCoordinatesInRange:withCoordinates:count:","type":"topic","navigatorTitle":[{"text":"replaceCoordinatesInRange:withCoordinates:count:","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"url":"\/documentation\/maplibre\/mlnshapesource","title":"MLNShapeSource","role":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","fragments":[{"kind":"identifier","text":"MLNShapeSource"}],"abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"type":"text","text":" is a map content source that supplies vector shapes to be"},{"type":"text","text":" "},{"type":"text","text":"shown on the map. The shapes may be instances of "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":" or "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or they may be defined by local or external"},{"type":"text","text":" "},{"type":"text","text":"GeoJSON"},{"type":"text","text":" code. A shape source is added to an"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"type":"text","text":" object along with an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the shape source. You"},{"type":"text","text":" "},{"type":"text","text":"can update a shape source by setting its "},{"type":"codeVoice","code":"shape"},{"type":"text","text":" or "},{"type":"codeVoice","code":"URL"},{"type":"text","text":" property."}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"role":"symbol","abstract":[{"type":"text","text":"The proxy object for the current map style."}],"fragments":[{"kind":"identifier","text":"MLNStyle"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","kind":"symbol","title":"MLNStyle","url":"\/documentation\/maplibre\/mlnstyle"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"url":"\/documentation\/maplibre\/mlnshape","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","fragments":[{"text":"MLNShape","kind":"identifier"}],"type":"topic","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":" is an abstract class that represents a shape or annotation. Shapes"},{"type":"text","text":" "},{"type":"text","text":"constitute the content of a map — not only the overlays atop the map, but also"},{"type":"text","text":" "},{"type":"text","text":"the content that forms the base map."}],"kind":"symbol","role":"symbol","title":"MLNShape"}}}