{"abstract":[{"type":"text","text":"Replaces the vertices at the given range in the shape with the specified number"},{"type":"text","text":" "},{"type":"text","text":"of vertices from a given C array."}],"sections":[],"variants":[{"paths":["\/documentation\/maplibre\/mlnmultipoint\/replacecoordinatesinrange:withcoordinates:count:"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"- (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"replaceCoordinatesInRange:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSRange","kind":"typeIdentifier","preciseIdentifier":"c:@S@_NSRange"},{"text":") ","kind":"text"},{"text":"range","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"withCoordinates:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"const","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CLLocationCoordinate2D","kind":"typeIdentifier","preciseIdentifier":"c:@S@CLLocationCoordinate2D"},{"text":" *) ","kind":"text"},{"text":"coords","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"count:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSUInteger","kind":"typeIdentifier","preciseIdentifier":"c:@T@NSUInteger"},{"text":") ","kind":"text"},{"text":"count","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"parameters":[{"name":"range","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The range of vertices to replace. The "},{"code":"location","type":"codeVoice"},{"type":"text","text":" field indicates"},{"type":"text","text":" "},{"type":"text","text":"the first vertex you are replacing, with "},{"code":"0","type":"codeVoice"},{"type":"text","text":" being the first vertex, "},{"code":"1","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"being the second vertex, and so on. The "},{"code":"length","type":"codeVoice"},{"type":"text","text":" field indicates the number"},{"type":"text","text":" "},{"type":"text","text":"of vertices to replace."}]}]},{"name":"coords","content":[{"inlineContent":[{"text":"The array of coordinates defining part of the shape. The data in","type":"text"},{"text":" ","type":"text"},{"text":"this array is copied to the shape’s ","type":"text"},{"code":"coordinates","type":"codeVoice"},{"text":" property.","type":"text"}],"type":"paragraph"}]},{"name":"count","content":[{"type":"paragraph","inlineContent":[{"text":"The number of coordinates from the ","type":"text"},{"code":"coords","type":"codeVoice"},{"text":" array to insert in","type":"text"},{"text":" ","type":"text"},{"text":"place of the coordinates in ","type":"text"},{"code":"range","type":"codeVoice"},{"text":". The sum of ","type":"text"},{"code":"range","type":"codeVoice"},{"text":"’s length and this","type":"text"},{"text":" ","type":"text"},{"text":"count must not exceed the number of items currently in the ","type":"text"},{"code":"coordinates","type":"codeVoice"},{"text":" ","type":"text"},{"text":"property.","type":"text"}]}]}],"kind":"parameters"},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"If the shape is currently visible on the map as an annotation, it is redrawn"},{"type":"text","text":" "},{"type":"text","text":"immediately. If the shape is part of an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"type":"text","text":" object, you must"},{"type":"text","text":" "},{"type":"text","text":"explicitly set the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape","type":"reference","isActive":true},{"type":"text","text":" property in order for any style"},{"type":"text","text":" "},{"type":"text","text":"layers that use the source to be redrawn."}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"count"},{"text":" is greater than the ","type":"text"},{"type":"codeVoice","code":"length"},{"text":" field of ","type":"text"},{"type":"codeVoice","code":"range"},{"text":", some vertices will","type":"text"},{"text":" ","type":"text"},{"text":"effectively be inserted into the shape. On the other hand, if ","type":"text"},{"type":"codeVoice","code":"count"},{"text":" is less","type":"text"},{"text":" ","type":"text"},{"text":"than the ","type":"text"},{"type":"codeVoice","code":"length"},{"text":" field of ","type":"text"},{"type":"codeVoice","code":"range"},{"text":", some vertices will effectively be removed.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"range","type":"codeVoice"},{"type":"text","text":" extends beyond the shape’s "},{"code":"coordinates","type":"codeVoice"},{"type":"text","text":" property, an"},{"type":"text","text":" "},{"code":"NSRangeException","type":"codeVoice"},{"type":"text","text":" is raised. If you want to append new vertices to the shape,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"code":"-appendCoordinates:count:","type":"codeVoice"},{"type":"text","text":" method."}],"type":"paragraph"}],"kind":"content"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint\/replaceCoordinatesInRange:withCoordinates:count:"},"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint"]]},"metadata":{"roleHeading":"Instance Method","externalID":"c:objc(cs)MLNMultiPoint(im)replaceCoordinatesInRange:withCoordinates:count:","role":"symbol","modules":[{"name":"MapLibre"}],"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"replaceCoordinatesInRange:withCoordinates:count:"}],"naviga