:"effectively be inserted into the shape. On the other hand, if ","type":"text"},{"type":"codeVoice","code":"count"},{"text":" is less","type":"text"},{"type":"text","text":" "},{"type":"text","text":"than the "},{"type":"codeVoice","code":"length"},{"type":"text","text":" field of "},{"type":"codeVoice","code":"range"},{"type":"text","text":", some vertices will effectively be removed."}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"range"},{"text":" extends beyond the shape’s ","type":"text"},{"type":"codeVoice","code":"coordinates"},{"text":" property, an","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"NSRangeException"},{"text":" is raised. If you want to append new vertices to the shape,","type":"text"},{"text":" ","type":"text"},{"text":"use the ","type":"text"},{"type":"codeVoice","code":"-appendCoordinates:count:"},{"type":"text","text":" method."}]}]}],"sections":[],"variants":[{"paths":["\/documentation\/maplibre\/mlnmultipoint\/replacecoordinatesinrange:withcoordinates:count:"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint"]]},"abstract":[{"type":"text","text":"Replaces the vertices at the given range in the shape with the specified number"},{"type":"text","text":" "},{"type":"text","text":"of vertices from a given C array."}],"metadata":{"roleHeading":"Instance Method","title":"replaceCoordinatesInRange:withCoordinates:count:","fragments":[{"text":"- ","kind":"text"},{"text":"replaceCoordinatesInRange:withCoordinates:count:","kind":"identifier"}],"navigatorTitle":[{"text":"replaceCoordinatesInRange:withCoordinates:count:","kind":"identifier"}],"externalID":"c:objc(cs)MLNMultiPoint(im)replaceCoordinatesInRange:withCoordinates:count:","role":"symbol","symbolKind":"method","modules":[{"name":"MapLib