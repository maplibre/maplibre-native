{"sections":[],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint\/replaceCoordinatesInRange:withCoordinates:count:","interfaceLanguage":"occ"},"metadata":{"title":"replaceCoordinatesInRange:withCoordinates:count:","symbolKind":"method","roleHeading":"Instance Method","modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNMultiPoint(im)replaceCoordinatesInRange:withCoordinates:count:","navigatorTitle":[{"kind":"identifier","text":"replaceCoordinatesInRange:withCoordinates:count:"}],"role":"symbol","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"replaceCoordinatesInRange:withCoordinates:count:"}]},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Replaces the vertices at the given range in the shape with the specified number"},{"type":"text","text":" "},{"type":"text","text":"of vertices from a given C array."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"- (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"replaceCoordinatesInRange:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:@S@_NSRange","text":"NSRange","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"range","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"withCoordinates:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"const","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"c:@S@CLLocationCoordinate2D","text":"CLLocationCoordinate2D","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"coords","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"count:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:@T@NSUInteger","text":"NSUInteger","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"count","kind":"internalParam"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The range of vertices to replace. The "},{"type":"codeVoice","code":"location"},{"type":"text","text":" field indicates"},{"type":"text","text":" "},{"type":"text","text":"the first vertex you are replacing, with "},{"type":"codeVoice","code":"0"},{"type":"text","text":" being the first vertex, "},{"type":"codeVoice","code":"1"},{"type":"text","text":" "},{"type":"text","text":"being the second vertex, and so on. The "},{"type":"codeVoice","code":"length"},{"type":"text","text":" field indicates the number"},{"type":"text","text":" "},{"type":"text","text":"of vertices to replace."}]}],"name":"range"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The array of coordinates defining part of the shape. The data in"},{"type":"text","text":" "},{"type":"text","text":"this array is copied to the shape’s "},{"code":"coordinates","type":"codeVoice"},{"type":"text","text":" property."}]}],"name":"coords"},{"content":[{"inlineContent":[{"type":"text","text":"The number of coordinates from the "},{"type":"codeVoice","code":"coords"},{"type":"text","text":" array to insert in"},{"type":"text","text":" "},{"type":"text","text":"place of the coordinates in "},{"type":"codeVoice","code":"range"},{"type":"text","text":". The sum of "},{"type":"codeVoice","code":"range"},{"type":"text","text":"’s length and this"},{"type":"text","text":" "},{"type":"text","text":"count must not exceed the number of items currently in the "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" "},{"type":"text","text":"property."}],"type":"paragraph"}],"name":"count"}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the shape is currently visible on the map as an annotation, it is redrawn"},{"type":"text","text":" "},{"type":"text","text":"immediately. If the shape is part of an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true,"type":"reference"},{"type":"text","text":" object, you must"},{"type":"text","text":" "},{"type":"text","text":"explicitly set the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape","isActive":true,"type":"reference"},{"type":"text","text":" property in order for any style"},{"type":"text","text":" "},{"type":"text","text":"layers that use the source to be redrawn."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"count","type":"codeVoice"},{"type":"text","text":" is greater than the "},{"code":"length","type":"codeVoice"},{"type":"text","text":" field of "},{"code":"range","type":"codeVoice"},{"type":"text","text":", some vertices will"},{"type":"text","text":" "},{"type":"text","text":"effectively be inserted into the shape. On the other hand, if "},{"code":"count","type":"codeVoice"},{"type":"text","text":" is less"},{"type":"text","text":" "},{"type":"text","text":"than the "},{"code":"length","type":"codeVoice"},{"type":"text","text":" field of "},{"code":"range","type":"codeVoice"},{"type":"text","text":", some vertices will effectively be removed."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"range","type":"codeVoice"},{"type":"text","text":" extends beyond the shape’s "},{"code":"coordinates","type":"codeVoice"},{"type":"text","text":" property, an"},{"type":"text","text":" "},{"code":"NSRangeException","type":"codeVoice"},{"type":"text","text":" is raised. If you want to append new vertices to the shape,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"code":"-appendCoordinates:count:","type":"codeVoice"},{"text":" method.","type":"text"}]}]}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmultipoint\/replacecoordinatesinrange:withcoordinates:count:"]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection","url":"\/documentation\/maplibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPoint":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint","url":"\/documentation\/maplibre\/mlnmultipoint","role":"symbol","kind":"symbol","title":"MLNMultiPoint","abstract":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint","isActive":true},{"text":" class is an abstract superclass used to define shapes","type":"text"},{"text":" ","type":"text"},{"text":"composed of multiple vertices.","type":"text"}],"fragments":[{"text":"MLNMultiPoint","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/shape":{"title":"shape","kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesource\/shape","role":"symbol","fragments":[{"text":"shape","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape","type":"topic","abstract":[{"text":"The contents of the source. A shape can represent a GeoJSON geometry, a","type":"text"},{"text":" ","type":"text"},{"text":"feature, or a collection of features.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","url":"\/documentation\/maplibre\/mlnstyle","abstract":[{"type":"text","text":"The proxy object for the current map style."}],"type":"topic","role":"symbol","fragments":[{"kind":"identifier","text":"MLNStyle"}],"kind":"symbol","title":"MLNStyle"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"url":"\/documentation\/maplibre\/mlnshapesource","kind":"symbol","fragments":[{"text":"MLNShapeSource","kind":"identifier"}],"abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"type":"text","text":" is a map content source that supplies vector shapes to be"},{"type":"text","text":" "},{"type":"text","text":"shown on the map. The shapes may be instances of "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":" or "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or they may be defined by local or external"},{"type":"text","text":" "},{"type":"text","text":"GeoJSON"},{"type":"text","text":" code. A shape source is added to an"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"type":"text","text":" object along with an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the shape source. You"},{"type":"text","text":" "},{"type":"text","text":"can update a shape source by setting its "},{"code":"shape","type":"codeVoice"},{"type":"text","text":" or "},{"code":"URL","type":"codeVoice"},{"type":"text","text":" property."}],"type":"topic","role":"symbol","title":"MLNShapeSource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},"