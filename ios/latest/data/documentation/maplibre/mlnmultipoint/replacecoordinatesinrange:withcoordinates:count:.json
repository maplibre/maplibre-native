{"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"abstract":[{"text":"Replaces the vertices at the given range in the shape with the specified number","type":"text"},{"text":" ","type":"text"},{"text":"of vertices from a given C array.","type":"text"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint\/replaceCoordinatesInRange:withCoordinates:count:"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint"]]},"primaryContentSections":[{"declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"],"tokens":[{"kind":"text","text":"- ("},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"kind":"identifier","text":"replaceCoordinatesInRange:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"NSRange","preciseIdentifier":"c:@S@_NSRange"},{"kind":"text","text":") "},{"kind":"internalParam","text":"range"},{"kind":"text","text":" "},{"kind":"identifier","text":"withCoordinates:"},{"kind":"text","text":"("},{"kind":"keyword","text":"const"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"CLLocationCoordinate2D","preciseIdentifier":"c:@S@CLLocationCoordinate2D"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"coords"},{"kind":"text","text":" "},{"kind":"identifier","text":"count:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"NSUInteger","preciseIdentifier":"c:@T@NSUInteger"},{"kind":"text","text":") "},{"kind":"internalParam","text":"count"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"range","content":[{"type":"paragraph","inlineContent":[{"text":"The range of vertices to replace. The ","type":"text"},{"code":"location","type":"codeVoice"},{"text":" field indicates","type":"text"},{"text":" ","type":"text"},{"text":"the first vertex you are replacing, with ","type":"text"},{"code":"0","type":"codeVoice"},{"text":" being the first vertex, ","type":"text"},{"code":"1","type":"codeVoice"},{"text":" ","type":"text"},{"text":"being the second vertex, and so on. The ","type":"text"},{"code":"length","type":"codeVoice"},{"text":" field indicates the number","type":"text"},{"text":" ","type":"text"},{"text":"of vertices to replace.","type":"text"}]}]},{"name":"coords","content":[{"type":"paragraph","inlineContent":[{"text":"The array of coordinates defining part of the shape. The data in","type":"text"},{"text":" ","type":"text"},{"text":"this array is copied to the shape’s ","type":"text"},{"code":"coordinates","type":"codeVoice"},{"text":" property.","type":"text"}]}]},{"name":"count","content":[{"type":"paragraph","inlineContent":[{"text":"The number of coordinates from the ","type":"text"},{"code":"coords","type":"codeVoice"},{"text":" array to insert in","type":"text"},{"text":" ","type":"text"},{"text":"place of the coordinates in ","type":"text"},{"code":"range","type":"codeVoice"},{"text":". The sum of ","type":"text"},{"code":"range","type":"codeVoice"},{"text":"’s length and this","type":"text"},{"text":" ","type":"text"},{"text":"count must not exceed the number of items currently in the ","type":"text"},{"code":"coordinates","type":"codeVoice"},{"text":" ","type":"text"},{"text":"property.","type":"text"}]}]}]},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the shape is currently visible on the map as an annotation, it is redrawn"},{"type":"text","text":" "},{"type":"text","text":"immediately. If the shape is part of an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"type":"text","text":" object, you must"},{"type":"text","text":" "},{"type":"text","text":"explicitly set the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape","type":"reference","isActive":true},{"type":"text","text":" property in order for any style"},{"type":"text","text":" "},{"type":"text","text":"layers that use the source to be redrawn."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"count"},{"type":"text","text":" is greater than the "},{"type":"codeVoice","code":"length"},{"type":"text","text":" field of "},{"type":"codeVoice","code":"range"},{"type":"text","text":", some vertices will"},{"type":"text","text":" "},{"type":"text","text":"effectively be inserted into the shape. On the other hand, if "},{"type":"codeVoice","code":"count"},{"type":"text","text":" is less"},{"type":"text","text":" "},{"type":"text","text":"than the "},{"type":"codeVoice","code":"length"},{"type":"text","text":" field of "},{"type":"codeVoice","code":"range"},{"type":"text","text":", some vertices will effectively be removed."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"range"},{"type":"text","text":" extends beyond the shape’s "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" property, an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSRangeException"},{"type":"text","text":" is raised. If you want to append new vertices to the shape,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"type":"codeVoice","code":"-appendCoordinates:count:"},{"type":"text","text":" method."}]}],"kind":"content"}],"metadata":{"role":"symbol","title":"replaceCoordinatesInRange:withCoordinates:count:","roleHeading":"Instance Method","externalID":"c:objc(cs)MLNMultiPoint(im)replaceCoordinatesInRange:withCoordinates:count:","symbolKind":"method","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"text":"- ","kind":"text"},{"text":"replaceCoordinatesInRange:withCoordinates:count:","kind":"identifier"}],"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"