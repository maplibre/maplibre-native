{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint\/replaceCoordinatesInRange:withCoordinates:count:"},"sections":[],"abstract":[{"type":"text","text":"Replaces the vertices at the given range in the shape with the specified number"},{"type":"text","text":" "},{"type":"text","text":"of vertices from a given C array."}],"variants":[{"paths":["\/documentation\/maplibre\/mlnmultipoint\/replacecoordinatesinrange:withcoordinates:count:"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"text","text":"- ("},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"kind":"identifier","text":"replaceCoordinatesInRange:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"NSRange","preciseIdentifier":"c:@S@_NSRange"},{"kind":"text","text":") "},{"kind":"internalParam","text":"range"},{"kind":"text","text":" "},{"kind":"identifier","text":"withCoordinates:"},{"kind":"text","text":"("},{"kind":"keyword","text":"const"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"CLLocationCoordinate2D","preciseIdentifier":"c:@S@CLLocationCoordinate2D"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"coords"},{"kind":"text","text":" "},{"kind":"identifier","text":"count:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"NSUInteger","preciseIdentifier":"c:@T@NSUInteger"},{"kind":"text","text":") "},{"kind":"internalParam","text":"count"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS","iPadOS","Mac Catalyst"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The range of vertices to replace. The "},{"type":"codeVoice","code":"location"},{"type":"text","text":" field indicates"},{"type":"text","text":" "},{"type":"text","text":"the first vertex you are replacing, with "},{"type":"codeVoice","code":"0"},{"type":"text","text":" being the first vertex, "},{"type":"codeVoice","code":"1"},{"type":"text","text":" "},{"type":"text","text":"being the second vertex, and so on. The "},{"type":"codeVoice","code":"length"},{"type":"text","text":" field indicates the number"},{"type":"text","text":" "},{"type":"text","text":"of vertices to replace."}]}],"name":"range"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The array of coordinates defining part of the shape. The data in"},{"type":"text","text":" "},{"type":"text","text":"this array is copied to the shape’s "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" property."}]}],"name":"coords"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The number of coordinates from the "},{"type":"codeVoice","code":"coords"},{"type":"text","text":" array to insert in"},{"type":"text","text":" "},{"type":"text","text":"place of the coordinates in "},{"type":"codeVoice","code":"range"},{"type":"text","text":". The sum of "},{"code":"range","type":"codeVoice"},{"text":"’s length and this","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"count must not exceed the number of items currently in the "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" "},{"type":"text","text":"property."}]}],"name":"count"}]},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"If the shape is currently visible on the map as an annotation, it is redrawn"},{"type":"text","text":" "},{"type":"text","text":"immediately. If the shape is part of an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true},{"type":"text","text":" object, you must"},{"type":"text","text":" "},{"type":"text","text":"explicitly set the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape","isActive":true},{"type":"text","text":" property in order for any style"},{"type":"text","text":" "},{"type":"text","text":"layers that use the source to be redrawn."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"count","type":"codeVoice"},{"type":"text","text":" is greater than the "},{"code":"length","type":"codeVoice"},{"type":"text","text":" field of "},{"code":"range","type":"codeVoice"},{"type":"text","text":", some vertices will"},{"type":"text","text":" "},{"type":"text","text":"effectively be inserted into the shape. On the other hand, if "},{"code":"count","type":"codeVoice"},{"type":"text","text":" is less"},{"type":"text","text":" "},{"type":"text","text":"than the "},{"type":"codeVoice","code":"length"},{"text":" field of ","type":"text"},{"type":"codeVoice","code":"range"},{"text":", some vertices will effectively be removed.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"range"},{"type":"text","text":" extends beyond the shape’s "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" property, an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSRangeException"},{"type":"text","text":" is raised. If you want to append new vertices to the shape,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"type":"codeVoice","code":"-appendCoordinates:count:"},{"type":"text","text":" method."}]}],"kind":"content"}],"metadata":{"role":"symbol","navigatorTitle":[{"kind":"text","text":"- "},{"kind":"identifier","text":"replaceCoordinatesInRange:withCoordinates:count:"}],"fragments":[{"text":"- ","kind":"text"},{"text":"replaceCoordinatesInRange:withCoordinates:count:","kind":"identifier"}],"title":"replaceCoordinatesInRange:withCoordinates:count:","externalID":"c:objc(cs)MLNMultiPoint(im)replaceCoordinatesInRange:withCoordinates:count:","symbolKind":"method","modules":[{"name":"MapLibre"}],"roleHeading":"Instanc