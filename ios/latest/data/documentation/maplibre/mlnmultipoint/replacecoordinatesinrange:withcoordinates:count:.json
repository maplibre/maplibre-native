ation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"text":" is an abstract class that represents a shape or annotation. Shapes","type":"text"},{"text":" ","type":"text"},{"text":"constitute the content of a map — not only the overlays atop the map, but also","type":"text"},{"text":" ","type":"text"},{"text":"the content that forms the base map.","type":"text"}],"kind":"symbol","fragments":[{"text":"MLNShape","kind":"identifier"}],"role":"symbol","title":"MLNShape"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPoint/replaceCoordinatesInRange:withCoordinates:count:":{"abstract":[{"text":"Replaces the vertices at the given range in the shape with the specified number","type":"text"},{"text":" ","type":"text"},{"text":"of vertices from a given C array.","type":"text"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnmultipoint\/replacecoordinatesinrange:withcoordinates:count:","title":"replaceCoordinatesInRange:withCoordinates:count:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint\/replaceCoordinatesInRange:withCoordinates:count:","role":"symbol","navigatorTitle":[{"text":"replaceCoordinatesInRange:withCoordinates:count:","kind":"identifier"}],"fragments":[{"text":"- ","kind":"text"},{"text":"replaceCoordinatesInRange:withCoordinates:count:","kind":"identifier"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"title":"MLNShapeSource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","role":"symbol","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"text":" is a map content source that supplies vector shapes to be","type":"text"},{"text":" ","type":"text"},{"text":"shown on the map. The shapes may be instances of ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"text":" or ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"or they may be defined by local or external","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"GeoJSON"},{"type":"text","text":" code. A shape source is added to an"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object along with an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the shape source. You"},{"type":"text","text":" "},{"type":"text","text":"can update a shape source by setting its "},{"code":"shape","type":"codeVoice"},{"type":"text","text":" or "},{"code":"URL","type":"codeVoice"},{"type":"text","text":" property."}],"kind":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeSource"}],"url":"\/documentation\/maplibre\/mlnshapesource","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"The proxy object for the current map style."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","url":"\/documentation\/maplibre\/mlnstyle","role":"symbol","fragments":[{"text":"MLNStyle","kind":"identifier"}],"title":"MLNStyle"}}}