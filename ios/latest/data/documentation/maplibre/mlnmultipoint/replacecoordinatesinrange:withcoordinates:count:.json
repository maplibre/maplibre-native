{"abstract":[{"text":"Replaces the vertices at the given range in the shape with the specified number","type":"text"},{"text":" ","type":"text"},{"text":"of vertices from a given C array.","type":"text"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint\/replaceCoordinatesInRange:withCoordinates:count:"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"text","text":"- ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"replaceCoordinatesInRange:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:@S@_NSRange","text":"NSRange"},{"kind":"text","text":") "},{"kind":"internalParam","text":"range"},{"kind":"text","text":" "},{"kind":"identifier","text":"withCoordinates:"},{"kind":"text","text":"("},{"kind":"keyword","text":"const"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"c:@S@CLLocationCoordinate2D","text":"CLLocationCoordinate2D"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"coords"},{"kind":"text","text":" "},{"kind":"identifier","text":"count:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@NSUInteger","text":"NSUInteger"},{"kind":"text","text":") "},{"kind":"internalParam","text":"count"},{"kind":"text","text":";"}]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The range of vertices to replace. The ","type":"text"},{"type":"codeVoice","code":"location"},{"text":" field indicates","type":"text"},{"text":" ","type":"text"},{"text":"the first vertex you are replacing, with ","type":"text"},{"type":"codeVoice","code":"0"},{"text":" being the first vertex, ","type":"text"},{"type":"codeVoice","code":"1"},{"text":" ","type":"text"},{"text":"being the second vertex, and so on. The ","type":"text"},{"type":"codeVoice","code":"length"},{"text":" field indicates the number","type":"text"},{"text":" ","type":"text"},{"text":"of vertices to replace.","type":"text"}]}],"name":"range"},{"content":[{"inlineContent":[{"type":"text","text":"The array of coordinates defining part of the shape. The data in"},{"type":"text","text":" "},{"type":"text","text":"this array is copied to the shape’s "},{"code":"coordinates","type":"codeVoice"},{"type":"text","text":" property."}],"type":"paragraph"}],"name":"coords"},{"content":[{"inlineContent":[{"type":"text","text":"The number of coordinates from the "},{"code":"coords","type":"codeVoice"},{"type":"text","text":" array to insert in"},{"type":"text","text":" "},{"type":"text","text":"place of the coordinates in "},{"code":"range","type":"codeVoice"},{"type":"text","text":". The sum of "},{"code":"range","type":"codeVoice"},{"type":"text","text":"’s length and this"},{"type":"text","text":" "},{"type":"text","text":"count must not exceed the number of items currently in the "},{"code":"coordinates","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"property."}],"type":"paragraph"}],"name":"count"}],"kind":"parameters"},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"If the shape is currently visible on the map as an annotation, it is redrawn","type":"text"},{"text":" ","type":"text"},{"text":"immediately. If the shape is part of an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"text":" object, you must","type":"text"},{"text":" ","type":"text"},{"text":"explicitly set the ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape","type":"reference","isActive":true},{"text":" property in order for any style","type":"text"},{"text":" ","type":"text"},{"text":"layers that use the source to be redrawn.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"count","type":"codeVoice"},{"type":"text","text":" is greater than the "},{"code":"length","type":"codeVoice"},{"type":"text","text":" field of "},{"code":"range","type":"codeVoice"},{"type":"text","text":", some vertices will"},{"type":"text","text":" "},{"type":"text","text":"effectively be inserted into the shape. On the other hand, if "},{"code":"count","type":"codeVoice"},{"type":"text","text":" is less"},{"text":" ","type":"text"},{"text":"than the ","type":"text"},{"code":"length","type":"codeVoice"},{"text":" field of ","type":"text"},{"code":"range","type":"codeVoice"},{"text":", some vertices will effectively be removed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"range","type":"codeVoice"},{"type":"text","text":" extends beyond the shape’s "},{"code":"coordinates","type":"codeVoice"},{"type":"text","text":" property, an"},{"type":"text","text":" "},{"code":"NSRangeException","type":"codeVoice"},{"type":"text","text":" is raised. If you want to append new vertices to the shape,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"code":"-appendCoordinates:count:","type":"codeVoice"},{"text":" method.","type":"text"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmultipoint\/replacecoordinatesinrange:withcoordinates:count:"]}],"kind":"symbol","metadata":{"navigatorTitle":[{"text":"replaceCoordinatesInRange:withCoordinates:count:","kind":"identifier"}],"fragments":[{"text":"- ","kind":"text"},{"text":"replaceCoordinatesInRange:withCoordinates:count:","kind":"identifier"}],"externalID":"c:objc(cs)MLNMultiPoint(im)replaceCoordinatesInRange:withCoordinates:count:","modules":[{"name":"MapLibre"}],"title":"replaceCoordinatesInRange:withCoordinates:count:","symbolKind":"method","roleHeading":"Instance Me