{"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint\/replaceCoordinatesInRange:withCoordinates:count:"},"sections":[],"metadata":{"modules":[{"name":"MapLibre"}],"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"replaceCoordinatesInRange:withCoordinates:count:"}],"role":"symbol","externalID":"c:objc(cs)MLNMultiPoint(im)replaceCoordinatesInRange:withCoordinates:count:","navigatorTitle":[{"kind":"identifier","text":"replaceCoordinatesInRange:withCoordinates:count:"}],"symbolKind":"method","roleHeading":"Instance Method","title":"replaceCoordinatesInRange:withCoordinates:count:"},"abstract":[{"text":"Replaces the vertices at the given range in the shape with the specified number","type":"text"},{"text":" ","type":"text"},{"text":"of vertices from a given C array.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"- ("},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"replaceCoordinatesInRange:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:@S@_NSRange","kind":"typeIdentifier","text":"NSRange"},{"kind":"text","text":") "},{"kind":"internalParam","text":"range"},{"kind":"text","text":" "},{"kind":"identifier","text":"withCoordinates:"},{"kind":"text","text":"("},{"kind":"keyword","text":"const"},{"kind":"text","text":" "},{"preciseIdentifier":"c:@S@CLLocationCoordinate2D","kind":"typeIdentifier","text":"CLLocationCoordinate2D"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"coords"},{"kind":"text","text":" "},{"kind":"identifier","text":"count:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:@T@NSUInteger","kind":"typeIdentifier","text":"NSUInteger"},{"kind":"text","text":") "},{"kind":"internalParam","text":"count"},{"kind":"text","text":";"}]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"The range of vertices to replace. The ","type":"text"},{"code":"location","type":"codeVoice"},{"text":" field indicates","type":"text"},{"text":" ","type":"text"},{"text":"the first vertex you are replacing, with ","type":"text"},{"code":"0","type":"codeVoice"},{"text":" being the first vertex, ","type":"text"},{"code":"1","type":"codeVoice"},{"text":" ","type":"text"},{"text":"being the second vertex, and so on. The ","type":"text"},{"code":"length","type":"codeVoice"},{"text":" field indicates the number","type":"text"},{"text":" ","type":"text"},{"text":"of vertices to replace.","type":"text"}],"type":"paragraph"}],"name":"range"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The array of coordinates defining part of the shape. The data in"},{"type":"text","text":" "},{"type":"text","text":"this array is copied to the shape’s "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" property."}]}],"name":"coords"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The number of coordinates from the "},{"type":"codeVoice","code":"coords"},{"type":"text","text":" array to insert in"},{"type":"text","text":" "},{"type":"text","text":"place of the coordinates in "},{"type":"codeVoice","code":"range"},{"type":"text","text":". The sum of "},{"type":"codeVoice","code":"range"},{"type":"text","text":"’s length and this"},{"type":"text","text":" "},{"type":"text","text":"count must not exceed the number of items currently in the "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" "},{"type":"text","text":"property."}]}],"name":"count"}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"If the shape is currently visible on the map as an annotation, it is redrawn"},{"type":"text","text":" "},{"type":"text","text":"immediately. If the shape is part of an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"type":"text","text":" object, you must"},{"type":"text","text":" "},{"type":"text","text":"explicitly set the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape","type":"reference","isActive":true},{"type":"text","text":" property in order for any style"},{"type":"text","text":" "},{"type":"text","text":"layers that use the source to be redrawn."}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"code":"count","type":"codeVoice"},{"text":" is greater than the ","type":"text"},{"code":"length","type":"codeVoice"},{"text":" field of ","type":"text"},{"code":"range","type":"codeVoice"},{"text":", some vertices will","type":"text"},{"text":" ","type":"text"},{"text":"effectively be inserted into the shape. On the other hand, if ","type":"text"},{"code":"count","type":"codeVoice"},{"text":" is less","type":"text"},{"text":" ","type":"text"},{"text":"than the ","type":"text"},{"code":"length","type":"codeVoice"},{"text":" field of ","type":"text"},{"code":"range","type":"codeVoice"},{"text":", some vertices will effectively be removed.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"code":"range","type":"codeVoice"},{"text":" extends beyond the shape’s ","type":"text"},{"code":"coordinates","type":"codeVoice"},{"text":" property, an","type":"text"},{"text":" ","type":"text"},{"code":"NSRangeException","type":"codeVoice"},{"text":" is raised. If you want to append new vertices to the shape,","type":"text"},{"text":" ","type":"text"},{"text":"use the ","type":"text"},{"code":"-appendCoordinates:count:","type":"codeVoice"},{"text":" method.","type":"text"}],"type":"paragraph"}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/M