. If you want to append new vertices to the shape,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"type":"codeVoice","code":"-appendCoordinates:count:"},{"type":"text","text":" method."}]}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/shape":{"fragments":[{"text":"shape","kind":"identifier"}],"role":"symbol","type":"topic","kind":"symbol","abstract":[{"text":"The contents of the source. A shape can represent a GeoJSON geometry, a","type":"text"},{"text":" ","type":"text"},{"text":"feature, or a collection of features.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape","title":"shape","url":"\/documentation\/maplibre\/mlnshapesource\/shape"},"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","url":"\/documentation\/maplibre","kind":"symbol","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPoint":{"fragments":[{"text":"MLNMultiPoint","kind":"identifier"}],"title":"MLNMultiPoint","type":"topic","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint","role":"symbol","abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint","isActive":true},{"type":"text","text":" class is an abstract superclass used to define shapes"},{"type":"text","text":" "},{"type":"text","text":"composed of multiple vertices."}],"url":"\/documentation\/maplibre\/mlnmultipoint"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"fragments":[{"text":"MLNStyle","kind":"identifier"}],"title":"MLNStyle","type":"topic","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/do