 or a collection of features."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape","role":"symbol","url":"\/documentation\/maplibre\/mlnshapesource\/shape","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPoint":{"type":"topic","fragments":[{"text":"MLNMultiPoint","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint","role":"symbol","title":"MLNMultiPoint","abstract":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint"},{"type":"text","text":" class is an abstract superclass used to define shapes"},{"type":"text","text":" "},{"type":"text","text":"composed of multiple vertices."}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnmultipoint"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPoint/replaceCoordinatesInRange:withCoordinates:count:":{"url":"\/documentation\/maplibre\/mlnmultipoint\/replacecoordinatesinrange:withcoordinates:count:","title":"replaceCoordinatesInRange:withCoordinates:count:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"replaceCoordinatesInRange:withCoordinates:count:"}],"type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"replaceCoordinatesInRange:withCoordinates:count:"}],"abstract":[{"type":"text","text":"Replaces the vertices at the given range in the shape with the specified number"},{"type":"text","text":" "},{"type":"text","text":"of vertices from a given C array."}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint\/replaceCoordinatesInRange:withCoordinates:count:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"topic","role":"symbol","title":"MLNShapeSource","fragments":[{"kind":"identifier","text":"MLN