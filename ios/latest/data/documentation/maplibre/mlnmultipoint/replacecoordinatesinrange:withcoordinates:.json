{"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint"]]},"variants":[{"paths":["\/documentation\/maplibre\/mlnmultipoint\/replacecoordinatesinrange:withcoordinates:"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"Replaces the vertices at the given range in the shape with the same number of"},{"type":"text","text":" "},{"type":"text","text":"vertices from a given C array."}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"- (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"replaceCoordinatesInRange:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:@S@_NSRange","text":"NSRange","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"range","kind":"internalParam"},{"text":" ","kind":"text"},{"kind":"identifier","text":"withCoordinates:"},{"kind":"text","text":"("},{"kind":"keyword","text":"const"},{"kind":"text","text":" "},{"preciseIdentifier":"c:@S@CLLocationCoordinate2D","kind":"typeIdentifier","text":"CLLocationCoordinate2D"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"coords"},{"kind":"text","text":";"}],"languages":["occ"]}],"kind":"declarations"},{"parameters":[{"name":"range","content":[{"type":"paragraph","inlineContent":[{"text":"The range of vertices to replace. The ","type":"text"},{"type":"codeVoice","code":"location"},{"text":" field indicates","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the first vertex you are replacing, with "},{"type":"codeVoice","code":"0"},{"type":"text","text":" being the first vertex, "},{"type":"codeVoice","code":"1"},{"type":"text","text":" "},{"type":"text","text":"being the second vertex, and so on. The "},{"type":"codeVoice","code":"length"},{"type":"text","text":" field indicates the number"},{"type":"text","text":" "},{"type":"text","text":"of vertices to replace."}]}]},{"name":"coords","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The array of coordinates defining part of the shape. The data in"},{"type":"text","text":" "},{"type":"text","text":"this array is copied to the shape’s "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" property."}]}]}],"kind":"parameters"},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"If the shape is currently visible on the map as an annotation, it is redrawn"},{"type":"text","text":" "},{"type":"text","text":"immediately. If the shape is part of an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"type":"text","text":" object, you must"},{"type":"text","text":" "},{"type":"text","text":"explicitly set the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape","type":"reference","isActive":true},{"type":"text","text":" property in order for any style"},{"type":"text","text":" "},{"type":"text","text":"layers that use the source to be redrawn."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The number of coordinates in "},{"type":"codeVoice","code":"coords"},{"type":"text","text":" must be equal to the length of "},{"type":"codeVoice","code":"range"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"If you want to insert or delete one or more vertices, use the"},{"type":"text","text":" "},{"type":"codeVoice","code":"-replaceCoordinatesInRange:withCoordinates:count:"},{"type":"text","text":" method."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"range"},{"type":"text","text":" extends beyond the shape’s "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" property, an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSRangeException"},{"type":"text","text":" is raised. If you want to append new vertices to the shape,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"type":"codeVoice","code":"-appendCoordinates:count:"},{"type":"text","text":" method."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"symbolKind":"method","externalID":"c:objc(cs)MLNMultiPoint(im)replaceCoordinatesInRange:withCoordinates:","navigatorTitle":[{"kind":"identifier","text":"replaceCoordinatesInRange:withCoordinates:"}],"role":"symbol","title":"replaceCoordinatesInRange:withCoordinates:","roleHeading":"Instance Method","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"replaceCoordinatesInRange:withCoordinates:"}],"modules":[{"name":"MapLibre"}]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint\/replaceCoordinatesInRange:withCoordinates:"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"kind":"symbol","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"text":" is an abstract class that represents a shape or annotation. Shapes","type":"text"},{"text":" ","type":"text"},{"text":"constitute the content of a map — not only the overlays atop the map, but also","type":"text"},{"text":" ","type":"text"},{"text":"the content that forms the base map.","type":"text"}],"url":"\/documentation\/maplibre\/mlnshape","title":"MLNShape","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","fragments":[{"kind":"identifier","text":"MLNShape"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPoint":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint","abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint","type":"reference","isActive":true},{"type":"text","text":" class is an abstract superclass used to define shapes"},{"type":"text","text":" "},{"type":"text","text":"composed of multiple vertices."}],"url":"\/documentation\/maplibre\/mlnmultipoint","role":"symbol","type":"topic","fragments":[{"kind":"identifier","text":"MLNMultiPoint"}],"title":"MLNMultiPoint","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/shape":{"fragments":[{"kind":"identifier","text":"shape"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape","abstract":[{"type":"text","text":"The contents of the source. A shape can represent a GeoJSON geometry, a"},{"type":"text","text":" "},{"type":"text","text":"feature, or a collection of features."}],"url":"\/documentation\/maplibre\/mlnshapesource\/shape","title":"shape","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"text":" is a map content source that supplies vector shapes to be","type":"text"},{"text":" ","type":"text"},{"text":"shown on the map. The shapes may be instances of ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"text":" or ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"or they may be defined by local or external","type":"text"},{"text":" ","type":"text"},{"text":"GeoJSON","type":"text"},{"text":" code. A shape source is added to an","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"text":" object along with an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"text":" object. The vector style","type":"text"},{"text":" ","type":"text"},{"text":"layer defines the appearance of any content supplied by the shape source. You","type":"text"},{"text":" ","type":"text"},{"text":"can update a shape source by setting its ","type":"text"},{"code":"shape","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"URL","type":"codeVoice"},{"text":" property.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"topic","fragments":[{"kind":"identifier","text":"MLNShapeSource"}],"url":"\/documentation\/maplibre\/mlnshapesource","title":"MLNShapeSource","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPoint/replaceCoordinatesInRange:withCoordinates:":{"url":"\/documentation\/maplibre\/mlnmultipoint\/replacecoordinatesinrange:withcoordinates:","title":"replaceCoordinatesInRange:withCoordinates:","navigatorTitle":[{"text":"replaceCoordinatesInRange:withCoordinates:","kind":"identifier"}],"type":"topic","fragments":[{"text":"- ","kind":"text"},{"text":"replaceCoordinatesInRange:withCoordinates:","kind":"identifier"}],"abstract":[{"text":"Replaces the vertices at the given range in the shape with the same number of","type":"text"},{"text":" ","type":"text"},{"text":"vertices from a given C array.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint\/replaceCoordinatesInRange:withCoordinates:","kind":"symbol","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"abstract":[{"text":"The proxy object for the current map style.","type":"text"}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","kind":"symbol","fragments":[{"text":"MLNStyle","kind":"identifier"}],"url":"\/documentation\/mapli