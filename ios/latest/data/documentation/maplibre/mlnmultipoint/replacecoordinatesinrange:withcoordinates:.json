xt"},{"text":" ","type":"text"},{"text":"the first vertex you are replacing, with ","type":"text"},{"type":"codeVoice","code":"0"},{"text":" being the first vertex, ","type":"text"},{"type":"codeVoice","code":"1"},{"text":" ","type":"text"},{"text":"being the second vertex, and so on. The ","type":"text"},{"type":"codeVoice","code":"length"},{"text":" field indicates the number","type":"text"},{"text":" ","type":"text"},{"text":"of vertices to replace.","type":"text"}],"type":"paragraph"}]},{"name":"coords","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The array of coordinates defining part of the shape. The data in"},{"type":"text","text":" "},{"type":"text","text":"this array is copied to the shape’s "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" property."}]}]}],"kind":"parameters"},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"text":"If the shape is currently visible on the map as an annotation, it is redrawn","type":"text"},{"text":" ","type":"text"},{"text":"immediately. If the shape is part of an ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference"},{"text":" object, you must","type":"text"},{"text":" ","type":"text"},{"text":"explicitly set the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape","type":"reference"},{"text":" property in order for any style","type":"text"},{"text":" ","type":"text"},{"text":"layers that use the source to be redrawn.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The number of coordinates in "},{"type":"codeVoice","code":"coords"},{"type":"text","text":" must be equal to the length of "},{"type":"codeVoice","code":"range"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"If you want to insert or delete one or more vertices, use the"},{"type":"text","text":" "},{"type":"codeVoice","code":"-replaceCoordinatesInRange:withCoordinates:count:"},{"type":"text","text":" method."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"range"},{"type":"text","text":" extends beyond the shape’s "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" property, an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSRangeException"},{"type":"text","text":" is raised. If you want to append new vertices to the shape,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"type":"codeVoice","code":"-appendCoordinates:count:"},{"type":"text","text":" method."}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"type":"text","text":"Replaces the vertices at the given range in the shape with the same number of"},{"type":"text","text":" "},{"type":"text","text":"vertices from a given C array."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/shape":{"role":"symbol","abstract":[{"text":"The contents of the source. A shape can represent a GeoJSON geometry, a","type":"text"},{"text":" ","type":"text"},{"text":"feature, or a collection of features.","type":"text"}],"url":"\/documentation\/maplibre\/mlnshapesource\/shape","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape","fragments":[{"kind":"identifier","text":"shape"}],"type":"topic","title":"shape","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","url":"\/documentation\/maplibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"role":"collection","title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPoint":{"kind":"symbol","identif