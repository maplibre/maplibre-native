{"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint"]]},"abstract":[{"type":"text","text":"Replaces the vertices at the given range in the shape with the same number of"},{"type":"text","text":" "},{"type":"text","text":"vertices from a given C array."}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint\/replaceCoordinatesInRange:withCoordinates:"},"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"modules":[{"name":"MapLibre"}],"title":"replaceCoordinatesInRange:withCoordinates:","roleHeading":"Instance Method","externalID":"c:objc(cs)MLNMultiPoint(im)replaceCoordinatesInRange:withCoordinates:","fragments":[{"text":"- ","kind":"text"},{"text":"replaceCoordinatesInRange:withCoordinates:","kind":"identifier"}],"navigatorTitle":[{"text":"replaceCoordinatesInRange:withCoordinates:","kind":"identifier"}],"role":"symbol","symbolKind":"method"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"- (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"replaceCoordinatesInRange:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSRange","preciseIdentifier":"c:@S@_NSRange","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"range","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"withCoordinates:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"const","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CLLocationCoordinate2D","preciseIdentifier":"c:@S@CLLocationCoordinate2D","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"coords","kind":"internalParam"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"name":"range","content":[{"inlineContent":[{"text":"The range of vertices to replace. The ","type":"text"},{"code":"location","type":"codeVoice"},{"text":" field indicates","type":"text"},{"text":" ","type":"text"},{"text":"the first vertex you are replacing, with ","type":"text"},{"code":"0","type":"codeVoice"},{"text":" being the first vertex, ","type":"text"},{"code":"1","type":"codeVoice"},{"text":" ","type":"text"},{"text":"being the second vertex, and so on. The ","type":"text"},{"code":"length","type":"codeVoice"},{"text":" field indicates the number","type":"text"},{"text":" ","type":"text"},{"text":"of vertices to replace.","type":"text"}],"type":"paragraph"}]},{"name":"coords","content":[{"type":"paragraph","inlineContent":[{"text":"The array of coordinates defining part of the shape. The data in","type":"text"},{"text":" ","type":"text"},{"text":"this array is copied to the shape’s ","type":"text"},{"code":"coordinates","type":"codeVoice"},{"text":" property.","type":"text"}]}]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"If the shape is currently visible on the map as an annotation, it is redrawn"},{"type":"text","text":" "},{"type":"text","text":"immediately. If the shape is part of an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":" object, you must"},{"type":"text","text":" "},{"type":"text","text":"explicitly set the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape"},{"type":"text","text":" property in order for any style"},{"type":"text","text":" "},{"type":"text","text":"layers that use the source to be redrawn."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The number of coordinates in "},{"type":"codeVoice","code":"coords"},{"type":"text","text":" must be equal to the length of "},{"type":"codeVoice","code":"range"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"If you want to insert or delete one or more vertices, use the"},{"type":"text","text":" "},{"type":"codeVoice","code":"-replaceCoordinatesInRange:withCoordinates:count:"},{"type":"text","text":" method."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"range"},{"type":"text","text":" extends beyond the shape’s "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" property, an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSRangeException"},{"type":"text","text":" is raised. If you want to append new vertices to the shape,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"type":"codeVoice","code":"-appendCoordinates:count:"},{"type":"text","text":" method."}],"type":"paragraph"}]}],"kind":"symbol","variants":[{"paths":["\/documentation\/maplibre\/mlnmultipoint\/replacecoordinatesinrange:withcoordinates:"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"fragments":[{"kind":"identifier","text":"MLNShapeSource"}],"abstract":[{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference"},{"type":"text","text":" is a map content source that supplies vector shapes to be"},{"type":"text","text":" "},{"type":"text","text":"shown on the map. The shapes may be instances of "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference"},{"type":"text","text":" or "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or they may be defined by local or external"},{"type":"text","text":" "},{"type":"text","text":"GeoJSON"},{"type":"text","text":" code. A shape source is added to an"},{"type":"text","text":" "},{"isAct