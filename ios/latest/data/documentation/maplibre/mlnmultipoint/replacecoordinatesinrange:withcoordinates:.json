xt","text":" extends beyond the shape’s "},{"type":"codeVoice","code":"coordinates"},{"type":"text","text":" property, an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSRangeException"},{"type":"text","text":" is raised. If you want to append new vertices to the shape,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"type":"codeVoice","code":"-appendCoordinates:count:"},{"type":"text","text":" method."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint"]]},"sections":[],"abstract":[{"type":"text","text":"Replaces the vertices at the given range in the shape with the same number of"},{"type":"text","text":" "},{"type":"text","text":"vertices from a given C array."}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint\/replaceCoordinatesInRange:withCoordinates:","interfaceLanguage":"occ"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"url":"\/documentation\/maplibre\/mlnstyle","fragments":[{"text":"MLNStyle","kind":"identifier"}],"role":"symbol","abstract":[{"text":"The proxy object for the current map style.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","title":"MLNStyle","type":"topic","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource/shape":{"url":"\/documentation\/maplibre\/mlnshapesource\/shape","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource\/shape","abstract":[{"type":"text","text":"The contents of the source. A shape can represent a GeoJSON geometry, a"},{"type":"text","text":" "},{"type":"text","text":"feature, or a collection of features."}],"type":"topic","role":"symbol","title":"shape","kind":"symbol","fragments":[{"text":"shape","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPoint