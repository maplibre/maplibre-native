ained"},{"type":"text","text":" "},{"type":"text","text":"by the map view."}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage","title":"MLNAnnotationImage","type":"topic","fragments":[{"kind":"identifier","text":"MLNAnnotationImage"}],"role":"symbol","url":"\/documentation\/maplibre\/mlnannotationimage"}}}