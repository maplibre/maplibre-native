kground style layer to configure a color or pattern to show below all"},{"type":"text","text":" "},{"type":"text","text":"other map content. If the style’s other layers use the Mapbox Streets source,"},{"type":"text","text":" "},{"type":"text","text":"the background style layer is responsible for drawing land, whereas the oceans"},{"type":"text","text":" "},{"type":"text","text":"and other bodies of water are drawn by "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNBackgroundStyleLayer","isActive":true},{"type":"text","text":" objects."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNFillStyleLayer/fillTranslation":{"url":"\/documentation\/maplibre\/mlnfillstylelayer\/filltranslation","role":"symbol","type":"topic","fragments":[{"kind":"identifier","text":"fillTranslation"}],"title":"fillTranslation","abstract":[{"type":"text","text":"The geometry’s offset."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFillStyleLayer\/fillTranslation","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNFillExtrusionStyleLayer":{"kind":"symbol","fragments":[{"kind":"identifier","text":"MLNFillExtrusionStyleLayer"}],"role":"symbol","title":"MLNFillExtrusionStyleLayer","abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFillExtrusionStyleLayer","isActive":true},{"type":"text","text":" is a style layer that renders one or more 3D"},{"type":"text","text":" "},{"type":"text","text":"extruded polygons on the map."}],"url":"\/documentation\/maplibre\/mlnfillextrusionstylelayer","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFillExtrusionStyleLayer"},"doc://org.swift.MyProject/documentation/MapLibre/MLNFillStyleLayer/fillPattern":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFillStyleLayer\/fillPattern","type":"topic","abstract":[{"type":"text","text"