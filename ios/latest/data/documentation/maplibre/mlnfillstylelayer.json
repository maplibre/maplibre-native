 "},{"type":"codeVoice","code":"URL"},{"type":"text","text":" property."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNFillStyleLayer":{"kind":"symbol","abstract":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFillStyleLayer"},{"type":"text","text":" is a style layer that renders one or more filled (and"},{"type":"text","text":" "},{"type":"text","text":"optionally stroked) polygons on the map."}],"role":"symbol","title":"MLNFillStyleLayer","fragments":[{"text":"MLNFillStyleLayer","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFillStyleLayer","type":"topic","url":"\/documentation\/maplibre\/mlnfillstylelayer"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"type":"topic","role":"symbol","url":"\/documentation\/maplibre\/mlnstyle","title":"MLNStyle","abstract":[{"type":"text","text":"The proxy object for the current map style."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","fragments":[{"kind":"identifier","text":"MLNStyle"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNBackgroundStyleLayer":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNBackgroundStyleLayer","kind":"symbol","abstract":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNBackgroundStyleLayer","isActive":true,"type":"reference"},{"text":" is a style layer that covers the entire map. Use","type":"text"},{"text":" ","type":"text"},{"text":"a background style layer to configure a color or pattern to show below all","type":"text"},{"text":" ","type":"text"},{"text":"other map content. If the style’s other layers use the Mapbox Streets source,","type":"text"},{"text":" ","type":"text"},{"text":"the background style layer is responsible for drawing land, whereas the oceans","type":"text"},{"text":" ","type":"text"},{"text":"and other bodies of water are drawn by ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNBackgroundStyleLayer","isActive":true,"type":"reference"},{"text":" objects.","type":"text"}],"type":"topic","title":"MLNBackgroundStyleLayer","fragments":[{"text":"MLNBackgroundStyleLayer","kind":"identifier"}],"role":"symbol","url":"\/documentation\/maplibre\/mlnbackgroundstylelayer"},"doc://org.swift.MyProject/documentation/MapLibre/MLNHillshadeStyleLayer":{"fragments":[{"text":"MLNHillshadeStyleLayer","kind":"identifier"}],"abstract":[{"text":"An ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer"},{"text":" is a style layer that renders raster ","type":"text"},{"text":"digital elevation","type":"text"},{"text":" ","type":"text"},{"text":"model","type":"text"},{"text":" (DEM) tiles on the map.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNHillshadeStyleLayer","role":"symbol","title":"MLNHillshadeStyleLayer","url":"\/documentation\/maplibre\/mlnhillshadestylelayer","kind":"symbol","type":"topic"}}}