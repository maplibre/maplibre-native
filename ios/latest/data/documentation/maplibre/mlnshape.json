ect is known as a point annotation or point shape. For"},{"type":"text","text":" "},{"type":"text","text":"example, you could use a point shape to represent a city at low zoom levels, an"},{"type":"text","text":" "},{"type":"text","text":"address at high zoom levels, or the location of a long press gesture."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation","title":"MLNPointAnnotation","role":"symbol","url":"\/documentation\/maplibre\/mlnpointannotation","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNEmptyFeature":{"type":"topic","fragments":[{"text":"MLNEmptyFeature","kind":"identifier"}],"abstract":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNEmptyFeature","type":"reference","isActive":true},{"text":" object associates an empty shape with an optional","type":"text"},{"text":" ","type":"text"},{"text":"identifier and attributes.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNEmptyFeature","title":"MLNEmptyFeature","role":"symbol","url":"\/documentation\/maplibre\/mlnemptyfeature","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeCollection":{"type":"topic","fragments":[{"text":"MLNShapeCollection","kind":"identifier"}],"abstract":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollection","type":"reference","isActive":true},{"text":" object represents a shape consisting of zero or more","type":"text"},{"text":" ","type":"text"},{"text":"distinct but related shapes that are instances of ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"text":". The constituent","type":"text"},{"text":" ","type":"text"},{"text":"shapes can be a mixture of different kinds of shapes.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLi