:"text"},{"text":" ","type":"text"},{"text":"annotations or overlays.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can filter the features in a "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","type":"reference","isActive":true},{"type":"text","text":" or vary their layout or"},{"type":"text","text":" "},{"type":"text","text":"paint attributes based on the features’ geographies. Pass an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference","isActive":true},{"type":"text","text":" into an"},{"type":"text","text":" "},{"code":"NSPredicate","type":"codeVoice"},{"type":"text","text":" with the format "},{"code":"SELF IN %@","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"%@ CONTAINS SELF","type":"codeVoice"},{"text":" and set the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer\/predicate","isActive":true,"type":"reference"},{"text":" property to that predicate, or set a layout or","type":"text"},{"text":" ","type":"text"},{"text":"paint attribute to a similarly formatted ","type":"text"},{"code":"NSExpression","type":"codeVoice"},{"text":".","type":"text"}]}]}],"metadata":{"modules":[{"name":"MapLibre"}],"symbolKind":"class","fragments":[{"text":"MLNShape","kind":"identifier"}],"title":"MLNShape","role":"symbol","roleHeading":"Class","navigatorTitle":[{"text":"MLNShape","kind":"identifier"}],"externalID":"c:objc(cs)MLNShape"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorStyleLayer/predicate":{"role":"symbol","abstract":[{"type":"text","text":"The style layer’s predicate."}],"title":"predicate","url":"\/documentation\/maplibre\/mlnvectorstylelayer\/predicate","type":"topic","fragments":[{"text":"predicate","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer\/predicate