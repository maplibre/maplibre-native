xt":" "},{"type":"text","text":"annotations or overlays."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can filter the features in a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer"},{"type":"text","text":" or vary their layout or"},{"type":"text","text":" "},{"type":"text","text":"paint attributes based on the features’ geographies. Pass an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":" into an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSPredicate"},{"type":"text","text":" with the format "},{"type":"codeVoice","code":"SELF IN %@"},{"text":" or ","type":"text"},{"code":"%@ CONTAINS SELF","type":"codeVoice"},{"text":" and set the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer\/predicate","isActive":true,"type":"reference"},{"text":" property to that predicate, or set a layout or","type":"text"},{"text":" ","type":"text"},{"text":"paint attribute to a similarly formatted ","type":"text"},{"code":"NSExpression","type":"codeVoice"},{"text":".","type":"text"}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","interfaceLanguage":"occ"},"topicSections":[{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape\/subtitle","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape\/title"],"generated":true,"title":"Instance Properties","anchor":"Instance-Properties"},{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape\/geoJSONDataUsingEncoding:"],"generated":true,"title":"Instance Methods","anchor":"Instance-Methods"},{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape\/shapeWithData:encoding:error:"],"generated":true,"title":"Type Methods","ancho