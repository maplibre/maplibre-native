ou can filter the features in a "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","type":"reference"},{"type":"text","text":" or vary their layout or"},{"type":"text","text":" "},{"type":"text","text":"paint attributes based on the features’ geographies. Pass an "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference"},{"type":"text","text":" into an"},{"type":"text","text":" "},{"code":"NSPredicate","type":"codeVoice"},{"type":"text","text":" with the format "},{"code":"SELF IN %@","type":"codeVoice"},{"type":"text","text":" or "},{"code":"%@ CONTAINS SELF","type":"codeVoice"},{"type":"text","text":" and set the"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer\/predicate","type":"reference"},{"type":"text","text":" property to that predicate, or set a layout or"},{"type":"text","text":" "},{"type":"text","text":"paint attribute to a similarly formatted "},{"code":"NSExpression","type":"codeVoice"},{"type":"text","text":"."}]}],"kind":"content"}],"kind":"symbol","metadata":{"fragments":[{"text":"MLNShape","kind":"identifier"}],"navigatorTitle":[{"text":"MLNShape","kind":"identifier"}],"externalID":"c:objc(cs)MLNShape","symbolKind":"class","title":"MLNShape","role":"symbol","modules":[{"name":"MapLibre"}],"roleHeading":"Class"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnshape"]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPoint":{"fragments":[{"kind":"identifier","text":"MLNMultiPoint"}],"title":"MLNMultiPoint","abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint","isActive":true},{"type":"text","text":" class is an abstract superclass used to define shapes"},{"type":"text","text":" "},{