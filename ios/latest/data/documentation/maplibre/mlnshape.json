by the shape source. You"},{"type":"text","text":" "},{"type":"text","text":"can update a shape source by setting its "},{"type":"codeVoice","code":"shape"},{"type":"text","text":" or "},{"type":"codeVoice","code":"URL"},{"type":"text","text":" property."}],"type":"topic","fragments":[{"kind":"identifier","text":"MLNShapeSource"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","url":"\/documentation\/maplibre\/mlnshapesource","role":"symbol","title":"MLNShapeSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape/title":{"type":"topic","abstract":[{"type":"text","text":"The title of the shape annotation."}],"kind":"symbol","fragments":[{"kind":"identifier","text":"title"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape\/title","title":"title","role":"symbol","url":"\/documentation\/maplibre\/mlnshape\/title"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape/subtitle":{"title":"subtitle","url":"\/documentation\/maplibre\/mlnshape\/subtitle","fragments":[{"text":"subtitle","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape\/subtitle","abstract":[{"text":"The subtitle of the shape annotation. The default value of this property is","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":".","type":"text"}],"role":"symbol","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape/geoJSONDataUsingEncoding:":{"navigatorTitle":[{"kind":"identifier","text":"geoJSONDataUsingEncoding:"}],"role":"symbol","abstract":[{"text":"Returns the GeoJSON string representation of the shape encapsulated in a data","type":"text"},{"text":" ","type":"text"},{"text":"object.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape\/geoJSONDataUsingEncoding:","title":"geoJSONDataUsingEncoding:","kind":"symbol","type":"topic","url":"\/documentation