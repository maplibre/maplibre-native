":"Type-Methods","title":"Type Methods"}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"@interface","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MLNShape","kind":"identifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSObject","text":"NSObject","kind":"typeIdentifier"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create instances of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation"},{"type":"text","text":", "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation"},{"type":"text","text":", "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolyline"},{"type":"text","text":", "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolyline"},{"type":"text","text":", "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolyline"},{"type":"text","text":", or "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolyline"},{"type":"text","text":" in"},{"type":"text","text":" "},{"type":"text","text":"order to use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":"’s methods. Do not create instances of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":" "},{"type":"text","text":"directly, and do not create your own subclasses of this class. The shape"},{"type":"text","text":" "},{"type":"text","text":"classes correspond to the"},{"type":"text","text":" "},{"type":"text","text":"Geometry"},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"types in the GeoJSON standard, but some have nonstandard names for backwards"},{"type":"text","text":" "},{"type":"text","text":"compatibility."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Although you do not create instances of this class directly, you can use its"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape\/shapeWithData:encoding:error:","type":"reference"},{"type":"text","text":" factory method to create one of the"},{"type":"text","text":" "},{"type":"text","text":"concrete subclasses of "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference"},{"type":"text","text":" noted above from GeoJSON data. To access a"},{"type":"text","text":" "},{"type":"text","text":"shape’s attributes, use the corresponding "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature","type":"reference"},{"type":"text","text":" class instead."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can add shapes to the map by adding them to an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":" object."},{"type":"text","text":" "},{"type":"text","text":"Configure the appearance of an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":"’s or "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":"’s"},{"type":"text","text":" "},{"type":"text","text":"shapes collectively using a concrete instance of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Alternatively, you can add some kinds of shapes directly to a map view as"},{"type":"text","text":" "},{"type":"text","text":"annotations or overlays."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can filter the features in a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer"},{"type":"text","text":" or vary their layout or"},{"type":"text","text":" "},{"type":"text","text":"paint attributes based on the features’ geographies. Pass an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":" into an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSPredicate"},{"type":"text","text":" with the format "},{"type":"codeVoice","code":"SELF IN %@"},{"type":"text","text":" or "},{"type":"codeVoice","code":"%@ CONTAINS SELF"},{"type":"text","text":" and set the"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer\/predicate"},{"type":"text","text":" property to that predicate, or set a layout or"},{"type":"text","text":" "},{"type":"text","text":"paint attribute to a similarly formatted "},{"type":"codeVoice","code":"NSExpression"},{"type":"text","text":"."}]}]}],"variants":[{"paths":["\/documentation\/maplibre\/mlnshape"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"symbol","seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNEmptyFeature","doc:\/\/org.swift.MyProject\/docum