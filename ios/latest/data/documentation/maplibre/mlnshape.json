text":" "},{"type":"text","text":"classes correspond to the"},{"type":"text","text":" "},{"type":"text","text":"Geometry"},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"types in the GeoJSON standard, but some have nonstandard names for backwards"},{"type":"text","text":" "},{"type":"text","text":"compatibility."}]},{"type":"paragraph","inlineContent":[{"text":"Although you do not create instances of this class directly, you can use its","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape\/shapeWithData:encoding:error:"},{"text":" factory method to create one of the","type":"text"},{"text":" ","type":"text"},{"text":"concrete subclasses of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"text":" noted above from GeoJSON data. To access a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"shape’s attributes, use the corresponding "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature"},{"text":" class instead.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You can add shapes to the map by adding them to an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true,"type":"reference"},{"text":" object.","type":"text"},{"text":" ","type":"text"},{"text":"Configure the appearance of an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true,"type":"reference"},{"text":"’s or ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true,"type":"reference"},{"text":"’s","type":"text"},{"text":" ","type":"text"},{"text":"shapes collectively using a concrete instance of ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","isActive":true,"type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Alternatively, you can add some kinds of shapes directly to a map view as","type":"text"},{"text":" ","type":"text"},{"text":"annotations or overlays.","type":"text"}]},{"inlineContent":[{"type":"text","text":"You can filter the features in a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer"},{"type":"text","text":" or vary their layout or"},{"type":"text","text":" "},{"type":"text","text":"paint attributes based on the features’ geographies. Pass an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":" into an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSPredicate"},{"type":"text","text":" with the format "},{"type":"codeVoice","code":"SELF IN %@"},{"text":" or ","type":"text"},{"code":"%@ CONTAINS SELF","type":"codeVoice"},{"text":" and set the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer\/predicate","type":"reference"},{"text":" property to that predicate, or set a layout or","type":"text"},{"text":" ","type":"text"},{"text":"paint attribute to a similarly formatted ","type":"text"},{"code":"NSExpression","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"kind":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","role":"symbol","url":"\/documentation\/maplibre\/mlnstyle","fragments":[{"kind":"identifier","text":"MLNStyle"}],"abstract":[{"type":"text","text":"The proxy object for the current map style."}],"title":"MLNStyle"},"doc://org.swift.MyProject/docume