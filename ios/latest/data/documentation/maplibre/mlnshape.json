umentation\/MapLibre\/MLNPointAnnotation","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolyline","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolyline","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolyline","isActive":true},{"type":"text","text":", or "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolyline","isActive":true},{"type":"text","text":" in"},{"type":"text","text":" "},{"type":"text","text":"order to use "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":"’s methods. Do not create instances of "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":" "},{"type":"text","text":"directly, and do not create your own subclasses of this class. The shape"},{"type":"text","text":" "},{"type":"text","text":"classes correspond to the"},{"type":"text","text":" "},{"type":"text","text":"Geometry"},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"types in the GeoJSON standard, but some have nonstandard names for backwards"},{"type":"text","text":" "},{"type":"text","text":"compatibility."}],"type":"paragraph"},{"inlineContent":[{"text":"Although you do not create instances of this class directly, you can use its","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape\/shapeWithData:encoding:error:","isActive":true,"type":"reference"},{"text":" factory method to create one of the","type":"text"},{"text":" ","type":"text"},{"text":"concrete subclasses of ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true,"type":"reference"},{"text":" noted above from GeoJSON data. To access a","type":"text"},{"text":" ","type":"text"},{"text":"shape’s attributes, use the corresponding ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNFeature","isActive":true,"type":"reference"},{"text":" class instead.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"You can add shapes to the map by adding them to an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"text":" object.","type":"text"},{"text":" ","type":"text"},{"text":"Configure the appearance of an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"text":"’s or ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"text":"’s","type":"text"},{"text":" ","type":"text"},{"text":"shapes collectively using a concrete instance of ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","type":"reference","isActive":true},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Alternatively, you can add some kinds of shapes directly to a map view as","type":"text"},{"text":" ","type":"text"},{"text":"annotations or overlays.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"You can filter the features in a ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","isActive":true,"type":"reference"},{"text":" or vary their layout or","type":"text"},{"text":" ","type":"text"},{"text":"paint attributes based on the features’ geographies. Pass an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true,"type":"reference"},{"text":" into an","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"NSPredicate"},{"text":" with the format ","type":"text"},{"type":"codeVoice","code":"SELF IN %@"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"%@ CONTAINS SELF"},{"text":" and set the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer\/predicate","isActive":true,"type":"reference"},{"text":" property to that predicate, or set a layout or","type":"text"},{"text":" ","type":"text"},{"text":"paint attribute to a similarly formatted ","type":"text"},{"type":"codeVoice","code":"NSExpression"},{"text":".","type":"text"}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/maplibre\/mlnshape"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":" is an abstract class that represents a shape or annotation. Shapes"},{"type":"text","text":" "},{"type":"text","text":"constitute the content of a map — not only the overlays atop the map, but also"},{"type":"text","text":" "},{"type":"text","text":"the content that forms the base map."}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNPolylineFeature":{"url":"\/documentation\/maplibre\/mlnpolylinefeature","type":"topic","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolylineFeature","fragments":[{"kind":"identifier","text":"MLNPolylineFeature"}],"abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/M