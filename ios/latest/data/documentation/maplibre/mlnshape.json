","text":"’s"},{"type":"text","text":" "},{"type":"text","text":"shapes collectively using a concrete instance of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Alternatively, you can add some kinds of shapes directly to a map view as"},{"type":"text","text":" "},{"type":"text","text":"annotations or overlays."}],"type":"paragraph"},{"inlineContent":[{"text":"You can filter the features in a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","type":"reference"},{"text":" or vary their layout or","type":"text"},{"text":" ","type":"text"},{"text":"paint attributes based on the features’ geographies. Pass an ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"reference"},{"text":" into an","type":"text"},{"text":" ","type":"text"},{"code":"NSPredicate","type":"codeVoice"},{"text":" with the format ","type":"text"},{"code":"SELF IN %@","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"%@ CONTAINS SELF","type":"codeVoice"},{"text":" and set the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer\/predicate","type":"reference"},{"text":" property to that predicate, or set a layout or","type":"text"},{"text":" ","type":"text"},{"text":"paint attribute to a similarly formatted ","type":"text"},{"code":"NSExpression","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeCollectionFeature":{"url":"\/documentation\/maplibre\/mlnshapecollectionfeature","type":"topic","title":"MLNShapeCollectionFeature","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollectionFeature