ayer defines the appearance of"},{"type":"text","text":" "},{"type":"text","text":"any content supplied by the vector tile source."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeCollectionFeature/shapeCollectionWithShapes:":{"type":"topic","role":"symbol","url":"\/documentation\/maplibre\/mlnshapecollectionfeature\/shapecollectionwithshapes:","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"shapeCollectionWithShapes:"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"shapeCollectionWithShapes:"}],"abstract":[],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollectionFeature\/shapeCollectionWithShapes:","title":"shapeCollectionWithShapes:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeCollection":{"title":"MLNShapeCollection","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollection","abstract":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollection"},{"type":"text","text":" object represents a shape consisting of zero or more"},{"type":"text","text":" "},{"type":"text","text":"distinct but related shapes that are instances of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":". The constituent"},{"type":"text","text":" "},{"type":"text","text":"shapes can be a mixture of different kinds of shapes."}],"role":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeCollection"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnshapecollection"}}}