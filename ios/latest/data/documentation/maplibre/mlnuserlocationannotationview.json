Libre\/MLNUserLocation","isActive":true},{"type":"text","text":" object from the"},{"type":"text","text":" "},{"type":"codeVoice","code":"userLocation"},{"type":"text","text":" property of the map view displayed in your application."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocation"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView/mapView":{"role":"symbol","kind":"symbol","fragments":[{"text":"mapView","kind":"identifier"}],"abstract":[{"type":"text","text":"Returns the associated map view."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\/mapView","url":"\/documentation\/maplibre\/mlnuserlocationannotationview\/mapview","type":"topic","title":"mapView"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView/update":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\/update","kind":"symbol","url":"\/documentation\/maplibre\/mlnuserlocationannotationview\/update","fragments":[{"text":"- ","kind":"text"},{"text":"update","kind":"identifier"}],"navigatorTitle":[{"text":"update","kind":"identifier"}],"title":"update","type":"topic","role":"symbol","abstract":[{"text":"Updates the user location annotation.","type":"text"}]}}}