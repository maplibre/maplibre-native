otation object, which is an","type":"text"},{"text":" ","type":"text"},{"text":"object that corresponds to the ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","isActive":true,"type":"reference"},{"text":" protocol. When an annotation’s","type":"text"},{"text":" ","type":"text"},{"text":"geographic coordinate is visible in the map view, the map view asks its","type":"text"},{"text":" ","type":"text"},{"text":"delegate to a corresponding annotation view. If an annotation view is created","type":"text"},{"text":" ","type":"text"},{"text":"with a reuse identifier, the map view may recycle the view when it goes","type":"text"},{"text":" ","type":"text"},{"text":"offscreen.","type":"text"}],"title":"MLNAnnotationView","fragments":[{"text":"MLNAnnotationView","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnannotationview","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView/hitTestLayer":{"type":"topic","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\/hitTestLayer","kind":"symbol","abstract":[{"text":"Returns the layer that should be used for annotation selection hit testing.","type":"text"}],"url":"\/documentation\/maplibre\/mlnuserlocationannotationview\/hittestlayer","fragments":[{"text":"hitTestLayer","kind":"identifier"}],"title":"hitTestLayer"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView/update":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\/update","abstract":[{"text":"Updates the user location annotation.","type":"text"}],"title":"update","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"update"}],"kind":"symbol","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"update"}],"