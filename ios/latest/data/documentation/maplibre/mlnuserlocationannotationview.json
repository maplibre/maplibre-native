tation selection hit testing."}],"url":"\/documentation\/maplibre\/mlnuserlocationannotationview\/hittestlayer","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\/hitTestLayer","title":"hitTestLayer","fragments":[{"kind":"identifier","text":"hitTestLayer"}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocation":{"abstract":[{"text":"The MLNUserLocation class defines a specific type of annotation that identifies","type":"text"},{"text":" ","type":"text"},{"text":"the user’s current location. You do not create instances of this class","type":"text"},{"text":" ","type":"text"},{"text":"directly. Instead, you retrieve an existing ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocation","isActive":true,"type":"reference"},{"text":" object from the","type":"text"},{"text":" ","type":"text"},{"code":"userLocation","type":"codeVoice"},{"text":" property of the map view displayed in your application.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocation","kind":"symbol","role":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnuserlocation","fragments":[{"text":"MLNUserLocation","kind":"identifier"}],"title":"MLNUserLocation"}}}