":"text","text":"to a map view. To use this protocol, you adopt it in any custom objects that"},{"type":"text","text":" "},{"type":"text","text":"store or represent annotation data. Each object then serves as the source of"},{"type":"text","text":" "},{"type":"text","text":"information about a single map annotation and provides critical information,"},{"type":"text","text":" "},{"type":"text","text":"such as the annotation’s location on the map. Annotation objects do not provide"},{"type":"text","text":" "},{"type":"text","text":"the visual representation of the annotation but typically coordinate (in"},{"type":"text","text":" "},{"type":"text","text":"conjunction with the map view’s delegate) the creation of an appropriate"},{"type":"text","text":" "},{"type":"text","text":"objects to handle the display."}],"role":"symbol","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView/mapView":{"kind":"symbol","url":"\/documentation\/maplibre\/mlnuserlocationannotationview\/mapview","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\/mapView","title":"mapView","role":"symbol","abstract":[{"text":"Returns the associated map view.","type":"text"}],"fragments":[{"kind":"identifier","text":"mapView"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView/update":{"type":"topic","kind":"symbol","url":"\/documentation\/maplibre\/mlnuserlocationannotationview\/update","abstract":[{"type":"text","text":"Updates the user location annotation."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\/update","title":"update","role":"symbol","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"update"}],"navigatorTitle":[{"kind":"identifier","text":"update"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocation":{"type":"topic","role":"symbol","url":"\/documentation\/maplibre\/mlnuserlocation","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocation","fragments":[{"kind":"identifier","text":"MLNUserLocation"}],"abstract":[{"type":"text","text":"The MLNUserLocation class defines a specific type of annotation that identifies"},{"type":"text","text":" "},{"type":"text","text":"the user’s current location. You do not create instances of this class"},{"type":"text","text":" "},{"type":"text","text":"directly. Instead, you retrieve an existing "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocation","type":"reference","isActive":true},{"type":"text","text":" object from the"},{"type":"text","text":" "},{"type":"codeVoice","code":"userLocation"},{"type":"text","text":" property of the map view displayed in your application."}],"title":"MLNUserLocation","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView/userLocation":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\/userLocation","type":"topic","url":"\/documentation\/maplibre\/mlnuserlocationannotationview\/userlocation","title":"userLocation","abstract":[{"type":"text","text":"Returns the annotation object indicating the user’s current location."}],"kind":"symbol","fragments":[{"kind":"identifier","text":"userLocation"}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView/hitTestLayer":{"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\/hitTestLayer","fragments":[{"kind":"identifier","text":"hitTestLayer"}],"title":"hitTestLayer","url":"\/documentation\/maplibre\/mlnuserlocationannotationview\/hittestlayer","abstract":[{"type":"text","text":"Returns the layer that should be used for annotation selection hit testing."}],"role":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotationView":{"identifier":"doc:\/\