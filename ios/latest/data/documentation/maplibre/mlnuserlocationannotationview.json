:[{"name":"MapLibre"}],"role":"symbol","remoteSource":{"fileName":"MLNUserLocationAnnotationView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNUserLocationAnnotationView.h#L14"},"symbolKind":"class","externalID":"c:objc(cs)MLNUserLocationAnnotationView","title":"MLNUserLocationAnnotationView","navigatorTitle":[{"kind":"identifier","text":"MLNUserLocationAnnotationView"}]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotationView":{"kind":"symbol","type":"topic","title":"MLNAnnotationView","url":"\/documentation\/maplibre\/mlnannotationview","abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView","type":"reference","isActive":true},{"type":"text","text":" class is responsible for marking a point annotation"},{"type":"text","text":" "},{"type":"text","text":"with a view. Annotation views represent an annotation object, which is an"},{"type":"text","text":" "},{"type":"text","text":"object that corresponds to the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","type":"reference","isActive":true},{"type":"text","text":" protocol. When an annotation’s"},{"type":"text","text":" "},{"type":"text","text":"geographic coordinate is visible in the map view, the map view asks its"},{"type":"text","text":" "},{"type":"text","text":"delegate to a corresponding annotation view. If an annotation view is created"},{"type":"text","text":" "},{"type":"text","text":"with a reuse identifier, the map view may recycle the view when it goes"},{"type":"text","text":" "},{"type":"text","text":"offscreen."}],"role":"symbol","fragments":[{"kind":"identifier","text":"MLNAnnotationView"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView/userLocation":{"kind":"symbol","abstract":[{"type":"text","text":"Returns the annotation object indicating the user’s current location."}],"url":"\/documentation\/maplibre\/mlnuserlocationannotationview\/userlocation","type":"topic","title":"userLocation","fragments":[{"kind":"identifier","text":"userLocation"}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\/userLocation"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView/hitTestLayer":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\/hitTestLayer","fragments":[{"kind":"identifier","text":"hitTestLayer"}],"url":"\/documentation\/maplibre\/mlnuserlocationannotationview\/hittestlayer","type":"topic","title":"hitTestLayer","role":"symbol","kind":"symbol","abstract":[{"text":"Returns the layer that should be used for annotation selection hit testing.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView/mapView":{"fragments":[{"kind":"identifier","text":"mapView"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\/mapView","role":"symbol","type":"topic","title":"mapView","kind":"symbol","url":"\/documentation\/maplibre\/mlnuserlocationannotationview\/mapview","abstract":[{"text":"Returns the associated map view.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView/update":{"url":"\/documentation\/maplibre\/mlnuserlocationannotationview\/update","role":"symbol","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"update"}],"navigatorTitle":[{"kind":"identifier","text":"update"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\/update","kind":"symbol","type":"topic","abstract":[{"text":"Updates the user location annotation.","type":"text"}],"title":"update"},"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.