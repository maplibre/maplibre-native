{"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView\/scalesWithViewingDistance"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView"]]},"metadata":{"modules":[{"name":"MapLibre"}],"role":"symbol","fragments":[{"kind":"identifier","text":"scalesWithViewingDistance"}],"symbolKind":"property","externalID":"c:objc(cs)MLNAnnotationView(py)scalesWithViewingDistance","title":"scalesWithViewingDistance","remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNAnnotationView.h#L180","fileName":"MLNAnnotationView.h"},"roleHeading":"Instance Property","navigatorTitle":[{"kind":"identifier","text":"scalesWithViewingDistance"}]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"assign","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:@T@BOOL","text":"BOOL","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"scalesWithViewingDistance","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"text":"When the value of this property is ","type":"text"},{"code":"YES","type":"codeVoice"},{"text":" and the map is tilted, the annotation","type":"text"},{"text":" ","type":"text"},{"text":"view appears smaller if it is towards the top of the view (closer to the","type":"text"},{"text":" ","type":"text"},{"text":"horizon) and larger if it is towards the bottom of the view (closer to the","type":"text"},{"text":" ","type":"text"},{"text":"viewpoint). This is also the behavior of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage","type":"reference"},{"text":" objects. When the","type":"text"},{"text":" ","type":"text"},{"text":"value of this property is ","type":"text"},{"code":"NO","type":"codeVoice"},{"text":" or the map’s pitch is zero, the annotation view","type":"text"},{"text":" ","type":"text"},{"text":"remains the same size regardless of its position on-screen.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The default value of this property is ","type":"text"},{"code":"NO","type":"codeVoice"},{"text":". Keep this property set to ","type":"text"},{"code":"NO","type":"codeVoice"},{"text":" if","type":"text"},{"text":" ","type":"text"},{"text":"the view’s legibility is important.","type":"text"}],"type":"paragraph"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Scaling many on-screen annotation views can contribute to poor map"},{"type":"text","text":" "},{"type":"text","text":"performance. Consider keeping this property disabled if your use case"},{"type":"text","text":" "},{"type":"text","text":"involves hundreds or thousands of annotation views."}]}],"type":"aside"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnannotationview\/scaleswithviewingdistance"]}],"sections":[],"kind":"symbol","abstract":[{"type":"text","text":"A Boolean value that determines whether the annotation view grows and shrinks"},{"type":"text","text":" "},{"type":"text","text":"as the distance between the viewpoint and the annotation view changes on a"},{"type":"text","text":" "},{"type":"text","text":"tilted map."}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","title":"MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotationImage":{"fragments":[{"text":"MLNAnnotationImage","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnannotationimage","title":"MLNAnnotationImage","role":"symbol","type":"topic","abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage","type":"reference","isActive":true},{"type":"text","text":" class is responsible for presenting point-based"},{"type":"text","text":" "},{"type":"text","text":"annotations visually on a map view. Annotation image objects wrap "},{"type":"codeVoice","code":"UIImage"},{"type":"text","text":" "},{"type":"text","text":"objects and may be recycled later and put into a reuse queue that is maintained"},{"type":"text","text":" "},{"type":"text","text":"by the map view."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage"},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotation":{"type":"topic","url":"\/documentation\/maplibre\/mlnannotation","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","kind":"symbol","title":"MLNAnnotation","role":"symbol","abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","isActive":true},{"type":"text","text":" protocol is used to provide annotation-related information"},{"type":"text","text":" "},{"type":"text","text":"to a map view. To use this protocol, you adopt it in any custom objects that"},{"type":"text","text":" "},{"type":"text","text":"store or represent annotation data. Each object then serves as the source of"},{"type":"text","text":" "},{"type":"text","text":"information about a single map annotation and provides critical information,"},{"type":"text","text":" "},{"type":"text","text":"such as the annotation’s location on the map. Annotation objects do not provide"},{"type":"text","text":" "},{"type":"text","text":"the visual representation of the annotation but typically coordinate (in"},{"type":"text","text":" "},{"type":"text","text":"conjunction with the map view’s delegate) the creation of an appropriate"},{"type":"text","text":" "},{"type":"text","text":"objects to handle the display."}],"fragments":[{"kind":"identifier","text":"MLNAnnotation"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotationView/scalesWithViewingDistance":{"url":"\/documentation\/maplibre\/mlnannotationview\/scaleswithviewingdistance","title":"scalesWithViewingDistance","abstract":[{"text":"A Boolean value that determines whether the annotation view grows and shrinks","type":"text"},{"text":" ","type":"text"},{"text":"as the distance between the viewpoint and the annotation view changes on a","type":"text"},{"text":" ","type":"text"},{"text":"tilted map.","type":"text"}],"fragments":[{"kind":"identifier","text":"scalesWithViewingDistance"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView\/scalesWithViewingDistance","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotationView":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView","isActive":true,"type":"reference"},{"type":"text","text":" class is responsible for marking a point annotation"},{"type":"text","text":" "},{"type":"text","text":"with a view. Annotation views represent an annotation object, which is an"},{"type":"text","text":" "},{"type":"text","text":"object that corresponds to the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","isActive":true,"type":"reference"},{"type":"text","text":" protocol. When an annotation’s"},{"type":"text","text":" "},{"type":"text","text":"geographic coordinate is visible in the map view, the map view asks its"},{"type":"text","text":" "},{"type":"text","text":"delegate to a corresponding annotation view. If an annotation view is created"},{"type":"text","text":" "},{"type":"text","text":"with a reuse identifier, the map view may recycle the view when it goes"},{"type":"text","text":" "},{"type":"text","text":"offscreen."}],"fragments":[{"text":"MLNAnnotationView","kind":"identifier"}],"title":"MLNAnnotationView","role":"symbol","url":"\/documentation\/maplibre\/mlnannotationview"}}}