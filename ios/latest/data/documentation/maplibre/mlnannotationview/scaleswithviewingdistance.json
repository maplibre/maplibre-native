{"abstract":[{"text":"A Boolean value that determines whether the annotation view grows and shrinks","type":"text"},{"type":"text","text":" "},{"type":"text","text":"as the distance between the viewpoint and the annotation view changes on a"},{"type":"text","text":" "},{"type":"text","text":"tilted map."}],"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView"]]},"metadata":{"modules":[{"name":"MapLibre"}],"roleHeading":"Instance Property","role":"symbol","title":"scalesWithViewingDistance","fragments":[{"text":"scalesWithViewingDistance","kind":"identifier"}],"remoteSource":{"fileName":"MLNAnnotationView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNAnnotationView.h#L180"},"symbolKind":"property","navigatorTitle":[{"kind":"identifier","text":"scalesWithViewingDistance"}],"externalID":"c:objc(cs)MLNAnnotationView(py)scalesWithViewingDistance"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"],"tokens":[{"kind":"keyword","text":"@property"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"kind":"keyword","text":"assign"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:@T@BOOL","kind":"typeIdentifier","text":"BOOL"},{"text":" ","kind":"text"},{"kind":"identifier","text":"scalesWithViewingDistance"},{"text":";","kind":"text"}]}]},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"text":"When the value of this property is ","type":"text"},{"code":"YES","type":"codeVoice"},{"text":" and the map is tilted, the annotation","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"view appears smaller if it is towards the top of the view (closer to the"},{"text":" ","type":"text"},{"text":"horizon) and larger if it is towards the bottom of the view (closer to the","type":"text"},{"type":"text","text":" "},{"text":"viewpoint). This is also the behavior of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage","type":"reference"},{"type":"text","text":" objects. When the"},{"type":"text","text":" "},{"type":"text","text":"value of this property is "},{"type":"codeVoice","code":"NO"},{"type":"text","text":" or the map’s pitch is zero, the annotation view"},{"type":"text","text":" "},{"type":"text","text":"remains the same size regardless of its position on-screen."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default value of this property is "},{"code":"NO","type":"codeVoice"},{"type":"text","text":". Keep this property set to "},{"code":"NO","type":"codeVoice"},{"type":"text","text":" if"},{"type":"text","text":" "},{"type":"text","text":"the view’s legibility is important."}]},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"Scaling many on-screen annotation views can contribute to poor map"},{"type":"text","text":" "},{"type":"text","text":"performance. Consider keeping this property disabled if your use case"},{"type":"text","text":" "},{"type":"text","text":"involves hundreds or thousands of annotation views."}],"type":"paragraph"}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView\/scalesWithViewingDistance","interfaceLanguage":"occ"},"kind":"symbol","variants":[{"paths":["\/documentation\/maplibre\/mlnannotationview\/scaleswithviewingdistance"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","title":"MapLibre","url":"\/documentation\/maplibre","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotation":{"fragments":[{"text":"MLNAnnotation","kind":"identifier"}],"type":"topic","title":"MLNAnnotation","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","url":"\/documentation\/maplibre\/mlnannotation","kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation"},{"type":"text","text":" protocol is used to provide annotation-related information"},{"type":"text","text":" "},{"type":"text","text":"to a map view. To use this protocol, you adopt it in any custom objects that"},{"type":"text","text":" "},{"type":"text","text":"store or represent annotation data. Each object then serves as the source of"},{"type":"text","text":" "},{"type":"text","text":"information about a single map annotation and provides critical information,"},{"type":"text","text":" "},{"type":"text","text":"such as the annotation’s location on the map. Annotation objects do not provide"},{"type":"text","text":" "},{"type":"text","text":"the visual representation of the annotation but typically coordinate (in"},{"type":"text","text":" "},{"type":"text","text":"conjunction with the map view’s delegate) the creation of an appropriate"},{"type":"text","text":" "},{"type":"text","text":"objects to handle the display."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotationView/scalesWithViewingDistance":{"title":"scalesWithViewingDistance","kind":"symbol","url":"\/documentation\/maplibre\/mlnannotationview\/scaleswithviewingdistance","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView\/scalesWithViewingDistance","type":"topic","abstract":[{"text":"A Boolean value that determines whether the annotation view grows and shrinks","type":"text"},{"text":" ","type":"text"},{"text":"as the distance between the viewpoint and the annotation view changes on a","type":"text"},{"text":" ","type":"text"},{"text":"tilted map.","type":"text"}],"role":"symbol","fragments":[{"kind":"identifier","text":"scalesWithViewingDistance"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotationImage":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage","kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlnannotationimage","abstract":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationImage"},{"type":"text","text":" class is responsible for presenting point-based"},{"type":"text","text":" "},{"type":"text","text":"annotations visually on a map view. Annotation image objects wrap "},{"type":"codeVoice","code":"UIImage"},{"type":"text","text":" "},{"type":"text","text":"objects and may be recycled later and put into a reuse queue that is maintained"},{"type":"text","text":" "},{"type":"text","text":"by the map view."}],"title":"MLNAnnotationImage","fragments":[{"text":"MLNAnnotationImage","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotationView":{"fragments":[{"kind":"identifier","text":"MLNAnnotationView"}],"type":"topic","title":"MLNAnnotationView","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView","url":"\/documentation\/maplibre\/mlnannotationview","kind":"symbol","role":"symbol","abstract":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView"},{"text":" class is responsible for marking a point annotation","type":"text"},{"text":" ","type":"text"},{"text":"with a view. Annotation views represent an annotation object, which is an","type":"text"},{"text":" ","type":"text"},{"text":"object that corresponds to the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation"},{"text":" protocol. When an annotation’s","type":"text"},{"text":" ","type":"text"},{"text":"geographic coordinate is visible in the map view, the map view asks its","type":"text"},{"text":" ","type":"text"},{"text":"delegate to a corresponding annotation view. If an annotation view is created","type":"text"},{"text":" ","type":"text"},{"text":"with a reuse identifier, the map view may recycle the view when it goes","type":"text"},{"text":" ","type":"text"},{"text":"offscreen.","type":"text"}]}}}