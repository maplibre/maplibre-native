 views represent an annotation object, which is an","type":"text"},{"text":" ","type":"text"},{"text":"object that corresponds to the ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","isActive":true,"type":"reference"},{"text":" protocol. When an annotation’s","type":"text"},{"text":" ","type":"text"},{"text":"geographic coordinate is visible in the map view, the map view asks its","type":"text"},{"text":" ","type":"text"},{"text":"delegate to a corresponding annotation view. If an annotation view is created","type":"text"},{"text":" ","type":"text"},{"text":"with a reuse identifier, the map view may recycle the view when it goes","type":"text"},{"text":" ","type":"text"},{"text":"offscreen.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotationView/setDragState:animated:":{"title":"setDragState:animated:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView\/setDragState:animated:","url":"\/documentation\/maplibre\/mlnannotationview\/setdragstate:animated:","type":"topic","navigatorTitle":[{"kind":"identifier","text":"setDragState:animated:"}],"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"setDragState:animated:"}],"role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"Sets the current drag state for the annotation view."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotationView/dragState":{"abstract":[{"type":"text","text":"The current drag state of the annotation view."}],"kind":"symbol","type":"topic","fragments":[{"kind":"identifier","text":"dragState"}],"url":"\/documentation\/maplibre\/mlnannotationview\/dragstate","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView\/dragState","title":"dragState"},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotation":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","type":"