ed view."}]},{"type":"paragraph","inlineContent":[{"text":"Setting this property changes the view’s appearance to reflect the new value","type":"text"},{"text":" ","type":"text"},{"text":"immediately. If you want the change to be animated, use the","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView\/setSelected:animated:","isActive":true},{"text":" method instead.","type":"text"}]}],"kind":"content"}],"metadata":{"externalID":"c:objc(cs)MLNAnnotationView(py)selected","title":"selected","navigatorTitle":[{"kind":"identifier","text":"selected"}],"fragments":[{"text":"selected","kind":"identifier"}],"remoteSource":{"fileName":"MLNAnnotationView.h","url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNAnnotationView.h#L212"},"symbolKind":"property","roleHeading":"Instance Property","role":"symbol","modules":[{"name":"MapLibre"}]},"abstract":[{"type":"text","text":"A Boolean value indicating whether the annotation view is currently selected."}],"kind":"symbol","identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView\/selected","interfaceLanguage":"occ"},"variants":[{"paths":["\/documentation\/maplibre\/mlnannotationview\/selected"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotationView/setSelected:animated:":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView\/setSelected:animated:","type":"topic","role":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"setSelected:animated:","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnannotationview\/setselected:animated:","title":"setSelected:animated:","kind":"symbol","navigatorTitle":[{"text":"setSelected:animated:","kind":"identifier"}],"abstract":[{"text":"Sets the selection state of the annotation view with an optional animat