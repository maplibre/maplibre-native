{"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView\/initWithReuseIdentifier:","interfaceLanguage":"occ"},"metadata":{"role":"symbol","modules":[{"name":"MapLibre"}],"symbolKind":"method","navigatorTitle":[{"text":"initWithReuseIdentifier:","kind":"identifier"}],"roleHeading":"Instance Method","fragments":[{"text":"- ","kind":"text"},{"text":"initWithReuseIdentifier:","kind":"identifier"}],"remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNAnnotationView.h#L77","fileName":"MLNAnnotationView.h"},"externalID":"c:objc(cs)MLNAnnotationView(im)initWithReuseIdentifier:","title":"initWithReuseIdentifier:"},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"text","text":"- ("},{"kind":"keyword","text":"instancetype"},{"kind":"text","text":") "},{"kind":"identifier","text":"initWithReuseIdentifier:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"NSString","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"reuseIdentifier"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"parameters":[{"name":"reuseIdentifier","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A unique string identifier for this view that allows you"},{"type":"text","text":" "},{"type":"text","text":"to reuse this view with multiple similar annotations. You can set this"},{"type":"text","text":" "},{"type":"text","text":"parameter to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" if you don’t intend to reuse the view, but it is a good"},{"type":"text","text":" "},{"type":"text","text":"idea in general to specify a reuse identifier to avoid creating redundant"},{"type":"text","text":" "},{"type":"text","text":"views."}]}]}],"kind":"parameters"},{"content":[{"text":"Return Value","type":"heading","level":2,"anchor":"return-value"},{"type":"paragraph","inlineContent":[{"text":"The initialized annotation view object.","type":"text"}]}],"kind":"content"},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The reuse identifier provides a way for you to improve performance by recycling"},{"type":"text","text":" "},{"type":"text","text":"annotation views as they enter and leave the map’s viewport. As an annotation"},{"type":"text","text":" "},{"type":"text","text":"leaves the viewport, the map view moves its associated view to a reuse queue."},{"type":"text","text":" "},{"type":"text","text":"When a new annotation becomes visible, you can request a view for that"},{"type":"text","text":" "},{"type":"text","text":"annotation by passing the appropriate reuse identifier string to the"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/dequeueReusableAnnotationViewWithIdentifier:","isActive":true},{"type":"text","text":" method."}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"type":"text","text":"Initializes and returns a new annotation view object."}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView"]]},"variants":[{"paths":["\/documentation\/maplibre\/mlnannotationview\/initwithreuseidentifier:"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"symbol","sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotation":{"abstract":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","type":"reference"},{"text":" protocol is used to provide annotation-related information","type":"text"},{"text":" ","type":"text"},{"text":"to a map view. To use this protocol, you adopt it in any custom objects that","type":"text"},{"text":" ","type":"text"},{"text":"store or represent annotation data. Each object then serves as the source of","type":"text"},{"text":" ","type":"text"},{"text":"information about a single map annotation and provides critical information,","type":"text"},{"text":" ","type":"text"},{"text":"such as the annotation’s location on the map. Annotation objects do not provide","type":"text"},{"text":" ","type":"text"},{"text":"the visual representation of the annotation but typically coordinate (in","type":"text"},{"text":" ","type":"text"},{"text":"conjunction with the map view’s delegate) the creation of an appropriate","type":"text"},{"text":" ","type":"text"},{"text":"objects to handle the display.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","fragments":[{"text":"MLNAnnotation","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnannotation","type":"topic","role":"symbol","title":"MLNAnnotation","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotationView/initWithReuseIdentifier:":{"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"initWithReuseIdentifier:"}],"url":"\/documentation\/maplibre\/mlnannotationview\/initwithreuseidentifier:","abstract":[{"type":"text","text":"Initializes and returns a new annotation view object."}],"type":"topic","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView\/initWithReuseIdentifier:","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"initWithReuseIdentifier:"}],"title":"initWithReuseIdentifier:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/dequeueReusableAnnotationViewWithIdentifier:":{"title":"dequeueReusableAnnotationViewWithIdentifier:","kind":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"dequeueReusableAnnotationViewWithIdentifier:","kind":"identifier"}],"navigatorTitle":[{"text":"dequeueReusableAnnotationViewWithIdentifier:","kind":"identifier"}],"abstract":[{"type":"text","text":"Returns a reusable annotation view object associated with its identifier."}],"url":"\/documentation\/maplibre\/mlnmapview\/dequeuereusableannotationviewwithidentifier:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/dequeueReusableAnnotationViewWithIdentifier:","type":"topic","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotationView":{"url":"\/documentation\/maplibre\/mlnannotationview","type":"topic","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView","role":"symbol","fragments":[{"text":"MLNAnnotationView","kind":"identifier"}],"abstract":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView","type":"reference"},{"text":" class is responsible for marking a point annotation","type":"text"},{"text":" ","type":"text"},{"text":"with a view. Annotation views represent an annotation object, which is an","type":"text"},{"text":" ","type":"text"},{"text":"object that corresponds to the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","type":"reference"},{"text":" protocol. When an annotation’s","type":"text"},{"text":" ","type":"text"},{"text":"geographic coordinate is visible in the map view, the map view asks its","type":"text"},{"text":" ","type":"text"},{"text":"delegate to a corresponding annotation view. If an annotation view is created","type":"text"},{"text":" ","type":"text"},{"text":"with a reuse identifier, the map view may recycle the view when it goes","type":"text"},{"text":" ","type":"text"},{"text":"offscreen.","type":"text"}],"title":"MLNAnnotationView"},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","type":"topic","kind":"symbol","title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection"}}}