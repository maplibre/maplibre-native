{"abstract":[{"text":"Initializes and returns a new annotation view object.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnannotationview\/initwithreuseidentifier:"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"- (","kind":"text"},{"text":"instancetype","kind":"keyword"},{"text":") ","kind":"text"},{"text":"initWithReuseIdentifier:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"text":"reuseIdentifier","kind":"internalParam"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A unique string identifier for this view that allows you","type":"text"},{"text":" ","type":"text"},{"text":"to reuse this view with multiple similar annotations. You can set this","type":"text"},{"text":" ","type":"text"},{"text":"parameter to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" if you don’t intend to reuse the view, but it is a good","type":"text"},{"text":" ","type":"text"},{"text":"idea in general to specify a reuse identifier to avoid creating redundant","type":"text"},{"text":" ","type":"text"},{"text":"views.","type":"text"}]}],"name":"reuseIdentifier"}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","text":"Return Value","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The initialized annotation view object."}]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The reuse identifier provides a way for you to improve performance by recycling"},{"type":"text","text":" "},{"type":"text","text":"annotation views as they enter and leave the map’s viewport. As an annotation"},{"type":"text","text":" "},{"type":"text","text":"leaves the viewport, the map view moves its associated view to a reuse queue."},{"type":"text","text":" "},{"type":"text","text":"When a new annotation becomes visible, you can request a view for that"},{"type":"text","text":" "},{"type":"text","text":"annotation by passing the appropriate reuse identifier string to the"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/dequeueReusableAnnotationViewWithIdentifier:"},{"type":"text","text":" method."}],"type":"paragraph"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView\/initWithReuseIdentifier:"},"metadata":{"modules":[{"name":"MapLibre"}],"navigatorTitle":[{"text":"initWithReuseIdentifier:","kind":"identifier"}],"title":"initWithReuseIdentifier:","role":"symbol","symbolKind":"method","externalID":"c:objc(cs)MLNAnnotationView(im)initWithReuseIdentifier:","roleHeading":"Instance Method","remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNAnnotationView.h#L77","fileName":"MLNAnnotationView.h"},"fragments":[{"text":"- ","kind":"text"},{"text":"initWithReuseIdentifier:","kind":"identifier"}]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapView/dequeueReusableAnnotationViewWithIdentifier:":{"title":"dequeueReusableAnnotationViewWithIdentifier:","kind":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnmapview\/dequeuereusableannotationviewwithidentifier:","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/dequeueReusableAnnotationViewWithIdentifier:","fragments":[{"text":"- ","kind":"text"},{"text":"dequeueReusableAnnotationViewWithIdentifier:","kind":"identifier"}],"abstract":[{"type":"text","text":"Returns a reusable annotation view object associated with its identifier."}],"navigatorTitle":[{"text":"dequeueReusableAnnotationViewWithIdentifier:","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotation":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation"},{"type":"text","text":" protocol is used to provide annotation-related information"},{"type":"text","text":" "},{"type":"text","text":"to a map view. To use this protocol, you adopt it in any custom objects that"},{"type":"text","text":" "},{"type":"text","text":"store or represent annotation data. Each object then serves as the source of"},{"type":"text","text":" "},{"type":"text","text":"information about a single map annotation and provides critical information,"},{"type":"text","text":" "},{"type":"text","text":"such as the annotation’s location on the map. Annotation objects do not provide"},{"type":"text","text":" "},{"type":"text","text":"the visual representation of the annotation but typically coordinate (in"},{"type":"text","text":" "},{"type":"text","text":"conjunction with the map view’s delegate) the creation of an appropriate"},{"type":"text","text":" "},{"type":"text","text":"objects to handle the display."}],"type":"topic","url":"\/documentation\/maplibre\/mlnannotation","title":"MLNAnnotation","fragments":[{"text":"MLNAnnotation","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotationView":{"role":"symbol","url":"\/documentation\/maplibre\/mlnannotationview","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView","fragments":[{"kind":"identifier","text":"MLNAnnotationView"}],"title":"MLNAnnotationView","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView","isActive":true},{"type":"text","text":" class is responsible for marking a point annotation"},{"type":"text","text":" "},{"type":"text","text":"with a view. Annotation views represent an annotation object, which is an"},{"type":"text","text":" "},{"type":"text","text":"object that corresponds to the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","isActive":true},{"type":"text","text":" protocol. When an annotation’s"},{"type":"text","text":" "},{"type":"text","text":"geographic coordinate is visible in the map view, the map view asks its"},{"type":"text","text":" "},{"type":"text","text":"delegate to a corresponding annotation view. If an annotation view is created"},{"type":"text","text":" "},{"type":"text","text":"with a reuse identifier, the map view may recycle the view when it goes"},{"type":"text","text":" "},{"type":"text","text":"offscreen."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNAnnotationView/initWithReuseIdentifier:":{"title":"initWithReuseIdentifier:","role":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"initWithReuseIdentifier:","kind":"identifier"}],"navigatorTitle":[{"text":"initWithReuseIdentifier:","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnannotationview\/initwithreuseidentifier:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotationView\/initWithReuseIdentifier:","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Initializes and returns a new annotation view object."}]},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","url":"\/documentation\/maplibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"kind":"symbol","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic"}}}