{"sections":[],"abstract":[{"text":"Returns a new camera with the given altitude, pitch, and heading.","type":"text"}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapCamera\/cameraLookingAtCenterCoordinate:altitude:pitch:heading:","interfaceLanguage":"occ"},"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"text":"instancetype","kind":"keyword"},{"text":") ","kind":"text"},{"text":"cameraLookingAtCenterCoordinate:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:@S@CLLocationCoordinate2D","text":"CLLocationCoordinate2D","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"centerCoordinate","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"altitude:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:@T@CLLocationDistance","text":"CLLocationDistance","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"altitude","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"pitch:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:@T@CGFloat","text":"CGFloat","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"pitch","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"heading:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:@T@CLLocationDirection","text":"CLLocationDirection","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"heading","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The geographic coordinate on which the map should be"},{"type":"text","text":" "},{"type":"text","text":"centered."}]}],"name":"centerCoordinate"},{"content":[{"inlineContent":[{"text":"The altitude (measured in meters) above the map at which the","type":"text"},{"text":" ","type":"text"},{"text":"camera should be situated. The altitude may be less than the distance from","type":"text"},{"text":" ","type":"text"},{"text":"the camera’s viewpoint to the camera’s focus point.","type":"text"}],"type":"paragraph"}],"name":"altitude"},{"content":[{"inlineContent":[{"type":"text","text":"The viewing angle of the camera, measured in degrees. A value of"},{"type":"text","text":" "},{"type":"codeVoice","code":"0"},{"type":"text","text":" results in a camera pointed straight down at the map. Angles greater"},{"type":"text","text":" "},{"type":"text","text":"than "},{"type":"codeVoice","code":"0"},{"type":"text","text":" result in a camera angled toward the horizon."}],"type":"paragraph"}],"name":"pitch"},{"content":[{"inlineContent":[{"type":"text","text":"The camera’s heading, measured in degrees clockwise from true"},{"type":"text","text":" "},{"type":"text","text":"north. A value of "},{"type":"codeVoice","code":"0"},{"type":"text","text":" means that the top edge of the map view corresponds to"},{"type":"text","text":" "},{"type":"text","text":"true north. The value "},{"type":"codeVoice","code":"90"},{"type":"text","text":" means the top of the map is pointing due east."},{"type":"text","text":" "},{"type":"text","text":"The value "},{"type":"codeVoice","code":"180"},{"type":"text","text":" means the top of the map points due south, and so on."}],"type":"paragraph"}],"name":"heading"}],"kind":"parameters"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapCamera"]]},"metadata":{"roleHeading":"Type Method","fragments":[{"text":"+ ","kind":"text"},{"text":"cameraLookingAtCenterCoordinate:altitude:pitch:heading:","kind":"identifier"}],"externalID":"c:objc(cs)MLNMapCamera(cm)cameraLookingAtCenterCoordinate:altitude:pitch:heading:","title":"cameraLookingAtCenterCoordinate:altitude:pitch:heading:","modules":[{"name":"MapLibre"}],"symbolKind":"method","role":"symbo