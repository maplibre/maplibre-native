{"abstract":[{"text":"Returns a new camera with the given altitude, pitch, and heading.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"text":"instancetype","kind":"keyword"},{"text":") ","kind":"text"},{"text":"cameraLookingAtCenterCoordinate:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"CLLocationCoordinate2D","kind":"typeIdentifier","preciseIdentifier":"c:@S@CLLocationCoordinate2D"},{"text":") ","kind":"text"},{"text":"centerCoordinate","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"altitude:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@CLLocationDistance","text":"CLLocationDistance"},{"kind":"text","text":") "},{"kind":"internalParam","text":"altitude"},{"kind":"text","text":" "},{"kind":"identifier","text":"pitch:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@CGFloat","text":"CGFloat"},{"kind":"text","text":") "},{"kind":"internalParam","text":"pitch"},{"kind":"text","text":" "},{"text":"heading:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"CLLocationDirection","preciseIdentifier":"c:@T@CLLocationDirection","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"heading","kind":"internalParam"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"The geographic coordinate on which the map should be","type":"text"},{"text":" ","type":"text"},{"text":"centered.","type":"text"}],"type":"paragraph"}],"name":"centerCoordinate"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The altitude (measured in meters) above the map at which the","type":"text"},{"text":" ","type":"text"},{"text":"camera should be situated. The altitude may be less than the distance from","type":"text"},{"text":" ","type":"text"},{"text":"the camera’s viewpoint to the camera’s focus point