,{"kind":"parameters","parameters":[{"name":"centerCoordinate","content":[{"inlineContent":[{"type":"text","text":"The geographic coordinate on which the map should be"},{"type":"text","text":" "},{"type":"text","text":"centered."}],"type":"paragraph"}]},{"name":"altitude","content":[{"inlineContent":[{"type":"text","text":"The altitude (measured in meters) above the map at which the"},{"type":"text","text":" "},{"type":"text","text":"camera should be situated. The altitude may be less than the distance from"},{"type":"text","text":" "},{"type":"text","text":"the camera’s viewpoint to the camera’s focus point."}],"type":"paragraph"}]},{"name":"pitch","content":[{"inlineContent":[{"type":"text","text":"The viewing angle of the camera, measured in degrees. A value of"},{"type":"text","text":" "},{"type":"codeVoice","code":"0"},{"type":"text","text":" results in a camera pointed straight down at the map. Angles greater"},{"type":"text","text":" "},{"type":"text","text":"than "},{"type":"codeVoice","code":"0"},{"type":"text","text":" result in a camera angled toward the horizon."}],"type":"paragraph"}]},{"name":"heading","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The camera’s heading, measured in degrees clockwise from true"},{"type":"text","text":" "},{"type":"text","text":"north. A value of "},{"type":"codeVoice","code":"0"},{"type":"text","text":" means that the top edge of the map view corresponds to"},{"type":"text","text":" "},{"type":"text","text":"true north. The value "},{"type":"codeVoice","code":"90"},{"type":"text","text":" means the top of the map is pointing due east."},{"type":"text","text":" "},{"type":"text","text":"The value "},{"type":"codeVoice","code":"180"},{"type":"text","text":" means the top of the map points due south, and so on."}]}]}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapcamera\/cameralookingatcentercoordinate:altitude:pitch:heading:"]}],"abstract":[{"text