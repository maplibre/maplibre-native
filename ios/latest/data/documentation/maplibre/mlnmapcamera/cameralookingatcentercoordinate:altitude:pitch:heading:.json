{"sections":[],"abstract":[{"type":"text","text":"Returns a new camera with the given altitude, pitch, and heading."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"],"tokens":[{"kind":"text","text":"+ ("},{"kind":"keyword","text":"instancetype"},{"kind":"text","text":") "},{"kind":"identifier","text":"cameraLookingAtCenterCoordinate:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:@S@CLLocationCoordinate2D","text":"CLLocationCoordinate2D"},{"kind":"text","text":") "},{"kind":"internalParam","text":"centerCoordinate"},{"kind":"text","text":" "},{"kind":"identifier","text":"altitude:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@CLLocationDistance","text":"CLLocationDistance"},{"kind":"text","text":") "},{"kind":"internalParam","text":"altitude"},{"kind":"text","text":" "},{"kind":"identifier","text":"pitch:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@CGFloat","text":"CGFloat"},{"kind":"text","text":") "},{"kind":"internalParam","text":"pitch"},{"kind":"text","text":" "},{"kind":"identifier","text":"heading:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@CLLocationDirection","text":"CLLocationDirection"},{"kind":"text","text":") "},{"kind":"internalParam","text":"heading"},{"kind":"text","text":";"}]}]},{"kind":"parameters","parameters":[{"name":"centerCoordinate","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The geographic coordinate on which the map should be"},{"type":"text","text":" "},{"type":"text","text":"centered."}]}]},{"name":"altitude","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The altitude (measured in meters) above the map at which the"},{"type":"text","text":" "},{"type":"text","text":"camera should be situated. The altitude may be less than the distance from"},{"type":"text","text":" "},{"t