{"abstract":[{"type":"text","text":"Returns a new camera with the given distance, pitch, and heading."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"kind":"keyword","text":"instancetype"},{"kind":"text","text":") "},{"kind":"identifier","text":"cameraLookingAtCenterCoordinate:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"CLLocationCoordinate2D","preciseIdentifier":"c:@S@CLLocationCoordinate2D"},{"kind":"text","text":") "},{"kind":"internalParam","text":"centerCoordinate"},{"kind":"text","text":" "},{"kind":"identifier","text":"acrossDistance:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"CLLocationDistance","preciseIdentifier":"c:@T@CLLocationDistance"},{"kind":"text","text":") "},{"kind":"internalParam","text":"distance"},{"kind":"text","text":" "},{"kind":"identifier","text":"pitch:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"CGFloat","preciseIdentifier":"c:@T@CGFloat"},{"kind":"text","text":") "},{"kind":"internalParam","text":"pitch"},{"kind":"text","text":" "},{"kind":"identifier","text":"heading:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"CLLocationDirection","preciseIdentifier":"c:@T@CLLocationDirection"},{"kind":"text","text":") "},{"kind":"internalParam","text":"heading"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}]},{"parameters":[{"name":"centerCoordinate","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The geographic coordinate on which the map should be"},{"type":"text","text":" "},{"type":"text","text":"centered."}]}]},{"name":"distance","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The straight-line distance from the viewpoint to the"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapCamera\/centerCoordinate","isActive":true},{"type":"text","text":"."}]}]},{"name":"pitch","conte