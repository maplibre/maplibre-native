{"abstract":[{"text":"Returns a new camera with the given distance, pitch, and heading.","type":"text"}],"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"kind":"keyword","text":"instancetype"},{"kind":"text","text":") "},{"kind":"identifier","text":"cameraLookingAtCenterCoordinate:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:@S@CLLocationCoordinate2D","text":"CLLocationCoordinate2D"},{"kind":"text","text":") "},{"kind":"internalParam","text":"centerCoordinate"},{"kind":"text","text":" "},{"kind":"identifier","text":"acrossDistance:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@CLLocationDistance","text":"CLLocationDistance"},{"kind":"text","text":") "},{"kind":"internalParam","text":"distance"},{"kind":"text","text":" "},{"kind":"identifier","text":"pitch:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@CGFloat","text":"CGFloat"},{"kind":"text","text":") "},{"kind":"internalParam","text":"pitch"},{"kind":"text","text":" "},{"kind":"identifier","text":"heading:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@CLLocationDirection","text":"CLLocationDirection"},{"kind":"text","text":") "},{"kind":"internalParam","text":"heading"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"parameters":[{"content":[{"inlineContent":[{"text":"The geographic coordinate on which the map should be","type":"text"},{"text":" ","type":"text"},{"text":"centered.","type":"text"}],"type":"paragraph"}],"name":"centerCoordinate"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The straight-line distance from the viewpoint to the"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapCamera\/centerCoordinate","isActive":true},{"type":"text","text":"."}]}],"name":"distance"},{"content":[{"type":"p