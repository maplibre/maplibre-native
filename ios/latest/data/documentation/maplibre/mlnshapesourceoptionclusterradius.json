ift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOption","title":"MLNShapeSourceOption","type":"topic","abstract":[{"type":"text","text":"Options for "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":" objects."}],"fragments":[{"text":"MLNShapeSourceOption","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoption","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"title":"MLNStyle","abstract":[{"type":"text","text":"The proxy object for the current map style."}],"type":"topic","role":"symbol","url":"\/documentation\/maplibre\/mlnstyle","kind":"symbol","fragments":[{"text":"MLNStyle","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSourceDataSource":{"title":"MLNComputedShapeSourceDataSource","type":"topic","abstract":[{"type":"text","text":"Data source for "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","isActive":true,"type":"reference"},{"type":"text","text":". This protocol defines two optional methods for fetching"},{"type":"text","text":" "},{"type":"text","text":"data, one based on tile coordinates, and one based on a bounding box. Classes that implement this"},{"type":"text","text":" "},{"type":"text","text":"protocol must implement one, and only one of the methods. Methods on this protocol will not be"},{"type":"text","text":" "},{"type":"text","text":"called on main thread, they will be called on the caller’s "},{"code":"requestQueue","type":"codeVoice"},{"type":"text","text":"."}],"role":"symbol","url":"\/documentation\/maplibre\/mlncomputedshapesourcedatasource","kind":"symbol","fragments":[{"text":"MLNComputedShapeSourceDataSource","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComput