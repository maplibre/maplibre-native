{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"readonly"},{"kind":"text","text":") "},{"kind":"typeIdentifier","preciseIdentifier":"c:Q$objc(cs)NSArray","text":"NSArray<MLNPolygon *>"},{"kind":"text","text":" * "},{"kind":"identifier","text":"interiorPolygons"},{"kind":"text","text":";"}],"platforms":["iOS"]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"text":"The area occupied by any interior polygons is excluded from the overall shape.","type":"text"},{"text":" ","type":"text"},{"text":"Interior polygons should not overlap. An interior polygon should not have","type":"text"},{"text":" ","type":"text"},{"text":"interior polygons of its own.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If there are no interior polygons, the value of this property is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon\/interiorPolygons"},"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"role":"symbol","symbolKind":"property","navigatorTitle":[{"kind":"identifier","text":"interiorPolygons"}],"externalID":"c:objc(cs)MLNPolygon(py)interiorPolygons","title":"interiorPolygons","modules":[{"name":"MapLibre"}],"roleHeading":"Instance Property","fragments":[{"kind":"identifier","text":"interiorPolygons"}]},"abstract":[{"type":"text","text":"The array of polygons nested inside the receiver."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documen