{"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon\/interiorPolygons","interfaceLanguage":"occ"},"abstract":[{"text":"The array of polygons nested inside the receiver.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"readonly","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:Q$objc(cs)NSArray","text":"NSArray<MLNPolygon *>","kind":"typeIdentifier"},{"text":" * ","kind":"text"},{"text":"interiorPolygons","kind":"identifier"},{"text":";","kind":"text"}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The area occupied by any interior polygons is excluded from the overall shape."},{"type":"text","text":" "},{"type":"text","text":"Interior polygons should not overlap. An interior polygon should not have"},{"type":"text","text":" "},{"type":"text","text":"interior polygons of its own."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If there are no interior polygons, the value of this property is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}],"type":"paragraph"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"fragments":[{"kind":"identifier","text":"interiorPolygons"}],"title":"interiorPolygons","role":"symbol","modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNPolygon(py)interiorPolygons","symbolKind":"property","navigatorTitle":[{"kind":"identifier","text":"interiorPolygons"}],"roleHeading":"Instance Property"},"variants":[{"paths":["\/documentation\/maplibre\/mlnpolygon\/interiorpolygons"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/docum