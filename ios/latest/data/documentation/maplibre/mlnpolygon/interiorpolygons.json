{"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon\/interiorPolygons","interfaceLanguage":"occ"},"variants":[{"paths":["\/documentation\/maplibre\/mlnpolygon\/interiorpolygons"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"The array of polygons nested inside the receiver."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"readonly","kind":"keyword"},{"text":") ","kind":"text"},{"text":"NSArray<MLNPolygon *>","kind":"typeIdentifier","preciseIdentifier":"c:Q$objc(cs)NSArray"},{"text":" * ","kind":"text"},{"text":"interiorPolygons","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"The area occupied by any interior polygons is excluded from the overall shape."},{"type":"text","text":" "},{"type":"text","text":"Interior polygons should not overlap. An interior polygon should not have"},{"type":"text","text":" "},{"type":"text","text":"interior polygons of its own."}],"type":"paragraph"},{"inlineContent":[{"text":"If there are no interior polygons, the value of this property is ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":".","type":"text"}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon"]]},"kind":"symbol","metadata":{"fragments":[{"text":"interiorPolygons","kind":"identifier"}],"title":"interiorPolygons","navigatorTitle":[{"text":"interiorPolygons","kind":"identifier"}],"roleHeading":"Instance Property","symbolKind":"property","externalID":"c:objc(cs)MLNPolygon(py)in