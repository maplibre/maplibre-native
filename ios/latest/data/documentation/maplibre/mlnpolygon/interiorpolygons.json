{"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon"]]},"abstract":[{"text":"The array of polygons nested inside the receiver.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"readonly"},{"kind":"text","text":") "},{"kind":"typeIdentifier","preciseIdentifier":"c:Q$objc(cs)NSArray","text":"NSArray<MLNPolygon *>"},{"kind":"text","text":" * "},{"kind":"identifier","text":"interiorPolygons"},{"kind":"text","text":";"}]}]},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"The area occupied by any interior polygons is excluded from the overall shape."},{"type":"text","text":" "},{"type":"text","text":"Interior polygons should not overlap. An interior polygon should not have"},{"type":"text","text":" "},{"type":"text","text":"interior polygons of its own."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If there are no interior polygons, the value of this property is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"roleHeading":"Instance Property","externalID":"c:objc(cs)MLNPolygon(py)interiorPolygons","role":"symbol","title":"interiorPolygons","navigatorTitle":[{"kind":"identifier","text":"interiorPolygons"}],"fragments":[{"kind":"identifier","text":"interiorPolygons"}],"symbolKind":"property","modules":[{"name":"MapLibre"}]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon\/interiorPolygons","interfaceLanguage":"occ"},"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"path