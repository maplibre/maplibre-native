{"abstract":[{"type":"text","text":"The array of polygons nested inside the receiver."}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"readonly"},{"kind":"text","text":") "},{"kind":"typeIdentifier","text":"NSArray<MLNPolygon *>","preciseIdentifier":"c:Q$objc(cs)NSArray"},{"kind":"text","text":" * "},{"text":"interiorPolygons","kind":"identifier"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"The area occupied by any interior polygons is excluded from the overall shape."},{"type":"text","text":" "},{"type":"text","text":"Interior polygons should not overlap. An interior polygon should not have"},{"type":"text","text":" "},{"type":"text","text":"interior polygons of its own."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If there are no interior polygons, the value of this property is "},{"code":"nil","type":"codeVoice"},{"type":"text","text":"."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon"]]},"variants":[{"paths":["\/documentation\/maplibre\/mlnpolygon\/interiorpolygons"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon\/interiorPolygons","interfaceLanguage":"occ"},"metadata":{"navigatorTitle":[{"text":"interiorPolygons","kind":"identifier"}],"role":"symbol","roleHeading":"Instance Property","modules":[{"name":"MapLibre"}],"title":"interiorPolygons","fragments":[{"text":"interiorPolygons","kind":"identifier"}],"externa