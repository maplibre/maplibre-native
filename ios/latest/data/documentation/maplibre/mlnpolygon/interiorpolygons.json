{"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"abstract":[{"type":"text","text":"The array of polygons nested inside the receiver."}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"readonly","kind":"keyword"},{"text":") ","kind":"text"},{"text":"NSArray<MLNPolygon *>","kind":"typeIdentifier","preciseIdentifier":"c:Q$objc(cs)NSArray"},{"text":" * ","kind":"text"},{"text":"interiorPolygons","kind":"identifier"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The area occupied by any interior polygons is excluded from the overall shape."},{"type":"text","text":" "},{"type":"text","text":"Interior polygons should not overlap. An interior polygon should not have"},{"type":"text","text":" "},{"type":"text","text":"interior polygons of its own."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If there are no interior polygons, the value of this property is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/maplibre\/mlnpolygon\/interiorpolygons"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"role":"symbol","roleHeading":"Instance Property","externalID":"c:objc(cs)MLNPolygon(py)interiorPolygons","fragments":[{"text":"interiorPolygons","kind":"identifier"}],"symbolKind":"property","title":"interiorPolygons","navigatorTitle":[{"kind":"identifier","text":"interiorPolygons"}],"modules":[{"name":"MapLibre"}]},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/Ma