ntation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNPolygon/interiorPolygons":{"title":"interiorPolygons","fragments":[{"kind":"identifier","text":"interiorPolygons"}],"kind":"symbol","type":"topic","abstract":[{"text":"The array of polygons nested inside the receiver.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon\/interiorPolygons","url":"\/documentation\/maplibre\/mlnpolygon\/interiorpolygons","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","url":"\/documentation\/maplibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","kind":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNPolygon":{"fragments":[{"text":"MLNPolygon","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnpolygon","role":"symbol","title":"MLNPolygon","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon","abstract":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon"},{"type":"text","text":" object represents a closed shape consisting of four or more"},{"type":"text","text":" "},{"type":"text","text":"vertices, specified as "},{"code":"CLLocationCoordinate2D","type":"codeVoice"},{"type":"text","text":" instances, and the edges that"},{"type":"text","text":" "},{"type":"text","text":"connect them. For example, you could use a polygon shape to represent a"},{"type":"text","text":" "},{"type":"text","text":"building, a lake, or an area you want to highlight."}],"type":"topic"}}}