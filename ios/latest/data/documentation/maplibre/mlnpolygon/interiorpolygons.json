{"abstract":[{"text":"The array of polygons nested inside the receiver.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"readonly","kind":"keyword"},{"text":") ","kind":"text"},{"text":"NSArray<MLNPolygon *>","kind":"typeIdentifier","preciseIdentifier":"c:Q$objc(cs)NSArray"},{"text":" * ","kind":"text"},{"kind":"identifier","text":"interiorPolygons"},{"kind":"text","text":";"}],"platforms":["iOS","iPadOS","Mac Catalyst"]}]},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"The area occupied by any interior polygons is excluded from the overall shape.","type":"text"},{"text":" ","type":"text"},{"text":"Interior polygons should not overlap. An interior polygon should not have","type":"text"},{"text":" ","type":"text"},{"text":"interior polygons of its own.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If there are no interior polygons, the value of this property is "},{"code":"nil","type":"codeVoice"},{"type":"text","text":"."}]}],"kind":"content"}],"sections":[],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon\/interiorPolygons","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon"]]},"metadata":{"title":"interiorPolygons","modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNPolygon(py)interiorPolygons","roleHeading":"Instance Property","fragments":[{"kind":"identifier","text":"interiorPolygons"}],"navigatorTitle":[{"kind":"identifier","text":"interiorPolygons"}],"symbolKind":"property","role":"symbol"},"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","variants":[{"paths":["\/document