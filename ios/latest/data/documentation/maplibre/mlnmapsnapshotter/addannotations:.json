pLibre\/MLNMultiPolyline","type":"reference","isActive":true},{"text":" objects","type":"text"},{"text":" ","type":"text"},{"text":"cannot be added to the snapshotter at this time. Nor can ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"objects that are not instances of ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolyline"},{"text":" or ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolyline"},{"text":". Any","type":"text"},{"type":"text","text":" "},{"type":"text","text":"multipoint, multipolyline, multipolygon, or shape collection objects that"},{"type":"text","text":" "},{"text":"are specified are silently ignored.","type":"text"}]}],"type":"aside"}]}],"sections":[],"metadata":{"role":"symbol","roleHeading":"Instance Method","externalID":"c:objc(cs)MLNMapSnapshotter(im)addAnnotations:","modules":[{"name":"MapLibre"}],"symbolKind":"method","fragments":[{"text":"- ","kind":"text"},{"kind":"identifier","text":"addAnnotations:"}],"title":"addAnnotations:","navigatorTitle":[{"text":"- ","kind":"text"},{"text":"addAnnotations:","kind":"identifier"}]},"abstract":[{"type":"text","text":"Adds an array of annotations to the snapshotter."}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter\/addAnnotations:","interfaceLanguage":"occ"},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","kind":"symbol","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"title":"MapLibre","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMap