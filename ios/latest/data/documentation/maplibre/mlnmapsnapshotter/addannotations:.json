t","text":" generates static raster images of the map. Each snapshot"},{"type":"text","text":" "},{"type":"text","text":"image depicts a portion of a map defined by an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotOptions","type":"reference","isActive":true},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"you provide. The snapshotter generates an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshot","type":"reference","isActive":true},{"type":"text","text":" object"},{"text":" ","type":"text"},{"text":"asynchronously, calling ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotterDelegate","type":"reference"},{"text":" methods if defined, then","type":"text"},{"text":" ","type":"text"},{"text":"passing it into a completion handler once tiles and other resources needed for","type":"text"},{"text":" ","type":"text"},{"text":"the snapshot are finished loading.","type":"text"}],"kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"MLNMapSnapshotter","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshot":{"type":"topic","url":"\/documentation\/maplibre\/mlnmapsnapshot","abstract":[{"type":"text","text":"An image generated by a snapshotter object."}],"role":"symbol","title":"MLNMapSnapshot","fragments":[{"text":"MLNMapSnapshot","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshot"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPoint":{"role":"symbol","title":"MLNMultiPoint","url":"\/documentation\/maplibre\/mlnmultipoint","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint","type":"topic","fragments":[{"text":"MLNMultiPoint","kind":"identifier"}],"abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint","isActive":true,"type":"reference"},{"text":" class is an abstract superclass used to define shapes","type":"text"},{"text":" ","type":"text"},{"text":"composed of multiple vertices.","type":"text"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshotter/addAnnotations:":{"title":"addAnnotations:","type":"topic","role":"symbol","kind":"symbol","url":"\/documentation\/maplibre\/mlnmapsnapshotter\/addannotations:","abstract":[{"type":"text","text":"Adds an array of annotations to the snapshotter."}],"fragments":[{"text":"- ","kind":"text"},{"text":"addAnnotations:","kind":"identifier"}],"navigatorTitle":[{"text":"addAnnotations:","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter\/addAnnotations:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPolyline":{"type":"topic","kind":"symbol","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolyline","type":"reference","isActive":true},{"type":"text","text":" object represents a shape consisting of one or more"},{"type":"text","text":" "},{"type":"text","text":"polylines. For example, you could use a multipolyline shape to represent both"},{"type":"text","text":" "},{"type":"text","text":"sides of a divided highway (dual carriageway), excluding the median (central"},{"type":"text","text":" "},{"type":"text","text":"reservation): each carriageway would be a distinct "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolyline","type":"reference","isActive":true},{"type":"text","text":" object."}],"role":"symbol","title":"MLNMultiPolyline","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolyline","url":"\/documentation\/maplibre\/mlnmultipolyline","fragments":[{"text":"MLNMultiPolyline","kind":"identifier"}]}}}