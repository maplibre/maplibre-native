},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolyline"},{"type":"text","text":" objects"},{"type":"text","text":" "},{"type":"text","text":"cannot be added to the snapshotter at this time. Nor can "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint"},{"type":"text","text":" "},{"type":"text","text":"objects that are not instances of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolyline"},{"type":"text","text":" or "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolyline"},{"type":"text","text":". Any"},{"type":"text","text":" "},{"type":"text","text":"multipoint, multipolyline, multipolygon, or shape collection objects that"},{"type":"text","text":" "},{"type":"text","text":"are specified are silently ignored."}],"type":"paragraph"}],"name":"Note","type":"aside","style":"note"}],"kind":"content"}],"abstract":[{"type":"text","text":"Adds an array of annotations to the snapshotter."}],"metadata":{"externalID":"c:objc(cs)MLNMapSnapshotter(im)addAnnotations:","symbolKind":"method","modules":[{"name":"MapLibre"}],"title":"addAnnotations:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"addAnnotations:"}],"navigatorTitle":[{"kind":"identifier","text":"addAnnotations:"}],"role":"symbol","roleHeading":"Instance Method"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPoint":{"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint","title":"MLNMultiPoint","kind":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnmultipoint","abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPoint","isActive":true,"type":"reference"},{"text":" class is an abstract super