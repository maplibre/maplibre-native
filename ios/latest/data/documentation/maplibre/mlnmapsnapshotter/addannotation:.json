","type":"text"},{"text":"such as the annotation’s location on the map. Annotation objects do not provide","type":"text"},{"text":" ","type":"text"},{"text":"the visual representation of the annotation but typically coordinate (in","type":"text"},{"text":" ","type":"text"},{"text":"conjunction with the map view’s delegate) the creation of an appropriate","type":"text"},{"text":" ","type":"text"},{"text":"objects to handle the display.","type":"text"}],"fragments":[{"text":"MLNAnnotation","kind":"identifier"}],"role":"symbol","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshotterDelegate":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotterDelegate","url":"\/documentation\/maplibre\/mlnmapsnapshotterdelegate","kind":"symbol","abstract":[{"type":"text","text":"Optional methods about significant events when creating a snapshot using an"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter"},{"type":"text","text":" object."}],"fragments":[{"text":"MLNMapSnapshotterDelegate","kind":"identifier"}],"title":"MLNMapSnapshotterDelegate","type":"topic","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshot":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshot","url":"\/documentation\/maplibre\/mlnmapsnapshot","title":"MLNMapSnapshot","abstract":[{"text":"An image generated by a snapshotter object.","type":"text"}],"type":"topic","role":"symbol","fragments":[{"kind":"identifier","text":"MLNMapSnapshot"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshotOptions":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotOptions","abstract":[{"text":"The options to use when creating images with the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter"},{"text":".","type":"text"}],"kind":"symbol","fragments":[{"kind":"identifier","text":"MLNMapSnapshotOptions"}],"type":"topic","title":"MLNMapSnapshotOptions","url":"\/documentation\/maplibre\/mlnmapsnapshotoptions","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNPointCollection":{"kind":"symbol","abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection","isActive":true},{"type":"text","text":" object represents a shape consisting of one or more"},{"type":"text","text":" "},{"type":"text","text":"disconnected vertices, specified as "},{"type":"codeVoice","code":"CLLocationCoordinate2D"},{"type":"text","text":" instances. The"},{"type":"text","text":" "},{"type":"text","text":"points in the collection may be related but are not connected spatially. For"},{"type":"text","text":" "},{"type":"text","text":"example, you could use a point collection to represent all the trees in an"},{"type":"text","text":" "},{"type":"text","text":"orchard."}],"url":"\/documentation\/maplibre\/mlnpointcollection","role":"symbol","fragments":[{"kind":"identifier","text":"MLNPointCollection"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointCollection","title":"MLNPointCollection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshotter/addAnnotation:":{"type":"topic","url":"\/documentation\/maplibre\/mlnmapsnapshotter\/addannotation:","navigatorTitle":[{"text":"addAnnotation:","kind":"identifier"}],"role":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"addAnnotation:","kind":"identifier"}],"abstract":[{"type":"text","text":"Adds an annotation to the snapshotter."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter\/addAnnotation:","kind":"symbol","title":"addAnnotation:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPolyline":{"title":"MLN