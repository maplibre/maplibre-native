{"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter\/delegate"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"weak","kind":"keyword"},{"text":") ","kind":"text"},{"text":"id<MLNMapSnapshotterDelegate>","kind":"typeIdentifier","preciseIdentifier":"c:Qoobjc(pl)MLNMapSnapshotterDelegate"},{"text":" ","kind":"text"},{"text":"delegate","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"The delegate is responsible for responding to significant changes during the"},{"type":"text","text":" "},{"type":"text","text":"snapshotting process, such as the style loading. Implement a delegate to"},{"type":"text","text":" "},{"type":"text","text":"customize the style that is depicted by the snapshot."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You set the delegate after initializing the snapshotter but before receiving"},{"type":"text","text":" "},{"type":"text","text":"the snapshot, typically before starting the snapshot. The snapshotter keeps a"},{"type":"text","text":" "},{"type":"text","text":"weak reference to its delegate, so you must keep a strong reference to it to"},{"type":"text","text":" "},{"type":"text","text":"ensure that your style customizations apply."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapsnapshotter\/delegate"]}],"abstract":[{"type":"text","text":"The snapshotter’s delegate."}],"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.My