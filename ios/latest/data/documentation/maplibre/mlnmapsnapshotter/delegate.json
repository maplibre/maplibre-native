apSnapshotOptions","isActive":true,"type":"reference"},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"you provide. The snapshotter generates an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshot","isActive":true,"type":"reference"},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"asynchronously, calling "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotterDelegate","isActive":true,"type":"reference"},{"type":"text","text":" methods if defined, then"},{"type":"text","text":" "},{"type":"text","text":"passing it into a completion handler once tiles and other resources needed for"},{"type":"text","text":" "},{"type":"text","text":"the snapshot are finished loading."}],"title":"MLNMapSnapshotter","kind":"symbol","url":"\/documentation\/maplibre\/mlnmapsnapshotter","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshot":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshot","fragments":[{"kind":"identifier","text":"MLNMapSnapshot"}],"url":"\/documentation\/maplibre\/mlnmapsnapshot","kind":"symbol","title":"MLNMapSnapshot","role":"symbol","type":"topic","abstract":[{"type":"text","text":"An image generated by a snapshotter object."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshotter/delegate":{"role":"symbol","fragments":[{"text":"delegate","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter\/delegate","url":"\/documentation\/maplibre\/mlnmapsnapshotter\/delegate","title":"delegate","abstract":[{"type":"text","text":"The snapshotter’s delegate."}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshotterDelegate":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotterDelegate","type":"topic","role":"symbol","url":"\/documentation\/m