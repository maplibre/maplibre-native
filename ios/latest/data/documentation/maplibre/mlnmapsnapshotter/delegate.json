{"abstract":[{"text":"The snapshotter’s delegate.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"weak","kind":"keyword"},{"text":") ","kind":"text"},{"text":"id<MLNMapSnapshotterDelegate>","preciseIdentifier":"c:Qoobjc(pl)MLNMapSnapshotterDelegate","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"delegate","kind":"identifier"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"text":"The delegate is responsible for responding to significant changes during the","type":"text"},{"text":" ","type":"text"},{"text":"snapshotting process, such as the style loading. Implement a delegate to","type":"text"},{"text":" ","type":"text"},{"text":"customize the style that is depicted by the snapshot.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"You set the delegate after initializing the snapshotter but before receiving","type":"text"},{"text":" ","type":"text"},{"text":"the snapshot, typically before starting the snapshot. The snapshotter keeps a","type":"text"},{"text":" ","type":"text"},{"text":"weak reference to its delegate, so you must keep a strong reference to it to","type":"text"},{"text":" ","type":"text"},{"text":"ensure that your style customizations apply.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter\/delegate","interfaceLanguage":"occ"},"metadata":{"roleHeading":"Instance Property","role":"symbol","symbolKind":"property","title":"delegate","modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNMapSnapshotter(py)delegate","fragments":[{"kind":"identifier","text":"delegate"}],"navigatorTitle":[{"text":"delegate","kind":"identif