 "},{"type":"text","text":"building, a lake, or an area you want to highlight."}],"type":"topic","role":"symbol","kind":"symbol","url":"\/documentation\/maplibre\/mlnpolygon","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon","title":"MLNPolygon","fragments":[{"kind":"identifier","text":"MLNPolygon"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","url":"\/documentation\/maplibre\/mlnstyle","kind":"symbol","title":"MLNStyle","role":"symbol","abstract":[{"type":"text","text":"The proxy object for the current map style."}],"fragments":[{"kind":"identifier","text":"MLNStyle"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer":{"role":"symbol","abstract":[{"text":"An ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer"},{"text":" is a style layer that renders icon and text labels","type":"text"},{"text":" ","type":"text"},{"text":"at points or along lines on the map.","type":"text"}],"type":"topic","title":"MLNSymbolStyleLayer","kind":"symbol","url":"\/documentation\/maplibre\/mlnsymbolstylelayer","fragments":[{"kind":"identifier","text":"MLNSymbolStyleLayer"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPolygonFeature":{"abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygonFeature","isActive":true},{"type":"text","text":" object associates a multipolygon shape with an"},{"type":"text","text":" "},{"type":"text","text":"optional identifier and attributes."}],"type":"topic","url":"\/documentation\/maplibre\/mlnmultipolygonfeature","role":"symbol","fragments":[{"text":"MLNMultiPolygonFeature","kind":"identifier"}],"identifier":"doc:\/\/or