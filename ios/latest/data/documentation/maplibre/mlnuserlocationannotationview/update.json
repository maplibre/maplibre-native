ion\/maplibre\/mlnuserlocation"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView":{"url":"\/documentation\/maplibre\/mlnuserlocationannotationview","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView","role":"symbol","abstract":[{"type":"text","text":"View representing an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocation","type":"reference","isActive":true},{"type":"text","text":" on screen."}],"type":"topic","title":"MLNUserLocationAnnotationView","fragments":[{"kind":"identifier","text":"MLNUserLocationAnnotationView"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView/update":{"abstract":[{"text":"Updates the user location annotation.","type":"text"}],"type":"topic","kind":"symbol","url":"\/documentation\/maplibre\/mlnuserlocationannotationview\/update","role":"symbol","title":"update","fragments":[{"text":"- ","kind":"text"},{"text":"update","kind":"identifier"}],"navigatorTitle":[{"text":"update","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\/update"}}}