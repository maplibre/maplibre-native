{"metadata":{"fragments":[{"text":"- ","kind":"text"},{"text":"update","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"title":"update","remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNUserLocationAnnotationView.h#L59","fileName":"MLNUserLocationAnnotationView.h"},"roleHeading":"Instance Method","role":"symbol","navigatorTitle":[{"text":"update","kind":"identifier"}],"symbolKind":"method","externalID":"c:objc(cs)MLNUserLocationAnnotationView(im)update"},"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnuserlocationannotationview\/update"]}],"abstract":[{"type":"text","text":"Updates the user location annotation."}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\/update"},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"- ("},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"kind":"identifier","text":"update"},{"kind":"text","text":";"}],"languages":["occ"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Use this method to update the appearance of the user location annotation. This"},{"type":"text","text":" "},{"type":"text","text":"method is called by the associated map view when it has determined that the"},{"type":"text","text":" "},{"type":"text","text":"user location annotation needs to be updated. This can happen in response to"},{"type":"text","text":" "},{"type":"text","text":"user interaction, a change in the user’s location, when the user tracking mode"},{"type":"text","text":" "},{"type":"text","text":"changes, or when the viewport changes."}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"During user interaction with the map, this method may be called many","type":"text"},{"text":" ","type":"text"},{"text":"times to update the user location annotation. Therefore, your implementation of","type":"text"},{"text":" ","type":"text"},{"text":"this method should be as lightweight as possible to avoid negatively affecting","type":"text"},{"text":" ","type":"text"},{"text":"performance.","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"}]}],"kind":"symbol","references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocation":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocation","title":"MLNUserLocation","url":"\/documentation\/maplibre\/mlnuserlocation","role":"symbol","fragments":[{"kind":"identifier","text":"MLNUserLocation"}],"abstract":[{"type":"text","text":"The MLNUserLocation class defines a specific type of annotation that identifies"},{"type":"text","text":" "},{"type":"text","text":"the user’s current location. You do not create instances of this class"},{"type":"text","text":" "},{"type":"text","text":"directly. Instead, you retrieve an existing "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocation","isActive":true,"type":"reference"},{"type":"text","text":" object from the"},{"type":"text","text":" "},{"code":"userLocation","type":"codeVoice"},{"type":"text","text":" property of the map view displayed in your application."}],"type":"topic","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView","fragments":[{"text":"MLNUserLocationAnnotationView","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnuserlocationannotationview","kind