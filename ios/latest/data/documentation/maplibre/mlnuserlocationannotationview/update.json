{"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"Updates the user location annotation."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"- (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"update","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"text":"Use this method to update the appearance of the user location annotation. This","type":"text"},{"text":" ","type":"text"},{"text":"method is called by the associated map view when it has determined that the","type":"text"},{"text":" ","type":"text"},{"text":"user location annotation needs to be updated. This can happen in response to","type":"text"},{"text":" ","type":"text"},{"text":"user interaction, a change in the user’s location, when the user tracking mode","type":"text"},{"text":" ","type":"text"},{"text":"changes, or when the viewport changes.","type":"text"}],"type":"paragraph"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"During user interaction with the map, this method may be called many","type":"text"},{"text":" ","type":"text"},{"text":"times to update the user location annotation. Therefore, your implementation of","type":"text"},{"text":" ","type":"text"},{"text":"this method should be as lightweight as possible to avoid negatively affecting","type":"text"},{"text":" ","type":"text"},{"text":"performance.","type":"text"}]}],"type":"aside","name":"Note"}],"kind":"content"}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\/update","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView"]]},"