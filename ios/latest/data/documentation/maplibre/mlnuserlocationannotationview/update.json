{"variants":[{"paths":["\/documentation\/maplibre\/mlnuserlocationannotationview\/update"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"text":"Updates the user location annotation.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView"]]},"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"- ("},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"kind":"identifier","text":"update"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"Use this method to update the appearance of the user location annotation. This","type":"text"},{"text":" ","type":"text"},{"text":"method is called by the associated map view when it has determined that the","type":"text"},{"text":" ","type":"text"},{"text":"user location annotation needs to be updated. This can happen in response to","type":"text"},{"text":" ","type":"text"},{"text":"user interaction, a change in the user’s location, when the user tracking mode","type":"text"},{"text":" ","type":"text"},{"text":"changes, or when the viewport changes.","type":"text"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"During user interaction with the map, this method may be called many"},{"type":"text","text":" "},{"type":"text","text":"times to update the user location annotation. Therefore, your implementation of"},{"type":"text","text":" "},{"type":"text","text":"this method should be as lightweight as possible to avoid negatively affecting"},{"type":"text","text":" "},{"type":"text","text":"performance."}]}],"type":"aside","style":"note","name":"Note"}],"kind":"content"}],"kind":"symbol","identifier":{"url":"doc:\/\/org.swift.MyProject\/documen