{"abstract":[{"text":"Updates the user location annotation.","type":"text"}],"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"- (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"update","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Use this method to update the appearance of the user location annotation. This","type":"text"},{"text":" ","type":"text"},{"text":"method is called by the associated map view when it has determined that the","type":"text"},{"text":" ","type":"text"},{"text":"user location annotation needs to be updated. This can happen in response to","type":"text"},{"text":" ","type":"text"},{"text":"user interaction, a change in the user’s location, when the user tracking mode","type":"text"},{"text":" ","type":"text"},{"text":"changes, or when the viewport changes.","type":"text"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"During user interaction with the map, this method may be called many"},{"type":"text","text":" "},{"type":"text","text":"times to update the user location annotation. Therefore, your implementation of"},{"type":"text","text":" "},{"type":"text","text":"this method should be as lightweight as possible to avoid negatively affecting"},{"type":"text","text":" "},{"type":"text","text":"performance."}]}],"name":"Note","type":"aside","style":"note"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnuserlocationannotationview\/update"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\/update"},"metadata":{"remoteSource":{"fileName