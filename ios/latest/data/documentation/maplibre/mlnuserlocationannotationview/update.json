{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\/update"},"sections":[],"abstract":[{"type":"text","text":"Updates the user location annotation."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"- (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"update","kind":"identifier"},{"text":";","kind":"text"}]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this method to update the appearance of the user location annotation. This"},{"type":"text","text":" "},{"type":"text","text":"method is called by the associated map view when it has determined that the"},{"type":"text","text":" "},{"type":"text","text":"user location annotation needs to be updated. This can happen in response to"},{"type":"text","text":" "},{"type":"text","text":"user interaction, a change in the user’s location, when the user tracking mode"},{"type":"text","text":" "},{"type":"text","text":"changes, or when the viewport changes."}]},{"content":[{"inlineContent":[{"type":"text","text":"During user interaction with the map, this method may be called many"},{"type":"text","text":" "},{"type":"text","text":"times to update the user location annotation. Therefore, your implementation of"},{"type":"text","text":" "},{"type":"text","text":"this method should be as lightweight as possible to avoid negatively affecting"},{"type":"text","text":" "},{"type":"text","text":"performance."}],"type":"paragraph"}],"name":"Note","type":"aside","style":"note"}]}],"metadata":{"remoteSource":{"url":"https:\/\/github.com\/maplibre\/maplibre-native\/blob\/main\/platform\/ios\/src\/MLNUserLocationAnnotationView.h#L59","fileName":"MLNUserLocationAnnotationView.h"},"role":"symbol","navigatorTitle":[{"text":"update","kind":"identifier"}],"roleHeading":"Instance Method","symbolKind":"method","title":"update","fragments":[{"text":"- ","kind":"text"},{"text":"update","kind":"identifier"}],"externalID":"c:objc(cs)MLNUserLocationAnnotationView(im)update","modules":[{"name":"MapLibre"}]},"kind":"symbol","variants":[{"paths":["\/documentation\/maplibre\/mlnuserlocationannotationview\/update"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView":{"abstract":[{"type":"text","text":"View representing an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocation","isActive":true},{"type":"text","text":" on screen."}],"title":"MLNUserLocationAnnotationView","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView","url":"\/documentation\/maplibre\/mlnuserlocationannotationview","fragments":[{"text":"MLNUserLocationAnnotationView","kind":"identifier"}],"type":"topic","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol","title":"MapLibre","url":"\/documentation\/maplibre","type":"topic","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView/update":{"url":"\/documentation\/maplibre\/mlnuserlocationannotationview\/update","navigatorTitle":[{"text":"update","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\