e"},{"text":" object from the","type":"text"},{"text":" ","type":"text"},{"code":"userLocation","type":"codeVoice"},{"text":" property of the map view displayed in your application.","type":"text"}],"url":"\/documentation\/maplibre\/mlnuserlocation","title":"MLNUserLocation","role":"symbol","fragments":[{"kind":"identifier","text":"MLNUserLocation"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView/update":{"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"update"}],"role":"symbol","url":"\/documentation\/maplibre\/mlnuserlocationannotationview\/update","abstract":[{"text":"Updates the user location annotation.","type":"text"}],"title":"update","kind":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\/update"},"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"url":"\/documentation\/maplibre","title":"MapLibre","role":"collection"}}}