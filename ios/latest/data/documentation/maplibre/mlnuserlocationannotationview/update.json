{"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"- (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"update","kind":"identifier"},{"text":";","kind":"text"}]}]},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Use this method to update the appearance of the user location annotation. This"},{"type":"text","text":" "},{"type":"text","text":"method is called by the associated map view when it has determined that the"},{"type":"text","text":" "},{"type":"text","text":"user location annotation needs to be updated. This can happen in response to"},{"type":"text","text":" "},{"type":"text","text":"user interaction, a change in the user’s location, when the user tracking mode"},{"type":"text","text":" "},{"type":"text","text":"changes, or when the viewport changes."}],"type":"paragraph"},{"name":"Note","type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"During user interaction with the map, this method may be called many"},{"type":"text","text":" "},{"type":"text","text":"times to update the user location annotation. Therefore, your implementation of"},{"type":"text","text":" "},{"type":"text","text":"this method should be as lightweight as possible to avoid negatively affecting"},{"type":"text","text":" "},{"type":"text","text":"performance."}],"type":"paragraph"}]}],"kind":"content"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView"]]},"metadata":{"roleHeading":"Instance Method","externalID":"c:objc(cs)MLNUserLocationAnnotationView(im)update","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"update"}],"role":"symbo