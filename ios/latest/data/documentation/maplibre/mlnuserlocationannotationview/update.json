{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\/update","interfaceLanguage":"occ"},"abstract":[{"text":"Updates the user location annotation.","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/maplibre\/mlnuserlocationannotationview\/update"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"declarations":[{"languages":["occ"],"tokens":[{"kind":"text","text":"- ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"update"},{"kind":"text","text":";"}],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Use this method to update the appearance of the user location annotation. This"},{"type":"text","text":" "},{"type":"text","text":"method is called by the associated map view when it has determined that the"},{"type":"text","text":" "},{"type":"text","text":"user location annotation needs to be updated. This can happen in response to"},{"type":"text","text":" "},{"type":"text","text":"user interaction, a change in the user’s location, when the user tracking mode"},{"type":"text","text":" "},{"type":"text","text":"changes, or when the viewport changes."}],"type":"paragraph"},{"name":"Note","content":[{"inlineContent":[{"type":"text","text":"During user interaction with the map, this method may be called many"},{"type":"text","text":" "},{"type":"text","text":"times to update the user location annotation. Therefore, your implementation of"},{"type":"text","text":" "},{"type":"text","text":"this method should be as lightweight as possible to avoid negatively affecting"},{"type":"text","text":