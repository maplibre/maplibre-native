, your implementation of"},{"type":"text","text":" "},{"type":"text","text":"this method should be as lightweight as possible to avoid negatively affecting"},{"type":"text","text":" "},{"type":"text","text":"performance."}],"type":"paragraph"}],"type":"aside","name":"Note","style":"note"}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView"]]},"variants":[{"paths":["\/documentation\/maplibre\/mlnuserlocationannotationview\/update"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"text":"Updates the user location annotation.","type":"text"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocation":{"role":"symbol","abstract":[{"type":"text","text":"The MLNUserLocation class defines a specific type of annotation that identifies"},{"type":"text","text":" "},{"type":"text","text":"the user’s current location. You do not create instances of this class"},{"type":"text","text":" "},{"type":"text","text":"directly. Instead, you retrieve an existing "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocation","type":"reference","isActive":true},{"type":"text","text":" object from the"},{"text":" ","type":"text"},{"code":"userLocation","type":"codeVoice"},{"text":" property of the map view displayed in your application.","type":"text"}],"title":"MLNUserLocation","type":"topic","fragments":[{"kind":"identifier","text":"MLNUserLocation"}],"url":"\/documentation\/maplibre\/mlnuserlocation","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocation","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView":{"type":"topic","abstract":[{"text":"View representing an ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocation"},{"text":" on screen.","type":"text"}],"role":"sy