led many"},{"text":" ","type":"text"},{"text":"times to update the user location annotation. Therefore, your implementation of","type":"text"},{"text":" ","type":"text"},{"text":"this method should be as lightweight as possible to avoid negatively affecting","type":"text"},{"text":" ","type":"text"},{"text":"performance.","type":"text"}]}],"name":"Note","style":"note","type":"aside"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/maplibre\/mlnuserlocationannotationview\/update"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView"]]},"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","url":"\/documentation\/maplibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView/update":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\/update","abstract":[{"type":"text","text":"Updates the user location annotation."}],"kind":"symbol","title":"update","type":"topic","role":"symbol","fragments":[{"kind":"text","text":"- "},{"text":"update","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnuserlocationannotationview\/update"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocation":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocation","abstract":[{"type":"text","text":"The MLNUserLocation class defines a specific type of annotation that identifies"},{"type":"text","text":" "},{"type":"text","text":"the user’s current location. You do not create instances of this class"},{"text":" ","type":"text"},{"type":"text","text":"directly. Instead, you retrieve an existing "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocation"},{"type":"text","text":" object from the"},{"type":"text","text":" "},{"type":"codeVoice","code":"userLocation"},{"type":"text","text":" property of the map view displayed in your application."}],"kind":"symbol","role":"symbol","title":"MLNUserLocation","url":"\/documentation\/maplibre\/mlnuserlocation","fragments":[{"kind":"identifier","text":"MLNUserLocation"}],"type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView","title":"MLNUserLocationAnnotationView","kind":"symbol","url":"\/documentation\/maplibre\/mlnuserlocationannotationview","type":"topic","role":"symbol","abstract":[{"type":"text","text":"View representing an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocation","isActive":true},{"type":"text","text":" on screen."}],"fragments":[{"text":"MLNUserLocationAnnotationView","kind":"identifier"}]}}}