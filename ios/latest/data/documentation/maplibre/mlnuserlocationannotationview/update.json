, or when the viewport changes.","type":"text"}],"type":"paragraph"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"During user interaction with the map, this method may be called many"},{"type":"text","text":" "},{"type":"text","text":"times to update the user location annotation. Therefore, your implementation of"},{"type":"text","text":" "},{"type":"text","text":"this method should be as lightweight as possible to avoid negatively affecting"},{"type":"text","text":" "},{"type":"text","text":"performance."}]}],"type":"aside"}]}],"abstract":[{"type":"text","text":"Updates the user location annotation."}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView/update":{"abstract":[{"type":"text","text":"Updates the user location annotation."}],"url":"\/documentation\/maplibre\/mlnuserlocationannotationview\/update","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView\/update","navigatorTitle":[{"text":"update","kind":"identifier"}],"title":"update","type":"topic","kind":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"update","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocationAnnotationView":{"role":"symbol","kind":"symbol","fragments":[{"kind":"identifier","text":"MLNUserLocationAnnotationView"}],"abstract":[{"type":"text","text":"View representing an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocation"},{"type":"text","text":" on screen."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocationAnnotationView","title":"MLNUserLocationAnnotationView","url":"\/documentation\/maplibre\/mlnuserlocationannotationview","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"c