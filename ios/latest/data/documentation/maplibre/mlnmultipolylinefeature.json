swift.MyProject\/documentation\/MapLibre\/MLNMultiPolylineFeature","type":"topic","role":"symbol","fragments":[{"text":"MLNMultiPolylineFeature","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnmultipolylinefeature","kind":"symbol","title":"MLNMultiPolylineFeature"},"doc://org.swift.MyProject/documentation/MapLibre/MLNPolylineFeature":{"url":"\/documentation\/maplibre\/mlnpolylinefeature","title":"MLNPolylineFeature","type":"topic","abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolylineFeature","isActive":true},{"type":"text","text":" object associates a polyline shape with an optional"},{"type":"text","text":" "},{"type":"text","text":"identifier and attributes."}],"fragments":[{"text":"MLNPolylineFeature","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolylineFeature","kind":"symbol","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNPointAnnotation":{"type":"topic","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation","type":"reference","isActive":true},{"type":"text","text":" object represents a one-dimensional shape located at a"},{"type":"text","text":" "},{"type":"text","text":"single geographical coordinate. Depending on how it is used, an"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPointAnnotation","type":"reference","isActive":true},{"type":"text","text":" object is known as a point annotation or point shape. For"},{"type":"text","text":" "},{"type":"text","text":"example, you could use a point shape to represent a city at low zoom levels, an"},{"type":"text","text":" "},{"type":"text","text":"address at high zoom levels, or the location of a long press gesture."}],"title":"MLNPointAnnotation","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPoint