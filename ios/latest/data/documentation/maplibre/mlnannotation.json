/MapLibre/MLNAnnotation/subtitle":{"role":"symbol","title":"subtitle","type":"topic","fragments":[{"text":"subtitle","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation\/subtitle","url":"\/documentation\/maplibre\/mlnannotation\/subtitle","abstract":[{"type":"text","text":"The string containing the annotation’s subtitle."}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNUserLocation":{"role":"symbol","title":"MLNUserLocation","type":"topic","fragments":[{"text":"MLNUserLocation","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocation","url":"\/documentation\/maplibre\/mlnuserlocation","abstract":[{"type":"text","text":"The MLNUserLocation class defines a specific type of annotation that identifies"},{"type":"text","text":" "},{"type":"text","text":"the user’s current location. You do not create instances of this class"},{"type":"text","text":" "},{"type":"text","text":"directly. Instead, you retrieve an existing "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNUserLocation","type":"reference"},{"type":"text","text":" object from the"},{"type":"text","text":" "},{"type":"codeVoice","code":"userLocation"},{"type":"text","text":" property of the map view displayed in your application."}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/AnnotationViewExample":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnnotationViewExample","abstract":[{"type":"text","text":"Add a custom annotation view"}],"title":"Custom Annotation View","kind":"article","role":"article","type":"topic","url":"\/documentation\/maplibre-native-for-ios\/annotationviewexample"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOverlay":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOverlay","abstract":[{"type":"text","text":"The "},{"type":"r