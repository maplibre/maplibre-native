MyProject\/documentation\/MapLibre\/MLNPolygon","type":"reference","isActive":true},{"type":"text","text":" object, while the surrounding"},{"text":" ","type":"text"},{"text":"atoll would be another. You could also use a multipolygon shape to represent a","type":"text"},{"text":" ","type":"text"},{"text":"group of disconnected but related buildings.","type":"text"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnmultipolygon","title":"MLNMultiPolygon","type":"topic","fragments":[{"kind":"identifier","text":"MLNMultiPolygon"}],"role":"symbol"}}}