esent a"},{"type":"text","text":" "},{"type":"text","text":"building, a lake, or an area you want to highlight."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPolygon/polygons":{"url":"\/documentation\/maplibre\/mlnmultipolygon\/polygons","type":"topic","abstract":[{"text":"An array of polygons forming the multipolygon.","type":"text"}],"role":"symbol","fragments":[{"text":"polygons","kind":"identifier"}],"kind":"symbol","title":"polygons","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon\/polygons"}}}