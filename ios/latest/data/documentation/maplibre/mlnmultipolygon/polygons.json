 related buildings."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon","role":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPolygon/polygons":{"abstract":[{"text":"An array of polygons forming the multipolygon.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon\/polygons","role":"symbol","type":"topic","fragments":[{"text":"polygons","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnmultipolygon\/polygons","kind":"symbol","title":"polygons"}}}