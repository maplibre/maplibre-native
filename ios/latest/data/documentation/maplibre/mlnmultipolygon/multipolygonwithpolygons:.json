{"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","metadata":{"title":"multiPolygonWithPolygons:","modules":[{"name":"MapLibre"}],"role":"symbol","externalID":"c:objc(cs)MLNMultiPolygon(cm)multiPolygonWithPolygons:","fragments":[{"text":"+ ","kind":"text"},{"text":"multiPolygonWithPolygons:","kind":"identifier"}],"symbolKind":"method","navigatorTitle":[{"text":"multiPolygonWithPolygons:","kind":"identifier"}],"roleHeading":"Type Method"},"abstract":[{"text":"Creates and returns a multipolygon object consisting of the given polygons.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon"]]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"kind":"text","text":"+ ("},{"kind":"keyword","text":"instancetype"},{"kind":"text","text":") "},{"kind":"identifier","text":"multiPolygonWithPolygons:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"NSArray<MLNPolygon *>","preciseIdentifier":"c:Q$objc(cs)NSArray"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"polygons"},{"kind":"text","text":";"}],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"The array of polygons defining the shape.","type":"text"}],"type":"paragraph"}],"name":"polygons"}]},{"kind":"content","content":[{"anchor":"return-value","level":2,"type":"heading","text":"Return Value"},{"inlineContent":[{"text":"A new multipolygon object.","type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmultipolygon\/multipolygonwithpolygons:"]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon\/multiPolygonWithPolygons:"},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","type":"topic","title":"MapLibre","url":"\/documentation\/maplibre","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPolygon":{"abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon","isActive":true},{"type":"text","text":" object represents a shape consisting of one or more"},{"type":"text","text":" "},{"type":"text","text":"polygons that do not overlap. For example, you could use a multipolygon shape"},{"type":"text","text":" "},{"type":"text","text":"to represent the body of land that consists of an island surrounded by an"},{"type":"text","text":" "},{"type":"text","text":"atoll: the inner island would be one "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon","isActive":true},{"type":"text","text":" object, while the surrounding"},{"type":"text","text":" "},{"type":"text","text":"atoll would be another. You could also use a multipolygon shape to represent a"},{"type":"text","text":" "},{"type":"text","text":"group of disconnected but related buildings."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon","kind":"symbol","type":"topic","role":"symbol","fragments":[{"kind":"identifier","text":"MLNMultiPolygon"}],"title":"MLNMultiPolygon","url":"\/documentation\/maplibre\/mlnmultipolygon"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPolygon/multiPolygonWithPolygons:":{"url":"\/documentation\/maplibre\/mlnmultipolygon\/multipolygonwithpolygons:","kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"Creates and returns a multipolygon object consisting of the given polygons."}],"type":"topic","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"multiPolygonWithPolygons:"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon\/multiPolygonWithPolygons:","title":"multiPolygonWithPolygons:","navigatorTitle":[{"kind":"identifier","text":"multiPolygonWithPolygons:"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNPolygon":{"kind":"symbol","role":"symbol","title":"MLNPolygon","fragments":[{"kind":"identifier","text":"MLNPolygon"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon","url":"\/documentation\/maplibre\/mlnpolygon","abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon","isActive":true},{"type":"text","text":" object represents a closed shape consisting of four or more"},{"type":"text","text":" "},{"type":"text","text":"vertices, specified as "},{"type":"codeVoice","code":"CLLocationCoordinate2D"},{"type":"text","text":" instances, and the edges that"},{"type":"text","text":" "},{"type":"text","text":"connect them. For example, you could use a polygon shape to represent a"},{"type":"text","text":" "},{"type":"text","text":"building, a lake, or an area you want to highlight."}]}}}