{"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmultipolygon\/multipolygonwithpolygons:"]}],"metadata":{"modules":[{"name":"MapLibre"}],"navigatorTitle":[{"kind":"identifier","text":"multiPolygonWithPolygons:"}],"roleHeading":"Type Method","fragments":[{"text":"+ ","kind":"text"},{"text":"multiPolygonWithPolygons:","kind":"identifier"}],"externalID":"c:objc(cs)MLNMultiPolygon(cm)multiPolygonWithPolygons:","role":"symbol","title":"multiPolygonWithPolygons:","symbolKind":"method"},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon\/multiPolygonWithPolygons:","interfaceLanguage":"occ"},"abstract":[{"type":"text","text":"Creates and returns a multipolygon object consisting of the given polygons."}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"text":"instancetype","kind":"keyword"},{"text":") ","kind":"text"},{"text":"multiPolygonWithPolygons:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSArray<MLNPolygon *>","kind":"typeIdentifier","preciseIdentifier":"c:Q$objc(cs)NSArray"},{"text":" *) ","kind":"text"},{"text":"polygons","kind":"internalParam"},{"text":";","kind":"text"}]}]},{"parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The array of polygons defining the shape."}],"type":"paragraph"}],"name":"polygons"}],"kind":"parameters"},{"content":[{"anchor":"return-value","type":"heading","level":2,"text":"Return Value"},{"type":"paragraph","inlineContent":[{"text":"A new multipolygon object.","type":"text"}]}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPolygon/multiPolygonWithPolygons:":{"title":"multiPolygonWithPolygons:","url":"\/documentation\/maplibre\/mlnmultipolygon\/multipolygonwithpolygons:","role":"symbol","kind":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"multiPolygonWithPolygons:","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon\/multiPolygonWithPolygons:","type":"topic","abstract":[{"type":"text","text":"Creates and returns a multipolygon object consisting of the given polygons."}],"navigatorTitle":[{"text":"multiPolygonWithPolygons:","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNPolygon":{"role":"symbol","abstract":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon"},{"type":"text","text":" object represents a closed shape consisting of four or more"},{"type":"text","text":" "},{"type":"text","text":"vertices, specified as "},{"type":"codeVoice","code":"CLLocationCoordinate2D"},{"type":"text","text":" instances, and the edges that"},{"type":"text","text":" "},{"type":"text","text":"connect them. For example, you could use a polygon shape to represent a"},{"type":"text","text":" "},{"type":"text","text":"building, a lake, or an area you want to highlight."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon","title":"MLNPolygon","kind":"symbol","type":"topic","fragments":[{"kind":"identifier","text":"MLNPolygon"}],"url":"\/documentation\/maplibre\/mlnpolygon"},"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol","title":"MapLibre","url":"\/documentation\/maplibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMultiPolygon":{"title":"MLNMultiPolygon","fragments":[{"text":"MLNMultiPolygon","kind":"identifier"}],"role":"symbol","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon","isActive":true,"type":"reference"},{"type":"text","text":" object represents a shape consisting of one or more"},{"type":"text","text":" "},{"type":"text","text":"polygons that do not overlap. For example, you could use a multipolygon shape"},{"type":"text","text":" "},{"type":"text","text":"to represent the body of land that consists of an island surrounded by an"},{"type":"text","text":" "},{"type":"text","text":"atoll: the inner island would be one "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon","isActive":true,"type":"reference"},{"type":"text","text":" object, while the surrounding"},{"type":"text","text":" "},{"type":"text","text":"atoll would be another. You could also use a multipolygon shape to represent a"},{"type":"text","text":" "},{"type":"text","text":"group of disconnected but related buildings."}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnmultipolygon","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolygon"}}}