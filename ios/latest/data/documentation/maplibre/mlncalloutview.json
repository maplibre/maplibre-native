ct/documentation/MapLibre/MLNAnnotation":{"abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","isActive":true},{"type":"text","text":" protocol is used to provide annotation-related information"},{"type":"text","text":" "},{"type":"text","text":"to a map view. To use this protocol, you adopt it in any custom objects that"},{"type":"text","text":" "},{"type":"text","text":"store or represent annotation data. Each object then serves as the source of"},{"type":"text","text":" "},{"type":"text","text":"information about a single map annotation and provides critical information,"},{"type":"text","text":" "},{"type":"text","text":"such as the annotation’s location on the map. Annotation objects do not provide"},{"type":"text","text":" "},{"type":"text","text":"the visual representation of the annotation but typically coordinate (in"},{"type":"text","text":" "},{"type":"text","text":"conjunction with the map view’s delegate) the creation of an appropriate"},{"type":"text","text":" "},{"type":"text","text":"objects to handle the display."}],"url":"\/documentation\/maplibre\/mlnannotation","fragments":[{"kind":"identifier","text":"MLNAnnotation"}],"title":"MLNAnnotation","type":"topic","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNAnnotation","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNCalloutView/dismissesAutomatically":{"type":"topic","fragments":[{"kind":"identifier","text":"dismissesAutomatically"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNCalloutView\/dismissesAutomatically","url":"\/documentation\/maplibre\/mlncalloutview\/dismissesautomatically","title":"dismissesAutomatically","kind":"symbol","abstract":[{"text":"A Boolean value indicating whether the callout view should be dismissed automatically","type":"text"},{"text":" ","type":"text"},{"text":"when the map view’s viewport changes. Note that a single tap on the map view","type":"text"},{"text":" ","type":"text"},{"text":"still dismisses the callout view regardless of the value of this property.","type":"text"},{"text":" ","type":"text"},{"text":"The callout view will be dismissed if this optional property is unimplemented.","type":"text"}],"role":"symbol"}}}