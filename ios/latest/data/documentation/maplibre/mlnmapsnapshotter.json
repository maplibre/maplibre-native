"},{"text":" ","type":"text"},{"text":"you do not need offline map functionality, you can use the ","type":"text"},{"type":"codeVoice","code":"Snapshot"},{"text":" class in","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/mapbox\/MapboxStatic.swift\/","type":"reference"},{"text":" to generate","type":"text"},{"text":" ","type":"text"},{"text":"static map images with overlays.","type":"text"}]},{"anchor":"Example","type":"heading","level":3,"text":"Example"},{"type":"codeListing","code":["let camera = MLNMapCamera(lookingAtCenter: CLLocationCoordinate2D(latitude: 37.7184, longitude:","-122.4365), altitude: 100, pitch: 20, heading: 0)","","let options = MLNMapSnapshotOptions(styleURL: MLNStyle.satelliteStreetsStyleURL, camera: camera,","size: CGSize(width: 320, height: 480)) options.zoomLevel = 10","","let snapshotter = MLNMapSnapshotter(options: options)","snapshotter.start { (snapshot, error) in","    if let error = error {","        fatalError(error.localizedDescription)","    }","","    image = snapshot?.image","}"],"syntax":"swift"},{"anchor":"Related-examples","type":"heading","level":4,"text":"Related examples"},{"type":"paragraph","inlineContent":[{"text":"TODO: Create a static map snapshot, learn how to use the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","isActive":true,"type":"reference"},{"text":" to generate a static image based on an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"object’s style, camera, and view bounds.","type":"text"}]}],"kind":"content"}],"metadata":{"modules":[{"name":"MapLibre"}],"role":"symbol","symbolKind":"class","roleHeading":"Class","externalID":"c:objc(cs)MLNMapSnapshotter","fragments":[{"text":"MLNMapSnapshotter","kind":"identifier"}],"title":"MLNMapSnapshotter","navig