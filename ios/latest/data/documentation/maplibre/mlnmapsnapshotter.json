{"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","isActive":true,"type":"reference"},{"type":"text","text":" generates static raster images of the map. Each snapshot"},{"type":"text","text":" "},{"type":"text","text":"image depicts a portion of a map defined by an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotOptions","isActive":true,"type":"reference"},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"you provide. The snapshotter generates an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshot","isActive":true,"type":"reference"},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"asynchronously, calling "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotterDelegate","isActive":true,"type":"reference"},{"type":"text","text":" methods if defined, then"},{"type":"text","text":" "},{"type":"text","text":"passing it into a completion handler once tiles and other resources needed for"},{"type":"text","text":" "},{"type":"text","text":"the snapshot are finished loading."}],"metadata":{"modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNMapSnapshotter","role":"symbol","navigatorTitle":[{"text":"MLNMapSnapshotter","kind":"identifier"}],"fragments":[{"text":"MLNMapSnapshotter","kind":"identifier"}],"roleHeading":"Class","title":"MLNMapSnapshotter","symbolKind":"class"},"seeAlsoSections":[{"title":"Snapshotter","generated":true,"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshot","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotOptions"],"anchor":"Snapshotter"}],"relationshipsSections":[{"title":"Inherits From","identifiers":["doc:\/\/org.swift.MyProject\/objc(cs)NSObject"