ype":"text","text":" class in"},{"type":"text","text":" "},{"identifier":"https:\/\/github.com\/mapbox\/MapboxStatic.swift\/","type":"reference","isActive":true},{"type":"text","text":" to generate"},{"type":"text","text":" "},{"text":"static map images with overlays.","type":"text"}],"type":"paragraph"},{"text":"Example","anchor":"Example","level":3,"type":"heading"},{"syntax":"swift","code":["let camera = MLNMapCamera(lookingAtCenter: CLLocationCoordinate2D(latitude: 37.7184, longitude:","-122.4365), altitude: 100, pitch: 20, heading: 0)","","let options = MLNMapSnapshotOptions(styleURL: MLNStyle.satelliteStreetsStyleURL, camera: camera,","size: CGSize(width: 320, height: 480)) options.zoomLevel = 10","","let snapshotter = MLNMapSnapshotter(options: options)","snapshotter.start { (snapshot, error) in","    if let error = error {","        fatalError(error.localizedDescription)","    }","","    image = snapshot?.image","}"],"type":"codeListing"},{"text":"Related examples","anchor":"Related-examples","level":4,"type":"heading"},{"inlineContent":[{"text":"TODO: Create a static map snapshot, learn how to use the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","type":"reference"},{"text":" to generate a static image based on an ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","type":"reference"},{"text":" ","type":"text"},{"text":"object’s style, camera, and view bounds.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","seeAlsoSections":[{"title":"Snapshotter","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshot","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotOptions"],"generated":true,"anchor":"Snapshotter"}],"metadata":{"title":"MLNMapSnapshotter","role":"symbol","symbolKind":"class","fragments":[{"text":"MLNMapSnapshotter