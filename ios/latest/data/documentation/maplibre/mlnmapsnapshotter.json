ct"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"inlineContent":[{"text":"You can change the snapshotter’s options at any time and reuse the snapshotter","type":"text"},{"text":" ","type":"text"},{"text":"for multiple distinct snapshots; however, the snapshotter can only generate one","type":"text"},{"text":" ","type":"text"},{"text":"snapshot at a time. If you need to generate multiple snapshots concurrently,","type":"text"},{"text":" ","type":"text"},{"text":"create multiple snapshotter objects.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For an interactive map, use the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","type":"reference","isActive":true},{"type":"text","text":" class. Both "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"and "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","type":"reference","isActive":true},{"type":"text","text":" are compatible with offline packs managed by the"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","type":"reference","isActive":true},{"type":"text","text":" class."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"From a snapshot, you can obtain an image and convert geographic coordinates to"},{"type":"text","text":" "},{"type":"text","text":"the image’s coordinate space in order to superimpose markers and overlays. If"},{"type":"text","text":" "},{"type":"text","text":"you do not need offline map functionality, you can use the "},{"type":"codeVoice","code":"Snapshot"},{"type":"text","text":" class in"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/mapbox\/MapboxS