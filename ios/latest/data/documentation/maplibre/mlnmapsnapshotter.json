{"type":"text","text":" class in"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/mapbox\/MapboxStatic.swift\/"},{"type":"text","text":" to generate"},{"type":"text","text":" "},{"type":"text","text":"static map images with overlays."}],"type":"paragraph"},{"type":"heading","text":"Example","anchor":"Example","level":3},{"code":["let camera = MLNMapCamera(lookingAtCenter: CLLocationCoordinate2D(latitude: 37.7184, longitude:","-122.4365), altitude: 100, pitch: 20, heading: 0)","","let options = MLNMapSnapshotOptions(styleURL: MLNStyle.satelliteStreetsStyleURL, camera: camera,","size: CGSize(width: 320, height: 480)) options.zoomLevel = 10","","let snapshotter = MLNMapSnapshotter(options: options)","snapshotter.start { (snapshot, error) in","    if let error = error {","        fatalError(error.localizedDescription)","    }","","    image = snapshot?.image","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"Related examples","anchor":"Related-examples","level":4},{"type":"paragraph","inlineContent":[{"type":"text","text":"TODO: Create a static map snapshot, learn how to use the"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter"},{"type":"text","text":" to generate a static image based on an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter"},{"type":"text","text":" "},{"type":"text","text":"object’s style, camera, and view bounds."}]}],"kind":"content"}],"references":{"https://github.com/mapbox/MapboxStatic.swift/":{"type":"link","titleInlineContent":[{"type":"text","text":"MapboxStatic.swift"}],"identifier":"https:\/\/github.com\/mapbox\/MapboxStatic.swift\/","title":"MapboxStatic.swift","url":"https:\/\/github.com\/mapbox\/MapboxStatic.swift\/"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshotter/delegate":{