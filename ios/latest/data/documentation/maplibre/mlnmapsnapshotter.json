{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@interface","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MLNMapSnapshotter","kind":"identifier"},{"text":" : ","kind":"text"},{"text":"NSObject","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSObject"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"inlineContent":[{"text":"You can change the snapshotter’s options at any time and reuse the snapshotter","type":"text"},{"text":" ","type":"text"},{"text":"for multiple distinct snapshots; however, the snapshotter can only generate one","type":"text"},{"text":" ","type":"text"},{"text":"snapshot at a time. If you need to generate multiple snapshots concurrently,","type":"text"},{"text":" ","type":"text"},{"text":"create multiple snapshotter objects.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For an interactive map, use the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"},{"text":" class. Both ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"},{"text":" are compatible with offline packs managed by the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"},{"text":" class.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"From a snapshot, you can obtain an image and convert geographic coordinates to"},{"type":"text","text":" "},{"typ