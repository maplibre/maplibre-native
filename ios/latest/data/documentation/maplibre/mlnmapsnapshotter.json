{"kind":"symbol","relationshipsSections":[{"identifiers":["doc:\/\/org.swift.MyProject\/objc(cs)NSObject"],"type":"inheritsFrom","title":"Inherits From","kind":"relationships"},{"identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStylable"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnmapsnapshotter"]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter"},"metadata":{"title":"MLNMapSnapshotter","symbolKind":"class","role":"symbol","fragments":[{"text":"MLNMapSnapshotter","kind":"identifier"}],"externalID":"c:objc(cs)MLNMapSnapshotter","navigatorTitle":[{"text":"MLNMapSnapshotter","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"roleHeading":"Class"},"abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","isActive":true},{"type":"text","text":" generates static raster images of the map. Each snapshot"},{"type":"text","text":" "},{"type":"text","text":"image depicts a portion of a map defined by an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotOptions","isActive":true},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"you provide. The snapshotter generates an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshot","isActive":true},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"asynchronously, calling "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotterDelegate","isActive":true},{"type":"text","text":" methods if defined, then"},{"type":"text","text":" "},{"type":"text","text":"passing it into a completion handler once tiles and other resources needed for"},{"type":"text","text":" "},{"type":"text","text":"the snapshot are finished loading."}],"sections":[],"topicSections":[{"generated":true,"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter\/delegate","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter\/loading","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter\/options","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter\/style"]},{"generated":true,"title":"Instance Methods","anchor":"Instance-Methods","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter\/addAnnotation:","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter\/addAnnotations:","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter\/cancel","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter\/initWithOptions:","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter\/startWithCompletionHandler:","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter\/startWithOverlayHandler:completionHandler:","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter\/startWithQueue:completionHandler:"]}],"seeAlsoSections":[{"generated":true,"title":"Snapshotter","anchor":"Snapshotter","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshot","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotOptions"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@interface","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MLNMapSnapshotter","kind":"identifier"},{"text":" : ","kind":"text"},{"text":"NSObject","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSObject"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"inlineContent":[{"text":"You can change the snapshotter’s options at any time and reuse the snapshotter","type":"text"},{"text":" ","type":"text"},{"text":"for multiple distinct snapshots; however, the snapshotter can only generate one","type":"text"},{"text":" ","type":"text"},{"text":"snapshot at a time. If you need to generate multiple snapshots concurrently,","type":"text"},{"text":" ","type":"text"},{"text":"create multiple snapshotter objects.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For an interactive map, use the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","isActive":true},{"type":"text","text":" class. Both "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","isActive":true},{"type":"text","text":" "},{"type":"text","text":"and "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","isActive":true},{"type":"text","text":" are compatible with offline packs managed by the"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","isActive":true},{"type":"text","text":" class."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"From a snapshot, you can obtain an image and convert geographic coordinates to"},{"type":"text","text":" "},{"type":"text","text":"the image’s coordinate space in order to superimpose markers and overlays. If"},{"type":"text","text":" "},{"type":"text","text":"you do not need offline map functionality, you can use the "},{"type":"codeVoice","code":"Snapshot"},{"type":"text","text":" class in"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/mapbox\/MapboxStatic.swift\/"},{"type":"text","text":" to generate"},{"type":"text","text":" "},{"type":"text","text":"static map images with overlays."}],"type":"paragraph"},{"level":3,"anchor":"Example","type":"heading","text":"Example"},{"code":["let camera = MLNMapCamera(lookingAtCenter: CLLocationCoordinate2D(latitude: 37.7184, longitude:","-122.4365), altitude: 100, pitch: 20, heading: 0)","","let options = MLNMapSnapshotOptions(styleURL: MLNStyle.satelliteStreetsStyleURL, camera: camera,","size: CGSize(width: 320, height: 480)) options.zoomLevel = 10","","let snapshotter = MLNMapSnapshotter(options: options)","snapshotter.start { (snapshot, error) in","    if let error = error {","        fatalError(error.localizedDescription)","    }","","    image = snapshot?.image","}"],"type":"codeListing","syntax":"swift"},{"level":4,"anchor":"Related-examples","type":"heading","text":"Related examples"},{"inlineContent":[{"type":"text","text":"TODO: Create a static map snapshot, learn how to use the"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","isActive":true},{"type":"text","text":" to generate a static image based on an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","isActive":true},{"type":"text","text":" "},{"type":"text","text":"object’s style, camera, and view bounds."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshotter/loading":{"type":"topic","title":"loading","abstract":[{"type":"text","text":"Indicates whether a snapshot is currently being generated."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter\/loading","url":"\/documentation\/maplibre\/mlnmapsnapshotter\/loading","role":"symbol","fragments":[{"text":"loading","kind":"identifier"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapsh