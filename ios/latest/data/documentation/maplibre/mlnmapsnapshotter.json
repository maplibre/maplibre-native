"text","text":" "},{"type":"text","text":"the image’s coordinate space in order to superimpose markers and overlays. If"},{"type":"text","text":" "},{"type":"text","text":"you do not need offline map functionality, you can use the "},{"type":"codeVoice","code":"Snapshot"},{"type":"text","text":" class in"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/github.com\/mapbox\/MapboxStatic.swift\/","isActive":true},{"type":"text","text":" to generate"},{"type":"text","text":" "},{"type":"text","text":"static map images with overlays."}],"type":"paragraph"},{"level":3,"text":"Example","type":"heading","anchor":"Example"},{"type":"codeListing","code":["let camera = MLNMapCamera(lookingAtCenter: CLLocationCoordinate2D(latitude: 37.7184, longitude:","-122.4365), altitude: 100, pitch: 20, heading: 0)","","let options = MLNMapSnapshotOptions(styleURL: MLNStyle.satelliteStreetsStyleURL, camera: camera,","size: CGSize(width: 320, height: 480)) options.zoomLevel = 10","","let snapshotter = MLNMapSnapshotter(options: options)","snapshotter.start { (snapshot, error) in","    if let error = error {","        fatalError(error.localizedDescription)","    }","","    image = snapshot?.image","}"],"syntax":"swift"},{"level":4,"text":"Related examples","type":"heading","anchor":"Related-examples"},{"inlineContent":[{"type":"text","text":"TODO: Create a static map snapshot, learn how to use the"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","type":"reference"},{"type":"text","text":" to generate a static image based on an "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","type":"reference"},{"type":"text","text":" "},{"type":"text","text":"object’s style, camera, and view bounds."}],"type":"paragraph"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"externalID":"c:objc(cs)MLNMapSnapshotter","symbolKind":"class