{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"languages":["occ"],"tokens":[{"text":"@interface","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MLNMapSnapshotter","kind":"identifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSObject","text":"NSObject","kind":"typeIdentifier"}],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"inlineContent":[{"type":"text","text":"You can change the snapshotter’s options at any time and reuse the snapshotter"},{"type":"text","text":" "},{"type":"text","text":"for multiple distinct snapshots; however, the snapshotter can only generate one"},{"type":"text","text":" "},{"type":"text","text":"snapshot at a time. If you need to generate multiple snapshots concurrently,"},{"type":"text","text":" "},{"type":"text","text":"create multiple snapshotter objects."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For an interactive map, use the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"},{"type":"text","text":" class. Both "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter"},{"type":"text","text":" "},{"type":"text","text":"and "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"},{"type":"text","text":" are compatible with offline packs managed by the"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"},{"type":"text","text":" class."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"From a snapshot, you can obtain an image and convert geographic coordinates to"},{"type":"text","text":" "},{"type":"text","text":"the image’s coordinate space in order to superimpose markers and overlays. If"},{"type":"text","text":" "},{"type":"text","text":"you do not need offline map functionality, you can use the "},{"type":"codeVoice","code":"Snapshot"},{"type":"text","text":" class in"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/github.com\/mapbox\/MapboxStatic.swift\/","isActive":true},{"type":"text","text":" to generate"},{"type":"text","text":" "},{"type":"text","text":"static map images with overlays."}],"type":"paragraph"},{"text":"Example","level":3,"anchor":"Example","type":"heading"},{"code":["let camera = MLNMapCamera(lookingAtCenter: CLLocationCoordinate2D(latitude: 37.7184, longitude:","-122.4365), altitude: 100, pitch: 20, heading: 0)","","let options = MLNMapSnapshotOptions(styleURL: MLNStyle.satelliteStreetsStyleURL, camera: camera,","size: CGSize(width: 320, height: 480)) options.zoomLevel = 10","","let snapshotter = MLNMapSnapshotter(options: options)","snapshotter.start { (snapshot, error) in","    if let error = error {","        fatalError(error.localizedDescription)","    }","","    image = snapshot?.image","}"],"syntax":"swift","type":"codeListing"},{"text":"Related examples","level":4,"anchor":"Related-examples","type":"heading"},{"inlineContent":[{"text":"TODO: Create a static map snapshot, learn how to use the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","isActive":true,"type":"reference"},{"text":" to generate a static image based on an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"object’s style, camera, and view bounds.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"metadata":{"title":"MLNMapSnapshotter","modules":[{"name":"MapLibre"}],"roleHeading":"Class","fragments":[{"kind":"identifier","text":"MLNMapSnapshotter"}],"navigatorTitle":[{"text