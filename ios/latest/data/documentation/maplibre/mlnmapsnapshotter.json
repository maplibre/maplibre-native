{"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"text":"@interface","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MLNMapSnapshotter","kind":"identifier"},{"text":" : ","kind":"text"},{"text":"NSObject","preciseIdentifier":"c:objc(cs)NSObject","kind":"typeIdentifier"}],"platforms":["iOS"]}]},{"kind":"content","content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"inlineContent":[{"text":"You can change the snapshotter’s options at any time and reuse the snapshotter","type":"text"},{"text":" ","type":"text"},{"text":"for multiple distinct snapshots; however, the snapshotter can only generate one","type":"text"},{"text":" ","type":"text"},{"text":"snapshot at a time. If you need to generate multiple snapshots concurrently,","type":"text"},{"text":" ","type":"text"},{"text":"create multiple snapshotter objects.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For an interactive map, use the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","type":"reference"},{"text":" class. Both ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","type":"reference"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","type":"reference"},{"text":" are compatible with offline packs managed by the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","type":"reference"},{"text":" class.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"From a snapshot, you can obtain an image and convert geographic coordinates to","type":"text"},{"text":" ","type":"text"},{"text":"the image’s coordinate space in order to superimpose markers and overlays. If","type":"text"},{"text":" ","type":"text"},{"text":"you do not need offline map functionality, you can use the ","type":"text"},{"type":"codeVoice","code":"Snapshot"},{"text":" class in","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/mapbox\/MapboxStatic.swift\/"},{"text":" to generate","type":"text"},{"text":" ","type":"text"},{"text":"static map images with overlays.","type":"text"}],"type":"paragraph"},{"text":"Example","anchor":"Example","type":"heading","level":3},{"code":["let camera = MLNMapCamera(lookingAtCenter: CLLocationCoordinate2D(latitude: 37.7184, longitude:","-122.4365), altitude: 100, pitch: 20, heading: 0)","","let options = MLNMapSnapshotOptions(styleURL: MLNStyle.satelliteStreetsStyleURL, camera: camera,","size: CGSize(width: 320, height: 480)) options.zoomLevel = 10","","let snapshotter = MLNMapSnapshotter(options: options)","snapshotter.start { (snapshot, error) in","    if let error = error {","        fatalError(error.localizedDescription)","    }","","    image = snapshot?.image","}"],"type":"codeListing","syntax":"swift"},{"text":"Related examples","anchor":"Related-examples","type":"heading","level":4},{"inlineContent":[{"text":"TODO: Create a static map snapshot, learn how to use the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","isActive":true,"type":"reference"},{"text":" to generate a static image based on an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"object’s style, camera, and view bounds.","type":"text"}],"type":"paragraph"}]}],"relationshipsSections":[{"type":"inheritsFrom","kind":"relationships","identifiers":["doc:\/\/org.swift.MyProject\/objc(cs)NSObject"],"title":"Inherits From"},{"type":"conformsTo","kind":"relationships","identifiers":["doc:\/\/org.swift.MyPro