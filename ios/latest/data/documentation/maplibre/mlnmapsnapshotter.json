{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter"},"variants":[{"paths":["\/documentation\/maplibre\/mlnmapsnapshotter"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"relationshipsSections":[{"title":"Inherits From","kind":"relationships","type":"inheritsFrom","identifiers":["doc:\/\/org.swift.MyProject\/objc(cs)NSObject"]},{"title":"Conforms To","kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStylable"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"text":"@interface","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MLNMapSnapshotter","kind":"identifier"},{"text":" : ","kind":"text"},{"text":"NSObject","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSObject"}],"platforms":["iOS"]}]},{"content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"You can change the snapshotter’s options at any time and reuse the snapshotter"},{"type":"text","text":" "},{"type":"text","text":"for multiple distinct snapshots; however, the snapshotter can only generate one"},{"type":"text","text":" "},{"type":"text","text":"snapshot at a time. If you need to generate multiple snapshots concurrently,"},{"type":"text","text":" "},{"type":"text","text":"create multiple snapshotter objects."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For an interactive map, use the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"},{"type":"text","text":" class. Both "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter"},{"type":"text","text":" "},{"type":"text","text":"and "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView"},{"type":"text","text":" are compatible with offline packs managed by the"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"},{"type":"text","text":" class."}],"type":"paragraph"},{"inlineContent":[{"text":"From a snapshot, you can obtain an image and convert geographic coordinates to","type":"text"},{"text":" ","type":"text"},{"text":"the image’s coordinate space in order to superimpose markers and overlays. If","type":"text"},{"text":" ","type":"text"},{"text":"you do not need offline map functionality, you can use the ","type":"text"},{"type":"codeVoice","code":"Snapshot"},{"text":" class in","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/mapbox\/MapboxStatic.swift\/"},{"text":" to generate","type":"text"},{"text":" ","type":"text"},{"text":"static map images with overlays.","type":"text"}],"type":"paragraph"},{"text":"Example","anchor":"Example","type":"heading","level":3},{"code":["let camera = MLNMapCamera(lookingAtCenter: CLLocationCoordinate2D(latitude: 37.7184, longitude:","-122.4365), altitude: 100, pitch: 20, heading: 0)","","let options = MLNMapSnapshotOptions(styleURL: MLNStyle.satelliteStreetsStyleURL, camera: camera,","size: CGSize(width: 320, height: 480)) options.zoomLevel = 10","","let snapshotter = MLNMapSnapshotter(options: options)","snapshotter.start { (snapshot, error) in","    if let error = error {","        fatalError(error.localizedDescription)","    }","","    image = snapshot?.image","}"],"syntax":"swift","type":"codeListing"},{"text":"Related examples","anchor":"Related-examples","type":"heading","level":4},{"inlineContent":[{"type":"text","text":"TODO: Create a static map snapshot, learn how to use the"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","isActive":true,"type":"reference"},{"type":"text","text":" to generate a static image based on an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"object’s style, camera, and view bounds."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","type":"reference","isActive":true},{"type":"text","text":" generates static raster images of the map. Each snapshot"},{"type":"text","text":" "},{"type":"text","text":"image depicts a portion of a map defined by an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotOptions","type":"reference","isActive":true},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"you provide. The snapshotter generates an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshot","type":"reference","isActive":true},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"asynchronously, calling "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotterDelegate","type":"reference","isActive":true},{"type":"text","text":" methods if defined, then"},{"type":"text","text":" "},{"type":"text","text":"passing it into a completion handler once tiles and other resources needed for"},{"type":"text","text":" "},{"type":"text","text":"the snapshot are finished loading."}],"seeAlsoSections":[{"title":"Snapshotter","generated":true,"anchor":"Snapshotter","identifiers":["doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshot","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotOptions"]}],"metadata":{"fragments":[{"kind":"identifier","text":"MLNMapSnapshotter"}],"navigatorTitle":[{"kind":"