e":"text"},{"text":"you do not need offline map functionality, you can use the ","type":"text"},{"type":"codeVoice","code":"Snapshot"},{"text":" class in","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/mapbox\/MapboxStatic.swift\/","isActive":true},{"text":" to generate","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"static map images with overlays."}],"type":"paragraph"},{"level":3,"anchor":"Example","type":"heading","text":"Example"},{"syntax":"swift","code":["let camera = MLNMapCamera(lookingAtCenter: CLLocationCoordinate2D(latitude: 37.7184, longitude:","-122.4365), altitude: 100, pitch: 20, heading: 0)","","let options = MLNMapSnapshotOptions(styleURL: MLNStyle.satelliteStreetsStyleURL, camera: camera,","size: CGSize(width: 320, height: 480)) options.zoomLevel = 10","","let snapshotter = MLNMapSnapshotter(options: options)","snapshotter.start { (snapshot, error) in","    if let error = error {","        fatalError(error.localizedDescription)","    }","","    image = snapshot?.image","}"],"type":"codeListing"},{"level":4,"anchor":"Related-examples","type":"heading","text":"Related examples"},{"inlineContent":[{"text":"TODO: Create a static map snapshot, learn how to use the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","type":"reference"},{"text":" to generate a static image based on an ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","type":"reference"},{"text":" ","type":"text"},{"text":"object’s style, camera, and view bounds.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"metadata":{"role":"symbol","title":"MLNMapSnapshotter","navigatorTitle":[{"text":"MLNMapSnapshotter","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"fragments":[{"text":"MLNMapSnapshotter","kind":"identifier"}],"externalID":"c:objc(cs)