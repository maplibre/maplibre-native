{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@interface","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MLNMapSnapshotter","kind":"identifier"},{"text":" : ","kind":"text"},{"text":"NSObject","preciseIdentifier":"c:objc(cs)NSObject","kind":"typeIdentifier"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"You can change the snapshotter’s options at any time and reuse the snapshotter"},{"type":"text","text":" "},{"type":"text","text":"for multiple distinct snapshots; however, the snapshotter can only generate one"},{"type":"text","text":" "},{"type":"text","text":"snapshot at a time. If you need to generate multiple snapshots concurrently,"},{"type":"text","text":" "},{"type":"text","text":"create multiple snapshotter objects."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For an interactive map, use the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","isActive":true},{"type":"text","text":" class. Both "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","isActive":true},{"type":"text","text":" "},{"type":"text","text":"and "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","isActive":true},{"type":"text","text":" are compatible with offline packs managed by the"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","isActive":true},{"type":"text","text":" class."}],"type":"paragraph"},{"inlineContent":[{"text":"From a snapshot, you can obtain an image and convert geographic coordinates to","type":"text"},{"text":" ","type":"text"},{"text":"the image’s coordinate space in order to superimpose markers and overlays. If","type":"text"},{"text":" ","type":"text"},{"text":"you do not need offline map functionality, you can use the ","type":"text"},{"code":"Snapshot","type":"codeVoice"},{"text":" class in","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/github.com\/mapbox\/MapboxStatic.swift\/","type":"reference","isActive":true},{"text":" to generate","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"static map images with overlays."}],"type":"paragraph"},{"anchor":"Example","level":3,"type":"heading","text":"Example"},{"syntax":"swift","code":["let camera = MLNMapCamera(lookingAtCenter: CLLocationCoordinate2D(latitude: 37.7184, longitude:","-122.4365), altitude: 100, pitch: 20, heading: 0)","","let options = MLNMapSnapshotOptions(styleURL: MLNStyle.satelliteStreetsStyleURL, camera: camera,","size: CGSize(width: 320, height: 480)) options.zoomLevel = 10","","let snapshotter = MLNMapSnapshotter(options: options)","snapshotter.start { (snapshot, error) in","    if let error = error {","        fatalError(error.localizedDescription)","    }","","    image = snapshot?.image","}"],"type":"codeListing"},{"anchor":"Related-examples","level":4,"type":"heading","text":"Related examples"},{"inlineContent":[{"type":"text","text":"TODO: Create a static map snapshot, learn how to use the"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","isActive":true},{"type":"text","text":" to generate a static image based on an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","isActive":true},{"type":"text","text":" "},{"type":"text","text":"object’s style, camera, and view bounds."}],"type":"paragraph"}],"kind":"content"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter"},"kind":"symbol","abstract":[{"type":"text