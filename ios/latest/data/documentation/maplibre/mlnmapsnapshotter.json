{"metadata":{"role":"symbol","symbolKind":"class","title":"MLNMapSnapshotter","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"kind":"identifier","text":"MLNMapSnapshotter"}],"fragments":[{"text":"MLNMapSnapshotter","kind":"identifier"}],"externalID":"c:objc(cs)MLNMapSnapshotter","roleHeading":"Class"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"sections":[],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"@interface","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MLNMapSnapshotter","kind":"identifier"},{"text":" : ","kind":"text"},{"text":"NSObject","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSObject"}],"languages":["occ"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"You can change the snapshotter’s options at any time and reuse the snapshotter","type":"text"},{"text":" ","type":"text"},{"text":"for multiple distinct snapshots; however, the snapshotter can only generate one","type":"text"},{"text":" ","type":"text"},{"text":"snapshot at a time. If you need to generate multiple snapshots concurrently,","type":"text"},{"text":" ","type":"text"},{"text":"create multiple snapshotter objects.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For an interactive map, use the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","isActive":true},{"type":"text","text":" class. Both "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","isActive":true},{"type":"text","text":" "},{"type":"text","text":"and "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","isActive":true},{"text":" are compatible with offline packs managed by the","type":"text"},{"text":" ","type":"text"},{"identif