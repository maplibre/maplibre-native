d":"typeIdentifier","text":"NSObject"}]}],"kind":"declarations"},{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"inlineContent":[{"text":"You can change the snapshotter’s options at any time and reuse the snapshotter","type":"text"},{"text":" ","type":"text"},{"text":"for multiple distinct snapshots; however, the snapshotter can only generate one","type":"text"},{"text":" ","type":"text"},{"text":"snapshot at a time. If you need to generate multiple snapshots concurrently,","type":"text"},{"text":" ","type":"text"},{"text":"create multiple snapshotter objects.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For an interactive map, use the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","type":"reference","isActive":true},{"type":"text","text":" class. Both "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"and "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView","type":"reference","isActive":true},{"type":"text","text":" are compatible with offline packs managed by the"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","type":"reference","isActive":true},{"type":"text","text":" class."}],"type":"paragraph"},{"inlineContent":[{"text":"From a snapshot, you can obtain an image and convert geographic coordinates to","type":"text"},{"text":" ","type":"text"},{"text":"the image’s coordinate space in order to superimpose markers and overlays. If","type":"text"},{"text":" ","type":"text"},{"text":"you do not need offline map functionality, you can use the ","type":"text"},{"code":"Snapshot","type":"codeVoice"},{"text":" class in","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/github.com\/mapbox\/MapboxStatic.swift\/","isActive":true,"type":"reference"},{"text":" to generate","type":"text"},{"text":" ","type":"text"},{"text":"static map images with overlays.","type":"text"}],"type":"paragraph"},{"text":"Example","type":"heading","level":3,"anchor":"Example"},{"syntax":"swift","type":"codeListing","code":["let camera = MLNMapCamera(lookingAtCenter: CLLocationCoordinate2D(latitude: 37.7184, longitude:","-122.4365), altitude: 100, pitch: 20, heading: 0)","","let options = MLNMapSnapshotOptions(styleURL: MLNStyle.satelliteStreetsStyleURL, camera: camera,","size: CGSize(width: 320, height: 480)) options.zoomLevel = 10","","let snapshotter = MLNMapSnapshotter(options: options)","snapshotter.start { (snapshot, error) in","    if let error = error {","        fatalError(error.localizedDescription)","    }","","    image = snapshot?.image","}"]},{"text":"Related examples","type":"heading","level":4,"anchor":"Related-examples"},{"inlineContent":[{"type":"text","text":"TODO: Create a static map snapshot, learn how to use the"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter"},{"type":"text","text":" to generate a static image based on an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter"},{"type":"text","text":" "},{"type":"text","text":"object’s style, camera, and view bounds."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshotter/delegate":{"fragments":[{"kind":"identifier","text":"delegate"}],"kind":"symbol","abstract":[{"type":"text","text":"The snapshotter’s delegate."}],"url":"\/documentation\/maplibre\/mlnmapsnapshotter\/delegate","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapSnapshotter\/delegate","type":"topic","title":"delegate"},"doc://org.swift.MyProject/documentation/MapLibre/MLNMapSnapshotter":{"type":"topic","ro