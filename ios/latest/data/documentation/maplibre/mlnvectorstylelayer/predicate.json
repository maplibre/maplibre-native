{"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"text":"NSPredicate","preciseIdentifier":"c:objc(cs)NSPredicate","kind":"typeIdentifier"},{"text":" * ","kind":"text"},{"text":"predicate","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Use the style layer’s predicate to include only the features in the source","type":"text"},{"text":" ","type":"text"},{"text":"layer that satisfy a condition that you define. If the style layer initially","type":"text"},{"text":" ","type":"text"},{"text":"comes from the style, its predicate corresponds to the","type":"text"},{"text":" ","type":"text"},{"code":"filter","type":"codeVoice"},{"text":" ","type":"text"},{"text":"property in the style JSON.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"See the “","type":"text"},{"text":"Predicates and Expressions","type":"text"},{"text":"”","type":"text"},{"text":" ","type":"text"},{"text":"guide for details about the predicate syntax supported by this class.","type":"text"}]},{"type":"heading","anchor":"Example","level":3,"text":"Example"},{"type":"paragraph","inlineContent":[{"text":"To filter the layer to include only the features whose ","type":"text"},{"type":"codeVoice","code":"index"},{"text":" attribute is 5","type":"text"},{"text":" ","type":"text"},{"text":"or 10 and whose ","type":"text"},{"code":"ele","type":"codeVoice"},{"text":" attribute is at least 1,500, you could create an","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"NSCompoundPredicate"},{"text":" along these lines:","type":"text"}]},{"code":["let laye