dicates and Expressions","type":"text"},{"text":"”","type":"text"},{"text":" ","type":"text"},{"text":"guide for details about the predicate syntax supported by this class.","type":"text"}]},{"type":"heading","anchor":"Example","text":"Example","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"To filter the layer to include only the features whose "},{"type":"codeVoice","code":"index"},{"type":"text","text":" attribute is 5"},{"type":"text","text":" "},{"type":"text","text":"or 10 and whose "},{"type":"codeVoice","code":"ele"},{"type":"text","text":" attribute is at least 1,500, you could create an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSCompoundPredicate"},{"type":"text","text":" along these lines:"}]},{"type":"codeListing","syntax":"swift","code":["let layer = MLNLineStyleLayer(identifier: \"contour\", source: terrain)","layer.sourceLayerIdentifier = \"contours\"","layer.predicate = NSPredicate(format: \"(index == 5 || index == 10) && CAST(ele, 'NSNumber') >=","1500.0\") mapView.style?.addLayer(layer)"]}]}],"kind":"symbol","references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorStyleLayer/predicate":{"title":"predicate","fragments":[{"text":"predicate","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnvectorstylelayer\/predicate","abstract":[{"type":"text","text":"The style layer’s predicate."}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer\/predicate","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol","role":"collection","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"title":"MLNShapeSource","url":"\/documen