 the features whose "},{"type":"codeVoice","code":"index"},{"type":"text","text":" attribute is 5"},{"text":" ","type":"text"},{"text":"or 10 and whose ","type":"text"},{"type":"codeVoice","code":"ele"},{"text":" attribute is at least 1,500, you could create an","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"NSCompoundPredicate"},{"text":" along these lines:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let layer = MLNLineStyleLayer(identifier: \"contour\", source: terrain)","layer.sourceLayerIdentifier = \"contours\"","layer.predicate = NSPredicate(format: \"(index == 5 || index == 10) && CAST(ele, 'NSNumber') >=","1500.0\") mapView.style?.addLayer(layer)"]}],"kind":"content"}],"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"fragments":[{"kind":"identifier","text":"predicate"}],"externalID":"c:objc(cs)MLNVectorStyleLayer(py)predicate","title":"predicate","role":"symbol","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"text":"predicate","kind":"identifier"}],"symbolKind":"property","roleHeading":"Instance Property"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorStyleLayer/predicate":{"kind":"symbol","url":"\/documentation\/maplibre\/mlnvectorstylelayer\/predicate","role":"symbol","abstract":[{"text":"The style layer’s predicate.","type":"text"}],"type":"topic","fragments":[{"kind":"identifier","text":"predicate"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer\/predicate","title":"predicate"},"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorStyleLayer":{"kind":"symbol","abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","isActive":true},{"type":"text","text":" is an abstract superclass for style layers whose content"},{"type":"text","text":" "},{"type":"text","text":"is defined by an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/d