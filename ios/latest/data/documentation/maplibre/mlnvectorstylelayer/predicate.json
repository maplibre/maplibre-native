t"},{"text":"Predicates and Expressions","type":"text"},{"text":"”","type":"text"},{"text":" ","type":"text"},{"text":"guide for details about the predicate syntax supported by this class.","type":"text"}]},{"text":"Example","type":"heading","level":3,"anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To filter the layer to include only the features whose "},{"type":"codeVoice","code":"index"},{"type":"text","text":" attribute is 5"},{"type":"text","text":" "},{"type":"text","text":"or 10 and whose "},{"type":"codeVoice","code":"ele"},{"type":"text","text":" attribute is at least 1,500, you could create an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSCompoundPredicate"},{"type":"text","text":" along these lines:"}]},{"type":"codeListing","code":["let layer = MLNLineStyleLayer(identifier: \"contour\", source: terrain)","layer.sourceLayerIdentifier = \"contours\"","layer.predicate = NSPredicate(format: \"(index == 5 || index == 10) && CAST(ele, 'NSNumber') >=","1500.0\") mapView.style?.addLayer(layer)"],"syntax":"swift"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorStyleLayer/predicate":{"abstract":[{"text":"The style layer’s predicate.","type":"text"}],"url":"\/documentation\/maplibre\/mlnvectorstylelayer\/predicate","kind":"symbol","role":"symbol","fragments":[{"kind":"identifier","text":"predicate"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer\/predicate","title":"predicate"},"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorStyleLayer":{"fragments":[{"text":"MLNVectorStyleLayer","kind":"identifier"}],"abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","isActive":true,"type":"reference"},{"text":" is an abstract superclass for style layers whose content","type":"text"},{"text":" ","type":"text"},{"text":"is defined by an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProj