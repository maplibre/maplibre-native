{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"kind":"typeIdentifier","text":"NSPredicate","preciseIdentifier":"c:objc(cs)NSPredicate"},{"kind":"text","text":" * "},{"kind":"identifier","text":"predicate"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the style layer’s predicate to include only the features in the source"},{"type":"text","text":" "},{"type":"text","text":"layer that satisfy a condition that you define. If the style layer initially"},{"type":"text","text":" "},{"type":"text","text":"comes from the style, its predicate corresponds to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"filter"},{"type":"text","text":" "},{"type":"text","text":"property in the style JSON."}]},{"type":"paragraph","inlineContent":[{"text":"See the “","type":"text"},{"text":"Predicates and Expressions","type":"text"},{"text":"”","type":"text"},{"text":" ","type":"text"},{"text":"guide for details about the predicate syntax supported by this class.","type":"text"}]},{"level":3,"type":"heading","text":"Example","anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To filter the layer to include only the features whose "},{"code":"index","type":"codeVoice"},{"type":"text","text":" attribute is 5"},{"type":"text","text":" "},{"type":"text","text":"or 10 and whose "},{"code":"ele","type":"codeVoice"},{"type":"text","text":" attribute is at least 1,500, you could create an"},{"type":"text","text":" "},{"code":"NSCompoundPredicate","type":"codeVoice"},{"type":"text","text":" along these lines:"}]},{"code":["let layer = MLNLineStyleLayer(id