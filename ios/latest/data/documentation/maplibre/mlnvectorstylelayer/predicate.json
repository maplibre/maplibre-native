{"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"The style layer’s predicate.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnvectorstylelayer\/predicate"]}],"sections":[],"metadata":{"title":"predicate","navigatorTitle":[{"kind":"identifier","text":"predicate"}],"role":"symbol","roleHeading":"Instance Property","fragments":[{"kind":"identifier","text":"predicate"}],"modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNVectorStyleLayer(py)predicate","symbolKind":"property"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"text":"NSPredicate","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSPredicate"},{"text":" * ","kind":"text"},{"text":"predicate","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"]}]},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"text":"Use the style layer’s predicate to include only the features in the source","type":"text"},{"text":" ","type":"text"},{"text":"layer that satisfy a condition that you define. If the style layer initially","type":"text"},{"text":" ","type":"text"},{"text":"comes from the style, its predicate corresponds to the","type":"text"},{"text":" ","type":"text"},{"code":"filter","type":"codeVoice"},{"text":" ","type":"text"},{"text":"property in the style JSON.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"See the “","type":"text"},{"text":"Predicates and Expressions","type":"text"},{"text":"”","type":"text"},{"text":" ","type":"text"},{"text":"guide for details about the predicate syntax supported by this class.","type":"text"}],"type":"paragraph"},{"anchor":"Example","type":"heading","level":3,"text":"Example"},{"inlineContent":[{"type":"text","text":"To filter the layer to include only the features whose "},{"type":"codeVoice","code":"index"},{"type":"text","text":" attribute is 5"},{"type":"text","text":" "},{"type":"text","text":"or 10 and whose "},{"type":"codeVoice","code":"ele"},{"type":"text","text":" attribute is at least 1,500, you could create an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSCompoundPredicate"},{"type":"text","text":" along these lines:"}],"type":"paragraph"},{"code":["let layer = MLNLineStyleLayer(identifier: \"contour\", source: terrain)","layer.sourceLayerIdentifier = \"contours\"","layer.predicate = NSPredicate(format: \"(index == 5 || index == 10) && CAST(ele, 'NSNumber') >=","1500.0\") mapView.style?.addLayer(layer)"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer\/predicate"},"kind":"symbol","references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorStyleLayer":{"abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer"},{"type":"text","text":" is an abstract superclass for style layers whose content"},{"type":"text","text":" "},{"type":"text","text":"is defined by an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":" or "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":" object."}],"type":"topic","fragments":[{"text":"MLNVectorStyleLayer","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnvectorstylelayer","role":"symbol","title":"MLNVectorStyleLayer","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer"},"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","kind":"symbol","url":"\/documentation\/maplibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorStyleLayer/predicate":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer\/predicate","url":"\/documentation\/maplibre\/mlnvectorstylelayer\/predicate","role":"symbol","abstract":[{"text":"The style layer’s predicate.","type":"text"}],"title":"predicate","fragments":[{"kind":"identifier","text":"predicate"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"type":"topic","title":"MLNShapeSource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","role":"symbol","fragments":[{"text":"MLNShapeSource","kind":"identifier"}],"abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true},{"text":" is a map content source that supplies vector shapes to be","type":"text"},{"text":" ","type":"text"},{"text":"shown on the map. The shapes may be instances of ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"text":" or ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"or they may be defined by local or external","type":"text"},{"text":" ","type":"text"},{"text":"GeoJSON","type":"text"},{"text":" code. A shape source is added to an","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true,"type":"reference"},{"text":" object along with an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true,"type":"reference"},{"text":" object. The vector style","type":"text"},{"text":" ","type":"text"},{"text":"layer defines the appearance of any content supplied by the shape source. You","type":"text"},{"text":" ","type":"text"},{"text":"can update a shape source by setting its ","type":"text"},{"code":"shape","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"URL","type":"codeVoice"},{"text":" property.","type":"text"}],"url":"\/documentation\/maplibre\/mlnshapesource","kind":"symbol"}}}