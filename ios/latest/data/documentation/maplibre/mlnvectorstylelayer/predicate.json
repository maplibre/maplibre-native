{"sections":[],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer\/predicate","interfaceLanguage":"occ"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSPredicate","text":"NSPredicate","kind":"typeIdentifier"},{"text":" * ","kind":"text"},{"text":"predicate","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"text":"Use the style layer’s predicate to include only the features in the source","type":"text"},{"text":" ","type":"text"},{"text":"layer that satisfy a condition that you define. If the style layer initially","type":"text"},{"text":" ","type":"text"},{"text":"comes from the style, its predicate corresponds to the","type":"text"},{"text":" ","type":"text"},{"code":"filter","type":"codeVoice"},{"text":" ","type":"text"},{"text":"property in the style JSON.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"See the “","type":"text"},{"text":"Predicates and Expressions","type":"text"},{"text":"”","type":"text"},{"text":" ","type":"text"},{"text":"guide for details about the predicate syntax supported by this class.","type":"text"}],"type":"paragraph"},{"anchor":"Example","level":3,"type":"heading","text":"Example"},{"inlineContent":[{"type":"text","text":"To filter the layer to include only the features whose "},{"type":"codeVoice","code":"index"},{"type":"text","text":" attribute is 5"},{"type":"text","text":" "},{"type":"text","text":"or 10 and whose "},{"type":"codeVoice","code":"ele"},{"type":"text","text":" attribute is at least 1,500, you could create an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSCompoundPredicate"},{"type":"text","text"