ource. You"},{"type":"text","text":" "},{"type":"text","text":"can update a shape source by setting its "},{"type":"codeVoice","code":"shape"},{"text":" or ","type":"text"},{"code":"URL","type":"codeVoice"},{"text":" property.","type":"text"}],"kind":"symbol","title":"MLNShapeSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorStyleLayer/predicate":{"type":"topic","kind":"symbol","role":"symbol","fragments":[{"kind":"identifier","text":"predicate"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer\/predicate","abstract":[{"type":"text","text":"The style layer’s predicate."}],"url":"\/documentation\/maplibre\/mlnvectorstylelayer\/predicate","title":"predicate"}}}