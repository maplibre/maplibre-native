{"abstract":[{"text":"The style layer’s predicate.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"preciseIdentifier":"c:objc(cs)NSPredicate","kind":"typeIdentifier","text":"NSPredicate"},{"text":" * ","kind":"text"},{"text":"predicate","kind":"identifier"},{"kind":"text","text":";"}]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"Use the style layer’s predicate to include only the features in the source"},{"type":"text","text":" "},{"type":"text","text":"layer that satisfy a condition that you define. If the style layer initially"},{"type":"text","text":" "},{"type":"text","text":"comes from the style, its predicate corresponds to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"filter"},{"type":"text","text":" "},{"type":"text","text":"property in the style JSON."}],"type":"paragraph"},{"inlineContent":[{"text":"See the “","type":"text"},{"type":"text","text":"Predicates and Expressions"},{"type":"text","text":"”"},{"type":"text","text":" "},{"type":"text","text":"guide for details about the predicate syntax supported by this class."}],"type":"paragraph"},{"type":"heading","text":"Example","anchor":"Example","level":3},{"inlineContent":[{"type":"text","text":"To filter the layer to include only the features whose "},{"type":"codeVoice","code":"index"},{"type":"text","text":" attribute is 5"},{"type":"text","text":" "},{"type":"text","text":"or 10 and whose "},{"type":"codeVoice","code":"ele"},{"type":"text","text":" attribute is at least 1,500, you could create an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSCompoundPredicate"},{"type":"text","text":" along these lines:"}],"type":"paragraph"},{"syntax":"s