d by the shape source. You"},{"type":"text","text":" "},{"type":"text","text":"can update a shape source by setting its "},{"type":"codeVoice","code":"shape"},{"type":"text","text":" or "},{"type":"codeVoice","code":"URL"},{"type":"text","text":" property."}],"title":"MLNShapeSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorStyleLayer/predicate":{"url":"\/documentation\/maplibre\/mlnvectorstylelayer\/predicate","title":"predicate","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer\/predicate","abstract":[{"type":"text","text":"The style layer’s predicate."}],"fragments":[{"kind":"identifier","text":"predicate"}],"type":"topic","role":"symbol","kind":"symbol"}}}