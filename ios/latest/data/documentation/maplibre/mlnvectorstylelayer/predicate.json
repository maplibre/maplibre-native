{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer\/predicate"},"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer"]]},"kind":"symbol","variants":[{"paths":["\/documentation\/maplibre\/mlnvectorstylelayer\/predicate"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"symbolKind":"property","fragments":[{"text":"predicate","kind":"identifier"}],"title":"predicate","roleHeading":"Instance Property","role":"symbol","externalID":"c:objc(cs)MLNVectorStyleLayer(py)predicate","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"text":"predicate","kind":"identifier"}]},"primaryContentSections":[{"declarations":[{"languages":["occ"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":") "},{"preciseIdentifier":"c:objc(cs)NSPredicate","kind":"typeIdentifier","text":"NSPredicate"},{"kind":"text","text":" * "},{"kind":"identifier","text":"predicate"},{"kind":"text","text":";"}],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"Use the style layer’s predicate to include only the features in the source"},{"type":"text","text":" "},{"type":"text","text":"layer that satisfy a condition that you define. If the style layer initially"},{"type":"text","text":" "},{"type":"text","text":"comes from the style, its predicate corresponds to the"},{"type":"text","text":" "},{"code":"filter","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"property in the style JSON."}],"type":"paragraph"},{"inlineContent":[{"text":"See the “","type":"text"},{"text":"Predicates and Expressions","type":"text"},{"text":"”","type":"text"},{"text":" ","type":"text"},{"text"