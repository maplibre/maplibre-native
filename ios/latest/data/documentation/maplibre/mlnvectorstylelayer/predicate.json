{"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"paths":["\/documentation\/maplibre\/mlnvectorstylelayer\/predicate"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer\/predicate","interfaceLanguage":"occ"},"abstract":[{"text":"The style layer’s predicate.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":") ","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSPredicate","text":"NSPredicate","kind":"typeIdentifier"},{"text":" * ","kind":"text"},{"text":"predicate","kind":"identifier"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Use the style layer’s predicate to include only the features in the source"},{"type":"text","text":" "},{"type":"text","text":"layer that satisfy a condition that you define. If the style layer initially"},{"type":"text","text":" "},{"type":"text","text":"comes from the style, its predicate corresponds to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"filter"},{"type":"text","text":" "},{"type":"text","text":"property in the style JSON."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"See the “"},{"type":"text","text":"Predicates and Expressions"},{"type":"text","text":"”"},{"type":"text","text":" "},{"type":"text","text":"guide for details about the predicate syntax supported by this class."}],"type":"paragraph"},{"text":"Example","anchor":"Example","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"To filter the layer to include only the features whose "},{"code":"index","type":"codeVoice"},{"type":"text","text":" attribute is 5"},{"type":"text","text":" "},{"type":"text","text":"or 10 and whose "},{"code":"ele","type":"codeVoice"},{"type":"text","text":" attribute is at least 1,500, you could create an"},{"type":"text","text":" "},{"code":"NSCompoundPredicate","type":"codeVoice"},{"type":"text","text":" along these lines:"}],"type":"paragraph"},{"code":["let layer = MLNLineStyleLayer(identifier: \"contour\", source: terrain)","layer.sourceLayerIdentifier = \"contours\"","layer.predicate = NSPredicate(format: \"(index == 5 || index == 10) && CAST(ele, 'NSNumber') >=","1500.0\") mapView.style?.addLayer(layer)"],"syntax":"swift","type":"codeListing"}]}],"metadata":{"modules":[{"name":"MapLibre"}],"fragments":[{"text":"predicate","kind":"identifier"}],"externalID":"c:objc(cs)MLNVectorStyleLayer(py)predicate","title":"predicate","navigatorTitle":[{"text":"predicate","kind":"identifier"}],"role":"symbol","symbolKind":"property","roleHeading":"Instance Property"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorStyleLayer/predicate":{"title":"predicate","role":"symbol","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer\/predicate","fragments":[{"kind":"identifier","text":"predicate"}],"type":"topic","url":"\/documentation\/maplibre\/mlnvectorstylelayer\/predicate","abstract":[{"type":"text","text":"The style layer’s predicate."}]},"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"type":"topic","url":"\/documentation\/maplibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","kind":"symbol","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNVectorStyleLayer":{"abstract":[{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","type":"reference"},{"text":" is an abstract superclass for style layers whose content","type":"text"},{"text":" ","type":"text"},{"text":"is defined by an ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference"},{"text":" or ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference"},{"text":" object.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorStyleLayer","role":"symbol","kind":"symbol","title":"MLNVectorStyleLayer","url":"\/documentation\/maplibre\/mlnvectorstylelayer","type":"topic","fragments":[{"text":"MLNVectorStyleLayer","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"url":"\/documentation\/maplibre\/mlnshapesource","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":" is a map content source that supplies vector shapes to be"},{"type":"text","text":" "},{"type":"text","text":"shown on the map. The shapes may be instances of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":" or "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or they may be defined by local or external"},{"type":"text","text":" "},{"type":"text","text":"GeoJSON"},{"type":"text","text":" code. A shape source is added to an"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object along with an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle"},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the shape source. You"},{"type":"text","text":" "},{"type":"text","text":"can update a shape source by setting its "},{"type":"codeVoice","code":"shape"},{"type":"text","text":" or "},{"type":"codeVoice","code":"URL"},{"type":"text","text":" property."}],"type":"topic","title":"MLNShapeSource","role":"symbol","fragments":[{"text":"MLNShapeSource","kind":"identifier"}],"kind":"symbol"}}}