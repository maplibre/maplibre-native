Libre/MLNShapeSourceOptionClusterProperties":{"fragments":[{"text":"MLNShapeSourceOptionClusterProperties","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnshapesourceoptionclusterproperties","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClusterProperties","kind":"symbol","abstract":[{"text":"An ","type":"text"},{"code":"NSDictionary","type":"codeVoice"},{"text":" object where the key is an ","type":"text"},{"code":"NSString","type":"codeVoice"},{"text":". The dictionary key will","type":"text"},{"text":" ","type":"text"},{"text":"be the feature attribute key. The resulting attribute value is","type":"text"},{"text":" ","type":"text"},{"text":"aggregated from the clustered points. The dictionary value is an ","type":"text"},{"code":"NSArray","type":"codeVoice"},{"text":" ","type":"text"},{"text":"consisting of two ","type":"text"},{"code":"NSExpression","type":"codeVoice"},{"text":" objects.","type":"text"}],"type":"topic","title":"MLNShapeSourceOptionClusterProperties","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOption":{"role":"symbol","abstract":[{"type":"text","text":"Options for "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"type":"text","text":" objects."}],"fragments":[{"kind":"identifier","text":"MLNShapeSourceOption"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOption","type":"topic","kind":"symbol","title":"MLNShapeSourceOption","url":"\/documentation\/maplibre\/mlnshapesourceoption"},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSource":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","kind":"symbol","fragments":[{"text":"MLNComputedShapeSource","kind":"identifier"}],"abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource",