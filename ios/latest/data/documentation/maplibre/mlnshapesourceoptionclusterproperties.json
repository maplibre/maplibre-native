:";","kind":"text"}],"platforms":["iOS"]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The first object determines how the attribute values are accumulated from the"},{"type":"text","text":" "},{"type":"text","text":"cluster points. It is an "},{"type":"codeVoice","code":"NSExpression"},{"type":"text","text":" with an expression function that accepts"},{"type":"text","text":" "},{"type":"text","text":"two or more arguments, such as "},{"type":"codeVoice","code":"sum"},{"type":"text","text":" or "},{"type":"codeVoice","code":"max"},{"type":"text","text":". The arguments should be"},{"type":"text","text":" "},{"type":"codeVoice","code":"featureAccumulated"},{"type":"text","text":" and the previously defined feature attribute key. The"},{"type":"text","text":" "},{"type":"text","text":"resulting value is assigned to the specified attribute key."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The second "},{"code":"NSExpression","type":"codeVoice"},{"type":"text","text":" in the array determines which"},{"type":"text","text":" "},{"type":"text","text":"attribute values are accessed from individual features within a cluster."}]},{"type":"codeListing","code":["let firstExpression = NSExpression(format: \"sum:({$featureAccumulated, sumValue})\")","let secondExpression = NSExpression(forKeyPath: \"magnitude\")","let clusterPropertiesDictionary = [\"sumValue\" : [firstExpression, secondExpression]]","","let options : [MLNShapeSourceOption : Any] = [.clustered : true,","                                           .clusterProperties: clusterPropertiesDictionary]"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This option corresponds to the"},{"type":"text","text":" "},{"type":"text","text":"clusterProperties"},{"type":"text","text":" "},{"type":"text","text":"source property in the MapLibre Style Spec."}]},{"type":"