{"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"modules":[{"name":"MapLibre"}],"role":"symbol","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionClusterProperties"}],"navigatorTitle":[{"kind":"identifier","text":"MLNShapeSourceOptionClusterProperties"}],"title":"MLNShapeSourceOptionClusterProperties","symbolKind":"var","roleHeading":"Global Variable","externalID":"c:@MLNShapeSourceOptionClusterProperties"},"primaryContentSections":[{"declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"tokens":[{"text":"extern","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"typeIdentifier","text":"MLNShapeSourceOption","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOption","preciseIdentifier":"c:MLNShapeSource.h@T@MLNShapeSourceOption"},{"kind":"text","text":" "},{"kind":"keyword","text":"const"},{"kind":"text","text":" "},{"kind":"identifier","text":"MLNShapeSourceOptionClusterProperties"},{"kind":"text","text":";"}],"languages":["occ"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The first object determines how the attribute values are accumulated from the"},{"type":"text","text":" "},{"type":"text","text":"cluster points. It is an "},{"type":"codeVoice","code":"NSExpression"},{"type":"text","text":" with an expression function that accepts"},{"text":" ","type":"text"},{"text":"two or more arguments, such as ","type":"text"},{"type":"codeVoice","code":"sum"},{"type":"text","text":" or "},{"type":"codeVoice","code":"max"},{"type":"text","text":". The arguments should be"},{"type":"text","text":" "},{"type":"codeVoice","code":"featureAccumulated"},{"text":" and the previously defined feature attribute key. The","type":"text"},{"text":" ","type":"text"},{"text":"resulting value is assigned to the specified attribute key.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The second "},{"type":"codeVoice","code":"NSExpression"},{"type":"text","text":" in the array determines which"},{"type":"text","text":" "},{"type":"text","text":"attribute values are accessed from individual features within a cluster."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let firstExpression = NSExpression(format: \"sum:({$featureAccumulated, sumValue})\")","let secondExpression = NSExpression(forKeyPath: \"magnitude\")","let clusterPropertiesDictionary = [\"sumValue\" : [firstExpression, secondExpression]]","","let options : [MLNShapeSourceOption : Any] = [.clustered : true,","                                           .clusterProperties: clusterPropertiesDictionary]"]},{"inlineContent":[{"type":"text","text":"This option corresponds to the"},{"type":"text","text":" "},{"type":"text","text":"clusterProperties"},{"type":"text","text":" "},{"type":"text","text":"source property in the MapLibre Style Spec."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This option only affects point features within an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true},{"type":"text","text":" object; it"},{"type":"text","text":" "},{"type":"text","text":"is ignored when creating an "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","type":"reference"},{"type":"text","text":" object."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClusterProperties","interfaceLanguage":"occ"},"abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSDictionary"},{"type":"text","text":" object where the key is an "},{"type":"codeVoice","code":"NSString"},{"type":"text","text":". The dictionary key will"},{"type":"text","text":" "},{"type":"text","text":"be the feature attribute key. The resulting attribute value is"},{"type":"text","text":" "},{"type":"text","text":"aggregated from the clustered points. The dictionary value is an "},{"type":"codeVoice","code":"NSArray"},{"type":"text","text":" "},{"type":"text","text":"consisting of two "},{"type":"codeVoice","code":"NSExpression"},{"type":"text","text":" objects."}],"kind":"symbol","variants":[{"paths":["\/documentation\/maplibre\/mlnshapesourceoptionclusterproperties"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true},{"type":"text","text":" is a map content source that supplies vector shapes to be"},{"type":"text","text":" "},{"type":"text","text":"shown on the map. The shapes may be instances of "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or they may be defined by local or external"},{"type":"text","text":" "},{"type":"text","text":"GeoJSON"},{"type":"text","text":" code. A shape source is added to an"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object along with an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the shape source. You"},{"type":"text","text":" "},{"type":"text","text":"can update a shape sourc