{"abstract":[{"type":"text","text":"An "},{"code":"NSDictionary","type":"codeVoice"},{"type":"text","text":" object where the key is an "},{"code":"NSString","type":"codeVoice"},{"type":"text","text":". The dictionary key will"},{"type":"text","text":" "},{"type":"text","text":"be the feature attribute key. The resulting attribute value is"},{"type":"text","text":" "},{"type":"text","text":"aggregated from the clustered points. The dictionary value is an "},{"code":"NSArray","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"consisting of two "},{"code":"NSExpression","type":"codeVoice"},{"type":"text","text":" objects."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnshapesourceoptionclusterproperties"]}],"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClusterProperties"},"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"navigatorTitle":[{"text":"MLNShapeSourceOptionClusterProperties","kind":"identifier"}],"symbolKind":"var","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionClusterProperties"}],"title":"MLNShapeSourceOptionClusterProperties","modules":[{"name":"MapLibre"}],"externalID":"c:@MLNShapeSourceOptionClusterProperties","role":"symbol","roleHeading":"Global Variable"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"extern","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MLNShapeSourceOption","kind":"typeIdentifier","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOption","preciseIdentifier":"c:MLNShapeSource.h@T@MLNShapeSourceOption"},{"text":" ","kind":"text"},{"kind":"keyword","text":"const"},{"kind":"text","text":" "},{"kind":"identifier","text":"MLNShapeSourceOptionClusterProperties"},{"kind":"text","text":";"}]