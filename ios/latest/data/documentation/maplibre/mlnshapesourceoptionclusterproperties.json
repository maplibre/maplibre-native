{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"kind":"symbol","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSDictionary"},{"type":"text","text":" object where the key is an "},{"type":"codeVoice","code":"NSString"},{"type":"text","text":". The dictionary key will"},{"type":"text","text":" "},{"type":"text","text":"be the feature attribute key. The resulting attribute value is"},{"type":"text","text":" "},{"type":"text","text":"aggregated from the clustered points. The dictionary value is an "},{"type":"codeVoice","code":"NSArray"},{"type":"text","text":" "},{"type":"text","text":"consisting of two "},{"type":"codeVoice","code":"NSExpression"},{"type":"text","text":" objects."}],"primaryContentSections":[{"declarations":[{"languages":["occ"],"tokens":[{"text":"extern","kind":"keyword"},{"text":" ","kind":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOption","text":"MLNShapeSourceOption","preciseIdentifier":"c:MLNShapeSource.h@T@MLNShapeSourceOption","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"const","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MLNShapeSourceOptionClusterProperties","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS","iPadOS","Mac Catalyst"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The first object determines how the attribute values are accumulated from the"},{"type":"text","text":" "},{"type":"text","text":"cluster points. It is an "},{"code":"NSExpression","type":"codeVoice"},{"type":"text","text":" with an expression function that accepts"},{"type":"text","text":" "},{"type":"text","text":"two or more arguments, such as "},{"code":"sum","type":"codeVoice"},{"type":"text","text":" or "},{"code":"max","type":"codeVoice"},{"type":"text","text":". The arguments should be"},{"type":"text","text":" "},{"code":"featureAccumulated","type":"codeVoice"},{"type":"text","text":" and the previously defined feature attribute key. The"},{"type":"text","text":" "},{"type":"text","text":"resulting value is assigned to the specified attribute key."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The second "},{"code":"NSExpression","type":"codeVoice"},{"type":"text","text":" in the array determines which"},{"type":"text","text":" "},{"type":"text","text":"attribute values are accessed from individual features within a cluster."}]},{"type":"codeListing","code":["let firstExpression = NSExpression(format: \"sum:({$featureAccumulated, sumValue})\")","let secondExpression = NSExpression(forKeyPath: \"magnitude\")","let clusterPropertiesDictionary = [\"sumValue\" : [firstExpression, secondExpression]]","","let options : [MLNShapeSourceOption : Any] = [.clustered : true,","                                           .clusterProperties: clusterPropertiesDictionary]"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This option corresponds to the"},{"type":"text","text":" "},{"type":"text","text":"clusterProperties"},{"type":"text","text":" "},{"type":"text","text":"source property in the MapLibre Style Spec."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This option only affects point features within an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true,"type":"reference"},{"type":"text","text":" object; it"},{"type":"text","text":" "},{"type":"text","text":"is ignored when creating an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","isActive":true,"type":"reference"},{"type":"text","text":" object."}]}],"kind":"content"}],"metadata":{"roleHeading":"Global Variable","externalID":"c:@MLNShapeSourceOptionClusterProperties","symbolKind":"var","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"text":"MLNShape