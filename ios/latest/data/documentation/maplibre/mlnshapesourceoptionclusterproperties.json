{"abstract":[{"text":"An ","type":"text"},{"code":"NSDictionary","type":"codeVoice"},{"text":" object where the key is an ","type":"text"},{"code":"NSString","type":"codeVoice"},{"type":"text","text":". The dictionary key will"},{"type":"text","text":" "},{"type":"text","text":"be the feature attribute key. The resulting attribute value is"},{"type":"text","text":" "},{"type":"text","text":"aggregated from the clustered points. The dictionary value is an "},{"code":"NSArray","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"consisting of two "},{"code":"NSExpression","type":"codeVoice"},{"type":"text","text":" objects."}],"primaryContentSections":[{"declarations":[{"languages":["occ"],"tokens":[{"text":"extern","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MLNShapeSourceOption","preciseIdentifier":"c:MLNShapeSource.h@T@MLNShapeSourceOption","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOption","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"const","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MLNShapeSourceOptionClusterProperties","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"The first object determines how the attribute values are accumulated from the"},{"type":"text","text":" "},{"type":"text","text":"cluster points. It is an "},{"type":"codeVoice","code":"NSExpression"},{"type":"text","text":" with an expression function that accepts"},{"type":"text","text":" "},{"type":"text","text":"two or more arguments, such as "},{"type":"codeVoice","code":"sum"},{"type":"text","text":" or "},{"type":"codeVoice","code":"max"},{"type":"text","text":". The arguments should be"},{"type":"text","text":" "},{"type":"codeVoice","code":"featureAccumulated"},{"type":"text","text":" and the previously defined feature attribute key. The"},{"type":"text","text":" "},{"type":"text","text":"resulting value is assigned to the specified attribute key."}],"type":"paragraph"},{"inlineContent":[{"text":"The second ","type":"text"},{"type":"codeVoice","code":"NSExpression"},{"text":" in the array determines which","type":"text"},{"text":" ","type":"text"},{"text":"attribute values are accessed from individual features within a cluster.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let firstExpression = NSExpression(format: \"sum:({$featureAccumulated, sumValue})\")","let secondExpression = NSExpression(forKeyPath: \"magnitude\")","let clusterPropertiesDictionary = [\"sumValue\" : [firstExpression, secondExpression]]","","let options : [MLNShapeSourceOption : Any] = [.clustered : true,","                                           .clusterProperties: clusterPropertiesDictionary]"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"This option corresponds to the"},{"type":"text","text":" "},{"type":"text","text":"clusterProperties"},{"type":"text","text":" "},{"type":"text","text":"source property in the MapLibre Style Spec."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This option only affects point features within an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":" object; it"},{"type":"text","text":" "},{"type":"text","text":"is ignored when creating an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource"},{"type":"text","text":" object."}],"type":"paragraph"}]}],"sections":[],"kind":"symbol","variants":[{"paths":["\/documentation\/maplibre\/mlnshapesourceoptionclusterproperties"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.