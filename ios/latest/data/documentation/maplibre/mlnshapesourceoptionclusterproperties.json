{"variants":[{"paths":["\/documentation\/maplibre\/mlnshapesourceoptionclusterproperties"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSDictionary"},{"type":"text","text":" object where the key is an "},{"type":"codeVoice","code":"NSString"},{"type":"text","text":". The dictionary key will"},{"type":"text","text":" "},{"type":"text","text":"be the feature attribute key. The resulting attribute value is"},{"type":"text","text":" "},{"type":"text","text":"aggregated from the clustered points. The dictionary value is an "},{"type":"codeVoice","code":"NSArray"},{"type":"text","text":" "},{"type":"text","text":"consisting of two "},{"type":"codeVoice","code":"NSExpression"},{"type":"text","text":" objects."}],"sections":[],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClusterProperties","interfaceLanguage":"occ"},"metadata":{"externalID":"c:@MLNShapeSourceOptionClusterProperties","symbolKind":"var","roleHeading":"Global Variable","title":"MLNShapeSourceOptionClusterProperties","fragments":[{"text":"MLNShapeSourceOptionClusterProperties","kind":"identifier"}],"role":"symbol","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"kind":"identifier","text":"MLNShapeSourceOptionClusterProperties"}]},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"extern","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MLNShapeSourceOption","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOption","preciseIdentifier":"c:MLNShapeSource.h@T@MLNShapeSourceOption","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"const","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MLNShapeSourceOptionClusterProperties","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"The first object determines how the attribute values are accumulated from the","type":"text"},{"text":" ","type":"text"},{"text":"cluster points. It is an ","type":"text"},{"type":"codeVoice","code":"NSExpression"},{"text":" with an expression function that accepts","type":"text"},{"text":" ","type":"text"},{"text":"two or more arguments, such as ","type":"text"},{"type":"codeVoice","code":"sum"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"max"},{"text":". The arguments should be","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"featureAccumulated"},{"text":" and the previously defined feature attribute key. The","type":"text"},{"text":" ","type":"text"},{"text":"resulting value is assigned to the specified attribute key.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The second ","type":"text"},{"code":"NSExpression","type":"codeVoice"},{"text":" in the array determines which","type":"text"},{"text":" ","type":"text"},{"text":"attribute values are accessed from individual features within a cluster.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let firstExpression = NSExpression(format: \"sum:({$featureAccumulated, sumValue})\")","let secondExpression = NSExpression(forKeyPath: \"magnitude\")","let clusterPropertiesDictionary = [\"sumValue\" : [firstExpression, secondExpression]]","","let options : [MLNShapeSourceOption : Any] = [.clustered : true,","                                           .clusterProperties: clusterPropertiesDictionary]"],"type":"codeListing"},{"inlineContent":[{"text":"This option corresponds to the","type":"text"},{"text":" ","type":"text"},{"text":"clusterProperties","type":"text"},{"text":" ","type":"text"},{"text":"source property in the MapLibre Style Spec.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":