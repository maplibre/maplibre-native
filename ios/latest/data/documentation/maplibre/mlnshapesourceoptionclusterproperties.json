{"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"extern","kind":"keyword"},{"text":" ","kind":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOption","text":"MLNShapeSourceOption","preciseIdentifier":"c:MLNShapeSource.h@T@MLNShapeSourceOption","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"const","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MLNShapeSourceOptionClusterProperties","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"The first object determines how the attribute values are accumulated from the"},{"type":"text","text":" "},{"type":"text","text":"cluster points. It is an "},{"type":"codeVoice","code":"NSExpression"},{"type":"text","text":" with an expression function that accepts"},{"type":"text","text":" "},{"type":"text","text":"two or more arguments, such as "},{"type":"codeVoice","code":"sum"},{"type":"text","text":" or "},{"type":"codeVoice","code":"max"},{"type":"text","text":". The arguments should be"},{"type":"text","text":" "},{"type":"codeVoice","code":"featureAccumulated"},{"type":"text","text":" and the previously defined feature attribute key. The"},{"type":"text","text":" "},{"type":"text","text":"resulting value is assigned to the specified attribute key."}],"type":"paragraph"},{"inlineContent":[{"text":"The second ","type":"text"},{"code":"NSExpression","type":"codeVoice"},{"text":" in the array determines which","type":"text"},{"text":" ","type":"text"},{"text":"attribute values are accessed from individual features within a cluster.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let firstExpression = NSExpression(format: \"sum:({$featureAccumulated, sumValue})\")","let secondExpression = NSExpression(forKeyPath: \"magnitude\")"