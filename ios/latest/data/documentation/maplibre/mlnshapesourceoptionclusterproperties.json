{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnshapesourceoptionclusterproperties"]}],"metadata":{"modules":[{"name":"MapLibre"}],"navigatorTitle":[{"text":"MLNShapeSourceOptionClusterProperties","kind":"identifier"}],"title":"MLNShapeSourceOptionClusterProperties","externalID":"c:@MLNShapeSourceOptionClusterProperties","role":"symbol","fragments":[{"text":"MLNShapeSourceOptionClusterProperties","kind":"identifier"}],"symbolKind":"var","roleHeading":"Global Variable"},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClusterProperties","interfaceLanguage":"occ"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"extern"},{"kind":"text","text":" "},{"kind":"typeIdentifier","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOption","preciseIdentifier":"c:MLNShapeSource.h@T@MLNShapeSourceOption","text":"MLNShapeSourceOption"},{"kind":"text","text":" "},{"kind":"keyword","text":"const"},{"kind":"text","text":" "},{"kind":"identifier","text":"MLNShapeSourceOptionClusterProperties"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The first object determines how the attribute values are accumulated from the"},{"type":"text","text":" "},{"type":"text","text":"cluster points. It is an "},{"code":"NSExpression","type":"codeVoice"},{"type":"text","text":" with an expression function that accepts"},{"type":"text","text":" "},{"type":"text","text":"two or more arguments, such as "},{"code":"sum","type":"codeVoice"},{"type":"text","text":" or "},{"code":"max","type":"codeVoice"},{"type":"text","text":". The arguments should be"},{"type":"text","text":" "},{"code":"featureAccumulated","type":"codeVoice"},{"type":"text","text":" and the previously defined feature attribute key. The"},{"type":"text","text":" "},{"type":"text","text":"resulting value is assigned to the specified attribute key."}]},{"type":"paragraph","inlineContent":[{"text":"The second ","type":"text"},{"code":"NSExpression","type":"codeVoice"},{"text":" in the array determines which","type":"text"},{"text":" ","type":"text"},{"text":"attribute values are accessed from individual features within a cluster.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let firstExpression = NSExpression(format: \"sum:({$featureAccumulated, sumValue})\")","let secondExpression = NSExpression(forKeyPath: \"magnitude\")","let clusterPropertiesDictionary = [\"sumValue\" : [firstExpression, secondExpression]]","","let options : [MLNShapeSourceOption : Any] = [.clustered : true,","                                           .clusterProperties: clusterPropertiesDictionary]"]},{"type":"paragraph","inlineContent":[{"text":"This option corresponds to the","type":"text"},{"text":" ","type":"text"},{"text":"clusterProperties","type":"text"},{"text":" ","type":"text"},{"text":"source property in the MapLibre Style Spec.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This option only affects point features within an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"type":"text","text":" object; it"},{"type":"text","text":" "},{"type":"text","text":"is ignored when creating an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","type":"reference","isActive":true},{"type":"text","text":" object."}]}]}],"abstract":[{"text":"An ","type":"text"},{"type":"codeVoice","code":"NSDictionary"},{"text":" object where the key is an ","type":"text"},{"type":"codeVoice","code":"NSString"},{"text":". The dictionary key will","type":"text"},{"text":" ","type":"text"},{"text":"be the feature attribute key. The resulting attribute value is","type":"text"},{"text":" ","type":"text"},{"text":"aggregated from the clustered points. The dictionary value is an ","type":"text"},{"type":"codeVoice","code":"NSArray"},{"text":" ","type":"text"},{"text":"consisting of two ","type":"text"},{"type":"codeVoice","code":"NSExpression"},{"text":" objects.","type":"text"}],"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol","type":"topic","title":"MapLibre","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSource":{"title":"MLNComputedShapeSource","role":"symbol","url":"\/documentation\/maplibre\/mlncomputedshapesource","kind":"symbol","fragments":[{"text":"MLNComputedShapeSource","kind":"identifier"}],"abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","isActive":true},{"type":"text","text":" is a map content source that supplies vector shapes,"},{"type":"text","text":" "},{"type":"text","text":"one tile at a time, to be shown on the map on demand. You implement a class"},{"type":"text","text":" "},{"type":"text","text":"conforming to the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource","isActive":true},{"type":"text","text":" protocol that returns"},{"type":"text","text":" "},{"type":"text","text":"instances of "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":", then add a computed shape source to an"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object along with an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the computed shape"},{"type":"text","text":" "},{"type":"text","text":"source."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSource":{"fragments":[{"kind":"identifier","text":"MLNShapeSource"}],"type":"topic","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true},{"type":"text","text":" is a map content source that supplies vector shapes to be"},{"type":"text","text":" "},{"type":"text","text":"shown on the map. The shapes may be instances of "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or they may be defined by local or external"},{"type":"text","text":" "},{"type":"text","text":"GeoJSON"},{"type":"text","text":" code. A shape source is added to an"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object along with an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","isActive":true},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the shape source. You"},{"type":"text","text":" "},{"type":"text","text":"can update a shape source by setting its "},{"type":"codeVoice","code":"shape"},{"type":"text","text":" or "},{"type":"codeVoice","code":"URL"},{"type":"text","text":" property."}],"title":"MLNShapeSource","url":"\/documentation\/maplibre\/mlnshapesource","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOption":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOption","abstract":[{"type":"text","text":"Options for "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","type":"reference","isActive":true},{"type":"text","text":" objects."}],"role":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoption","kind":"symbol","title":"MLNShapeSourceOption","fragments":[{"text":"MLNShapeSourceOption","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","role":"symbol","abstract":[{"type":"text","text":"The proxy object for the current map style."}],"title":"MLNStyle","fragments":[{"text":"MLNStyle","kind":"identifier"}],"type":"topic","url":"\/documentation\/maplibre\/mlnstyle","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"role":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","title":"MLNShape","kind":"symbol","url":"\/documentation\/maplibre\/mlnshape","fragments":[{"text":"MLNShape","kind":"identifier"}],"abstract":[{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true},{"text":" is an abstract class that represents a shape or annotation. Shapes","type":"text"},{"text":" ","type":"text"},{"text":"constitute the content of a map — not only the overlays atop the map, but also","type":"text"},{"text":" ","type":"text"},{"text":"the content that forms the base map.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSourceDataSource":{"url":"\/documentation\/maplibre\/mlncomputedshapesourcedatasource","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource","role":"symbol","title":"MLNComputedShapeSourceDataSource","type":"topic","abstract":[{"type":"text","text":"Data source for "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","isActive":true},{"type":"text","text":". This protocol defines two optional methods for fetching"},{"type":"text","text":" "},{"type":"text","text":"data, one based on tile coordinates, and one based on a bounding box. Classes that implement this"},{"type":"text","text":" "},{"type":"text","text":"protocol must implement one, and only one of the methods. Methods on this protocol will not be"},{"type":"text","text":" "},{"type":"text","text":"called on main thread, they will be called on the caller’s "},{"type":"codeVoice","code":"requestQueue"},{"type":"text","text":"."}],"fragments":[{"kind":"identifier","text":"MLNComputedShapeSourceDataSource"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOptionClusterProperties":{"role":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnshapesourceoptionclusterproperties","fragments":[{"text":"MLNShapeSourceOptionClusterProperties","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClusterProperties","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSDictionary"},{"type":"text","text":" object where the key is an "},{"type":"codeVoice","code":"NSString"},{"type":"text","text":". The dictionary key will"},{"type":"text","text":" "},{"type":"text","text":"be the feature attribute key. The resulting attribute value is"},{"type":"text","text":" "},{"type":"text","text":"aggregated from the clustered points. The dictionary value is an "},{"type":"codeVoice","code":"NSArray"},{"type":"text","text":" "},{"text":"consisting of two ","type":"text"},{"type":"codeVoice","code":"NSExpression"},{"text":" objects.","type":"text"}],"title":"MLNShapeSourceOptionClusterProperties"}}}