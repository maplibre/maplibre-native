":"heading"},{"type":"paragraph","inlineContent":[{"text":"The first object determines how the attribute values are accumulated from the","type":"text"},{"text":" ","type":"text"},{"text":"cluster points. It is an ","type":"text"},{"type":"codeVoice","code":"NSExpression"},{"text":" with an expression function that accepts","type":"text"},{"text":" ","type":"text"},{"text":"two or more arguments, such as ","type":"text"},{"type":"codeVoice","code":"sum"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"max"},{"text":". The arguments should be","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"featureAccumulated"},{"text":" and the previously defined feature attribute key. The","type":"text"},{"text":" ","type":"text"},{"text":"resulting value is assigned to the specified attribute key.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The second ","type":"text"},{"code":"NSExpression","type":"codeVoice"},{"text":" in the array determines which","type":"text"},{"text":" ","type":"text"},{"text":"attribute values are accessed from individual features within a cluster.","type":"text"}]},{"code":["let firstExpression = NSExpression(format: \"sum:({$featureAccumulated, sumValue})\")","let secondExpression = NSExpression(forKeyPath: \"magnitude\")","let clusterPropertiesDictionary = [\"sumValue\" : [firstExpression, secondExpression]]","","let options : [MLNShapeSourceOption : Any] = [.clustered : true,","                                           .clusterProperties: clusterPropertiesDictionary]"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"This option corresponds to the","type":"text"},{"text":" ","type":"text"},{"text":"clusterProperties","type":"text"},{"text":" ","type":"text"},{"text":"source property in the MapLibre Style Spec.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This option only affects point features within an ","type":"text"},{"isActive":true,"type":"re