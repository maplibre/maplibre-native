","text":" "},{"type":"text","text":"be the feature attribute key. The resulting attribute value is"},{"type":"text","text":" "},{"type":"text","text":"aggregated from the clustered points. The dictionary value is an "},{"code":"NSArray","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"consisting of two "},{"code":"NSExpression","type":"codeVoice"},{"type":"text","text":" objects."}],"fragments":[{"text":"MLNShapeSourceOptionClusterProperties","kind":"identifier"}],"role":"symbol","title":"MLNShapeSourceOptionClusterProperties","kind":"symbol","url":"\/documentation\/maplibre\/mlnshapesourceoptionclusterproperties"}}}