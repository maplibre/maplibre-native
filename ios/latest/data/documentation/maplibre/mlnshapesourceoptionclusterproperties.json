: \"sum:({$featureAccumulated, sumValue})\")","let secondExpression = NSExpression(forKeyPath: \"magnitude\")","let clusterPropertiesDictionary = [\"sumValue\" : [firstExpression, secondExpression]]","","let options : [MLNShapeSourceOption : Any] = [.clustered : true,","                                           .clusterProperties: clusterPropertiesDictionary]"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"This option corresponds to the","type":"text"},{"text":" ","type":"text"},{"text":"clusterProperties","type":"text"},{"text":" ","type":"text"},{"text":"source property in the MapLibre Style Spec.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This option only affects point features within an ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"text":" object; it","type":"text"},{"text":" ","type":"text"},{"text":"is ignored when creating an ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource"},{"text":" object.","type":"text"}],"type":"paragraph"}]}],"metadata":{"navigatorTitle":[{"kind":"identifier","text":"MLNShapeSourceOptionClusterProperties"}],"externalID":"c:@MLNShapeSourceOptionClusterProperties","fragments":[{"kind":"identifier","text":"MLNShapeSourceOptionClusterProperties"}],"modules":[{"name":"MapLibre"}],"roleHeading":"Global Variable","symbolKind":"var","role":"symbol","title":"MLNShapeSourceOptionClusterProperties"},"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSDictionary"},{"type":"text","text":" object where the key is an "},{"type":"codeVoice","code":"NSString"},{"type":"text","text":". The dictionary key will"},{"type":"text","text":" "},{"type":"text"