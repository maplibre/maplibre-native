{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"NSDictionary"},{"type":"text","text":" object where the key is an "},{"type":"codeVoice","code":"NSString"},{"type":"text","text":". The dictionary key will"},{"type":"text","text":" "},{"type":"text","text":"be the feature attribute key. The resulting attribute value is"},{"type":"text","text":" "},{"type":"text","text":"aggregated from the clustered points. The dictionary value is an "},{"type":"codeVoice","code":"NSArray"},{"type":"text","text":" "},{"type":"text","text":"consisting of two "},{"type":"codeVoice","code":"NSExpression"},{"type":"text","text":" objects."}],"metadata":{"modules":[{"name":"MapLibre"}],"title":"MLNShapeSourceOptionClusterProperties","navigatorTitle":[{"text":"MLNShapeSourceOptionClusterProperties","kind":"identifier"}],"symbolKind":"var","role":"symbol","externalID":"c:@MLNShapeSourceOptionClusterProperties","fragments":[{"text":"MLNShapeSourceOptionClusterProperties","kind":"identifier"}],"roleHeading":"Global Variable"},"variants":[{"paths":["\/documentation\/maplibre\/mlnshapesourceoptionclusterproperties"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"extern"},{"kind":"text","text":" "},{"preciseIdentifier":"c:MLNShapeSource.h@T@MLNShapeSourceOption","kind":"typeIdentifier","text":"MLNShapeSourceOption","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOption"},{"kind":"text","text":" "},{"kind":"keyword","text":"const"},{"kind":"text","text":" "},{"kind":"identifier","text":"MLNShapeSourceOptionClusterProperties"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The first object determines how the attribute values are accumulated from the"},{"type":"text","text":" "},{"type":"text","text":"cluster points. It is an "},{"type":"codeVoice","code":"NSExpression"},{"type":"text","text":" with an expression function that accepts"},{"type":"text","text":" "},{"type":"text","text":"two or more arguments, such as "},{"type":"codeVoice","code":"sum"},{"type":"text","text":" or "},{"type":"codeVoice","code":"max"},{"type":"text","text":". The arguments should be"},{"type":"text","text":" "},{"type":"codeVoice","code":"featureAccumulated"},{"type":"text","text":" and the previously defined feature attribute key. The"},{"type":"text","text":" "},{"type":"text","text":"resulting value is assigned to the specified attribute key."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The second "},{"type":"codeVoice","code":"NSExpression"},{"type":"text","text":" in the array determines which"},{"type":"text","text":" "},{"type":"text","text":"attribute values are accessed from individual features within a cluster."}]},{"syntax":"swift","code":["let firstExpression = NSExpression(format: \"sum:({$featureAccumulated, sumValue})\")","let secondExpression = NSExpression(forKeyPath: \"magnitude\")","let clusterPropertiesDictionary = [\"sumValue\" : [firstExpression, secondExpression]]","","let options : [MLNShapeSourceOption : Any] = [.clustered : true,","                                           .clusterProperties: clusterPropertiesDictionary]"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This option corresponds to the"},{"type":"text","text":" "},{"type":"text","text":"clusterProperties"},{"type":"text","text":" "},{"type":"text","text":"source property in the MapLibre Style Spec."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This option only affects point features within an "},{"type":"reference","isActive":true,"