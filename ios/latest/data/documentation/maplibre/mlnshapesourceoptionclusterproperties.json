tyle","isActive":true,"type":"reference"},{"type":"text","text":" object. The vector style"},{"type":"text","text":" "},{"type":"text","text":"layer defines the appearance of any content supplied by the computed shape"},{"type":"text","text":" "},{"type":"text","text":"source."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource","url":"\/documentation\/maplibre\/mlncomputedshapesource","title":"MLNComputedShapeSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"type":"topic","fragments":[{"text":"MLNStyle","kind":"identifier"}],"kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"The proxy object for the current map style."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","url":"\/documentation\/maplibre\/mlnstyle","title":"MLNStyle"},"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","kind":"symbol","role":"collection","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/documentation\/maplibre","title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShapeSourceOption":{"url":"\/documentation\/maplibre\/mlnshapesourceoption","type":"topic","fragments":[{"text":"MLNShapeSourceOption","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOption","title":"MLNShapeSourceOption","abstract":[{"type":"text","text":"Options for "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true,"type":"reference"},{"type":"text","text":" objects."}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"url":"\/documentation\/maplibre\/mlnshape","fragments":[{"text":"MLNShape","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/Ma