{"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"An ","type":"text"},{"code":"NSDictionary","type":"codeVoice"},{"text":" object where the key is an ","type":"text"},{"code":"NSString","type":"codeVoice"},{"text":". The dictionary key will","type":"text"},{"text":" ","type":"text"},{"text":"be the feature attribute key. The resulting attribute value is","type":"text"},{"text":" ","type":"text"},{"text":"aggregated from the clustered points. The dictionary value is an ","type":"text"},{"code":"NSArray","type":"codeVoice"},{"text":" ","type":"text"},{"text":"consisting of two ","type":"text"},{"code":"NSExpression","type":"codeVoice"},{"text":" objects.","type":"text"}],"metadata":{"externalID":"c:@MLNShapeSourceOptionClusterProperties","modules":[{"name":"MapLibre"}],"role":"symbol","navigatorTitle":[{"text":"MLNShapeSourceOptionClusterProperties","kind":"identifier"}],"roleHeading":"Global Variable","title":"MLNShapeSourceOptionClusterProperties","symbolKind":"var","fragments":[{"text":"MLNShapeSourceOptionClusterProperties","kind":"identifier"}]},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"kind":"symbol","identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClusterProperties","interfaceLanguage":"occ"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnshapesourceoptionclusterproperties"]}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"extern","kind":"keyword"},{"text":" ","kind":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOption","text":"MLNShapeSourceOption","preciseIdentifier":"c:MLNShapeSource.h@T@MLNShapeSourceOption","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"const","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MLNShapeSourceOptionClusterProperties","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"The first object determines how the attribute values are accumulated from the","type":"text"},{"text":" ","type":"text"},{"text":"cluster points. It is an ","type":"text"},{"code":"NSExpression","type":"codeVoice"},{"text":" with an expression function that accepts","type":"text"},{"text":" ","type":"text"},{"text":"two or more arguments, such as ","type":"text"},{"code":"sum","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"max","type":"codeVoice"},{"text":". The arguments should be","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"featureAccumulated"},{"type":"text","text":" and the previously defined feature attribute key. The"},{"type":"text","text":" "},{"type":"text","text":"resulting value is assigned to the specified attribute key."}]},{"type":"paragraph","inlineContent":[{"text":"The second ","type":"text"},{"type":"codeVoice","code":"NSExpression"},{"text":" in the array determines which","type":"text"},{"text":" ","type":"text"},{"text":"attribute values are accessed from individual features within a cluster.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let firstExpression = NSExpression(format: \"sum:({$featureAccumulated, sumValue})\")","let secondExpression = NSExpression(forKeyPath: \"magnitude\")","let clusterPropertiesDictionary = [\"sumValue\" : [firstExpression, secondExpression]]","","let options : [MLNShapeSourceOption : Any] = [.clustered : true,","                                           .clusterProperties: clusterPropertiesDictionary]"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This option corresponds to the"},{"type":"text","text":" "},{"type":"text","text":"clusterProperties"},{"type":"text","text":" "},{"type":"text","text":"source property in the MapLibre Style Spec."}]},{"type":"paragraph","inlineContent":[{"t