{"sections":[],"variants":[{"paths":["\/documentation\/maplibre\/mlnshapesourceoptionclusterproperties"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre"]]},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOptionClusterProperties","interfaceLanguage":"occ"},"metadata":{"role":"symbol","title":"MLNShapeSourceOptionClusterProperties","externalID":"c:@MLNShapeSourceOptionClusterProperties","roleHeading":"Global Variable","symbolKind":"var","navigatorTitle":[{"text":"MLNShapeSourceOptionClusterProperties","kind":"identifier"}],"fragments":[{"text":"MLNShapeSourceOptionClusterProperties","kind":"identifier"}],"modules":[{"name":"MapLibre"}]},"abstract":[{"type":"text","text":"An "},{"code":"NSDictionary","type":"codeVoice"},{"type":"text","text":" object where the key is an "},{"code":"NSString","type":"codeVoice"},{"type":"text","text":". The dictionary key will"},{"type":"text","text":" "},{"type":"text","text":"be the feature attribute key. The resulting attribute value is"},{"type":"text","text":" "},{"type":"text","text":"aggregated from the clustered points. The dictionary value is an "},{"code":"NSArray","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"consisting of two "},{"code":"NSExpression","type":"codeVoice"},{"type":"text","text":" objects."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"extern","kind":"keyword"},{"text":" ","kind":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOption","text":"MLNShapeSourceOption","preciseIdentifier":"c:MLNShapeSource.h@T@MLNShapeSourceOption","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"const","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MLNShapeSourceOptionClusterProperties","kind":"identifier"},{"text":";","kind":"text"}]