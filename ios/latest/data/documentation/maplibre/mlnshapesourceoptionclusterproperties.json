documentation\/MapLibre\/MLNStyle","type":"reference","isActive":true},{"text":" object. The vector style","type":"text"},{"text":" ","type":"text"},{"text":"layer defines the appearance of any content supplied by the computed shape","type":"text"},{"text":" ","type":"text"},{"text":"source.","type":"text"}],"title":"MLNComputedShapeSource"},"doc://org.swift.MyProject/documentation/MapLibre/MLNStyle":{"title":"MLNStyle","kind":"symbol","abstract":[{"type":"text","text":"The proxy object for the current map style."}],"role":"symbol","url":"\/documentation\/maplibre\/mlnstyle","fragments":[{"kind":"identifier","text":"MLNStyle"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNStyle","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNShape":{"fragments":[{"kind":"identifier","text":"MLNShape"}],"role":"symbol","abstract":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","isActive":true,"type":"reference"},{"type":"text","text":" is an abstract class that represents a shape or annotation. Shapes"},{"type":"text","text":" "},{"type":"text","text":"constitute the content of a map — not only the overlays atop the map, but also"},{"type":"text","text":" "},{"type":"text","text":"the content that forms the base map."}],"url":"\/documentation\/maplibre\/mlnshape","kind":"symbol","title":"MLNShape","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShape","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNComputedShapeSourceDataSource":{"url":"\/documentation\/maplibre\/mlncomputedshapesourcedatasource","title":"MLNComputedShapeSourceDataSource","role":"symbol","fragments":[{"text":"MLNComputedShapeSourceDataSource","kind":"identifier"}],"abstract":[{"text":"Data source for ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSource"},{"text":". This protocol defines two optional methods for fetching","type":"text"},{"text":" ","type":"text"},{"text":"data, one based on tile coordinates, and one based on a bounding box. Classes that implement this","type":"text"},{"text":" ","type":"text"},{"text":"protocol must implement one, and only one of the methods. Methods on this protocol will not be","type":"text"},{"text":" ","type":"text"},{"text":"called on main thread, they will be called on the caller’s ","type":"text"},{"type":"codeVoice","code":"requestQueue"},{"text":".","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNComputedShapeSourceDataSource","type":"topic","kind":"symbol"}}}