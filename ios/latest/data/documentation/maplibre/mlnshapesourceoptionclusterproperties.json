{"sections":[],"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["occ"],"tokens":[{"text":"extern","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MLNShapeSourceOption","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSourceOption","preciseIdentifier":"c:MLNShapeSource.h@T@MLNShapeSourceOption","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"const","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MLNShapeSourceOptionClusterProperties","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"The first object determines how the attribute values are accumulated from the"},{"type":"text","text":" "},{"type":"text","text":"cluster points. It is an "},{"type":"codeVoice","code":"NSExpression"},{"type":"text","text":" with an expression function that accepts"},{"type":"text","text":" "},{"type":"text","text":"two or more arguments, such as "},{"type":"codeVoice","code":"sum"},{"type":"text","text":" or "},{"type":"codeVoice","code":"max"},{"type":"text","text":". The arguments should be"},{"type":"text","text":" "},{"type":"codeVoice","code":"featureAccumulated"},{"type":"text","text":" and the previously defined feature attribute key. The"},{"type":"text","text":" "},{"type":"text","text":"resulting value is assigned to the specified attribute key."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The second "},{"type":"codeVoice","code":"NSExpression"},{"type":"text","text":" in the array determines which"},{"type":"text","text":" "},{"type":"text","text":"attribute values are accessed from individual features within a cluster."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let firstExpression = NSExpression(format: \"sum:({$featureAccumulated, sumValue})\")","let secondExpression = NSExpression(forKeyP