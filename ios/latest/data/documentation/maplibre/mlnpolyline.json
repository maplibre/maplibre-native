"},{"text":"order to close the polyline. To fill the space within the shape, use an","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon","type":"reference","isActive":true},{"text":" object. To group multiple polylines together in one shape, use an","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolyline","type":"reference","isActive":true},{"text":" or ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollection","type":"reference","isActive":true},{"text":" object.","type":"text"}]},{"inlineContent":[{"type":"text","text":"To make the polyline go across the antimeridian or international date line,"},{"type":"text","text":" "},{"type":"text","text":"specify some longitudes less than −180 degrees or greater than 180 degrees."},{"type":"text","text":" "},{"type":"text","text":"For example, a polyline that stretches from Tokyo to San Francisco would have"},{"type":"text","text":" "},{"type":"text","text":"coordinates of (35.68476, -220.24257) and (37.78428, -122.41310)."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let coordinates = [","    CLLocationCoordinate2D(latitude: 35.68476, longitude: -220.24257),","    CLLocationCoordinate2D(latitude: 37.78428, longitude: -122.41310)","]","let polyline = MLNPolyline(coordinates: coordinates, count: UInt(coordinates.count))"]},{"inlineContent":[{"type":"text","text":"A polyline is known as a"},{"type":"text","text":" "},{"type":"text","text":"LineString"},{"type":"text","text":" "},{"type":"text","text":"geometry in GeoJSON."}],"type":"paragraph"},{"type":"heading","level":4,"text":"Related examples","anchor":"Related-examples"},{"items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineOnUserTap","isActive":true,"type":"reference"}],"type":"paragrap