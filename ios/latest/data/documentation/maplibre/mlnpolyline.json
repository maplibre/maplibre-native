ence","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","isActive":true},{"type":"text","text":"’s polylines collectively using an "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","isActive":true},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer","isActive":true},{"type":"text","text":" object. To access a polyline’s attributes, use an"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolylineFeature","isActive":true},{"type":"text","text":" object."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Alternatively, you can add a polyline overlay directly to a map view using the"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/addAnnotation:"},{"type":"text","text":" or "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/addOverlay:"},{"type":"text","text":" methods. Configure"},{"type":"text","text":" "},{"type":"text","text":"a polyline overlay’s appearance using"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:strokeColorForShapeAnnotation:"},{"type":"text","text":" and"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:lineWidthForPolylineAnnotation:","isActive":true,"type":"reference"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"The vertices are automatically connected in the order in which you provide","type":"text"},{"text":" ","type":"text"},{"text":"them. The first and last vertices are not connected to each other, but you can","type":"text"},{"text":" ","type":"text"},{"text":"specify the same ","type":"text"},{"type":"codeVoice","code":"CLLocationCoordinate2D"},{"text":" as the first and last vertices in","type":"text"},{"text":" ","type":"text"},{"text":"order to close the polyline. To fill the space within the shape, use an","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon"},{"text":" object. To group multiple polylines together in one shape, use an","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolyline"},{"text":" or ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollection"},{"text":" object.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To make the polyline go across the antimeridian or international date line,"},{"type":"text","text":" "},{"type":"text","text":"specify some longitudes less than −180 degrees or greater than 180 degrees."},{"type":"text","text":" "},{"type":"text","text":"For example, a polyline that stretches from Tokyo to San Francisco would have"},{"type":"text","text":" "},{"type":"text","text":"coordinates of (35.68476, -220.24257) and (37.78428, -122.41310)."}]},{"syntax":"swift","code":["let coordinates = [","    CLLocationCoordinate2D(latitude: 35.68476, longitude: -220.24257),","    CLLocationCoordinate2D(latitude: 37.78428, longitude: -122.41310)","]","let polyline = MLNPolyline(coordinates: coordinates, count: UInt(coordinates.count))"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"A polyline is known as a","type":"text"},{"text":" ","type":"text"},{"text":"LineString","type":"text"},{"text":" ","type":"text"},{"text":"geometry in GeoJSON.","type":"text"}]},{"anchor":"Relate