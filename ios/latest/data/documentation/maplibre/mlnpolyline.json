Predicates_and_Expressions"],"kind":"mentions"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"inlineContent":[{"text":"You can add polyline shapes to the map by adding them to an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"object. Configure the appearance of an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource","isActive":true,"type":"reference"},{"text":"’s or","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource","isActive":true,"type":"reference"},{"text":"’s polylines collectively using an ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer","isActive":true,"type":"reference"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer","isActive":true,"type":"reference"},{"text":" object. To access a polyline’s attributes, use an","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolylineFeature","isActive":true,"type":"reference"},{"text":" object.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Alternatively, you can add a polyline overlay directly to a map view using the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/addAnnotation:","isActive":true,"type":"reference"},{"text":" or ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/addOverlay:","isActive":true,"type":"reference"},{"text":" methods. Configure","type":"text"},{"text":" ","type":"text"},{"text":"a polyline overlay’s appearance using","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:strokeColorForShapeAnnotation:","isActive":true,"type":"reference"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:lineWidthForPolylineAnnotation:","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The vertices are automatically connected in the order in which you provide","type":"text"},{"text":" ","type":"text"},{"text":"them. The first and last vertices are not connected to each other, but you can","type":"text"},{"text":" ","type":"text"},{"text":"specify the same ","type":"text"},{"type":"codeVoice","code":"CLLocationCoordinate2D"},{"text":" as the first and last vertices in","type":"text"},{"text":" ","type":"text"},{"text":"order to close the polyline. To fill the space within the shape, use an","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon","isActive":true,"type":"reference"},{"text":" object. To group multiple polylines together in one shape, use an","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolyline","isActive":true,"type":"reference"},{"text":" or ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollection","isActive":true,"type":"reference"},{"text":" object.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To make the polyline go across the antimeridian or international date line,","type":"text"},{"text":" ","type":"text"},{"text":"specify some longitudes less than −180 degrees or greater than 180 degrees.","type":"text"},{"text":" ","type":"text"},{"text":"For example, a polyline that stretches from Tokyo to San Francisco would have","type":"text"},{"text":" ","type":"text"},{"text":"coordinates of (35.68476, -220.24257) and (37.78428, -122.41310).","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let coordinates = [","    CLLocationCoordinate2D(latitude: 35.68476, longitude: -220.24257),","    CLLocationCoordinate2D(latitude: 37.78428, longitude: -122.41310)","]","let polyline = MLNPolyline(coordinates: coordinates, count: UInt(coordinates.count))"]},{"inlineContent":[{"text":"A polyline is known as a","type":"text"},{"text":" ","type":"text"},{"text":"LineString","type":"text"},{"text":" ","type":"text"},{"text":"geometry in GeoJSON.","type":"text"}],"type":"paragraph"},{"level":4,"type":"heading","text":"Related examples","anchor":"Related-examples"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/LineOnUserTap","type":"reference","isActive":true}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/AnimatedLineExample","type":"reference","isActive":true}],"type":"paragraph"}]}]}]}],"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNSymbolStyleLayer":{"fragments":[{"kind":"identifier","text":"MLNSymbolStyleLayer"}],"type":"topic","title":"MLNSymbolStyleLayer","abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer","isActive":true},{"type":"text","text":" is a style layer that renders icon and text labels"},{"type":"text","text":" "},{"type":"text","text":"at points or along lines on the map."}],"url":"\/documentation\/maplibre\/mlnsymbolstylelayer","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer","kind":"symbol","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOverlay":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\