doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeSource"},{"type":"text","text":"’s or"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNVectorTileSource"},{"type":"text","text":"’s polylines collectively using an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNLineStyleLayer"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNSymbolStyleLayer"},{"type":"text","text":" object. To access a polyline’s attributes, use an"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolylineFeature"},{"type":"text","text":" object."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Alternatively, you can add a polyline overlay directly to a map view using the"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/addAnnotation:","type":"reference"},{"type":"text","text":" or "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapView\/addOverlay:","type":"reference"},{"type":"text","text":" methods. Configure"},{"type":"text","text":" "},{"type":"text","text":"a polyline overlay’s appearance using"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:strokeColorForShapeAnnotation:","type":"reference"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMapViewDelegate\/mapView:lineWidthForPolylineAnnotation:","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"The vertices are automatically connected in the order in which you provide","type":"text"},{"text":" ","type":"text"},{"text":"them. The first and last vertices are not connected to each other, but you can","type":"text"},{"text":" ","type":"text"},{"text":"specify the same ","type":"text"},{"code":"CLLocationCoordinate2D","type":"codeVoice"},{"text":" as the first and last vertices in","type":"text"},{"text":" ","type":"text"},{"text":"order to close the polyline. To fill the space within the shape, use an","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNPolygon","type":"reference"},{"text":" object. To group multiple polylines together in one shape, use an","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNMultiPolyline","type":"reference"},{"text":" or ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNShapeCollection","type":"reference"},{"text":" object.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To make the polyline go across the antimeridian or international date line,"},{"type":"text","text":" "},{"type":"text","text":"specify some longitudes less than −180 degrees or greater than 180 degrees."},{"type":"text","text":" "},{"type":"text","text":"For example, a polyline that stretches from Tokyo to San Francisco would have"},{"type":"text","text":" "},{"type":"text","text":"coordinates of (35.68476, -220.24257) and (37.78428, -122.41310)."}],"type":"paragraph"},{"code":["let coordinates = [","    CLLocationCoordinate2D(latitude: 35.68476, longitude: -220.24257),","    CLLocationCoordinate2D(latitude: 37.78428, longitude: -122.41310)","]","let polyline = MLNPolyline(coordinates: coordinates, count: UInt(coordinates.count))"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"A polyline is known as a","type":"text"},{"text":" ",