{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"metadata":{"modules":[{"name":"MapLibre"}],"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"setMaximumAmbientCacheSize:withCompletionHandler:"}],"role":"symbol","title":"setMaximumAmbientCacheSize:withCompletionHandler:","symbolKind":"method","roleHeading":"Instance Method","navigatorTitle":[{"kind":"identifier","text":"setMaximumAmbientCacheSize:withCompletionHandler:"}],"externalID":"c:objc(cs)MLNOfflineStorage(im)setMaximumAmbientCacheSize:withCompletionHandler:"},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/setMaximumAmbientCacheSize:withCompletionHandler:","interfaceLanguage":"occ"},"abstract":[{"type":"text","text":"Sets the maximum ambient cache size in bytes. The default maximum cache"},{"type":"text","text":" "},{"type":"text","text":"size is 50 MB. To disable ambient caching, set the maximum ambient cache size"},{"type":"text","text":" "},{"type":"text","text":"to "},{"type":"codeVoice","code":"0"},{"type":"text","text":". Setting the maximum ambient cache size does not impact the maximum size"},{"type":"text","text":" "},{"type":"text","text":"of offline packs."}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"- ("},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"setMaximumAmbientCacheSize:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:@T@NSUInteger","kind":"typeIdentifier","text":"NSUInteger"},{"kind":"text","text":") "},{"kind":"internalParam","text":"cacheSize"},{"kind":"text","text":" "},{"kind":"identifier","text":"withCompletionHandler:"},{"kind":"text","text":"("},{"text":"void","preciseIdentif