pe":"text","text":"size has been set. This handler is executed synchronously on the main queue."}],"type":"paragraph"}],"name":"completion"}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"text":"This method does not limit the space available to offline packs, and data in","type":"text"},{"text":" ","type":"text"},{"text":"offline packs does not count towards this limit. If you set the maximum ambient","type":"text"},{"text":" ","type":"text"},{"text":"cache size to 30 MB then download 20 MB of offline packs, 30 MB will remain","type":"text"},{"text":" ","type":"text"},{"text":"available for the ambient cache.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This method should be called before the map and map style have been loaded."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This method is potentially expensive, as the database will trim cached data"},{"type":"text","text":" "},{"type":"text","text":"in order to prevent the ambient cache from being larger than the"},{"type":"text","text":" "},{"type":"text","text":"specified amount."}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinestorage\/setmaximumambientcachesize:withcompletionhandler:"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/setMaximumAmbientCacheSize:withCompletionHandler:","interfaceLanguage":"occ"},"abstract":[{"text":"Sets the maximum ambient cache size in bytes. The default maximum cache","type":"text"},{"text":" ","type":"text"},{"text":"size is 50 MB. To disable ambient caching, set the maximum ambient cache size","type":"text"},{"text":" ","type":"text"},{"text":"to ","type":"text"},{"code":"0","type":"codeVoice"},{"text":". Setting the maximum ambient cache size does not impact the maximum size","type":"text"},{"text":" ","type":"text"},{"text":"of of