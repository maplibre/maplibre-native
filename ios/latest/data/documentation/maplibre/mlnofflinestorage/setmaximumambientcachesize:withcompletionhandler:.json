e"},{"type":"text","text":" "},{"type":"text","text":"size is 50 MB. To disable ambient caching, set the maximum ambient cache size"},{"type":"text","text":" "},{"type":"text","text":"to "},{"type":"codeVoice","code":"0"},{"type":"text","text":". Setting the maximum ambient cache size does not impact the maximum size"},{"type":"text","text":" "},{"type":"text","text":"of offline packs."}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinestorage\/setmaximumambientcachesize:withcompletionhandler:"}}}