ffline packs, 30 MB will remain","type":"text"},{"text":" ","type":"text"},{"text":"available for the ambient cache.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This method should be called before the map and map style have been loaded."}],"type":"paragraph"},{"inlineContent":[{"text":"This method is potentially expensive, as the database will trim cached data","type":"text"},{"text":" ","type":"text"},{"text":"in order to prevent the ambient cache from being larger than the","type":"text"},{"text":" ","type":"text"},{"text":"specified amount.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"metadata":{"title":"setMaximumAmbientCacheSize:withCompletionHandler:","symbolKind":"method","role":"symbol","roleHeading":"Instance Method","fragments":[{"text":"- ","kind":"text"},{"text":"setMaximumAmbientCacheSize:withCompletionHandler:","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNOfflineStorage(im)setMaximumAmbientCacheSize:withCompletionHandler:","navigatorTitle":[{"text":"setMaximumAmbientCacheSize:withCompletionHandler:","kind":"identifier"}]},"abstract":[{"text":"Sets the maximum ambient cache size in bytes. The default maximum cache","type":"text"},{"text":" ","type":"text"},{"text":"size is 50 MB. To disable ambient caching, set the maximum ambient cache size","type":"text"},{"text":" ","type":"text"},{"text":"to ","type":"text"},{"code":"0","type":"codeVoice"},{"text":". Setting the maximum ambient cache size does not impact the maximum size","type":"text"},{"text":" ","type":"text"},{"text":"of offline packs.","type":"text"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinestorage\/setmaximumambientcachesize:withcompletionhandler:"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/setMaximumAmbientCacheSize:withCompletionHandler:","interfaceLan