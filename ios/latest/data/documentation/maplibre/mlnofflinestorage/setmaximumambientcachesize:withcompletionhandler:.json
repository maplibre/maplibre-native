{"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"- (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"setMaximumAmbientCacheSize:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSUInteger","kind":"typeIdentifier","preciseIdentifier":"c:@T@NSUInteger"},{"text":") ","kind":"text"},{"text":"cacheSize","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"withCompletionHandler:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":" (^)(","kind":"text"},{"text":"NSError","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSError"},{"text":" * ","kind":"text"},{"text":"error","kind":"internalParam"},{"text":")) ","kind":"text"},{"text":"completion","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"parameters":[{"name":"cacheSize","content":[{"type":"paragraph","inlineContent":[{"text":"The maximum size in bytes for the ambient cache.","type":"text"}]}]},{"name":"completion","content":[{"inlineContent":[{"text":"The completion handler to call once the maximum ambient cache","type":"text"},{"text":" ","type":"text"},{"text":"size has been set. This handler is executed synchronously on the main queue.","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"This method does not limit the space available to offline packs, and data in","type":"text"},{"text":" ","type":"text"},{"text":"offline packs does not count towards this limit. If you set the maximum ambient","type":"text"},{"text":" ","type":"text"},{"text":"cache size to 30 MB then download 20 MB of offline packs, 30 MB will remain","type":"text"},{"text":" ","type":"text"},{"text":"available for the ambient cache.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This method should be called before the map and map style have been loaded."}],"type":"paragraph"},{"inlineContent":[{"text":"This method is potentially expensive, as the database will trim cached data","type":"text"},{"text":" ","type":"text"},{"text":"in order to prevent the ambient cache from being larger than the","type":"text"},{"text":" ","type":"text"},{"text":"specified amount.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"text":"Sets the maximum ambient cache size in bytes. The default maximum cache","type":"text"},{"text":" ","type":"text"},{"text":"size is 50 MB. To disable ambient caching, set the maximum ambient cache size","type":"text"},{"text":" ","type":"text"},{"text":"to ","type":"text"},{"code":"0","type":"codeVoice"},{"text":". Setting the maximum ambient cache size does not impact the maximum size","type":"text"},{"text":" ","type":"text"},{"text":"of offline packs.","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"modules":[{"name":"MapLibre"}],"title":"setMaximumAmbientCacheSize:withCompletionHandler:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"setMaximumAmbientCacheSize:withCompletionHandler:"}],"externalID":"c:objc(cs)MLNOfflineStorage(im)setMaximumAmbientCacheSize:withCompletionHandler:","symbolKind":"method","navigatorTitle":[{"kind":"identifier","text":"setMaximumAmbientCacheSize:withCompletionHandler:"}],"role":"symbol","roleHeading":"Instance Method"},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/setMaximumAmbientCacheSize:withCompletionHandler:","interfaceLanguage":"occ"},"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinestorage\/setmaximumambientcachesize:withcompletionhandler:"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/setMaximumAmbientCacheSize:withCompletionHandler:":{"abstract":[{"text":"Sets the maximum ambient cache size in bytes. The default maximum cache","type":"text"},{"text":" ","type":"text"},{"text":"size is 50 MB. To disable ambient caching, set the maximum ambient cache size","type":"text"},{"text":" ","type":"text"},{"text":"to ","type":"text"},{"type":"codeVoice","code":"0"},{"text":". Setting the maximum ambient cache size does not impact the maximum size","type":"text"},{"text":" ","type":"text"},{"text":"of offline packs.","type":"text"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinestorage\/setmaximumambientcachesize:withcompletionhandler:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"setMaximumAmbientCacheSize:withCompletionHandler:"}],"title":"setMaximumAmbientCacheSize:withCompletionHandler:","type":"topic","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/setMaximumAmbientCacheSize:withCompletionHandler:","navigatorTitle":[{"kind":"identifier","text":"setMaximumAmbientCacheSize:withCompletionHandler:"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"abstract":[{"text":"MLNOfflineStorage implements a singleton (shared object) that manages offline","type":"text"},{"text":" ","type":"text"},{"text":"packs and ambient caching. All of this class’s instance methods are asynchronous,","type":"text"},{"text":" ","type":"text"},{"text":"reflecting the fact that offline resources are stored in a database. The shared","type":"text"},{"text":" ","type":"text"},{"text":"object maintains a canonical collection of offline packs in its ","type":"text"},{"code":"packs","type":"codeVoice"},{"text":" property.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","url":"\/documentation\/maplibre\/mlno