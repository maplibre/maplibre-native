esource being"},{"type":"text","text":" "},{"type":"text","text":"downloaded or because the pack discovers during the download that more"},{"type":"text","text":" "},{"type":"text","text":"resources are required for offline viewing. This notification is posted"},{"type":"text","text":" "},{"type":"text","text":"whenever any field in the "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" property changes."}],"role":"symbol","kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification","fragments":[{"text":"MLNOfflinePackProgressChangedNotification","kind":"identifier"}],"title":"MLNOfflinePackProgressChangedNotification","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification"}}}