cation","isActive":true},{"type":"text","text":"s about that pack."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To detect when any call to this method results in a new pack, observe KVO"},{"type":"text","text":" "},{"type":"text","text":"change notifications on the shared offline storage object’s "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" key path."},{"type":"text","text":" "},{"type":"text","text":"Additions to that array result in an "},{"type":"codeVoice","code":"NSKeyValueChangeInsertion"},{"type":"text","text":" change."}],"type":"paragraph"}],"kind":"content"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/addPackForRegion:withContext:completionHandler:"},"sections":[],"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinestorage\/addpackforregion:withcontext:completionhandler:"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"symbol","abstract":[{"text":"Creates and registers an offline pack that downloads the resources needed to","type":"text"},{"text":" ","type":"text"},{"text":"use the given region offline.","type":"text"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/addPackForRegion:withContext:completionHandler:":{"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/addPackForRegion:withContext:completionHandler:","fragments":[{"text":"- ","kind":"text"},{"text":"addPackForRegion:withContext:completionHandler:","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnofflinestorage\/addpackforregion:withcontext:completionhandler:","type":"topic","title":"addPackForRegion:withContext:completionHandler:","kind":"symbol","abstract":[{"type":"text","text":"Creates and registers an offline pack that downloads the resources needed to"},{"type":"text","text":" "},{"type":"text","text":"use the given region offline."}]},"doc://org.swift.MyProject/documenta