 the pack from within"},{"type":"text","text":" "},{"type":"text","text":"the completion handler. To monitor download progress, add an observer for"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","isActive":true},{"type":"text","text":"s about that pack."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To detect when any call to this method results in a new pack, observe KVO"},{"type":"text","text":" "},{"type":"text","text":"change notifications on the shared offline storage object’s "},{"code":"packs","type":"codeVoice"},{"type":"text","text":" key path."},{"type":"text","text":" "},{"type":"text","text":"Additions to that array result in an "},{"code":"NSKeyValueChangeInsertion","type":"codeVoice"},{"type":"text","text":" change."}],"type":"paragraph"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"url":"\/documentation\/maplibre\/mlnofflinepack","role":"symbol","type":"topic","title":"MLNOfflinePack","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","kind":"symbol","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","type":"reference","isActive":true},{"type":"text","text":" represents a collection of resources necessary for viewing"},{"type":"text","text":" "},{"type":"text","text":"a region offline to a local database."}],"fragments":[{"kind":"identifier","text":"MLNOfflinePack"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackProgressChangedNotification":{"type":"topic","kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinepackprogresschangednotification","title":"MLNOfflinePackProgressChangedNotification","fragments":[{"kind":"identifier","text":"MLNOfflinePackProgressChangedNotification"}],"abstract":[{"type":"text","text":"Posted by the shared "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","type":"reference","isActive":true},{"type":"text","text":" object when an "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"object’s progress changes. The progress may change due to a resource being"},{"type":"text","text":" "},{"type":"text","text":"downloaded or because the pack discovers during the download that more"},{"type":"text","text":" "},{"type":"text","text":"resources are required for offline viewing. This notification is posted"},{"type":"text","text":" "},{"type":"text","text":"whenever any field in the "},{"type":"codeVoice","code":"progress"},{"type":"text","text":" property changes."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackProgressChangedNotification","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/addPackForRegion:withContext:completionHandler:":{"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"addPackForRegion:withContext:completionHandler:"}],"title":"addPackForRegion:withContext:completionHandler:","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/addPackForRegion:withContext:completionHandler:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"addPackForRegion:withContext:completionHandler:"}],"abstract":[{"type":"text","text":"Creates and registers an offline pack that downloads the resources needed to"},{"type":"text","text":" "},{"type":"text","text":"use the given region offline."}],"url":"\/documentation\/maplibre\/mlnofflinestorage\/addpackforregion:withcontext:completionhandler:","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackAdditionCompletionHandler":{"title":"MLNOfflinePackAdditionCompletionHandler","fragments":[{"kind":"identifier","text":"MLNO