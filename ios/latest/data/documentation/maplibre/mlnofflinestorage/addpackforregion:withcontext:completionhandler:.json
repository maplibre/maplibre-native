{"kind":"symbol","abstract":[{"type":"text","text":"Creates and registers an offline pack that downloads the resources needed to"},{"type":"text","text":" "},{"type":"text","text":"use the given region offline."}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"- (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"addPackForRegion:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"id<MLNOfflineRegion>","kind":"typeIdentifier","preciseIdentifier":"c:Qoobjc(pl)MLNOfflineRegion"},{"text":") ","kind":"text"},{"text":"region","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"withContext:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSData","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSData"},{"text":" *) ","kind":"text"},{"text":"context","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"completionHandler:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"MLNOfflinePackAdditionCompletionHandler","kind":"typeIdentifier","preciseIdentifier":"c:MLNOfflineStorage.h@T@MLNOfflinePackAdditionCompletionHandler","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackAdditionCompletionHandler"},{"text":") ","kind":"text"},{"text":"completion","kind":"internalParam"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"parameters":[{"content":[{"inlineContent":[{"type":"text","text":"A region to download."}],"type":"paragraph"}],"name":"region"},{"content":[{"inlineContent":[{"text":"Arbitrary data to store alongside the downloaded resources.","type":"text"}],"type":"paragraph"}],"name":"context"},{"content":[{"inlineContent":[{"text":"The completion handler to call once the pack has been added.","type":"text"},{"text":"