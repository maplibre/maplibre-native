nt":[{"type":"text","text":"A string representation of the file path. The file path must be"},{"type":"text","text":" "},{"type":"text","text":"writable as schema updates may be perfomed."}],"type":"paragraph"}]},{"name":"completion","content":[{"type":"paragraph","inlineContent":[{"text":"The completion handler to call once the contents of the given","type":"text"},{"text":" ","type":"text"},{"text":"file has been added to offline storage. This handler is executed","type":"text"},{"text":" ","type":"text"},{"text":"asynchronously on the main queue.","type":"text"}]}]}],"kind":"parameters"},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"text":"The file must be a valid offline pack database bundled with the application or","type":"text"},{"text":" ","type":"text"},{"text":"downloaded separately.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The resulting packs are added or updated to the shared offline storage object’s"},{"type":"text","text":" "},{"code":"packs","type":"codeVoice"},{"type":"text","text":" property, then the "},{"code":"completion","type":"codeVoice"},{"type":"text","text":" block is executed."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","type":"topic","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","url":"\/documentation\/maplibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/addContentsOfFile:withCompletionHandler:":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/addContentsOfFil