ates may be perfomed."}]}],"name":"filePath"},{"content":[{"inlineContent":[{"type":"text","text":"The completion handler to call once the contents of the given"},{"type":"text","text":" "},{"type":"text","text":"file has been added to offline storage. This handler is executed"},{"type":"text","text":" "},{"type":"text","text":"asynchronously on the main queue."}],"type":"paragraph"}],"name":"completion"}],"kind":"parameters"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"The file must be a valid offline pack database bundled with the application or"},{"type":"text","text":" "},{"type":"text","text":"downloaded separately."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The resulting packs are added or updated to the shared offline storage object’s"},{"type":"text","text":" "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property, then the "},{"type":"codeVoice","code":"completion"},{"type":"text","text":" block is executed."}],"type":"paragraph"}],"kind":"content"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinestorage\/addcontentsoffile:withcompletionhandler:"]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"title":"MapLibre","kind":"symbol","type":"topic","url":"\/documentation\/maplibre","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNBatchedOfflinePackAdditionCompletionHandler":{"url":"\/documentation\/maplibre\/mlnbatchedofflinepackadditioncompletionhandler","identifier":"doc:\/\/org.swift.M