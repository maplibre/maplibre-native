xt","text":" "},{"type":"text","text":"reflecting the fact that offline resources are stored in a database. The shared"},{"type":"text","text":" "},{"type":"text","text":"object maintains a canonical collection of offline packs in its "},{"type":"codeVoice","code":"packs"},{"text":" property.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"},"doc://org.swift.MyProject/documentation/MapLibre/MLNBatchedOfflinePackAdditionCompletionHandler":{"title":"MLNBatchedOfflinePackAdditionCompletionHandler","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNBatchedOfflinePackAdditionCompletionHandler","fragments":[{"text":"MLNBatchedOfflinePackAdditionCompletionHandler","kind":"identifier"}],"type":"topic","abstract":[{"type":"text","text":"A block to be called once the contents of a file are copied into the current packs."}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnbatchedofflinepackadditioncompletionhandler","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/addContentsOfFile:withCompletionHandler:":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/addContentsOfFile:withCompletionHandler:","role":"symbol","title":"addContentsOfFile:withCompletionHandler:","kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinestorage\/addcontentsoffile:withcompletionhandler:","abstract":[{"text":"Adds the offline packs located at the given file path to offline storage.","type":"text"}],"type":"topic","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"addContentsOfFile:withCompletionHandler:"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol","url":"\/documentation\/maplibre","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and