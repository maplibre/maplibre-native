id offline pack database bundled with the application or","type":"text"},{"text":" ","type":"text"},{"text":"downloaded separately.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The resulting packs are added or updated to the shared offline storage object’s"},{"type":"text","text":" "},{"code":"packs","type":"codeVoice"},{"type":"text","text":" property, then the "},{"code":"completion","type":"codeVoice"},{"type":"text","text":" block is executed."}],"type":"paragraph"}]}],"kind":"symbol","metadata":{"role":"symbol","roleHeading":"Instance Method","externalID":"c:objc(cs)MLNOfflineStorage(im)addContentsOfFile:withCompletionHandler:","fragments":[{"text":"- ","kind":"text"},{"text":"addContentsOfFile:withCompletionHandler:","kind":"identifier"}],"symbolKind":"method","navigatorTitle":[{"kind":"identifier","text":"addContentsOfFile:withCompletionHandler:"}],"modules":[{"name":"MapLibre"}],"title":"addContentsOfFile:withCompletionHandler:"},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/addContentsOfFile:withCompletionHandler:"},"abstract":[{"type":"text","text":"Adds the offline packs located at the given file path to offline storage."}],"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinestorage\/addcontentsoffile:withcompletionhandler:"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/addContentsOfFile:withCompletionHandler:":{"url":"\/documentation\/maplibre\/mlnofflinestorage\/addcontentsoffile:withcompletionhandler:","fragments":[{"text":"- ","kind":"text"},{"text":"addContentsOfFile:withCompletionHandler:","kind":"identifier"}],"type":"topic","navigatorTitle":[{"text":"addContentsOfFile:withCompletionHandler:","kind":"identifier"}],"abstract":[{"text":"Adds the offline packs located at the given file path to offline storage.","type":"text"}],"kind":"symbol","identifier":"doc:\