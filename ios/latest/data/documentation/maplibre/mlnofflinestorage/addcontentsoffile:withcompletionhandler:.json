ragraph","inlineContent":[{"text":"A string representation of the file path. The file path must be","type":"text"},{"text":" ","type":"text"},{"text":"writable as schema updates may be perfomed.","type":"text"}]}],"name":"filePath"},{"content":[{"inlineContent":[{"type":"text","text":"The completion handler to call once the contents of the given"},{"type":"text","text":" "},{"type":"text","text":"file has been added to offline storage. This handler is executed"},{"type":"text","text":" "},{"type":"text","text":"asynchronously on the main queue."}],"type":"paragraph"}],"name":"completion"}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"The file must be a valid offline pack database bundled with the application or","type":"text"},{"text":" ","type":"text"},{"text":"downloaded separately.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The resulting packs are added or updated to the shared offline storage object’s"},{"type":"text","text":" "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property, then the "},{"type":"codeVoice","code":"completion"},{"type":"text","text":" block is executed."}]}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"url":"\/documentation\/maplibre","role":"collection","title":"MapLibre","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNBatchedOfflinePackAdditionCompletionHandler":{"type":"topic","role":"symbol","kind":"symbol","url":"\/documentation\/maplibre\/mlnbatchedofflinepackadditioncompl