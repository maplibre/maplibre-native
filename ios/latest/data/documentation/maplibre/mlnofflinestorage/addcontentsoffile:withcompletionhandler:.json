ages offline"},{"type":"text","text":" "},{"type":"text","text":"packs and ambient caching. All of this class’s instance methods are asynchronous,"},{"type":"text","text":" "},{"type":"text","text":"reflecting the fact that offline resources are stored in a database. The shared"},{"type":"text","text":" "},{"type":"text","text":"object maintains a canonical collection of offline packs in its "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","fragments":[{"kind":"identifier","text":"MLNOfflineStorage"}],"url":"\/documentation\/maplibre\/mlnofflinestorage","type":"topic","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/addContentsOfFile:withCompletionHandler:":{"type":"topic","abstract":[{"type":"text","text":"Adds the offline packs located at the given file path to offline storage."}],"url":"\/documentation\/maplibre\/mlnofflinestorage\/addcontentsoffile:withcompletionhandler:","role":"symbol","navigatorTitle":[{"text":"addContentsOfFile:withCompletionHandler:","kind":"identifier"}],"kind":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"addContentsOfFile:withCompletionHandler:","kind":"identifier"}],"title":"addContentsOfFile:withCompletionHandler:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/addContentsOfFile:withCompletionHandler:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNBatchedOfflinePackAdditionCompletionHandler":{"title":"MLNBatchedOfflinePackAdditionCompletionHandler","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNBatchedOfflinePackAdditionCompletionHandler","abstract":[{"type":"text","text":"A block to be called once the contents of a file are copied into the current packs."}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnbatchedofflinepackadditioncompletionhandler","role":"symbol","type":"topic","fragments":[{"text"