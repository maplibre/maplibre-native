":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"A string representation of the file path. The file path must be","type":"text"},{"text":" ","type":"text"},{"text":"writable as schema updates may be perfomed.","type":"text"}],"type":"paragraph"}],"name":"filePath"},{"content":[{"inlineContent":[{"type":"text","text":"The completion handler to call once the contents of the given"},{"type":"text","text":" "},{"type":"text","text":"file has been added to offline storage. This handler is executed"},{"type":"text","text":" "},{"type":"text","text":"asynchronously on the main queue."}],"type":"paragraph"}],"name":"completion"}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The file must be a valid offline pack database bundled with the application or"},{"type":"text","text":" "},{"type":"text","text":"downloaded separately."}]},{"type":"paragraph","inlineContent":[{"text":"The resulting packs are added or updated to the shared offline storage object’s","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"packs"},{"text":" property, then the ","type":"text"},{"code":"completion","type":"codeVoice"},{"text":" block is executed.","type":"text"}]}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/addContentsOfFile:withCompletionHandler:":{"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/addContentsOfFile:withCompletionHandler:","abstract":[{"type":"text","text":"Adds the offline packs located at the given file path to offline storage."}],"fragments":[{"text":"- ","kind":"text"},{"text":"addContentsOfFile:withCompletionHandler:","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnof