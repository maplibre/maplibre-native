orage.","type":"text"}],"fragments":[{"text":"- ","kind":"text"},{"text":"addContentsOfFile:withCompletionHandler:","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","url":"\/documentation\/maplibre","kind":"symbol","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"url":"\/documentation\/maplibre\/mlnofflinestorage","role":"symbol","fragments":[{"text":"MLNOfflineStorage","kind":"identifier"}],"title":"MLNOfflineStorage","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","kind":"symbol","abstract":[{"text":"MLNOfflineStorage implements a singleton (shared object) that manages offline","type":"text"},{"text":" ","type":"text"},{"text":"packs and ambient caching. All of this class’s instance methods are asynchronous,","type":"text"},{"text":" ","type":"text"},{"text":"reflecting the fact that offline resources are stored in a database. The shared","type":"text"},{"text":" ","type":"text"},{"text":"object maintains a canonical collection of offline packs in its ","type":"text"},{"type":"codeVoice","code":"packs"},{"text":" property.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNBatchedOfflinePackAdditionCompletionHandler":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNBatchedOfflinePackAdditionCompletionHandler","title":"MLNBatchedOfflinePackAdditionCompletionHandler","url":"\/documentation\/maplibre\/mlnbatchedofflinepackadditioncompletionhandler","kind":"symbol","type":"topic","role":"symbol","abstract":[{"text":"A block to be called once the contents of a file are copied into the current packs.","type":"text"}],"fragments":[{"text":"MLNBatchedOfflinePackAdditionCompleti