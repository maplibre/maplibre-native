":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"A string representation of the file path. The file path must be"},{"type":"text","text":" "},{"type":"text","text":"writable as schema updates may be perfomed."}],"type":"paragraph"}],"name":"filePath"},{"content":[{"inlineContent":[{"type":"text","text":"The completion handler to call once the contents of the given"},{"type":"text","text":" "},{"type":"text","text":"file has been added to offline storage. This handler is executed"},{"type":"text","text":" "},{"type":"text","text":"asynchronously on the main queue."}],"type":"paragraph"}],"name":"completion"}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"The file must be a valid offline pack database bundled with the application or","type":"text"},{"text":" ","type":"text"},{"text":"downloaded separately.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The resulting packs are added or updated to the shared offline storage object’s","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"packs"},{"text":" property, then the ","type":"text"},{"type":"codeVoice","code":"completion"},{"text":" block is executed.","type":"text"}]}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"fragments":[{"kind":"identifier","text":"MLNOfflineStorage"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","title":"MLNOfflineStorage","abstract":[{"type":"text","text":"MLNOfflineStorage implements a singleton (shared object) that manages offline"},{"type":"text","text":" "},{"type":"text","text":"packs and ambient caching. All of this class’s instance methods are asynchronous,"},{"type":"text","text":" "},{"type":"text","text":"reflecting the fact that offline resources are stored in a database. The shared"},{"type":"text","text":" "},{"type":"text","text":"object maintains a canonical collection of offline packs in its "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property."}],"url":"\/documentation\/maplibre\/mlnofflinestorage","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNBatchedOfflinePackAdditionCompletionHandler":{"type":"topic","abstract":[{"type":"text","text":"A block to be called once the contents of a file are copied into the current packs."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNBatchedOfflinePackAdditionCompletionHandler","role":"symbol","kind":"symbol","url":"\/documentation\/maplibre\/mlnbatchedofflinepackadditioncompletionhandler","title":"MLNBatchedOfflinePackAdditionCompletionHandler","fragments":[{"kind":"identifier","text":"MLNBatchedOfflinePackAdditionCompletionHandler"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/addContentsOfFile:withCompletionHandler:":{"type":"topic","abstract":[{"type":"text","text":"Adds the offline packs located at the given file path to offline storage."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/addContentsOfFile:withCompletionHandler:","role":"symbol","kind":"symbol","title":"addContentsOfFile:withCompletionHandler:","url":"\/documentation\/maplibre\/mlnofflinestorage\/addcontentsoffile:withcompletionhandler:","fragments":[{"text":"- ","kind":"text"},{"text":"addContentsOfFile:withCompletionHandler:","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","url":"\/documentation\/maplibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data source