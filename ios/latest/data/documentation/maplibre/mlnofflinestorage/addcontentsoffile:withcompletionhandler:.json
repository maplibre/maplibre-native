"text":"completion","kind":"internalParam"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"parameters":[{"name":"filePath","content":[{"inlineContent":[{"text":"A string representation of the file path. The file path must be","type":"text"},{"text":" ","type":"text"},{"text":"writable as schema updates may be perfomed.","type":"text"}],"type":"paragraph"}]},{"name":"completion","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The completion handler to call once the contents of the given"},{"type":"text","text":" "},{"type":"text","text":"file has been added to offline storage. This handler is executed"},{"type":"text","text":" "},{"type":"text","text":"asynchronously on the main queue."}]}]}],"kind":"parameters"},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The file must be a valid offline pack database bundled with the application or"},{"type":"text","text":" "},{"type":"text","text":"downloaded separately."}]},{"type":"paragraph","inlineContent":[{"text":"The resulting packs are added or updated to the shared offline storage object’s","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"packs"},{"text":" property, then the ","type":"text"},{"type":"codeVoice","code":"completion"},{"text":" block is executed.","type":"text"}]}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/addContentsOfFile:withCompletionHandler:":{"fragments":[{"text":"- ","kind":"text"},{"text":"addContentsOfFile:withCompletionHandler:","kind":"identifier"}],"navigatorTitle":[{"text":"addContentsOfFile:withCompletionHandler:","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/addContentsOfFile:withCompletionHandler:","kind":"symbol","abstract":[{"text":"Adds the offline packs located at the given file path to offline storage.","type":"text"}],