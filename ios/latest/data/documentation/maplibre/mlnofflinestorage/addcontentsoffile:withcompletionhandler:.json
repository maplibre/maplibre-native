"text":"completion","kind":"internalParam"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"parameters":[{"name":"filePath","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A string representation of the file path. The file path must be"},{"type":"text","text":" "},{"type":"text","text":"writable as schema updates may be perfomed."}]}]},{"name":"completion","content":[{"type":"paragraph","inlineContent":[{"text":"The completion handler to call once the contents of the given","type":"text"},{"text":" ","type":"text"},{"text":"file has been added to offline storage. This handler is executed","type":"text"},{"text":" ","type":"text"},{"text":"asynchronously on the main queue.","type":"text"}]}]}],"kind":"parameters"},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"The file must be a valid offline pack database bundled with the application or","type":"text"},{"text":" ","type":"text"},{"text":"downloaded separately.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The resulting packs are added or updated to the shared offline storage object’s"},{"type":"text","text":" "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property, then the "},{"type":"codeVoice","code":"completion"},{"type":"text","text":" block is executed."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","kind":"symbol","url":"\/documentation\/maplibre","type":"topic","title":"MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNBatchedOfflinePackAdditionCompletionHandler":{"role":"symbol","title":"MLNBatchedOfflinePackAdditionCompletionHandler","identifier":"doc:\/\/org.swift.MyProject\