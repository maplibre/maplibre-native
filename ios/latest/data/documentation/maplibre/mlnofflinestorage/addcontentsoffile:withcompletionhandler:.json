The completion handler to call once the contents of the given","type":"text"},{"text":" ","type":"text"},{"text":"file has been added to offline storage. This handler is executed","type":"text"},{"text":" ","type":"text"},{"text":"asynchronously on the main queue.","type":"text"}]}],"name":"completion"}]},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"The file must be a valid offline pack database bundled with the application or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"downloaded separately."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The resulting packs are added or updated to the shared offline storage object’s"},{"type":"text","text":" "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property, then the "},{"type":"codeVoice","code":"completion"},{"type":"text","text":" block is executed."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"Adds the offline packs located at the given file path to offline storage."}],"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinestorage\/addcontentsoffile:withcompletionhandler:"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/addContentsOfFile:withCompletionHandler:":{"fragments":[{"text":"- ","kind":"text"},{"text":"addContentsOfFile:withCompletionHandler:","kind":"identifier"}],"title":"addContentsOfFile:withCompletionHandler:","url":"\/documentation\/maplibre\/mlnofflinestorage\/addcontentsoffile:withcompletionhandler:","abstract":[{"text":"Adds the offline packs located at the given file path to offline storage.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProj