ared","type":"text"},{"text":" ","type":"text"},{"text":"object maintains a canonical collection of offline packs in its ","type":"text"},{"code":"packs","type":"codeVoice"},{"text":" property.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","type":"topic","kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlnofflinestorage"},"doc://org.swift.MyProject/documentation/MapLibre/MLNBatchedOfflinePackAdditionCompletionHandler":{"title":"MLNBatchedOfflinePackAdditionCompletionHandler","fragments":[{"text":"MLNBatchedOfflinePackAdditionCompletionHandler","kind":"identifier"}],"abstract":[{"text":"A block to be called once the contents of a file are copied into the current packs.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNBatchedOfflinePackAdditionCompletionHandler","type":"topic","kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlnbatchedofflinepackadditioncompletionhandler"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/addContentsOfFile:withCompletionHandler:":{"role":"symbol","fragments":[{"text":"- ","kind":"text"},{"text":"addContentsOfFile:withCompletionHandler:","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/addContentsOfFile:withCompletionHandler:","url":"\/documentation\/maplibre\/mlnofflinestorage\/addcontentsoffile:withcompletionhandler:","abstract":[{"type":"text","text":"Adds the offline packs located at the given file path to offline storage."}],"title":"addContentsOfFile:withCompletionHandler:","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","kind":"symbol","type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sourc