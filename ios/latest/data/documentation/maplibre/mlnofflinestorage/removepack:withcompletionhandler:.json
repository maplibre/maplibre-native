{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"metadata":{"navigatorTitle":[{"kind":"identifier","text":"removePack:withCompletionHandler:"}],"symbolKind":"method","roleHeading":"Instance Method","externalID":"c:objc(cs)MLNOfflineStorage(im)removePack:withCompletionHandler:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"removePack:withCompletionHandler:"}],"modules":[{"name":"MapLibre"}],"title":"removePack:withCompletionHandler:","role":"symbol"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinestorage\/removepack:withcompletionhandler:"]}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"- ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"removePack:"},{"kind":"text","text":"("},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)MLNOfflinePack","text":"MLNOfflinePack"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"pack"},{"kind":"text","text":" "},{"kind":"identifier","text":"withCompletionHandler:"},{"kind":"text","text":"("},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackRemovalCompletionHandler","kind":"typeIdentifier","preciseIdentifier":"c:MLNOfflineStorage.h@T@MLNOfflinePackRemovalCompletionHandler","text":"MLNOfflinePackRemovalCompletionHandler"},{"kind":"text","text":") "},{"kind":"internalParam","text":"completion"},{"kind":"text","text":";"}]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The offline pack to remove."}],"type":"paragraph"}],"name":"pack"},{"name":"completion","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The completion handler to call once the pack has been"},{"type":"text","text":" "},{"type":"text","text":"removed. This handler is executed asynchronously on the main queue."}]}]}]},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"As soon as this method is called on a pack, the pack becomes invalid; any","type":"text"},{"text":" ","type":"text"},{"text":"attempt to send it a message will result in an exception being thrown. If an","type":"text"},{"text":" ","type":"text"},{"text":"error occurs and the pack cannot be removed, do not attempt to reuse the pack","type":"text"},{"text":" ","type":"text"},{"text":"object. Instead, if you need continued access to the pack, suspend all packs","type":"text"},{"text":" ","type":"text"},{"text":"and use the ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/reloadPacks","isActive":true},{"type":"text","text":" method to obtain valid pointers to all the packs."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To detect when any call to this method results in a pack being removed, observe"},{"type":"text","text":" "},{"type":"text","text":"KVO change notifications on the shared offline storage object’s "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" key"},{"type":"text","text":" "},{"type":"text","text":"path. Removals from that array result in an "},{"type":"codeVoice","code":"NSKeyValueChangeRemoval"},{"type":"text","text":" change."}]},{"type":"paragraph","inlineContent":[{"text":"When you remove an offline pack, any resources that are required by that pack,","type":"text"},{"text":" ","type":"text"},{"text":"but not other packs, become eligible for deletion from offline storage. Because","type":"text"},{"text":" ","type":"text"},{"text":"the backing store used for offline storage is also used as a general purpose","type":"text"},{"text":" ","type":"text"},{"text":"cache for map resources, such resources may not be immediately removed if the","type":"text"},{"text":" ","type":"text"},{"text":"implementation determines that they remain useful for general performance of","type":"text"},{"text":" ","type":"text"},{"text":"the map.","type":"text"}]}],"kind":"content"}],"sections":[],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/removePack:withCompletionHandler:","interfaceLanguage":"occ"},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"Unregisters the given offline pack and allows resources that are no longer"},{"type":"text","text":" "},{"type":"text","text":"required by any remaining packs to be potentially freed."}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/removePack:withCompletionHandler:":{"title":"removePack:withCompletionHandler:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"removePack:withCompletionHandler:"}],"type":"topic","kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinestorage\/removepack:withcompletionhandler:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/removePack:withCompletionHandler:","navigatorTitle":[{"kind":"identifier","text":"removePack:withCompletionHandler:"}],"role":"symbol","abstract":[{"type":"text","text":"Unregisters the given offline pack and allows resources that are no longer"},{"type":"text","text":" "},{"type":"text","text":"required by any remaining packs to be potentially freed."}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/reloadPacks":{"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Forcibly, asynchronously reloads the "},{"code":"packs","type":"codeVoice"},{"type":"text","text":" property. At some point after this"},{"type":"text","text":" "},{"type":"text","text":"method is called, the pointer values of the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true,"type":"reference"},{"type":"text","text":" objects in the"},{"type":"text","text":" "},{"code":"packs","type":"codeVoice"},{"type":"text","text":" property change, even if the underlying data for these packs has not"},{"type":"text","text":" "},{"type":"text","text":"changed. If this method is called while a pack is actively downloading, the"},{"type":"text","text":" "},{"type":"text","text":"behavior is undefined."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/reloadPacks","url":"\/documentation\/maplibre\/mlnofflinestorage\/reloadpacks","title":"reloadPacks","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"reloadPacks"}],"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"reloadPacks"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"abstract":[{"text":"MLNOfflineStorage implements a singleton (shared object) that manages offline","type":"text"},{"text":" ","type":"text"},{"text":"packs and ambient caching. All of this class’s instance methods are asynchronous,","type":"text"},{"text":" ","type":"text"},{"text":"reflecting the fact that offline resources are stored in a database. The shared","type":"text"},{"text":" ","type":"text"},{"text":"object maintains a canonical collection of offline packs in its ","type":"text"},{"code":"packs","type":"codeVoice"},{"text":" property.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","url":"\/documentation\/maplibre\/mlnofflinestorage","role":"symbol","title":"MLNOfflineStorage","type":"topic","fragments":[{"text":"MLNOfflineStorage","kind":"identifier"}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"url":"\/documentation\/maplibre\/mlnofflinepack","role":"symbol","type":"topic","title":"MLNOfflinePack","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","kind":"symbol","abstract":[{"type":"text","text":"An "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","type":"reference","isActive":true},{"type":"text","text":" represents a collection of resources necessary for viewing"},{"type":"text","text":" "},{"type":"text","text":"a region offline to a local database."}],"fragments":[{"kind":"identifier","text":"MLNOfflinePack"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","kind":"symbol","type":"topic","title":"MapLibre","url":"\/documentation\/maplibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackRemovalCompletionHandler":{"title":"MLNOfflinePackRemovalCompletionHandler","abstract":[{"type":"text","text":"A block to be called once an offline pack has been completely invalidated and"},{"type":"text","text":" "},{"type":"text","text":"removed."}],"kind":"symbol","type":"topic","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackRemovalCompletionHandler","fragments":[{"kind":"identifier","text":"MLNOfflinePackRemovalCompletionHandler"}],"url":"\/documentation\/maplibre\/mlnofflinepackremovalcompletionhandler"}}}