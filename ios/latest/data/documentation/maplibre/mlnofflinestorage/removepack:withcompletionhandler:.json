{"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinestorage\/removepack:withcompletionhandler:"]}],"kind":"symbol","sections":[],"abstract":[{"text":"Unregisters the given offline pack and allows resources that are no longer","type":"text"},{"text":" ","type":"text"},{"text":"required by any remaining packs to be potentially freed.","type":"text"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/removePack:withCompletionHandler:"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"primaryContentSections":[{"declarations":[{"languages":["occ"],"tokens":[{"text":"- (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"removePack:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)MLNOfflinePack","text":"MLNOfflinePack","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"pack","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"withCompletionHandler:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"MLNOfflinePackRemovalCompletionHandler","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackRemovalCompletionHandler","kind":"typeIdentifier","preciseIdentifier":"c:MLNOfflineStorage.h@T@MLNOfflinePackRemovalCompletionHandler"},{"text":") ","kind":"text"},{"text":"completion","kind":"internalParam"},{"text":";","kind":"text"}],"platforms":["iOS"]}],"kind":"declarations"},{"parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The offline pack to remove."}],"type":"paragraph"}],"name":"pack"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The completion handler to call once the pack has been"},{"type":"text","text":" "},{"type":"text","text":"removed. This handler is executed asynchronously on the main queue."}]}],"name":"completion"}],"kind":"parameters"},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"text":"As soon as this method is called on a pack, the pack becomes invalid; any","type":"text"},{"text":" ","type":"text"},{"text":"attempt to send it a message will result in an exception being thrown. If an","type":"text"},{"text":" ","type":"text"},{"text":"error occurs and the pack cannot be removed, do not attempt to reuse the pack","type":"text"},{"text":" ","type":"text"},{"text":"object. Instead, if you need continued access to the pack, suspend all packs","type":"text"},{"text":" ","type":"text"},{"text":"and use the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/reloadPacks"},{"text":" method to obtain valid pointers to all the packs.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To detect when any call to this method results in a pack being removed, observe"},{"type":"text","text":" "},{"type":"text","text":"KVO change notifications on the shared offline storage object’s "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" key"},{"type":"text","text":" "},{"type":"text","text":"path. Removals from that array result in an "},{"type":"codeVoice","code":"NSKeyValueChangeRemoval"},{"type":"text","text":" change."}],"type":"paragraph"},{"inlineContent":[{"text":"When you remove an offline pack, any resources that are required by that pack,","type":"text"},{"text":" ","type":"text"},{"text":"but not other packs, become eligible for deletion from offline storage. Because","type":"text"},{"text":" ","type":"text"},{"text":"the backing store used for offline storage is also used as a general purpose","type":"text"},{"text":" ","type":"text"},{"text":"cache for map resources, such resources may not be immediately removed if the","type":"text"},{"text":" ","type":"text"},{"text":"implementation determines that they remain useful for general performance of","type":"text"},{"text":" ","type":"text"},{"text":"the map.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"metadata":{"externalID":"c:objc(cs)MLNOfflineStorage(im)removePack:withCompletionHandler:","navigatorTitle":[{"text":"removePack:withCompletionHandler:","kind":"identifier"}],"role":"symbol","title":"removePack:withCompletionHandler:","symbolKind":"method","fragments":[{"text":"- ","kind":"text"},{"text":"removePack:withCompletionHandler:","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"roleHeading":"Instance Method"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"type":"topic","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","url":"\/documentation\/maplibre\/mlnofflinestorage","title":"MLNOfflineStorage","abstract":[{"type":"text","text":"MLNOfflineStorage implements a singleton (shared object) that manages offline"},{"type":"text","text":" "},{"type":"text","text":"packs and ambient caching. All of this class’s instance methods are asynchronous,"},{"type":"text","text":" "},{"type":"text","text":"reflecting the fact that offline resources are stored in a database. The shared"},{"type":"text","text":" "},{"type":"text","text":"object maintains a canonical collection of offline packs in its "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property."}],"role":"symbol","fragments":[{"text":"MLNOfflineStorage","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/removePack:withCompletionHandler:":{"navigatorTitle":[{"text":"removePack:withCompletionHandler:","kind":"identifier"}],"fragments":[{"text":"- ","kind":"text"},{"text":"removePack:withCompletionHandler:","kind":"identifier"}],"abstract":[{"text":"Unregisters the given offline pack and allows resources that are no longer","type":"text"},{"text":" ","type":"text"},{"text":"required by any remaining packs to be potentially freed.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/removePack:withCompletionHandler:","title":"removePack:withCompletionHandler:","kind":"symbol","role":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnofflinestorage\/removepack:withcompletionhandler:"},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","type":"topic","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"kind":"symbol","title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"fragments":[{"text":"MLNOfflinePack","kind":"identifier"}],"abstract":[{"text":"An ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","type":"reference"},{"text":" represents a collection of resources necessary for viewing","type":"text"},{"text":" ","type":"text"},{"text":"a region offline to a local database.","type":"text"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","title":"MLNOfflinePack","type":"topic","url":"\/documentation\/maplibre\/mlnofflinepack"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackRemovalCompletionHandler":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackRemovalCompletionHandler","title":"MLNOfflinePackRemovalCompletionHandler","abstract":[{"type":"text","text":"A block to be called once an offline pack has been completely invalidated and"},{"type":"text","text":" "},{"type":"text","text":"removed."}],"kind":"symbol","role":"symbol","url":"\/documentation\/maplibre\/mlnofflinepackremovalcompletionhandler","type":"topic","fragments":[{"kind":"identifier","text":"MLNOfflinePackRemovalCompletionHandler"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/reloadPacks":{"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/reloadPacks","title":"reloadPacks","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"reloadPacks"}],"navigatorTitle":[{"kind":"identifier","text":"reloadPacks"}],"abstract":[{"text":"Forcibly, asynchronously reloads the ","type":"text"},{"code":"packs","type":"codeVoice"},{"text":" property. At some point after this","type":"text"},{"text":" ","type":"text"},{"text":"method is called, the pointer values of the ","type":"text"},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true},{"text":" objects in the","type":"text"},{"text":" ","type":"text"},{"code":"packs","type":"codeVoice"},{"text":" property change, even if the underlying data for these packs has not","type":"text"},{"text":" ","type":"text"},{"text":"changed. If this method is called while a pack is actively downloading, the","type":"text"},{"text":" ","type":"text"},{"text":"behavior is undefined.","type":"text"}],"url":"\/documentation\/maplibre\/mlnofflinestorage\/reloadpacks","kind":"symbol","type":"topic"}}}