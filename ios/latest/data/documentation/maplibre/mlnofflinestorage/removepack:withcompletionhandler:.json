{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"text","text":"- ("},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"removePack:"},{"kind":"text","text":"("},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","preciseIdentifier":"c:objc(cs)MLNOfflinePack","kind":"typeIdentifier","text":"MLNOfflinePack"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"pack"},{"kind":"text","text":" "},{"kind":"identifier","text":"withCompletionHandler:"},{"kind":"text","text":"("},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackRemovalCompletionHandler","preciseIdentifier":"c:MLNOfflineStorage.h@T@MLNOfflinePackRemovalCompletionHandler","kind":"typeIdentifier","text":"MLNOfflinePackRemovalCompletionHandler"},{"kind":"text","text":") "},{"kind":"internalParam","text":"completion"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}]},{"parameters":[{"name":"pack","content":[{"inlineContent":[{"text":"The offline pack to remove.","type":"text"}],"type":"paragraph"}]},{"name":"completion","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The completion handler to call once the pack has been"},{"type":"text","text":" "},{"type":"text","text":"removed. This handler is executed asynchronously on the main queue."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"As soon as this method is called on a pack, the pack becomes invalid; any"},{"type":"text","text":" "},{"type":"text","text":"attempt to send it a message will result in an exception being thrown. If an"},{"type":"text","text":" "},{"type":"text","text":"error occurs and the pack cannot be removed, do not attempt to reuse the pack"},{"type":"text","text":" "},{"type":"text","text":"object. Instead, if you need continued access to the pack, suspend all packs"},{"type":"text","text":" "},{"type":"text","text":"and use the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/reloadPacks","type":"reference","isActive":true},{"type":"text","text":" method to obtain valid pointers to all the packs."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To detect when any call to this method results in a pack being removed, observe"},{"type":"text","text":" "},{"type":"text","text":"KVO change notifications on the shared offline storage object’s "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" key"},{"type":"text","text":" "},{"type":"text","text":"path. Removals from that array result in an "},{"type":"codeVoice","code":"NSKeyValueChangeRemoval"},{"type":"text","text":" change."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When you remove an offline pack, any resources that are required by that pack,"},{"type":"text","text":" "},{"type":"text","text":"but not other packs, become eligible for deletion from offline storage. Because"},{"type":"text","text":" "},{"type":"text","text":"the backing store used for offline storage is also used as a general purpose"},{"type":"text","text":" "},{"type":"text","text":"cache for map resources, such resources may not be immediately removed if the"},{"type":"text","text":" "},{"type":"text","text":"implementation determines that they remain useful for general performance of"},{"type":"text","text":" "},{"type":"text","text":"the map."}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinestorage\/removepack:withcompletionhandler:"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"type":"text","text":"Unregisters the given offline pack and allows resources that are no longer"},{"type":"text","text":" "},{"type":"text","text":"required by any remaining packs to be potentially freed."}],"metadata":{"externalID":"c:objc(cs)MLNOfflineStorage(im)removePack:withCompletionHandler:","navigatorTitle":[{"text":"removePack:withCompletionHandler:","kind":"identifier"}],"roleHeading":"Instance Method","modules":[{"name":"MapLibre"}],"role":"symbol","symbolKind":"method","fragments":[{"text":"- ","kind":"text"},{"text":"removePack:withCompletionHandler:","kind":"identifier"}],"title":"removePack:withCompletionHandler:"},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/removePack:withCompletionHandler:"},"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/removePack:withCompletionHandler:":{"role":"symbol","abstract":[{"type":"text","text":"Unregisters the given offline pack and allows resources that are no longer"},{"type":"text","text":" "},{"type":"text","text":"required by any remaining packs to be potentially freed."}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/removePack:withCompletionHandler:","url":"\/documentation\/maplibre\/mlnofflinestorage\/removepack:withcompletionhandler:","fragments":[{"text":"- ","kind":"text"},{"text":"removePack:withCompletionHandler:","kind":"identifier"}],"title":"removePack:withCompletionHandler:","type":"topic","navigatorTitle":[{"text":"removePack:withCompletionHandler:","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackRemovalCompletionHandler":{"title":"MLNOfflinePackRemovalCompletionHandler","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackRemovalCompletionHandler","url":"\/documentation\/maplibre\/mlnofflinepackremovalcompletionhandler","abstract":[{"type":"text","text":"A block to be called once an offline pack has been completely invalidated and"},{"type":"text","text":" "},{"type":"text","text":"removed."}],"type":"topic","fragments":[{"kind":"identifier","text":"MLNOfflinePackRemovalCompletionHandler"}],"role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/reloadPacks":{"role":"symbol","title":"reloadPacks","url":"\/documentation\/maplibre\/mlnofflinestorage\/reloadpacks","fragments":[{"text":"- ","kind":"text"},{"text":"reloadPacks","kind":"identifier"}],"abstract":[{"text":"Forcibly, asynchronously reloads the ","type":"text"},{"code":"packs","type":"codeVoice"},{"text":" property. At some point after this","type":"text"},{"text":" ","type":"text"},{"text":"method is called, the pointer values of the ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true,"type":"reference"},{"text":" objects in the","type":"text"},{"text":" ","type":"text"},{"code":"packs","type":"codeVoice"},{"text":" property change, even if the underlying data for these packs has not","type":"text"},{"text":" ","type":"text"},{"text":"changed. If this method is called while a pack is actively downloading, the","type":"text"},{"text":" ","type":"text"},{"text":"behavior is undefined.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/reloadPacks","navigatorTitle":[{"text":"reloadPacks","kind":"identifier"}],"kind":"symbol","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre":{"role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","kind":"symbol","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"url":"\/documentation\/maplibre","title":"MapLibre","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"kind":"symbol","abstract":[{"text":"MLNOfflineStorage implements a singleton (shared object) that manages offline","type":"text"},{"text":" ","type":"text"},{"text":"packs and ambient caching. All of this class’s instance methods are asynchronous,","type":"text"},{"text":" ","type":"text"},{"text":"reflecting the fact that offline resources are stored in a database. The shared","type":"text"},{"text":" ","type":"text"},{"text":"object maintains a canonical collection of offline packs in its ","type":"text"},{"code":"packs","type":"codeVoice"},{"text":" property.","type":"text"}],"url":"\/documentation\/maplibre\/mlnofflinestorage","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","title":"MLNOfflineStorage","type":"topic","role":"symbol","fragments":[{"text":"MLNOfflineStorage","kind":"identifier"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"role":"symbol","type":"topic","abstract":[{"text":"An ","type":"text"},{"isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","type":"reference"},{"text":" represents a collection of resources necessary for viewing","type":"text"},{"text":" ","type":"text"},{"text":"a region offline to a local database.","type":"text"}],"kind":"symbol","title":"MLNOfflinePack","fragments":[{"text":"MLNOfflinePack","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","url":"\/documentation\/maplibre\/mlnofflinepack"}}}