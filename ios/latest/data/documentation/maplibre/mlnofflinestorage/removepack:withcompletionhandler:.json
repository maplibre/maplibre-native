{"kind":"symbol","abstract":[{"type":"text","text":"Unregisters the given offline pack and allows resources that are no longer"},{"type":"text","text":" "},{"type":"text","text":"required by any remaining packs to be potentially freed."}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"sections":[],"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinestorage\/removepack:withcompletionhandler:"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"text","text":"- ("},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"removePack:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)MLNOfflinePack","kind":"typeIdentifier","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","text":"MLNOfflinePack"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"pack"},{"kind":"text","text":" "},{"kind":"identifier","text":"withCompletionHandler:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:MLNOfflineStorage.h@T@MLNOfflinePackRemovalCompletionHandler","kind":"typeIdentifier","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackRemovalCompletionHandler","text":"MLNOfflinePackRemovalCompletionHandler"},{"kind":"text","text":") "},{"kind":"internalParam","text":"completion"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS","iPadOS","Mac Catalyst"]}],"kind":"declarations"},{"parameters":[{"name":"pack","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The offline pack to remove."}]}]},{"name":"completion","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The completion handler to call once the pack has been"},{"type":"text","text":" "},{"type":"text","text":"removed. This handler is executed asynchronously on the main queue."}]}]}],"kind":"parameters"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"As soon as this method is called on a pack, the pack becomes invalid; any"},{"type":"text","text":" "},{"type":"text","text":"attempt to send it a message will result in an exception being thrown. If an"},{"type":"text","text":" "},{"type":"text","text":"error occurs and the pack cannot be removed, do not attempt to reuse the pack"},{"type":"text","text":" "},{"type":"text","text":"object. Instead, if you need continued access to the pack, suspend all packs"},{"type":"text","text":" "},{"type":"text","text":"and use the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/reloadPacks","isActive":true},{"type":"text","text":" method to obtain valid pointers to all the packs."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To detect when any call to this method results in a pack being removed, observe"},{"type":"text","text":" "},{"type":"text","text":"KVO change notifications on the shared offline storage object’s "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" key"},{"type":"text","text":" "},{"type":"text","text":"path. Removals from that array result in an "},{"type":"codeVoice","code":"NSKeyValueChangeRemoval"},{"type":"text","text":" change."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When you remove an offline pack, any resources that are required by that pack,"},{"type":"text","text":" "},{"type":"text","text":"but not other packs, become eligible for deletion from offline storage. Because"},{"type":"text","text":" "},{"type":"text","text":"the backing store used for offline storage is also used as a general purpose"},{"type":"text","text":" "},{"type":"text","text":"cache for map resources, such resources may not be immediately removed if the"},{"type":"text","text":" "},{"type":"text","text":"implementation determines that they remain useful for general performance of"},{"type":"text","text":" "},{"type":"text","text":"the map."}],"type":"paragraph"}],"kind":"content"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/removePack:withCompletionHandler:"},"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"modules":[{"name":"MapLibre"}],"role":"symbol","title":"removePack:withCompletionHandler:","roleHeading":"Instance Method","symbolKind":"method","navigatorTitle":[{"text":"- ","kind":"text"},{"text":"removePack:withCompletionHandler:","kind":"identifier"}],"externalID":"c:objc(cs)MLNOfflineStorage(im)removePack:withCompletionHandler:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"removePack:withCompletionHandler:"}]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackRemovalCompletionHandler":{"fragments":[{"kind":"identifier","text":"MLNOfflinePackRemovalCompletionHandler"}],"abstract":[{"type":"text","text":"A block to be called once an offline pack has been completely invalidated and"},{"type":"text","text":" "},{"type":"text","text":"removed."}],"type":"topic","url":"\/documentation\/maplibre\/mlnofflinepackremovalcompletionhandler","title":"MLNOfflinePackRemovalCompletionHandler","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackRemovalCompletionHandler","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"title":"MLNOfflinePack","kind":"symbol","abstract":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true,"type":"reference"},{"text":" represents a collection of resources necessary for viewing","type":"text"},{"text":" ","type":"text"},{"text":"a region offline to a local database.","type":"text"}],"type":"topic","role":"symbol","url":"\/documentation\/maplibre\/mlnofflinepack","fragments":[{"kind":"identifier","text":"MLNOfflinePack"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"abstract":[{"text":"MLNOfflineStorage implements a singleton (shared object) that manages offline","type":"text"},{"text":" ","type":"text"},{"text":"packs and ambient caching. All of this class’s instance methods are asynchronous,","type":"text"},{"text":" ","type":"text"},{"text":"reflecting the fact that offline resources are stored in a database. The shared","type":"text"},{"text":" ","type":"text"},{"text":"object maintains a canonical collection of offline packs in its ","type":"text"},{"code":"packs","type":"codeVoice"},{"text":" property.","type":"text"}],"url":"\/documentation\/maplibre\/mlnofflinestorage","fragments":[{"kind":"identifier","text":"MLNOfflineStorage"}],"title":"MLNOfflineStorage","role":"symbol","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","kind":"symbol","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"url":"\/documentation\/maplibre","title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/removePack:withCompletionHandler:":{"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"removePack:withCompletionHandler:"}],"abstract":[{"type":"text","text":"Unregisters the given offline pack and allows resources that are no longer"},{"type":"text","text":" "},{"type":"text","text":"required by any remaining packs to be potentially freed."}],"type":"topic","url":"\/documentation\/maplibre\/mlnofflinestorage\/removepack:withcompletionhandler:","title":"removePack:withCompletionHandler:","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/removePack:withCompletionHandler:","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/reloadPacks":{"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"reloadPacks"}],"abstract":[{"type":"text","text":"Forcibly, asynchronously reloads the "},{"code":"packs","type":"codeVoice"},{"type":"text","text":" property. At some point after this"},{"type":"text","text":" "},{"type":"text","text":"method is called, the pointer values of the "},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true,"type":"reference"},{"type":"text","text":" objects in the"},{"type":"text","text":" "},{"code":"packs","type":"codeVoice"},{"type":"text","text":" property change, even if the underlying data for these packs has not"},{"type":"text","text":" "},{"type":"text","text":"changed. If this method is called while a pack is actively downloading, the"},{"type":"text","text":" "},{"type":"text","text":"behavior is undefined."}],"type":"topic","url":"\/documentation\/maplibre\/mlnofflinestorage\/reloadpacks","title":"reloadPacks","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/reloadPacks","kind":"symbol"}}}