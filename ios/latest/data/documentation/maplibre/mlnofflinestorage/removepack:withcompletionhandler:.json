{"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/removePack:withCompletionHandler:","interfaceLanguage":"occ"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"- (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"removePack:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)MLNOfflinePack","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","text":"MLNOfflinePack","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"pack","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"withCompletionHandler:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"MLNOfflinePackRemovalCompletionHandler","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackRemovalCompletionHandler","preciseIdentifier":"c:MLNOfflineStorage.h@T@MLNOfflinePackRemovalCompletionHandler","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"completion","kind":"internalParam"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"parameters":[{"name":"pack","content":[{"type":"paragraph","inlineContent":[{"text":"The offline pack to remove.","type":"text"}]}]},{"name":"completion","content":[{"type":"paragraph","inlineContent":[{"text":"The completion handler to call once the pack has been","type":"text"},{"text":" ","type":"text"},{"text":"removed. This handler is executed asynchronously on the main queue.","type":"text"}]}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"As soon as this method is called on a pack, the pack becomes invalid; any","type":"text"},{"text":" ","type":"text"},{"text":"attempt to send it a message will result in an exception being thrown. If an","type":"text"},{"text":" ","type":"text"},{"text":"error occurs and the pack cannot be removed, do not attempt to reuse the pack","type":"text"},{"text":" ","type":"text"},{"text":"object. Instead, if you need continued access to the pack, suspend all packs","type":"text"},{"text":" ","type":"text"},{"text":"and use the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/reloadPacks"},{"text":" method to obtain valid pointers to all the packs.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To detect when any call to this method results in a pack being removed, observe","type":"text"},{"text":" ","type":"text"},{"text":"KVO change notifications on the shared offline storage object’s ","type":"text"},{"type":"codeVoice","code":"packs"},{"text":" key","type":"text"},{"text":" ","type":"text"},{"text":"path. Removals from that array result in an ","type":"text"},{"type":"codeVoice","code":"NSKeyValueChangeRemoval"},{"text":" change.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When you remove an offline pack, any resources that are required by that pack,"},{"type":"text","text":" "},{"type":"text","text":"but not other packs, become eligible for deletion from offline storage. Because"},{"type":"text","text":" "},{"type":"text","text":"the backing store used for offline storage is also used as a general purpose"},{"type":"text","text":" "},{"type":"text","text":"cache for map resources, such resources may not be immediately removed if the"},{"type":"text","text":" "},{"type":"text","text":"implementation determines that they remain useful for general performance of"},{"type":"text","text":" "},{"type":"text","text":"the map."}],"type":"paragraph"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"variants":[{"traits":[{"inter