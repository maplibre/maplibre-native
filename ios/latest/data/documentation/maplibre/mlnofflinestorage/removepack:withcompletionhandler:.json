{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"abstract":[{"text":"Unregisters the given offline pack and allows resources that are no longer","type":"text"},{"text":" ","type":"text"},{"text":"required by any remaining packs to be potentially freed.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"text":"- (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"removePack:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"MLNOfflinePack","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","preciseIdentifier":"c:objc(cs)MLNOfflinePack","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"pack","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"withCompletionHandler:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"MLNOfflinePackRemovalCompletionHandler","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackRemovalCompletionHandler","preciseIdentifier":"c:MLNOfflineStorage.h@T@MLNOfflinePackRemovalCompletionHandler","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"completion","kind":"internalParam"},{"text":";","kind":"text"}],"platforms":["iOS","iPadOS","Mac Catalyst"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The offline pack to remove.","type":"text"}]}],"name":"pack"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The completion handler to call once the pack has been","type":"text"},{"text":" ","type":"text"},{"text":"removed. This handler is executed asynchronously on the main queue.","type":"text"}]}],"name":"completion"}]},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"As soon as this method is called on a pack, the pack becomes invalid; any","type":"text"},{"text":" ","type":"text"},{"text":"attempt to send it a message will result in an exception being thrown. If an","type":"text"},{"text":" ","type":"text"},{"text":"error occurs and the pack cannot be removed, do not attempt to reuse the pack","type":"text"},{"text":" ","type":"text"},{"text":"object. Instead, if you need continued access to the pack, suspend all packs","type":"text"},{"text":" ","type":"text"},{"text":"and use the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/reloadPacks"},{"text":" method to obtain valid pointers to all the packs.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To detect when any call to this method results in a pack being removed, observe"},{"type":"text","text":" "},{"type":"text","text":"KVO change notifications on the shared offline storage object’s "},{"code":"packs","type":"codeVoice"},{"type":"text","text":" key"},{"type":"text","text":" "},{"type":"text","text":"path. Removals from that array result in an "},{"code":"NSKeyValueChangeRemoval","type":"codeVoice"},{"type":"text","text":" change."}]},{"type":"paragraph","inlineContent":[{"text":"When you remove an offline pack, any resources that are required by that pack,","type":"text"},{"text":" ","type":"text"},{"text":"but not other packs, become eligible for deletion from offline storage. Because","type":"text"},{"text":" ","type":"text"},{"text":"the backing store used for offline storage is also used as a general purpose","type":"text"},{"type":"text","text":" "},{"type":"text","text":"cache for map resources, such resources may not be immediately removed if the"},{"type":"text","text":" "},{"text":"implementation determines that they remain useful for general performance of","type":"text"},{"text":" ","type":"text"},{"text":"the map.","type":"text"}]}],"kind":"content"}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinestorage\/removepack:withcompletionhandler:"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/removePack:withCompletionHandler:","interfaceLanguage":"occ"},"metadata":{"navigatorTitle":[{"kind":"text","text":"- "},{"kind":"identifier","text":"removePack:withCompletionHandler:"}],"roleHeading":"Instance Method","title":"removePack:withCompletionHandler:","symbolKind":"method","externalID":"c:objc(cs)MLNOfflineStorage(im)removePack:withCompletionHandler:","role":"symbol","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"removePack:withCompletionHandler:"}],"modules":[{"name":"MapLibre"}]},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"url":"\/documentation\/maplibre\/mlnofflinepack","role":"symbol","type":"topic","abstract":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"},{"type":"text","text":" represents a collection of resources necessary for viewing"},{"type":"text","text":" "},{"type":"text","text":"a region offline to a local database."}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","fragments":[{"kind":"identifier","text":"MLNOfflinePack"}],"title":"MLNOfflinePack"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/removePack:withCompletionHandler:":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/removePack:withCompletionHandler:","kind":"symbol","title":"removePack:withCompletionHandler:","fragments":[{"text":"- ","kind":"text"},{"text":"removePack:withCompletionHandler:","kind":"identifier"}],"abstract":[{"text":"Unregisters the given offline pack and allows resources that are no longer","type":"text"},{"text":" ","type":"text"},{"text":"required by any remaining packs to be potentially freed.","type":"text"}],"url":"\/documentation\/maplibre\/mlnofflinestorage\/removepack:withcompletionhandler:","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/reloadPacks":{"kind":"symbol","abstract":[{"type":"text","text":"Forcibly, asynchronously reloads the "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property. At some point after this"},{"type":"text","text":" "},{"type":"text","text":"method is called, the pointer values of the "},{"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true},{"type":"text","text":" objects in the"},{"type":"text","text":" "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property change, even if the underlying data for these packs has not"},{"type":"text","text":" "},{"type":"text","text":"changed. If this method is called while a pack is actively downloading, the"},{"type":"text","text":" "},{"type":"text","text":"behavior is undefined."}],"url":"\/documentation\/maplibre\/mlnofflinestorage\/reloadpacks","title":"reloadPacks","role":"symbol","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"reloadPacks"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/reloadPacks"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"role":"symbol","title":"MLNOfflineStorage","abstract":[{"text":"MLNOfflineStorage implements a singleton (shared object) that manages offline","type":"text"},{"text":" ","type":"text"},{"text":"packs and ambient caching. All of this class’s instance methods are asynchronous,","type":"text"},{"text":" ","type":"text"},{"text":"reflecting the fact that offline resources are stored in a database. The shared","type":"text"},{"text":" ","type":"text"},{"text":"object maintains a canonical collection of offline packs in its ","type":"text"},{"code":"packs","type":"codeVoice"},{"text":" property.","type":"text"}],"fragments":[{"kind":"identifier","text":"MLNOfflineStorage"}],"url":"\/documentation\/maplibre\/mlnofflinestorage","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","type":"topic","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","role":"collection","type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackRemovalCompletionHandler":{"role":"symbol","title":"MLNOfflinePackRemovalCompletionHandler","abstract":[{"text":"A block to be called once an offline pack has been completely invalidated and","type":"text"},{"text":" ","type":"text"},{"text":"removed.","type":"text"}],"fragments":[{"text":"MLNOfflinePackRemovalCompletionHandler","kind":"identifier"}],"url":"\/documentation\/maplibre\/mlnofflinepackremovalcompletionhandler","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackRemovalCompletionHandler","type":"topic","kind":"symbol"}}}