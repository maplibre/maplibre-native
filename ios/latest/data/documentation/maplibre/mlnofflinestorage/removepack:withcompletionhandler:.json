{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"tokens":[{"kind":"text","text":"- ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"removePack:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","preciseIdentifier":"c:objc(cs)MLNOfflinePack","text":"MLNOfflinePack"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"pack"},{"kind":"text","text":" "},{"kind":"identifier","text":"withCompletionHandler:"},{"kind":"text","text":"("},{"text":"MLNOfflinePackRemovalCompletionHandler","kind":"typeIdentifier","preciseIdentifier":"c:MLNOfflineStorage.h@T@MLNOfflinePackRemovalCompletionHandler","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackRemovalCompletionHandler"},{"text":") ","kind":"text"},{"kind":"internalParam","text":"completion"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"parameters":[{"name":"pack","content":[{"type":"paragraph","inlineContent":[{"text":"The offline pack to remove.","type":"text"}]}]},{"name":"completion","content":[{"type":"paragraph","inlineContent":[{"text":"The completion handler to call once the pack has been","type":"text"},{"text":" ","type":"text"},{"text":"removed. This handler is executed asynchronously on the main queue.","type":"text"}]}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"As soon as this method is called on a pack, the pack becomes invalid; any"},{"type":"text","text":" "},{"type":"text","text":"attempt to send it a message will result in an exception being thrown. If an"},{"type":"text","text":" "},{"type":"text","text":"error occurs and the pack cannot be removed, do not attempt to reuse the pack"},{"type":"text","text":" "},{"type":"text","text":"object. Instead, if you need continued access to the pack, suspend all packs"},{"type":"text","text":" "},{"type":"text","text":"and use the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/reloadPacks"},{"type":"text","text":" method to obtain valid pointers to all the packs."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To detect when any call to this method results in a pack being removed, observe"},{"text":" ","type":"text"},{"text":"KVO change notifications on the shared offline storage object’s ","type":"text"},{"type":"codeVoice","code":"packs"},{"text":" key","type":"text"},{"text":" ","type":"text"},{"text":"path. Removals from that array result in an ","type":"text"},{"type":"codeVoice","code":"NSKeyValueChangeRemoval"},{"text":" change.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"When you remove an offline pack, any resources that are required by that pack,","type":"text"},{"text":" ","type":"text"},{"text":"but not other packs, become eligible for deletion from offline storage. Because","type":"text"},{"text":" ","type":"text"},{"text":"the backing store used for offline storage is also used as a general purpose","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"cache for map resources, such resources may not be immediately removed if the"},{"type":"text","text":" "},{"text":"implementation determines that they remain useful for general performance of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the map."}],"type":"paragraph"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","abstract":[{"text":"Unregisters the given offline pack and allows resources that are no longer","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"required by any remaining packs to be potentially freed."}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/removePack:withCompletionHandler:","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinestorage\/removepack:withcompletionhandler:"]}],"metadata":{"title":"removePack:withCompletionHandler:","role":"symbol","externalID":"c:objc(cs)MLNOfflineStorage(im)removePack:withCompletionHandler:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"removePack:withCompletionHandler:"}],"navigatorTitle":[{"kind":"text","text":"- "},{"kind":"identifier","text":"removePack:withCompletionHandler:"}],"symbolKind":"method","roleHeading":"Instance Method","modules":[{"name":"MapLibre"}]},"sections":[],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"kind":"symbol","title":"MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"url":"\/documentation\/maplibre","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"abstract":[{"text":"MLNOfflineStorage implements a singleton (shared object) that manages offline","type":"text"},{"text":" ","type":"text"},{"text":"packs and ambient caching. All of this class’s instance methods are asynchronous,","type":"text"},{"type":"text","text":" "},{"text":"reflecting the fact that offline resources are stored in a database. The shared","type":"text"},{"type":"text","text":" "},{"text":"object maintains a canonical collection of offline packs in its ","type":"text"},{"code":"packs","type":"codeVoice"},{"text":" property.","type":"text"}],"title":"MLNOfflineStorage","fragments":[{"text":"MLNOfflineStorage","kind":"identifier"}],"role":"symbol","kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinestorage","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/removePack:withCompletionHandler:":{"fragments":[{"text":"- ","kind":"text"},{"text":"removePack:withCompletionHandler:","kind":"identifier"}],"kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"Unregisters the given offline pack and allows resources that are no longer"},{"type":"text","text":" "},{"type":"text","text":"required by any remaining packs to be potentially freed."}],"type":"topic","url":"\/documentation\/maplibre\/mlnofflinestorage\/removepack:withcompletionhandler:","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/removePack:withCompletionHandler:","title":"removePack:withCompletionHandler:"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePack":{"fragments":[{"text":"MLNOfflinePack","kind":"identifier"}],"kind":"symbol","role":"symbol","abstract":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","isActive":true,"type":"reference"},{"text":" represents a collection of resources necessary for viewing","type":"text"},{"text":" ","type":"text"},{"text":"a region offline to a local database.","type":"text"}],"type":"topic","url":"\/documentation\/maplibre\/mlnofflinepack","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","title":"MLNOfflinePack"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflinePackRemovalCompletionHandler":{"abstract":[{"text":"A block to be called once an offline pack has been completely invalidated and","type":"text"},{"text":" ","type":"text"},{"text":"removed.","type":"text"}],"title":"MLNOfflinePackRemovalCompletionHandler","fragments":[{"kind":"identifier","text":"MLNOfflinePackRemovalCompletionHandler"}],"role":"symbol","kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinepackremovalcompletionhandler","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackRemovalCompletionHandler","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/reloadPacks":{"fragments":[{"text":"- ","kind":"text"},{"text":"reloadPacks","kind":"identifier"}],"kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"Forcibly, asynchronously reloads the "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property. At some point after this"},{"type":"text","text":" "},{"type":"text","text":"method is called, the pointer values of the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack"},{"type":"text","text":" objects in the"},{"type":"text","text":" "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property change, even if the underlying data for these packs has not"},{"type":"text","text":" "},{"type":"text","text":"changed. If this method is called while a pack is actively downloading, the"},{"type":"text","text":" "},{"type":"text","text":"behavior is undefined."}],"type":"topic","url":"\/documentation\/maplibre\/mlnofflinestorage\/reloadpacks","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/reloadPacks","title":"reloadPacks"}}}