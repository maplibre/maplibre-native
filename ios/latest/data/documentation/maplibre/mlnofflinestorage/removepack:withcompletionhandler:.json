{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/removePack:withCompletionHandler:"},"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinestorage\/removepack:withcompletionhandler:"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"- (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"removePack:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)MLNOfflinePack","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","text":"MLNOfflinePack","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"pack","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"withCompletionHandler:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"MLNOfflinePackRemovalCompletionHandler","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePackRemovalCompletionHandler","preciseIdentifier":"c:MLNOfflineStorage.h@T@MLNOfflinePackRemovalCompletionHandler","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"completion","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The offline pack to remove.","type":"text"}]}],"name":"pack"},{"content":[{"inlineContent":[{"type":"text","text":"The completion handler to call once the pack has been"},{"type":"text","text":" "},{"type":"text","text":"removed. This handler is executed asynchronously on the main queue."}],"type":"paragraph"}],"name":"completion"}],"kind":"parameters"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"As soon as this method is called on a pack, the pack becomes invalid; any","type":"text"},{"text":" ","type":"text"},{"text":"attempt to send it a message will result in an exception being thrown. If an","type":"text"},{"text":" ","type":"text"},{"text":"error occurs and the pack cannot be removed, do not attempt to reuse the pack","type":"text"},{"text":" ","type":"text"},{"text":"object. Instead, if you need continued access to the pack, suspend all packs","type":"text"},{"text":" ","type":"text"},{"text":"and use the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/reloadPacks"},{"text":" method to obtain valid pointers to all the packs.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To detect when any call to this method results in a pack being removed, observe","type":"text"},{"text":" ","type":"text"},{"text":"KVO change notifications on the shared offline storage object’s ","type":"text"},{"type":"codeVoice","code":"packs"},{"text":" key","type":"text"},{"text":" ","type":"text"},{"text":"path. Removals from that array result in an ","type":"text"},{"type":"codeVoice","code":"NSKeyValueChangeRemoval"},{"text":" change.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When you remove an offline pack, any resources that are required by that pack,"},{"type":"text","text":" "},{"type":"text","text":"but not other packs, become eligible for deletion from offline storage. Because"},{"type":"text","text":" "},{"type":"text","text":"the backing store used for offline storage is also used as a general purpose"},{"type":"text","text":" "},{"type":"text","text":"cache for map resources, such resources may not be immediately removed if the"},{"type":"text","text":" "},{"type":"text","text":"implementation determines that they remain useful for general performance of"},{"type":"text","text":" "},{"type":"text","text":"the map."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"sections":[],"abstract":[{"text":"Unregisters the given offline pack and allows resources that are no longer","type":"text"},{"text":" ","type":"text"},{"text":"required by any remaining packs to be potentially freed.","type":"text"}],"metadata":{"externalID":"c:objc(cs)MLNOfflineStorage(im)removePack:withCompletionHandler:","roleHeading":"Instance Method","fragments":[{"text":"- ","kind":"text"},{"text":"removePack:withCompletionHandler:","kind":"identifier"}],"title":"removePack:withCompletionHandler:","symbolKind":"method","navigatorTitle":[{"text":"removePack:withCompletionHandler:","kind":"identifier"}],"modules":[{"name":"MapLibre"}],"role":"symbol"},"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/reloadPacks":{"role":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"reloadPacks"}],"url":"\/documentation\/maplibre\/mlnofflinestorage\/reloadpacks","abstract":[{"text":"Forcibly, asynchronously reloads the ","type":"text"},{"type":"codeVoice","code":"packs"},{"text":" property. At some point after this","type":"text"},{"text":" ","type":"text"},{"text":"method is called, the pointer values of the ","type":"text"},{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflinePack","type":"reference","isActive":true},{"text":" objects in the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"packs"},{"text":" property change, even if the underlying data for these packs has not","type":"text"},{"text":" ","type":"text"},{"text":"changed. If this method is called while a pack is actively downloading, the","type":"text"},{"text":" ","type":"text"},{"text":"behavior is undefined.","type":"text"}],"kind":"symbol","title":"reloadPacks","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/reloadPacks","fragments":[{"k