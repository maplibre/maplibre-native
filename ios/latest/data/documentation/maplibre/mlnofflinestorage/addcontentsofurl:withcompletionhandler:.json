d":"text"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"A file URL specifying the file to add. The URL should be a valid","type":"text"},{"text":" ","type":"text"},{"text":"system path. The URL must be writable as schema updates may be performed.","type":"text"}],"type":"paragraph"}],"name":"fileURL"},{"content":[{"inlineContent":[{"type":"text","text":"The completion handler to call once the contents of the given"},{"type":"text","text":" "},{"type":"text","text":"file has been added to offline storage. This handler is executed"},{"type":"text","text":" "},{"type":"text","text":"asynchronously on the main queue."}],"type":"paragraph"}],"name":"completion"}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The file must be a valid offline pack database bundled with the application or"},{"type":"text","text":" "},{"type":"text","text":"downloaded separately."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The resulting packs are added or updated to the shared offline storage object’s"},{"type":"text","text":" "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property, then the "},{"type":"codeVoice","code":"completion"},{"type":"text","text":" block is executed."}]}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/addContentsOfURL:withCompletionHandler:":{"navigatorTitle":[{"kind":"identifier","text":"addContentsOfURL:withCompletionHandler:"}],"title":"addContentsOfURL:withCompletionHandler:","fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"addContentsOfURL:withCompletionHandler:"}],"url":"\/documentation\/maplibre\/mlnofflinestorage\/addcontentsofurl:withcompletionhandler:","role":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/addContentsOfURL:withCompletionHandler:","abstract":[{"type":"text","text":"Adds the offline packs located at the given URL to offline storage."}],"kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"type":"topic","url":"\/documentation\/maplibre"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"abstract":[{"type":"text","text":"MLNOfflineStorage implements a singleton (shared object) that manages offline"},{"type":"text","text":" "},{"type":"text","text":"packs and ambient caching. All of this class’s instance methods are asynchronous,"},{"type":"text","text":" "},{"type":"text","text":"reflecting the fact that offline resources are stored in a database. The shared"},{"type":"text","text":" "},{"type":"text","text":"object maintains a canonical collection of offline packs in its "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property."}],"kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","title":"MLNOfflineStorage","role":"symbol","type":"topic","url":"\/documentation\/maplibre\/mlnofflinestorage","fragments":[{"kind":"identifier","text":"MLNOfflineStorage"}]},"doc://org.swift.MyProject/documentation/MapLibre/MLNBatchedOfflinePackAdditionCompletionHandler":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNBatchedOfflinePackAdditionCompletionHandler","abstract":[{"text":"A block to be called once the contents of a file are copied into the current packs.","type":"text"}],"url":"\/documentation\/maplibre\/mlnbatchedofflinepackadditioncompletionhandler","type":"topic","kind":"symbol","fragments":[{"kind":"identifier","text":"MLNBatchedOfflinePackAdditionCompletionHandler"}],"ti