ication or","type":"text"},{"text":" ","type":"text"},{"text":"downloaded separately.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The resulting packs are added or updated to the shared offline storage object’s","type":"text"},{"text":" ","type":"text"},{"code":"packs","type":"codeVoice"},{"text":" property, then the ","type":"text"},{"code":"completion","type":"codeVoice"},{"text":" block is executed.","type":"text"}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinestorage\/addcontentsofurl:withcompletionhandler:"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","sections":[],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/addContentsOfURL:withCompletionHandler:","interfaceLanguage":"occ"},"metadata":{"symbolKind":"method","role":"symbol","title":"addContentsOfURL:withCompletionHandler:","navigatorTitle":[{"text":"- ","kind":"text"},{"text":"addContentsOfURL:withCompletionHandler:","kind":"identifier"}],"roleHeading":"Instance Method","externalID":"c:objc(cs)MLNOfflineStorage(im)addContentsOfURL:withCompletionHandler:","modules":[{"name":"MapLibre"}],"fragments":[{"text":"- ","kind":"text"},{"text":"addContentsOfURL:withCompletionHandler:","kind":"identifier"}]},"abstract":[{"type":"text","text":"Adds the offline packs located at the given URL to offline storage."}],"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","title":"MapLibre","url":"\/documentation\/maplibre","role":"collection","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}]},"doc://org.swift.MyProject/do