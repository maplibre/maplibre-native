aded separately."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The resulting packs are added or updated to the shared offline storage object’s"},{"type":"text","text":" "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property, then the "},{"type":"codeVoice","code":"completion"},{"type":"text","text":" block is executed."}]}],"kind":"content"}],"sections":[],"abstract":[{"type":"text","text":"Adds the offline packs located at the given URL to offline storage."}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/addContentsOfURL:withCompletionHandler:","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"metadata":{"symbolKind":"method","modules":[{"name":"MapLibre"}],"navigatorTitle":[{"kind":"identifier","text":"addContentsOfURL:withCompletionHandler:"}],"fragments":[{"kind":"text","text":"- "},{"kind":"identifier","text":"addContentsOfURL:withCompletionHandler:"}],"title":"addContentsOfURL:withCompletionHandler:","externalID":"c:objc(cs)MLNOfflineStorage(im)addContentsOfURL:withCompletionHandler:","roleHeading":"Instance Method","role":"symbol"},"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinestorage\/addcontentsofurl:withcompletionhandler:"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/addContentsOfURL:withCompletionHandler:":{"title":"addContentsOfURL:withCompletionHandler:","kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinestorage\/addcontentsofurl:withcompletionhandler:","role":"symbol","navigatorTitle":[{"text":"addContentsOfURL:withCompletionHandler:","kind":"identifier"}],"abstract":[{"type":"text","text":"Adds the offline packs located at the given URL to offline storage."}],"fragments":[{"text":"- ","kind":"text"},{"text":"addContentsOfURL:withCompletionHandler:","kind":"identifier"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/addContentsOfURL:withCompletionHandler:","type":"topic"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","title":"MLNOfflineStorage","fragments":[{"text":"MLNOfflineStorage","kind":"identifier"}],"role":"symbol","abstract":[{"type":"text","text":"MLNOfflineStorage implements a singleton (shared object) that manages offline"},{"type":"text","text":" "},{"type":"text","text":"packs and ambient caching. All of this class’s instance methods are asynchronous,"},{"type":"text","text":" "},{"type":"text","text":"reflecting the fact that offline resources are stored in a database. The shared"},{"type":"text","text":" "},{"type":"text","text":"object maintains a canonical collection of offline packs in its "},{"code":"packs","type":"codeVoice"},{"type":"text","text":" property."}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinestorage"},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","title":"MapLibre","type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre/MLNBatchedOfflinePackAdditionCompletionHandler":{"kind":"symbol","role":"symbol","title":"MLNBatchedOfflinePackAdditionCompletionHandler","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNBatchedOfflinePackAdditionCompletionHandler","abstract":[{"text":"A block to be called once the contents of a file are copied into the current packs.","type":"text"}],"fragments":[{"text":"MLNBatchedOfflinePackAdditionCompletionHandler","kind":"identifier"}],"url":"\/documentation\/map