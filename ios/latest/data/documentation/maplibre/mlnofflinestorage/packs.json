t that offline resources are stored in a database. The shared"},{"type":"text","text":" "},{"type":"text","text":"object maintains a canonical collection of offline packs in its "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property."}],"title":"MLNOfflineStorage","kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinestorage","fragments":[{"kind":"identifier","text":"MLNOfflineStorage"}],"role":"symbol","type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"}}}