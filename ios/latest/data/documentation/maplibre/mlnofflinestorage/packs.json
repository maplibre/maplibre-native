ct when the shared offline storage object has finished loading its"},{"type":"text","text":" "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property, observe KVO change notifications on the "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" key path."},{"type":"text","text":" "},{"type":"text","text":"The initial load results in an "},{"type":"codeVoice","code":"NSKeyValueChangeSetting"},{"type":"text","text":" change."}]}]}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/packs"},"sections":[],"kind":"symbol","abstract":[{"type":"text","text":"An array of all known offline packs, in the order in which they were created."}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/packs":{"abstract":[{"type":"text","text":"An array of all known offline packs, in the order in which they were created."}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinestorage\/packs","title":"packs","role":"symbol","fragments":[{"text":"packs","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/packs"},"doc://org.swift.MyProject/documentation/MapLibre":{"url":"\/documentation\/maplibre","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","role":"collection","title":"MapLibre"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/ManageOfflineRegionsExample":{"title":"Manage Offline Regions","kind":"article","type":"topic","abstract":[{"type":"text","text":"Query, delete and download offline regions"}],"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/ManageOfflineRegionsExample","role":"article","url":"\/documentation\/maplibre-native-for-ios\/manageofflineregionsexample"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"role":"symbol","fragments":[{"kind":"identifier","text":"MLNOfflineStorage"}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinestorage","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","abstract":[{"type":"text","text":"MLNOfflineStorage implements a singleton (shared object) that manages offline"},{"type":"text","text":" "},{"type":"text","text":"packs and ambient caching. All of this class’s instance methods are asynchronous,"},{"type":"text","text":" "},{"type":"text","text":"reflecting the fact that offline resources are stored in a database. The shared"},{"type":"text","text":" "},{"type":"text","text":"object maintains a canonical collection of offline packs in its "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property."}],"type":"topic","title":"MLNOfflineStorage"}}}