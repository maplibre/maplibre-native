{"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"fragments":[{"kind":"identifier","text":"packs"}],"symbolKind":"property","roleHeading":"Instance Property","role":"symbol","title":"packs","modules":[{"name":"MapLibre"}],"externalID":"c:objc(cs)MLNOfflineStorage(py)packs","navigatorTitle":[{"text":"packs","kind":"identifier"}]},"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"strong"},{"kind":"text","text":", "},{"kind":"keyword","text":"readonly"},{"kind":"text","text":") "},{"kind":"typeIdentifier","preciseIdentifier":"c:Q$objc(cs)NSArray","text":"NSArray<MLNOfflinePack *>"},{"kind":"text","text":" * "},{"kind":"identifier","text":"packs"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property is set to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", indicating that the receiver does not yet know"},{"type":"text","text":" "},{"type":"text","text":"the existing packs, for an undefined amount of time starting from the moment"},{"type":"text","text":" "},{"type":"text","text":"the shared offline storage object is initialized until the packs are fetched"},{"type":"text","text":" "},{"type":"text","text":"from the database. After that point, this property is always non-nil, but it"},{"type":"text","text":" "},{"type":"text","text":"may be empty to indicate that no packs are present."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To detect when the shared offline storage object has finished loading its"},{"type":"text","text":" "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property, observe KVO change notifications on the "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" key path."},{"type":"text","text":" "},{"type":"text","text":"The initial load results in an "},{"type":"codeVoice","code":"NSKeyValueChangeSetting"},{"type":"text","text":" change."}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/packs","interfaceLanguage":"occ"},"abstract":[{"text":"An array of all known offline packs, in the order in which they were created.","type":"text"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinestorage\/packs"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"type":"topic","title":"MLNOfflineStorage","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","fragments":[{"text":"MLNOfflineStorage","kind":"identifier"}],"abstract":[{"type":"text","text":"MLNOfflineStorage implements a singleton (shared object) that manages offline"},{"type":"text","text":" "},{"type":"text","text":"packs and ambient caching. All of this class’s instance methods are asynchronous,"},{"type":"text","text":" "},{"type":"text","text":"reflecting the fact that offline resources are stored in a database. The shared"},{"type":"text","text":" "},{"type":"text","text":"object maintains a canonical collection of offline packs in its "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property."}],"kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinestorage"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/packs":{"role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/packs","type":"topic","kind":"symbol","url":"\/documentation\/maplibre\/mlnofflinestorage\/packs","title":"p