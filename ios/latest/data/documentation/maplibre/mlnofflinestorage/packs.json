{"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"strong","kind":"keyword"},{"text":", ","kind":"text"},{"text":"readonly","kind":"keyword"},{"text":") ","kind":"text"},{"text":"NSArray<MLNOfflinePack *>","preciseIdentifier":"c:Q$objc(cs)NSArray","kind":"typeIdentifier"},{"text":" * ","kind":"text"},{"text":"packs","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This property is set to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", indicating that the receiver does not yet know"},{"type":"text","text":" "},{"type":"text","text":"the existing packs, for an undefined amount of time starting from the moment"},{"type":"text","text":" "},{"type":"text","text":"the shared offline storage object is initialized until the packs are fetched"},{"type":"text","text":" "},{"type":"text","text":"from the database. After that point, this property is always non-nil, but it"},{"type":"text","text":" "},{"type":"text","text":"may be empty to indicate that no packs are present."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To detect when the shared offline storage object has finished loading its"},{"type":"text","text":" "},{"code":"packs","type":"codeVoice"},{"type":"text","text":" property, observe KVO change notifications on the "},{"code":"packs","type":"codeVoice"},{"type":"text","text":" key path."},{"type":"text","text":" "},{"type":"text","text":"The initial load results in an "},{"code":"NSKeyValueChangeSetting","type":"codeVoice"},{"type":"text","text":" change."}]}],"kind":"content"}],"abstract":[{"type":"text","text":"An array of all known offline packs, in the order in which they were created."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/maplibre\/mlnofflinestorage\/packs"]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/packs","interfaceLanguage":"occ"},"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"fragments":[{"kind":"identifier","text":"packs"}],"roleHeading":"Instance Property","navigatorTitle":[{"text":"packs","kind":"identifier"}],"title":"packs","externalID":"c:objc(cs)MLNOfflineStorage(py)packs","role":"symbol","symbolKind":"property","modules":[{"name":"MapLibre"}]},"kind":"symbol","references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"abstract":[{"type":"text","text":"MLNOfflineStorage implements a singleton (shared object) that manages offline"},{"type":"text","text":" "},{"type":"text","text":"packs and ambient caching. All of this class’s instance methods are asynchronous,"},{"type":"text","text":" "},{"type":"text","text":"reflecting the fact that offline resources are stored in a database. The shared"},{"type":"text","text":" "},{"type":"text","text":"object maintains a canonical collection of offline packs in its "},{"code":"packs","type":"codeVoice"},{"type":"text","text":" property."}],"title":"MLNOfflineStorage","type":"topic","url":"\/documentation\/maplibre\/mlnofflinestorage","kind":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","role":"symbol","fragments":[{"kind":"identifier","text":"MLNOfflineStorage"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"type":"topic","role":"collection","url":"\/documentation\/maplibre","kind":"symbol","title":"MapLibre","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-sour