til the packs are fetched"},{"type":"text","text":" "},{"type":"text","text":"from the database. After that point, this property is always non-nil, but it"},{"type":"text","text":" "},{"type":"text","text":"may be empty to indicate that no packs are present."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To detect when the shared offline storage object has finished loading its"},{"type":"text","text":" "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property, observe KVO change notifications on the "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" key path."},{"type":"text","text":" "},{"type":"text","text":"The initial load results in an "},{"type":"codeVoice","code":"NSKeyValueChangeSetting"},{"type":"text","text":" change."}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/packs","interfaceLanguage":"occ"},"references":{"doc://org.swift.MyProject/documentation/MapLibre":{"identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","title":"MapLibre","type":"topic","abstract":[{"text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling.","type":"text"}],"url":"\/documentation\/maplibre","role":"collection","kind":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre-Native-for-iOS/ManageOfflineRegionsExample":{"role":"article","kind":"article","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre-Native-for-iOS\/ManageOfflineRegionsExample","type":"topic","title":"Manage Offline Regions","abstract":[{"type":"text","text":"Query, delete and download offline regions"}],"url":"\/documentation\/maplibre-native-for-ios\/manageofflineregionsexample"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/packs":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/packs","url":"\/documentation\/maplibre\/mlnoffl