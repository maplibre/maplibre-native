xt":" ","type":"text"},{"text":"may be empty to indicate that no packs are present.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To detect when the shared offline storage object has finished loading its"},{"type":"text","text":" "},{"code":"packs","type":"codeVoice"},{"type":"text","text":" property, observe KVO change notifications on the "},{"code":"packs","type":"codeVoice"},{"type":"text","text":" key path."},{"type":"text","text":" "},{"type":"text","text":"The initial load results in an "},{"code":"NSKeyValueChangeSetting","type":"codeVoice"},{"type":"text","text":" change."}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"type":"text","text":"An array of all known offline packs, in the order in which they were created."}],"references":{"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage":{"type":"topic","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","abstract":[{"type":"text","text":"MLNOfflineStorage implements a singleton (shared object) that manages offline"},{"type":"text","text":" "},{"type":"text","text":"packs and ambient caching. All of this class’s instance methods are asynchronous,"},{"type":"text","text":" "},{"type":"text","text":"reflecting the fact that offline resources are stored in a database. The shared"},{"type":"text","text":" "},{"type":"text","text":"object maintains a canonical collection of offline packs in its "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property."}],"fragments":[{"kind":"identifier","text":"MLNOfflineStorage"}],"url":"\/documentation\/maplibre\/mlnofflinestorage","title":"MLNOfflineStorage","kind":"symbol","role":"symbol"},"doc://org.swift.MyProject/documentation/MapLibre":{"abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","url":"\/docu