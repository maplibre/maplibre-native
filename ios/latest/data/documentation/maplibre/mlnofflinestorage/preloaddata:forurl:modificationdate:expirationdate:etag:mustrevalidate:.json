r this resource. The data is expected to"},{"type":"text","text":" "},{"type":"text","text":"be uncompressed; internally, the cache will compress data as necessary."}],"type":"paragraph"}]},{"name":"url","content":[{"inlineContent":[{"type":"text","text":"The URL at which the data can normally be found."}],"type":"paragraph"}]},{"name":"modified","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The date the resource was last modified."}]}]},{"name":"expires","content":[{"type":"paragraph","inlineContent":[{"text":"The date after which the resource is no longer valid.","type":"text"}]}]},{"name":"eTag","content":[{"type":"paragraph","inlineContent":[{"text":"An HTTP entity tag.","type":"text"}]}]},{"name":"mustRevalidate","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A Boolean value indicating whether the data is still"},{"type":"text","text":" "},{"type":"text","text":"usable past the expiration date."}]}]}],"kind":"parameters"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"This method mimics the caching that would take place if the equivalent resource"},{"type":"text","text":" "},{"type":"text","text":"were requested in the process of map rendering. Use this method to pre-warm the"},{"type":"text","text":" "},{"type":"text","text":"cache with resources you know will be requested."}],"type":"paragraph"},{"inlineContent":[{"text":"This method is asynchronous; the data may not be immediately available for","type":"text"},{"text":" ","type":"text"},{"text":"in-progress requests, though subsequent requests should have access to the","type":"text"},{"text":" ","type":"text"},{"text":"cached data.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To find out when the resource is ready to retrieve from the cache, use the"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.swift.MyProj