ation/MapLibre/MLNOfflineStorage":{"kind":"symbol","fragments":[{"text":"MLNOfflineStorage","kind":"identifier"}],"role":"symbol","url":"\/documentation\/maplibre\/mlnofflinestorage","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage","type":"topic","abstract":[{"type":"text","text":"MLNOfflineStorage implements a singleton (shared object) that manages offline"},{"type":"text","text":" "},{"type":"text","text":"packs and ambient caching. All of this class’s instance methods are asynchronous,"},{"type":"text","text":" "},{"type":"text","text":"reflecting the fact that offline resources are stored in a database. The shared"},{"type":"text","text":" "},{"type":"text","text":"object maintains a canonical collection of offline packs in its "},{"type":"codeVoice","code":"packs"},{"type":"text","text":" property."}],"title":"MLNOfflineStorage"},"doc://org.swift.MyProject/documentation/MapLibre/MLNOfflineStorage/delegate":{"url":"\/documentation\/maplibre\/mlnofflinestorage\/delegate","kind":"symbol","fragments":[{"kind":"identifier","text":"delegate"}],"type":"topic","title":"delegate","role":"symbol","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/delegate","abstract":[{"text":"The receiver’s delegate.","type":"text"}]},"doc://org.swift.MyProject/documentation/MapLibre":{"title":"MapLibre","url":"\/documentation\/maplibre","role":"collection","identifier":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre","abstract":[{"type":"text","text":"Powerful, free and open-source mapping toolkit with full control over data sources and styling."}],"kind":"symbol","type":"topic"}}}