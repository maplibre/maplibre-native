{"abstract":[{"type":"text","text":"The receiver’s delegate."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"nonatomic"},{"kind":"text","text":", "},{"kind":"keyword","text":"weak"},{"kind":"text","text":") "},{"kind":"typeIdentifier","preciseIdentifier":"c:Qoobjc(pl)MLNOfflineStorageDelegate","text":"id<MLNOfflineStorageDelegate>"},{"kind":"text","text":" "},{"kind":"identifier","text":"delegate"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}]},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An offline storage object sends messages to its delegate to allow it to"},{"type":"text","text":" "},{"type":"text","text":"transform URLs before they are requested from the internet. This can be used"},{"type":"text","text":" "},{"type":"text","text":"add or remove custom parameters, or reroute certain requests to other servers"},{"type":"text","text":" "},{"type":"text","text":"or endpoints."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.swift.MyProject\/documentation\/MapLibre","doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/org.swift.MyProject\/documentation\/MapLibre\/MLNOfflineStorage\/delegate"},"sections":[],"metadata":{"fragments":[{"kind":"identifier","text":"delegate"}],"role":"symbol","externalID":"c:objc(cs)MLNOfflineStorage(py)delegate","title":"delegate","roleHeading":"Instance Property","symbolKind":"property","navigatorTitle":[{"text":"delegate","kind":"identifier"}],"modules":[{"name":"MapLibre"}]},"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"paths":["\/documentation\/maplibre\/mlnofflinestorage\/delegate"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"symbol","references":{"doc://org.swift.MyProject/document