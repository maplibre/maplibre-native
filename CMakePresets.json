{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "ios",
      "hidden": true,
      "generator": "Xcode",
      "description": "Base iOS preset",
      "toolchainFile": "${sourceDir}/platform/ios/ios.toolchain.cmake",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "14.0"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "ios-metal",
      "displayName": "iOS Metal",
      "inherits": "ios",
      "binaryDir": "${sourceDir}/build-ios",
      "cacheVariables": {
        "MLN_WITH_METAL": "ON"
      }
    },
    {
      "name": "ios-webgpu-dawn",
      "displayName": "iOS WebGPU (Dawn)",
      "inherits": "ios",
      "binaryDir": "${sourceDir}/build-ios-webgpu-dawn",
      "cacheVariables": {
        "MLN_WITH_WEBGPU": "ON",
        "MLN_WEBGPU_IMPL_DAWN": "ON"
      }
    },
    {
      "name": "ios-webgpu-wgpu",
      "displayName": "iOS WebGPU (wgpu-native)",
      "inherits": "ios",
      "binaryDir": "${sourceDir}/build-ios-webgpu-wgpu",
      "cacheVariables": {
        "MLN_WITH_WEBGPU": "ON",
        "MLN_WEBGPU_IMPL_WGPU": "ON"
      }
    },
    {
      "name": "macos",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Darwin",
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "14.3",
        "CMAKE_BUILD_TYPE": "Debug",
        "MLN_DARWIN_USE_LIBUV": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "macos-metal",
      "displayName": "macOS Metal",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-macos-metal",
      "inherits": "macos",
      "cacheVariables": {
        "MLN_WITH_METAL": "ON"
      }
    },
    {
      "name": "macos-metal-xcode",
      "displayName": "macOS (Xcode)",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build-macos-metal-xcode",
      "inherits": "macos-metal"
    },
    {
      "name": "macos-vulkan",
      "displayName": "macOS Vulkan",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-macos-vulkan",
      "inherits": "macos",
      "cacheVariables": {
        "MLN_WITH_VULKAN": "ON"
      }
    },
    {
      "name": "macos-vulkan-xcode",
      "displayName": "macOS Vulkan (Xcode)",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build-macos-vulkan-xcode",
      "inherits": "macos-vulkan"
    },
    {
      "name": "macos-metal-node",
      "inherits": "macos-metal",
      "binaryDir": "${sourceDir}/build",
      "displayName": "MacOS Node",
      "description": "MacOS Node build (Metal renderer)",
      "cacheVariables": {
        "MLN_WITH_NODE": "ON",
        "MLN_WITH_WERROR": "OFF",
        "MLN_CREATE_AUTORELEASEPOOL": "ON",
        "MLN_DARWIN_USE_LIBUV": "OFF"
      }
    },
    {
      "name": "macos-webgpu-dawn",
      "displayName": "macOS WebGPU (Dawn)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-macos-webgpu-dawn",
      "inherits": "macos",
      "cacheVariables": {
        "MLN_WITH_WEBGPU": "ON",
        "MLN_WEBGPU_IMPL_DAWN": "ON",
        "MLN_DARWIN_USE_LIBUV": "ON"
      }
    },
    {
      "name": "macos-webgpu-wgpu",
      "displayName": "macOS WebGPU (wgpu-native)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-macos-webgpu-wgpu",
      "inherits": "macos",
      "cacheVariables": {
        "MLN_WITH_WEBGPU": "ON",
        "MLN_WEBGPU_IMPL_WGPU": "ON",
        "MLN_DARWIN_USE_LIBUV": "ON"
      }
    },
    {
      "name": "linux",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Linux",
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
        "MLN_WITH_METAL": "OFF",
        "MLN_WITH_OPENGL": "OFF",
        "MLN_WITH_VULKAN": "OFF",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_BUILD_WITH_INSTALL_RPATH": "ON",
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "MLN_WITH_CLANG_TIDY": "OFF",
        "MLN_WITH_WAYLAND": "ON",
        "MLN_WITH_X11": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-opengl",
      "binaryDir": "${sourceDir}/build-linux-opengl",
      "generator": "Ninja",
      "inherits": "linux",
      "cacheVariables": {
        "MLN_WITH_OPENGL": "ON"
      }
    },
    {
      "name": "linux-vulkan",
      "binaryDir": "${sourceDir}/build-linux-vulkan",
      "inherits": "linux",
      "cacheVariables": {
        "MLN_WITH_VULKAN": "ON",
        "MLN_WITH_WAYLAND": "OFF",
        "MLN_WITH_X11": "ON"
      }
    },
    {
      "name": "linux-webgpu-dawn",
      "binaryDir": "${sourceDir}/build-linux-webgpu-dawn",
      "inherits": "linux",
      "cacheVariables": {
        "MLN_WITH_WEBGPU": "ON",
        "MLN_WEBGPU_IMPL_DAWN": "ON",
        "MLN_WITH_WAYLAND": "OFF",
        "MLN_WITH_X11": "ON"
      }
    },
    {
      "name": "linux-webgpu-wgpu",
      "binaryDir": "${sourceDir}/build-linux-webgpu-wgpu",
      "inherits": "linux",
      "cacheVariables": {
        "MLN_WITH_WEBGPU": "ON",
        "MLN_WEBGPU_IMPL_WGPU": "ON",
        "MLN_WITH_WAYLAND": "OFF",
        "MLN_WITH_X11": "ON"
      }
    },
    {
      "name": "android-webgpu-dawn",
      "displayName": "Android WebGPU (Dawn)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-android-webgpu-dawn",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{ANDROID_NDK}/build/cmake/android.toolchain.cmake",
        "CMAKE_ANDROID_NDK": "$env{ANDROID_NDK}",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-26",
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "MLN_WITH_WEBGPU": "ON",
        "MLN_WEBGPU_IMPL_DAWN": "ON"
      }
    },
    {
      "name": "android-webgpu-wgpu",
      "displayName": "Android WebGPU (wgpu-native)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-android-webgpu-wgpu",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{ANDROID_NDK}/build/cmake/android.toolchain.cmake",
        "CMAKE_ANDROID_NDK": "$env{ANDROID_NDK}",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-26",
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "MLN_WITH_WEBGPU": "ON",
        "MLN_WEBGPU_IMPL_WGPU": "ON"
      }
    },
    {
      "name": "linux-opengl-node",
      "inherits": "linux",
      "binaryDir": "${sourceDir}/build",
      "displayName": "Linux Node",
      "description": "Linux Node build (OpenGL renderer)",
      "cacheVariables": {
        "MLN_WITH_NODE": "ON",
        "MLN_WITH_OPENGL": "ON",
        "MLN_WITH_WAYLAND": "OFF",
        "MLN_WITH_X11": "ON",
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache"
      }
    },
    {
      "name": "ohos",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-ohos",
      "condition": {
        "type": "notEquals",
        "lhs": "$env{OHOS_SDK_NATIVE}",
        "rhs": ""
      },
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{OHOS_SDK_NATIVE}/build/cmake/ohos.toolchain.cmake",
        "OHOS_ARCH": "arm64-v8a",
        "OHOS_STL": "c++_shared",
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "MLN_WITH_GLFW": "OFF",
        "MLN_WITH_OPENGL": "ON",
        "MLN_WITH_EGL": "ON"
      }
    },
    {
      "name": "ohos-opengl",
      "inherits": "ohos",
      "displayName": "OpenHarmony OpenGL",
      "description": "OpenHarmony build using GLES/EGL"
    },
    {
      "name": "ohos-opengl-link-smoke",
      "inherits": "ohos",
      "binaryDir": "${sourceDir}/build-ohos-link-smoke",
      "displayName": "OpenHarmony OpenGL Link Smoke",
      "description": "OpenHarmony GLES/EGL build with a final shared-library link smoke target",
      "cacheVariables": {
        "MLN_OHOS_BUILD_LINK_SMOKE": "ON"
      }
    },
    {
      "name": "ohos-opengl-native",
      "inherits": "ohos",
      "binaryDir": "${sourceDir}/build-ohos-native",
      "displayName": "OpenHarmony Native Module",
      "description": "OpenHarmony GLES/EGL build with the experimental NAPI/XComponent native module",
      "cacheVariables": {
        "MLN_OHOS_BUILD_NATIVE_MODULE": "ON"
      }
    },
    {
      "name": "ohos-vulkan-native",
      "inherits": "ohos",
      "binaryDir": "${sourceDir}/build-ohos-vulkan-native",
      "displayName": "OpenHarmony Vulkan Native Module",
      "description": "OpenHarmony Vulkan build with the experimental NAPI/XComponent native module",
      "cacheVariables": {
        "MLN_WITH_OPENGL": "OFF",
        "MLN_WITH_EGL": "OFF",
        "MLN_WITH_VULKAN": "ON",
        "MLN_OHOS_BUILD_NATIVE_MODULE": "ON"
      }
    },
    {
      "name": "ohos-opengl-core",
      "inherits": "ohos",
      "binaryDir": "${sourceDir}/build-ohos-core",
      "displayName": "OpenHarmony OpenGL Core",
      "description": "OpenHarmony core-only build using GLES/EGL",
      "cacheVariables": {
        "MLN_WITH_CORE_ONLY": "ON"
      }
    },
    {
      "name": "harmonyos",
      "hidden": true,
      "inherits": "ohos",
      "binaryDir": "${sourceDir}/build-harmonyos",
      "condition": {
        "type": "allOf",
        "conditions": [
          {
            "type": "notEquals",
            "lhs": "$env{OHOS_SDK_NATIVE}",
            "rhs": ""
          },
          {
            "type": "notEquals",
            "lhs": "$env{HMOS_SDK_NATIVE}",
            "rhs": ""
          }
        ]
      },
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{HMOS_SDK_NATIVE}/build/cmake/hmos.toolchain.cmake",
        "OHOS_SDK_NATIVE": "$env{OHOS_SDK_NATIVE}",
        "HMOS_SDK_NATIVE": "$env{HMOS_SDK_NATIVE}",
        "MLN_OHOS_WITH_HMS_RCP": "ON"
      }
    },
    {
      "name": "harmonyos-opengl",
      "inherits": "harmonyos",
      "displayName": "HarmonyOS OpenGL",
      "description": "HarmonyOS build using GLES/EGL and HMS RemoteCommunicationKit HTTP"
    },
    {
      "name": "harmonyos-opengl-link-smoke",
      "inherits": "harmonyos",
      "binaryDir": "${sourceDir}/build-harmonyos-link-smoke",
      "displayName": "HarmonyOS OpenGL Link Smoke",
      "description": "HarmonyOS GLES/EGL and HMS RCP build with a final shared-library link smoke target",
      "cacheVariables": {
        "MLN_OHOS_BUILD_LINK_SMOKE": "ON"
      }
    },
    {
      "name": "harmonyos-opengl-native",
      "inherits": "harmonyos",
      "binaryDir": "${sourceDir}/build-harmonyos-native",
      "displayName": "HarmonyOS Native Module",
      "description": "HarmonyOS GLES/EGL and HMS RCP build with the experimental NAPI/XComponent native module",
      "cacheVariables": {
        "MLN_OHOS_BUILD_NATIVE_MODULE": "ON"
      }
    },
    {
      "name": "harmonyos-vulkan-native",
      "inherits": "harmonyos",
      "binaryDir": "${sourceDir}/build-harmonyos-vulkan-native",
      "displayName": "HarmonyOS Vulkan Native Module",
      "description": "HarmonyOS Vulkan and HMS RCP build with the experimental NAPI/XComponent native module",
      "cacheVariables": {
        "MLN_WITH_OPENGL": "OFF",
        "MLN_WITH_EGL": "OFF",
        "MLN_WITH_VULKAN": "ON",
        "MLN_OHOS_BUILD_NATIVE_MODULE": "ON"
      }
    },
    {
      "name": "windows",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Windows",
        "MLN_WITH_OPENGL": "OFF",
        "MLN_WITH_EGL": "OFF",
        "MLN_WITH_VULKAN": "OFF",
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
